") (commentRss nil "http://www.bouletcorp.com/2015/11/10/idees-nocturnes/feed/") (comments nil "124")) (item nil (title nil "Mon Cerveau est un Connard") (link nil "http://www.bouletcorp.com/2015/10/29/mon-cerveau-est-un-connard/?utm_source=rss&utm_medium=rss&utm_campaign=mon-cerveau-est-un-connard") (comments nil "http://www.bouletcorp.com/2015/10/29/mon-cerveau-est-un-connard/#comments") (pubDate nil "Thu, 29 Oct 2015 11:56:06 +0000") (creator nil "boulet") (category nil "Non classé") (category nil "cerveau") (category nil "connard") (category nil "insomnie") (category nil "nuit") (guid ((isPermaLink . "false")) "http://www.bouletcorp.com/?p=6070") (description nil "") (encoded nil "<p><img src=\"http://www.bouletcorp.com/wp-content/uploads/2015/10/CerveauConnard1.png\" title=\"Il y a quelque chose de très mystérieux dans le cerveau. Le fait qu'on ne le contrôle pas du tout, pour commencer. La conscience est -difficilement- un petit spartiate dans un char tiré par une horde de chevaux furieux qui courent dans tous les sens en se mordant les uns les autres\" alt=\"\" /><br />
<img src=\"http://www.bouletcorp.com/wp-content/uploads/2015/10/CerveauConnard21.png\" title=\"Encore une fois j'y vois un écosystème. 'Je' est une jungle: il y a nos cultures, ce qu'on essaie d'entretenir et préserver, des régions sauvages, des troncs millénaires, plantés là par la société, de jolis arbres fruitiers plantés par nos parents...\" alt=\"\" /><br />
<img src=\"http://www.bouletcorp.com/wp-content/uploads/2015/10/CerveauConnard3.png\" title=\"Des putains de mauvaises herbes portées par le vent, qu'on arrache et qui reviennent encore et encore...\" alt=\"\" /><br />
<img src=\"http://www.bouletcorp.com/wp-content/uploads/2015/10/CerveauConnard4.png\" title=\"... Cette idée du cerveau qui n'en fait qu'à sa tête est dans l'air, par exemple: il y a eu Vice Versa, et un de mes potes, Joe Decie, a récemment fait une note là-dessus, un peu avant que je commence celle-ci, sans qu'on en ai parlé avant.\" alt=\"\" /><br />
<img src=\"http://www.bouletcorp.com/wp-content/uploads/2015/10/CerveauConnard5.png\" title=\"... J'ai parfois l'impression que les idées sont vivantes, qu'elle se reproduisent, sautent de tête en tête jusqu'à trouver une forêt accueillante.\" alt=\"\" /><br />
<img src=\"http://www.bouletcorp.com/wp-content/uploads/2015/10/CerveauConnard6.png\" title=\"... Et c'est souvent la nuit, quand tout est noir, que cette forêt se met soudain à bruisser de mille bruits étranges et inquiétants.\" alt=\"\" /></p>

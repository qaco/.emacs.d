type formule =
  | Var of string
  | Neg of formule
  | Et of formule * formule
  | Ou of formule * formule ;;
  (* Ex 1 *)
let rec string_of_formule f = match f with
  | Var(s) -> s
  | Neg(form) -> String.concat " " ["Neg" ; string_of_formule form]
  | Et(form1,form2) -> String.concat " " ["(" ;
				    string_of_formule form1 ;
				    "Et" ; string_of_formule form2 ;
				    ")"]
  | Ou(form1,form2) -> String.concat " " ["(" ;
				    string_of_formule form1 ;
				    "Ou" ;
				    string_of_formule form2 ; ")"]
;;
let rec list_of_vars f = match f with
  | Var(s) -> [s]
  | Neg(form) -> list_of_vars form
  | Et(form1,form2) -> list_of_vars form1 @ list_of_vars form2
  | Ou(form1,form2) -> list_of_vars form1 @ list_of_vars form2
;;
(* Ex 2 *)
let rec eval_formule f list = match f with
  | Var(s) -> List.assoc s list
  | Neg(form) -> not (eval_formule form list)
  | Et(form1,form2) -> eval_formule form1 list && eval_formule form2 list
  | Ou(form1,form2) -> eval_formule form1 list || eval_formule form2 list ;;
  (* Ex 3 *)
let add_to_all elt list =
  let make elt1 list1 = elt1::list1 in 
  List.map (make elt) list ;;
let rec affectation_vars l = match l with
  |  [] -> [[]]
  | a::p -> let af = affectation_vars p in
	    (add_to_all (a,true) af) @ (add_to_all (a,false) af);;
let rec affectations form = affectation_vars(list_of_vars(form)) ;;


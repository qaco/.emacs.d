#include <stdlib.h>
#include <check.h>
#include "../misc/word.h"
#include "../misc/wordlist.h"

WordList *biggest, *small_in_size, *small_in_elts ;

/* Comparaison */

void comparison_wordlist_setup(void) {
  biggest = build_empty_wordlist() ;
  add_charseq_wordlist(biggest, "haha", strlen("haha")) ;
  add_charseq_wordlist(biggest, "hihi", strlen("haha")) ;
  add_charseq_wordlist(biggest, "zaza", strlen("haha")) ;
  small_in_size = build_empty_wordlist() ;
  add_charseq_wordlist(small_in_size, "haha", strlen("haha")) ;
  add_charseq_wordlist(small_in_size, "hihi", strlen("haha")) ;
  small_in_elts = build_empty_wordlist() ;
  add_charseq_wordlist(small_in_elts, "haha", strlen("haha")) ;
  add_charseq_wordlist(small_in_elts, "hihi", strlen("haha")) ;
  add_charseq_wordlist(small_in_elts, "hoho", strlen("haha")) ;
}

void comparison_wordlist_teardown(void) {
  destruct_wordlist(biggest) ;
  destruct_wordlist(small_in_size) ;
  destruct_wordlist(small_in_elts) ;
}

START_TEST(test_compare_wordlist_gt) {
  int insize, inelts ;

  insize = compare_wordlist(biggest, small_in_size) ;
  inelts = compare_wordlist(biggest, small_in_elts) ;

  ck_assert_int_gt(insize, 0) ;
  ck_assert_int_gt(inelts, 0) ;
}
END_TEST

START_TEST(test_compare_wordlist_lt) {
  int insize, inelts ;

  insize = compare_wordlist(small_in_size, biggest) ;
  inelts = compare_wordlist(small_in_elts, biggest) ;

  ck_assert_int_lt(insize, 0) ;
  ck_assert_int_lt(inelts, 0) ;
}
END_TEST

START_TEST(test_compare_wordlist_eq) {
  int equal ;

  equal = compare_wordlist(biggest, biggest) ;
  ck_assert_int_eq(equal, 0) ;
}
END_TEST

TCase* wordlist_comparison_case(void) {
  TCase* tc_comp ;

  tc_comp = tcase_create("Wordlist comparison") ;
  tcase_add_checked_fixture(tc_comp,
                            comparison_wordlist_setup,
                            comparison_wordlist_teardown) ;
  tcase_add_test(tc_comp, test_compare_wordlist_gt) ;
  tcase_add_test(tc_comp, test_compare_wordlist_lt) ;
  tcase_add_test(tc_comp, test_compare_wordlist_eq) ;
  return tc_comp ;
}

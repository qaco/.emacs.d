
package protocol ;

import java.io.InputStream ;
import java.io.IOException ;
import java.util.ArrayList ;
import java.util.Arrays ;
import java.nio.charset.Charset ;

public abstract class ProtocolFactory {

    protected byte[][] readStream(InputStream in) throws IOException {
        byte res[][] ;
        int succplus = 0 ;
        ArrayList<ArrayList<Byte>> wholelist = new ArrayList<ArrayList<Byte>>() ;
        ArrayList<Byte> currentlist = new ArrayList<Byte>() ;
        
        wholelist.add(currentlist) ;
        
        while (succplus < 3) {
            byte b = ((byte)in.read()) ;
            if (b == 32) {
                currentlist = new ArrayList<Byte>() ;
                wholelist.add(currentlist) ;
            }
            else if (b == 43) {
                currentlist.add(new Byte(b)) ;
                succplus++ ;
            }
            else {
                currentlist.add(new Byte(b)) ;
                succplus = 0 ;
            }
        }

        res = new byte[wholelist.size()][] ; 
        
        for (int i = 0 ; i < res.length ; i++) { 
            res[i] = new byte[wholelist.get(i).size()] ;
            for (int j = 0 ; j < wholelist.get(i).size() ; j++) {
                // on ne prend pas les trois derniers bytes
                if (i < res.length - 2 && j < res[i].length - 3)
                    res[i][j] = wholelist.get(i).get(j).byteValue() ;
            }
        }
        return res ;
    }

    protected String extractCode(byte[][] cmd) {
        return new String(cmd[0], Charset.forName("US-ASCII")) ;
    }

    protected byte[] joinArray(byte[][] arr, int index) {
        int sepsize = 1 ;
        byte[][] tail = Arrays.copyOfRange(arr, index, arr.length) ;
        byte[] joined ;
        int nonblankbytes = 0 ;
        int mainc = 0 ;
        for (int i = 0 ; i < tail.length ; i++)
            nonblankbytes += tail[i].length ;
        joined = new byte[nonblankbytes + (sepsize*tail.length)] ;
        for (int i = 0 ; i < tail.length ; i++) {
            if (i > 0)
                joined[mainc++] = 32 ;
            for (int j = 0 ; i < tail[i].length ; j++)
                joined[mainc++] = tail[i][j] ;
        }
        return joined ;
    }
}

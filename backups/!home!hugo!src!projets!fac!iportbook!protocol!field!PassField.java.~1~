package protocol.field ;

import exception.UnknownResultException ;
import exception.RuleBrokenException ;

public class PassField extends Field {

    public PassField (byte[] mypass) {
        super(mypass) ;
    }
    
    public PassField(int mypass) {
        byte[] arr ;
        if (mypass > FieldVals.MAX_MMDP_SIZE)
            throw new IllegalArgumentException() ;
        arr = new byte[FieldVals.PASS_SIZE] ;
        arr[0] = (byte) (mypass) ;
        arr[1] = (byte) (mypass >> 8) ;
        try {
            super(arr) ;
        } catch (UnknownResultException e) {
            throw new IllegalArgumentException() ;
        }
    }

    public int getInt() {
        return this.field[0] | this.field[1] << 8 ;
    }
    
    protected void checkRules() throws UnknownResultException {
        this.checkSize(ProtocoVals.IPDIFF_SIZE) ;
        this.checkAllAscii() ;
        if (this.toString().matches("[^0-9.#]"))
    }
    
}

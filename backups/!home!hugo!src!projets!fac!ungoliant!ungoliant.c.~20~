#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <ctype.h>
#include <unistd.h>
#include <sys/types.h>
#include <dirent.h>
#include "crawl/crawler.h"
#include "query/query_engine.h"

#define DB_PATH "database"
#define DOT_PATH "netgraph.dot"
#define CRAWLER_FLAG "-c"
#define QUERY_FLAG "-q"
#define RESET_FLAG "-r"

static int is_number(char* string)
{
  for (int i = 0 ; i < strlen(string) ; i++)
    if (!isdigit(*(string + i)))
      return 0 ;
  return 1 ;
}

static void help(void) {
  fprintf(stderr, "SYNOPSIS\n") ;
  fprintf(stderr, "ungoliant [CMDS]\n\n") ;
  fprintf(stderr, "CMD1\n-q keyword\n") ;
  fprintf(stderr, "-> recherche le keyword dans les pages crawlées.\n") ;
  fprintf(stderr, "CMD2\n-c url depth\n") ;
  fprintf(stderr, "-> crawle l'url et les url vers lesquelles elle pointe") ;
  fprintf(stderr, " jusqu'à la profondeur depth.\n") ;
  fprintf(stderr, "CMD3\n-r\n") ;
  fprintf(stderr, "-> réinitialise l'index et le graphe réseau.\n") ;
}

static int rmrf(char *dirpath) {
  struct dirent* tmp ;
  DIR* current ;
  char* file_path ;
  current = opendir(dirpath) ;
  if (current) {
    tmp = readdir(current) ;
    while(tmp !=NULL) {
      if (strcmp(tmp->d_name, ".") && strcmp(tmp->d_name, "..")) {
        int size = strlen(DB_PATH) + strlen(tmp->d_name) + 2 ;
        file_path = malloc(sizeof(char)*size) ;
        strcpy(file_path, DB_PATH) ;
        strcat(file_path, "/") ;
        strcat(file_path, tmp->d_name) ;
        remove(file_path) ;
      }
      tmp = readdir(current) ;
    } ;
    closedir(current) ;
    remove(DB_PATH) ;
    return EXIT_FAILURE ;
  }
  else
    return EXIT_SUCCESS ;
}

int main (int argc, char* argv[])
{
  int ret = EXIT_SUCCESS ;

  argc-- ;
  argv++ ;

  if (!argc)
    help() ;
  while (argc && ret == EXIT_SUCCESS) {
    if (strcmp(*argv, QUERY_FLAG) == 0 &&
        argc >=2) {
      ret = queries_input(*(argv + 1)) ;
      argc -= 2 ;
      argv += 2 ;
    }
    else if (strcmp(*argv, CRAWLER_FLAG) == 0 &&
             argc >= 3 &&
             is_number(*(argv + 2))) {
      int depth = atoi(*(argv + 2)) ;
      ret = crawl(*(argv + 1), depth) ;
      argc -= 3 ;
      argv += 3 ;
    }
    else if (strcmp(*argv, RESET_FLAG) == 0) {
      rmrf(DB_PATH) ;
      remove(DOT_PATH) ;
      argc-- ;
      argv++ ;
    }
    else {
      help() ;
      break ;
    }
  }
  return ret ;
}

#! /usr/bin/env python3

import os.path, Control, View, Slogan, Shutter
from gi.repository import Gtk
from PIL import ImageFont

SHUT_COL = (0,0,0)
SHUT_ALPHA = 80
TEXT_COL = (255, 255 , 255)
FONT_PATH = "/usr/share/fonts/truetype"

HEIGHT = 600
PARAM_WIDTH = 300

def list_directory(path):  
    fichier=[]  
    for root, dirs, files in os.walk(path):  
        for i in files:  
            fichier.append(os.path.join(root, i))  
    return fichier

def ttflist_to_fontdicts(l_paths):
    nametopath = dict()
    fonttofamilies = dict()
    for path in l_paths:
        f = ImageFont.truetype(path)
        name = f.font.family, f.font.style
        nametopath[name] = path
        if f.font.family in fonttofamilies:
            fonttofamilies[f.font.family].append(f.font.style)
        else:
            fonttofamilies[f.font.family] = [f.font.style]
    for key in fonttofamilies:
        fonttofamilies[key].sort()
    return nametopath, fonttofamilies

def main():
    lfonts = list_directory(FONT_PATH)
    dfonts = ttflist_to_fontdicts(lfonts)

    control = Control.Motherboard(Shutter.BOTTOM_SHUTTER,SHUT_COL, SHUT_ALPHA,
                                  Slogan.NAIVE_SLOGAN, TEXT_COL, dfonts)
    window = View.Console(HEIGHT, PARAM_WIDTH)
    window.add_controler(control)
    window.show_all()
    Gtk.main()

main()

#include <stdlib.h>
#include <stdio.h>
#include <gtk/gtk.h>

#define TILEMAP_PATH "../ressources/images/allmap.jpg"
#define TEXTMAP_PATH "../ressources/conf/map.cluedo"
#define DEST_SIZE 20
#define SRC_SIZE 37
#define V_TILES  26
#define H_TILES  24

char** gen_text_map() {
  char tmp ;
  FILE* file = fopen(TEXTMAP_PATH, "r") ;
  char** res = malloc(V_TILES*sizeof(char*)) ;
  for (int i = 0 ; i < V_TILES ; i++)
    *(res+i) = malloc(H_TILES*sizeof(char)+1) ;
  int i = 0, j = 0 ;
  do {
    tmp = fgetc(file) ;
    if (tmp == '\n') {
      *(*(res + i) + j) = '\0' ;
      i++ ;
      j = 0 ;
    }
    else {
      *(*(res + i) + j) = tmp ;
      j++ ;
    }
  } while (i < V_TILES - 1 || j < H_TILES) ;
  fclose(file) ;
  
  return res ;
}

GtkWidget* custom_gen_tile_map() {
  GdkPixbuf* tmp ;
  GdkPixbuf* done ;
  GError* gerror = NULL ;
  GdkPixbuf* all_tiles = gdk_pixbuf_new_from_file (TILEMAP_PATH,
						   &gerror);
  GtkWidget* drawing ;
  GdkGC* gc ;
  GtkWidget* table = gtk_table_new (V_TILES, H_TILES, TRUE) ;

  if(!all_tiles) {
    printf("error message: %s\n", gerror->message);
    exit(1);
  }
  
  for (int i = 0 ; i < V_TILES ; i++) {
    for (int j = 0 ; j < H_TILES ; j++) {
      tmp = gdk_pixbuf_new_subpixbuf (all_tiles,
				      j*SRC_SIZE,
				      i*SRC_SIZE,
				      SRC_SIZE,
				      SRC_SIZE);
      done = gdk_pixbuf_scale_simple (tmp,
				      DEST_SIZE,
				      DEST_SIZE,
				      GDK_INTERP_BILINEAR) ;
      drawing = gtk_drawing_area_new ();
      gtk_drawing_area_size ((GtkDrawingArea*)drawing,
			     DEST_SIZE, DEST_SIZE) ;
      if GTK_WIDGET_DRAWABLE(wid)
      gc = gdk_gc_new(drawing->window) ;
      gdk_draw_pixbuf (drawing->window, gc, done,
		       0, 0, 0, 0, DEST_SIZE, DEST_SIZE,
		       GDK_RGB_DITHER_NORMAL, 0, 0) ;
      gtk_table_attach_defaults((GtkTable*)table, drawing, 
				j, j+1, i, i+1) ;
    }
  }
  return table ;
}


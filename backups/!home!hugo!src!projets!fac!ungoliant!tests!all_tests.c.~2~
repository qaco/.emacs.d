#include <check.h>
#include "word_cases.h"


Suite *word_suite(void) {
  TCase *tc_comp ;
  Suite *s ;

  tc_comp = word_comparison_case() ;

  s = suite_create("All") ;
  suite_add_tcase(s, tc_comp) ;

  return s ;
}

int main() {
  Suite* s = word_suite() ;
  SRunner* runner ;

  runner = srunner_create(s) ;

  srunner_run_all(runner, CK_NORMAL) ;

  srunner_free(runner) ;

  return 0 ;
}
  
  
  

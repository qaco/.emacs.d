#include <stdio.h>

int main() {
  char[70] saisie ;
  scanf("%s", saisie) ;
  for (int i = 0 ; i < strlen(saisie) ; i++) {
    if (!alpha(saisie[i]))
      printf("La saisie ne contient que des caractères alphabétiques\n") ;
    if (!num(saisie[i]))
      printf("La saisie ne contient que des caractères numériques\n") ;
    return 0 ;
  }
}

#ifndef GAME
#define GAME

typedef struct {
  Perso mon_perso ;
  GtkWidget* pion ;
} Joueur ;

typedef enum {
  MOUTARDE,
  OLIVE,
  VIOLET,
  PERVENCHE,
  ROSE,
  LEBLANC
} Perso ;

Joueur* construct_joueur(Perso perso, GtkWidget* image) ;
void destruct_joueur(Joueur* j) ;

/* Étant donné un identifiant de personnage et un tableau de pointeurs
   sur joueur, renvoie un pointeur sur le premier joueur dont le
   personnage correspond au paramètre */
Joueur* select_joueur(Perso perso, Joueur* ensemble[]) ;

boolean can_move_joueur(Joueur* j, GtkWidget* event_box) ;
void move_joueur(Joueur* j, GtkWidget* event_box) ;

#endif

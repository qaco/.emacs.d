CC=gcc
CFLAGS=-std=c99 -Wall
LINKS=-lm
EXEC=main
SRC=musique.c lines.c miroir.c main.c
OBJ=$(SRC:.c=.o)

all : $(EXEC)

main : $(OBJ)
	$(CC) $(LINKS) -o $@ $^

main.o : miroir.h

miroir.o : lines.h musique.h

%.o: %.c
	$(CC) $(CFLAGS) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

package protocol ;

import exception.* ;

public abstract class AbstractFirstMessage {

    protected String id ;
    protected int num ;

    public AbstractFirstMessage (String myid, String mynum)
        throws UnknownResultException {
        this.id = myid ;
        try {
            this.num = Integer.parseInt(mynum) ;
        } catch (NumberFormatException e) {
            throw new WrongTypeException() ;
        }
        this.checkRules() ;
    }

    public AbstractFirstMessage (String myid, int mynum)
        throws UnknownResultException {
        this.id = myid ;
        this.num = mynum ;
        this.checkRules() ;
    }

    private void checkRules() throws RuleBroken {
        if (this.num < 0)
            throw new RuleBroken() ;
    }
}

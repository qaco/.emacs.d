START_TEST(test_compare_word_gt) {
  Word *first, *second ;
  int greater ;

  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
  greater = compare_word(first, second) ;

  ck_assert_int_gt(greater, 0) ;

  destruct_word(first) ;
  destruct_word(second) ;
}
END_TEST

START_TEST(test_compare_word_lt) {
  Word *first, *second ;
  int smaller ;

  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
  smaller = compare_word(second, first) ;
  
  ck_assert_int_lt(smaller, 0) ;

  destruct_word(first) ;
  destruct_word(second) ;
}
END_TEST

START_TEST(test_compare_word_eq) {
  Word *first, *second ;
  int equal ;

  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
  equal = compare_word(second, second) ;

  ck_assert_int_eq(equal, 0) ;

  destruct_word(first) ;
  destruct_word(second) ;
}
END_TEST

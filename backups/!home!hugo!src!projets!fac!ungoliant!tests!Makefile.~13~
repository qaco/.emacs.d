CC = gcc
CFLAGS = -std=gnu99 -Wall -Werror -g
LIBS = $(shell pkg-config --libs check)
NAME = tests
SOURCES = word_subword_case.c word_comparison_case.c wordlist_accessor_case.c wordlist_comparison_case.c wordlist_split_case.c worddict_accessor_case.c worddict_dot_case.c all_tests.c
OBJS = $(SOURCES:%.c=%.o)
OBJS2 = ../misc/word.o ../misc/wordlist.o ../misc/worddict.o ../crawl/crawler.o

all:
	make -C ../misc word.o wordlist.o worddict.o
	make -C ../crawl crawler.o
	make $(NAME)

$(NAME) : $(OBJS) $(OBJS2)
	$(CC) $(CFLAGS) -o $@ $^ $(LIBS)

%.o: %.c
	$(CC) $(CFLAGS) -c $<

clean:
	make -C ../misc clean
	rm -f $(NAME) $(OBJS)

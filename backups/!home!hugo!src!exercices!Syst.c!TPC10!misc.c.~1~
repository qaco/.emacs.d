#include <math.h>

int characters_in_int(int num) {
  return (int)((ceil(log10(num))+1)*sizeof(char)) ;
}

int file_to_int(FILE *fic) {
    char* buf = malloc(sizeof(char)*SIZE_BUF) ;
    char tmp ;
    int res, i = 0 ;
    do {
      tmp = fgetc(fic) ;
      if (tmp != '\n')
	*(buf + i++) = tmp ;
    } while (tmp != '\n') ;
    *(buf + i) = '\0' ;
    res = atoi(buf) ;
    free(buf) ;
    return res ;
}

void int_to_file(int entier, FILE* fic) {
  int size = characters_in_int(entier) ;
  char *str = malloc(size + 1) ;
  sprintf(str, "%d\n", entier);
  fputs(str,fic) ;
  free(str) ;
}

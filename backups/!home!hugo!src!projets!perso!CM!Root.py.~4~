class Frame:
    def __init__(self, upper_size=None,corner=None, size=None):
        self.upper_size = upper_size
        self.corner = corner
        self.size = size

    def generate_frame(self):
        return Frame(self.upper_size, self.corner, self.size)
        
class AbstractCalc(Frame):
    def __init__(self, upper_size=None,corner=None, size=None):
        super().__init__(upper_size, corner, size)
        self.img = None

    def process_position(self):
        raise NotImplementedError()
    
    def generate_img(self):
        raise NotImplementedError()

package protocol ;

import exception.* ;
import java.io.InputStream ;
import java.io.IOException ;
import java.util.LinkedList ;

public class BlockingReceiver extends Receiver {

    private InputStream in ;

    public BlockingReceiver(InputStream myin) {
        super() ;
        this.in = myin ;
    }

    public void receive() throws UnknownResultException, IOException {
        byte tmp[] ;
        byte res[][] ;
        int c = 0 ;
        LinkedList<Byte> list = new LinkedList<Byte>() ;
        
        while (c < suffix.length) {
            byte b = ((byte)in.read()) ;
            list.add(new Byte(b)) ;
            if (b == this.suffix[c]) c++ ;
            else c = 0 ;
        }

        tmp = new byte[list.size()] ;

        for (int i = 0 ; i < tmp.length - 3 ; i++)
            tmp[i] = list.get(i).byteValue() ;

        this.raw = tmp ;
    }
}

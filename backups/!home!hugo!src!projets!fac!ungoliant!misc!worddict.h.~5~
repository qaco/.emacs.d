#ifndef WORDDICT
#define WORDDICT

typedef struct {
  Word key ;
  WordList values ;
} Page ;

typedef struct {
  Page *pages ;
  size_t length ;
  size_t allocated ;
} WordDict ;

WordDict construct_empty_worddict() ;
int get_value_worddict(WordList* values,
                       const WordDict mydict, const Word myword) ;
int add_line_worddict(WordDict* mydict,
                      const Word myword, const WordList mylist) ;
int remove_key_worddict(WordDict* mydict, const Word myword) ;
int is_in_worddict(const Word myword, const WordDict mydict) ;
void destruct_worddict(WordDict* mydict) ;
int print_worddict(const WordDict mydict, FILE* stream) ;

#endif

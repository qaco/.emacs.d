package protocol.knock ;

import exception.UnknownResultException ;

public abstract class Knock {
    protected byte lowest ;
    protected byte highest ;

    public Knock(int flows) throws UnknownResultException{
        if (flows < 0)
            throw new UnknownResultException() ;
        this.lowest = (byte) (flows) ;
        this.highest = (byte) (flows >> 8) ;
    }

    public Knock(byte mylow, byte myhigh) throws UnknownResultException {
        this.lowest = mylow ;
        this.highest = myhigh ;
        if (this.getNumFlows() < 0)
            throw new UnknownResultException() ;
    }

    public int getNumFlows() {
        return lowest | highest << 8 ;
    }
        
    public byte[] getArray() {
        byte arr[] = { this.getCode(), this.lowest, this.highest } ;
        return arr ;
    }

    protected abstract byte getCode() ;
    protected abstract String popUp() ;

    public void exec() {
        System.out.println(this.popUp()) ;
        System.out.println(String.valueOf(this.getNumFlows()) +
                           " flows waiting.") ;
    }
}

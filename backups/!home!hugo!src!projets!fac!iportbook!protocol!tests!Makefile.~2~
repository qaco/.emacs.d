JC = javac
JUNIT_PATH = /usr/share/java/junit4.jar

ROOT_DIR = $(shell pwd)/../..

TCASES_SRC = \
	CommandFactoryTest.java \
	FeedBackFactoryTest.java \
	FlowFactoryTest.java \
RUNNER_SRC = ProtocolTestRunner.java

TCASES_CLASS = $(TCASES_SRC:%.java=%.class)
RUNNER_CLASS = $(RUNNER_SRC:%.java=%.class)

$(RUNNER_CLASS) = $(RUNNER_SRC) $(TCASES_CLASS) 

%.class: %.java
	$(JC) -cp $(JUNIT_PATH):$(ROOT_DIR) $<

clean :
	rm *.class

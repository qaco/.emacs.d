#include <check.h>
#include <stdlib.h>
#include "../misc/word.h"

START_TEST(test_construct_word) {
  Word* myword ;
  char* temoin = malloc(sizeof(char)*(strlen("hello") + 1)) ;
  char* buffer ;
  
  strcpy(temoin, "hello") ;
  myword = construct_word(strlen(temoin), temoin) ;
  buffer = malloc(sizeof(char)*(get_size_word(myword) + 1)) ;
  get_content_word(myword, buffer) ;

  ck_assert_int_eq(get_size_word(myword), strlen(temoin)) ;
  ck_assert_str_eq(buffer, temoin) ;

  destruct_word(myword) ;
  free(temoin) ;
  free(buffer) ;
}
END_TEST

START_TEST(test_compare_word_gt) {
  Word *first, *second ;
  int greater ;

  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
  greater = compare_word(first, second) ;

  ck_assert_int_gt(greater, 0) ;

  destruct_word(first) ;
  destruct_word(second) ;
}
END_TEST

START_TEST(test_compare_word_lt) {
  Word *first, *second ;
  int smaller ;

  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
  smaller = compare_word(second, first) ;
  
  ck_assert_int_lt(smaller, 0) ;

  destruct_word(first) ;
  destruct_word(second) ;
}
END_TEST

START_TEST(test_compare_word_eq) {
  Word *first, *second ;
  int equal ;

  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
  equal = compare_word(second, second) ;

  ck_assert_int_eq(equal, 0) ;

  destruct_word(first) ;
  destruct_word(second) ;
}
END_TEST

START_TEST(test_cut_sub_word_isin) {
  Word *whole,  *isin ;
  int actual ;

  whole = construct_word(strlen("hello you"), "hello you") ;
  isin = construct_word(strlen("you"), "you") ;
  actual = cut_sub_word(whole, isin) ;
  ck_assert_int_eq(actual, 6) ;

  destruct_word(whole) ;
  destruct_word(isin) ;
}END_TEST

START_TEST(test_cut_sub_word_isnotin) {
  Word *whole, *isnotin ;
  int wrong ;

  whole = construct_word(strlen("hello you"), "hello you") ;
  isnotin = construct_word(strlen("bye"), "bye") ;
  wrong = cut_sub_word(whole, isnotin) ;

  ck_assert_int_eq(actual, 6) ;
  ck_assert_int_lt(wrong, 0) ;

  destruct_word(whole) ;
  destruct_word(isnotin) ;
}END_TEST

TCase* word_case(void) {
  TCase* tc_word ;

  tc_word = tcase_create("Word") ;
  tcase_add_test(tc_word, test_construct_word) ;
  tcase_add_test(tc_word, test_compare_word_gt) ;
  tcase_add_test(tc_word, test_compare_word_lt) ;
  tcase_add_test(tc_word, test_compare_word_eq) ;
  tcase_add_test(tc_word, test_cut_sub_word_isin) ;
  tcase_add_test(tc_word, test_cut_sub_word_isnotin) ;

  return tc_word ;
}

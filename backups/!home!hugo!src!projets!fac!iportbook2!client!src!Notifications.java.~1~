package client.src;

import java.io.*;
import java.net.*;
import exception.UnknownResultException;
import protocol.knock.KnockFactory;
import protocol.knock.Knock;

public class Notifications implements Runnable {

    ServerRequest sr;

    public Notifications(ServerRequest sr) throws IOException {
	this.sr = sr;
    }

    public void handle_paquet(DatagramPacket dp) throws UnknownResultException {
	KnockFactory knockf = new KnockFactory();
	Knock knock = knockf.create(dp);
	knock.exec();
    }

    public void run() {
	try {
	    int udp = Integer.parseInt(this.sr.getUdp());
	    DatagramSocket dso = new DatagramSocket(udp);
	    byte[] data = new byte[3];
	    DatagramPacket paquet = new DatagramPacket(data,data.length);
		    
	    boolean breaker = true;
	    while(breaker) {
		try {
		    dso.receive(paquet);
		    handle_paquet(paquet);
		    synchronized(this.sr) {
			breaker = this.sr.getStatus();
		    }
		} catch (UnknownResultException e) {
		    System.out.println("[Requête inconnue du serveur.]");
		}
	    }
	} catch (IOException e) {
	    System.out.println("[Communication interrompue.]") ;
	}
    }
}

/**
 * \file build.c
 * \brief Fonctions de construction et de manipulation de chaînes.
 */
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdarg.h>
#include "build.h"

/**
 * \fn char* int_to_string(const int offset, const long int nb)
 * \brief Retourne la représentation en n caractères d'un entier.
 * \param offset Le nombre de caractères de la chaîne à retourner.
 * \param nb L'entier à représenter en caractères.
 * \return La représentation de l'entier sous forme de chaîne.
 */
char* int_to_string(const int offset, const long int nb)
{
  char* res = malloc(sizeof(char)*(offset+1)) ;
  sprintf(res, "%0*ld", offset, nb) ;
  res[offset] = '\0' ;
  return res ;
}

/**
 * \fn char* add_a_string (char** init, const char *toadd)
 * \brief Ajoute une chaîne à une autre de manière à respecter le protocole.
 * \param init Le pointeur sur la chaîne de destination.
 * \param toadd La chaîne à concaténer.
 * \return La concaténation des deux chaînes respectant le protocole.
 */
char* add_a_string (char** init, const char *toadd)
{
  int issize = strlen(toadd) ;
  char* ssize = int_to_string(NB_SIZE,issize) ;

  *init = realloc(*init, strlen(*init) + NB_SIZE + issize + 1) ;
  strcat(*init, ssize) ;
  strcat(*init, toadd) ;

  free(ssize) ;
  return *init ;
}

/**
 * \fn int extract_string (char** dest, char* string)
 * \brief Extrait le texte d'une chaîne respectant le protocole.
 * \param dest Le pointeur sur la chaîne de destination.
 * \param string La chaîne dont on extrait le texte.
 * \return La taille totale (nombre + texte) de la chaîne traitée.
 */
int extract_string (char** dest, char* string)
{
  char* ssize = malloc(sizeof(char)*(NB_SIZE + 1)) ;
  int isize ;

  /* Extraction du nombre */
  strncpy(ssize, string, NB_SIZE) ;
  *(ssize + NB_SIZE) = '\0' ;
  string += NB_SIZE ;
  isize = atoi(ssize) ;

  /* Extraction de la chaîne */
  *dest = malloc(sizeof(char)*(isize + 1)) ;
  strncpy(*dest, string, isize) ;
  *(*dest + isize) = '\0' ;
  string += isize;

  free(ssize) ;
  
  return isize + NB_SIZE ;
}

/**
 * \fn int extract_int (char* string)
 * \brief Extrait un entier respectant le protocole.
 * \param string Le message dont on extrait l'entier.
 * \return L'entier extrait.
 */
int extract_int (char* string)
{
  char* slong = malloc(sizeof(char)*(NB_SIZE + 1)) ;
  int ilong ;
  strncpy(slong, string, NB_SIZE) ;
  *(slong + NB_SIZE) = '\0' ;
  ilong = atoi(slong) ;
  free(slong) ;
  return ilong ;
}

/**
 * \fn char* build_msg(const int client,const char* typem,...)
 * \brief Construit une chaîne respectant le protocole.
 * \param client Indique si on construit une chaîne pour le client.
 * \param typem Le type du message à construire.
 * \param ... Arguments permettant de construire la chaîne du type demandé,
 * à fournir dans l'ordre prévu par le protocole après le type.
 * \return Le message respectant le protocole.
 */
char* build_msg(const int client, const char* typem, ...)
{
  va_list va ;
  int
    client_in = client && strcmp(typem, T_IN) == 0,
    client_public = (client && !strcmp(typem, T_PUB)) || (!client && !strcmp(typem, T_LIST)),
    client_private = client && strcmp(typem, T_PRIV) == 0,
    client_admin = client && strcmp(typem, T_DBG) == 0,
    server_msg = !client && (!strcmp(typem, T_PUB) || !strcmp(typem, T_PRIV)),
    server_shut = !client && strcmp(typem, T_SHUT) == 0,
    client_file = client && strcmp(typem, T_FILE) == 0,
    server_file = !client && strcmp(typem, T_FILE) == 0,
    first_file = 0 ;
                             
  int total_size ;
  char* res = malloc(sizeof(char)*(strlen(typem) == 4 + 1)) ; 
  char* new_res ;

  va_start(va,typem) ;
  
  /* res <- [type | ... ] */
  strcpy(res,typem) ;

  /* res <- [res | serie | ... ] */
  if (client_file || server_file)
    {
      int serie = va_arg(va,int) ;
      char* sserie = int_to_string(NB_SIZE, serie) ;

      res = string_realloc(res, sizeof(char)*(strlen(res) + NB_SIZE + 1)) ;
      strcat(res,sserie) ;
      free(sserie) ;
      first_file = serie == 0 ;
    }
  /* [res | id | ... ] */
  if (!client_admin && !client_in && !server_msg && !server_shut)
    {
      int iid = va_arg(va,int) ;
      char* sid = int_to_string(NB_SIZE,iid) ;

      res = string_realloc(res, sizeof(char)*(strlen(res) + NB_SIZE + 1)) ;
      strcat(res,sid) ;
      free(sid) ;
    }
  /* res <- [res | string | ... ] */
  if (client_private || client_in || server_msg || (client_file && first_file))
    add_a_string(&res, va_arg(va, char*)) ;

  /* res <- [res | long | ... ] */
  if (first_file)
    {
      long int size = va_arg(va, long int) ;
      char* ssize = int_to_string(NB_SIZE*2, size) ;
      
      res = string_realloc(res, sizeof(char)*(strlen(res) + NB_SIZE*2 + 1)) ;
      strcat(res,ssize) ;
      free(ssize) ;
    }
      
  /* res <- [res | string ] */
  if (client_public || client_private || server_msg
      || client_in || server_shut || first_file)
    add_a_string(&res, va_arg(va, char*)) ;
  /* res <- [res | donnees ] */
  else if (client_file || server_file)
    {
      char* donnees = va_arg(va, char*) ;
      res = string_realloc(res, sizeof(char)*(strlen(res) + strlen(donnees) + 1)) ;
      strcat(res, donnees) ;
    }
  
  /* Calcul et écriture des 4 premiers caractères
     res <- [nombre | res ] */
  total_size = strlen(res) + NB_SIZE ;
  new_res = int_to_string(NB_SIZE,total_size) ;
  new_res = realloc(new_res, strlen(new_res) + strlen(res) + 1) ;
  strcat(new_res,res) ;
  free(res) ;
  res = new_res ;
  va_end(va) ;

  return res ;
}

/**
 * \fn char* string_realloc(char* ptr, size_t size)
 * \brief Empêche le programme de continuer en cas de problème avec realloc.
 * \param ptr Le pointeur sur le bloc mémoire à réallouer.
 * \param size La taille à assigner au nouveau bloc mémoire.
 * \return Le pointeur sur le nouveau bloc mémoire.
 */
char* string_realloc(char* ptr, const size_t size)
{
  ptr = realloc(ptr, size) ;
  if (ptr == NULL)
    {
      fprintf(stderr, "REALLOC FAILURE") ;
      exit(EXIT_FAILURE) ;
    }
  else
    return ptr ;
}

/**
 * \fn char *string_copy(char *string)
 * \brief Simplification de la copie d'une chaîne.
 * \param string La chaîne à copier.
 * \return La chaîne résultant de la copie.
 */
char *string_copy(const char *string)
{
  char *res = malloc((strlen(string)+1)*sizeof(char)) ;
  strcpy(res, string) ;
  return res ;
}

/**
 * \fn char *get_substring(char *string, int beginIndex, int endIndex)
 * \brief Retourne la sous chaîne d'une chaîne delimitee par 2 indices.
 * \param string La chaîne dont on veut extraire une sous-chaîne.
 * \param beginIndex L'indice de début de la sous-chaîne.
 * \param endIndex L'indice de fin de la sous-chaîne.
 * \return La sous-chaîne résultant de l'opération.
 */
char *get_substring(const char *string, const int beginIndex, const int endIndex)
{
  int len = endIndex-beginIndex ;
  char *buffer = malloc((len+1)*sizeof(char)) ;

  strncpy(buffer, &string[beginIndex], len) ;
  buffer[len] = '\0' ;

  return buffer ;
}

package protocol.field ;

import exception.* ;

import java.nio.charset.Charset ;

public class PortField extends NumStringField {

    public PortField(byte[] myport) throws UnknownResultException {
        super(myport) ;
    }

    public PortField(int myport) {
        super(myport, FieldVals.PORT_SIZE) ;
    }

    protected void checkRules() throws UnknownResultException {
        String tmp = this.toString() ;
        try {
            int val = this.getInt() ;
            if (val > FieldVals.MAX_PORT)
                throw new RuleBrokenException("Port", tmp + " too big") ;
            else if (val < 0)
                throw new RuleBrokenException("Port", tmp + " < 0");
        } catch (NumberFormatException e) {
            throw new WrongTypeException("PortField", tmp, "int") ;
        }
    }
}
        

package client.src;

import exception.UnknownResultException ;
import java.util.Scanner;
import java.io.PrintWriter;
import java.io.InputStream;
import java.io.InputStreamReader;
import java.io.IOException;
import java.net.Socket;

import protocol.feedback.Feedback;
import protocol.feedback.FeedbackFactory;
import protocol.flow.Flow;
import protocol.flow.FlowFactory;
import protocol.command.Deconnection;
import protocol.command.FirstMessage;
import protocol.command.SomeMessage;
import protocol.command.FlooMessage;
import protocol.command.SeeList;
import protocol.command.AskFriend;
import protocol.command.Consultation;
import protocol.answer.* ;

public class ServerRequest {

    private String id, udp;
    private Scanner sc;
    private Socket so;
    private InputStream is;
    private PrintWriter pw;
    private boolean status;
    private Thread abt;
    private Abonnement ab;
    private Thread notift;
    private Notifications notif;
    
    public ServerRequest(String id, String udp, Socket so) 
	throws IOException {
	this.status = true;
	this.sc = new Scanner(System.in);
	this.id = id;
	this.udp = udp;
	this.so = so;	    
	this.pw = new PrintWriter(so.getOutputStream());
	this.is = so.getInputStream();
	this.abt = null;
	this.ab = null;
	this.notif = null;
	this.notift = null;
    }
    
    private String client_input() throws IOException {
	String input = "";
	try {
	    System.out.print("> ");
	    input = this.sc.nextLine();
	} catch (Exception e) {
	    System.out.println("[Entrée non reconue.]");
	}
	return input;
    }

    private void client_frrequest() throws IOException {
	try {
	    System.out.print("-- id ami : ");
	    String friend_id = this.sc.nextLine();

	    AskFriend ask = new AskFriend(friend_id);
	    this.pw.write(ask.toBytes());
	    this.pw.flush();
	    FeedbackFactory fbackfactory = new FeedbackFactory();
	    Feedback fback = fbackfactory.create(this.is);
	    fback.exec(this);   
	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}
    }
    
    private String formated_mess_size(int size) {	
	try {
	    return String.format("%04d", size);
	} catch (Exception e) {
	    System.out.println("[Problème au formatage.]");
	}
	return "";
    }

    private boolean input_verification(String input) {
	if(input.length() >= 3) {
	    for (int i = 0; i < input.length()-2; i++) {
		char fst = input.charAt(i);
		char snd = input.charAt(i+1); 
		char thd = input.charAt(i+2); 
		if ((fst == '+') && (snd == '+') && (thd == '+'))
		    return false;
	    } 
	}
	return true;
    }

    private void client_messageto() throws IOException {
	try {
	    String friend_id;
	    String input;
	    int num_mess;
	    
	    System.out.print("-- id ami : ");
	    friend_id = this.sc.nextLine();	
	    System.out.print("-- entrez votre message : ");
	    input = this.sc.nextLine();
	    num_mess = (input.length() / 200) + 1;	    
	    String num_mess_ = formated_mess_size(num_mess);

	    if (num_mess_.length() > 0 && input_verification(input)) {
		FirstMessage fmess = new FirstMessage(friend_id, num_mess_);
		this.pw.write(fmess.toBytes());
		this.pw.flush();
		
	    	for (int i = 0; i < num_mess; i++) {
		    SomeMessage smess;
		    if (i+1 == num_mess) {
			smess = new SomeMessage(i, input);
			this.pw.write(smess.toBytes());
			this.pw.flush();
		    } else {
			smess = new SomeMessage(i, input.substring(0, 200));
			this.pw.write(smess.toBytes());
			this.pw.flush();
			input = input.substring(200, input.length());
		    }
		}
	    } else {
		System.out.println("[Aucun message à envoyer.]");
		return;
	    }	    

	    FeedbackFactory fbackfactory = new FeedbackFactory();
	    Feedback fback = fbackfactory.create(this.is);
	    fback.exec(this);
	    
	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}
    }

    private void client_flood() throws IOException {
	try {
	    System.out.print("-- message d'inondation : ");
	    String input = this.sc.nextLine();
	    
	    if (input.length() > 200) {
		System.out.println("[Message trop long.]");
	    } else {
		FlooMessage floo = new FlooMessage(input);
		this.pw.write(floo.toBytes());
		this.pw.flush();

		FeedbackFactory fbackfactory = new FeedbackFactory();
		Feedback fback = fbackfactory.create(this.is);
		fback.exec(this);
	    }
	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}
    }

    private void client_list() throws IOException {
	try {
	    SeeList sl = new SeeList();
	    this.pw.write(sl.toBytes());
	    this.pw.flush();
	    
	    FeedbackFactory fbackfactory = new FeedbackFactory();
	    Feedback fback = fbackfactory.create(this.is);
	    fback.exec(this); 

	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}	
    }

    private void client_consu() throws IOException {
	try {
	    Consultation consu = new Consultation();
	    this.pw.write(consu.toBytes());
	    this.pw.flush();

	    FlowFactory ffactory = new FlowFactory();
	    Flow flow = ffactory.create(this.is);
	    flow.exec(this);
	    
	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}
    }

    public void client_reponse_fr(String id) throws IOException {
	try {
	    System.out.print("Ajouter "+id+" à vos amis ? [oui/non] ");
	    String input = this.sc.nextLine();
	    switch (input) {
	    case "oui" : 
		AcceptFriend acc = new AcceptFriend();
		this.pw.write(acc.toBytes());
		this.pw.flush();
		break;
	    case "non" : 
		RefuseFriend ref = new RefuseFriend();
		this.pw.write(ref.toBytes());
		this.pw.flush();
		break; 
	    default : 
		client_reponse_fr(id); 
		break;
	    }

	    FeedbackFactory fbackfactory = new FeedbackFactory();
	    Feedback fback = fbackfactory.create(this.is);
	    fback.exec(this);
    
	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}
    }

    private void start_subscribe(String ip_diff, String port) throws IOException {
	this.ab = new Abonnement(this, ip_diff, port);
	this.abt = new Thread(ab);
	this.abt.start();
    }

    public void client_subscribe(String ip_diff, String port) throws IOException {
	System.out.print("Voulez-vous vous abonner ? [oui/non] ");
	String input = this.sc.nextLine();
	switch (input) {
	case "oui" :
	    start_subscribe(ip_diff, port);
	    break;
	default : break;
	}
    }

    private void client_deconnexion() throws IOException {
	try {
	    Deconnection deco = new Deconnection();
	    this.pw.write(deco.toBytes());
	    this.pw.flush();

	    FeedbackFactory fbackfactory = new FeedbackFactory();
	    Feedback fback = fbackfactory.create(this.is);
	    fback.exec(this);

	} catch (UnknownResultException e) {
	    System.out.println("[Requête inconnue du serveur.]");
	}
    }

    public void setStatus(boolean b) {
	this.status = b;
    }

    public InputStream getIs() {
	return this.is;
    }    
    public boolean getStatus() {
	return this.status;
    }
    public String getUdp() {
	return this.udp;
    }

    public void client_hub() throws IOException {
	boolean breaker = true;
	while(breaker) {
	    if (status) {
		switch(client_input()) {
		case "deconnexion" : client_deconnexion(); break;
		case "friend request" : client_frrequest(); break;
		case "messageto" : client_messageto(); break;
		case "flood" : client_flood(); break;
		case "list" : client_list(); break;
		case "consultation" : client_consu(); break;
		default : break ;
		}	
	    }
	    else {
		breaker = false;
	    }
	}
    }

    public void start_notifications() throws IOException {
	this.notif = new Notifications(this);
	this.notift = new Thread(notif);
	notift.start();
    }

    public void run() {
	try {
	    start_notifications();
	    client_hub();
	    this.so.close();
	    this.is.close();
	    this.pw.close();
        } catch (IOException e) {
	    System.out.println("[Communication interrompue.]");
	    e.printStackTrace();
	}
    }
}

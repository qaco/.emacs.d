#include <check.h>
#include <stdlib.h>
#include "../misc/word.h"

Word* first, *second ;

/* Comparaison */

void comparison_setup(void) {
  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("bye"), "bye") ;
}

void comparison_teardown(void) {
  destruct_word(first) ;
  destruct_word(second) ;
}

START_TEST(test_compare_word_gt) {
  int greater ;
  greater = compare_word(first, second) ;
  ck_assert_int_gt(greater, 0) ;
}
END_TEST

START_TEST(test_compare_word_lt) {
  int smaller ;
  smaller = compare_word(second, first) ;
  ck_assert_int_lt(smaller, 0) ;
}
END_TEST

START_TEST(test_compare_word_eq) {
  int equal ;

  equal = compare_word(second, second) ;
  ck_assert_int_eq(equal, 0) ;
}
END_TEST

TCase* word_comparison_case(void) {
  TCase* tc_comp ;

  tc_comp = tcase_create("Comparison") ;
  tcase_add_checked_fixture(tc_comp, comparison_setup, comparison_teardown) ;
  tcase_add_test(tc_comp, test_compare_word_gt) ;
  tcase_add_test(tc_comp, test_compare_word_lt) ;
  tcase_add_test(tc_comp, test_compare_word_eq) ;
  return tc_comp ;
}

/* Subword */

Word *whole ;

void subword_setup(void) {
  whole = construct_word(strlen("how are you ?"), "how are you ?") ;
}

void subword_teardown(void) {
  destruct_word(whole) ;
}

START_TEST(test_get_subword_correct) {
  Word *dest ;
  int start = 2 ;
  int end = 6 ;
  int ret ;
  char* temoin ;
  char* alafin ;

  temoin = malloc(sizeof(char)*(get_size_word(whole) + 1)) ;
  get_content_word(whole, temoin) ;
  dest = construct_word(0, NULL) ;
  ret = get_sub_word(dest, whole, start, end) ;
  alafin = malloc(sizeof(char)*(get_size_word(dest) + 1)) ;
  get_content_word(dest, alafin) ;

  print_word(whole, stdout) ;
  printf("\n") ;
  
  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(*(temoin + start), *alafin) ;
  ck_assert_int_eq(*(temoin + start + end - 1), *(alafin + end - 1)) ;
}
END_TEST

TCase* word_subword_case(void) {
  TCase* tc_sub ;

  tc_sub = tcase_create("Subword") ;
  tcase_add_checked_fixture(tc_sub, subword_setup, subword_teardown) ;
  tcase_add_test(tc_sub, test_get_subword_correct) ;
  return tc_sub ;
}

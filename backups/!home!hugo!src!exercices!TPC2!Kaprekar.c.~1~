#include <stdio.h>
#include <math.h>

void intToTab(int n, int tab[]) {
  if (n/1000 <= 9 && n/1000 > 0) {
    tab[0] = n/1000 ;
    tab[1] = n/100 - tab[0] * 10 ;
    tab[2] = n/10 - (tab[0] * 100 + tab[1] * 10) ;
    tab[3] = n - (tab[0] * 1000 + tab[1] * 100 + tab[2] * 10) ;
  }
}

int tabToInt(int tab[]) {
  int res = 0 ;
  for (int i = 0 ; i < 4 ; i++)
    res += tab[i] * pow(10,3-i) ;
  return res ;
}

int reverseTabToInt(int tab[]) {
  int res = 0 ;
  for (int i = 0 ; i < 4 ; i++)
    res += tab[i] * pow(10,i) ;
  return res ;
}

int*  ordreCroissant(int t[]) {
  int posmini ;
  int tmp ;
  for (int i = 0 ; i < 3 ; i++) {
    posmini = i ;
    for (int j = i + 1 ; j < 4 ; j++)
      if (t[j] < t[posmini])
	posmini = j ;
    tmp = j[posmini] ;
    t[posmini] = t[i] ;
    t[i] = tmp ;
  }
  return t ;
}

int main() {
  int n = 0 ;
  int big, small, diff ;
  do {
    printf("Saisir un entier de 4 chiffres :\n") ;
    scanf("%d",&n) ;
  } while (n/1000 > 9 || n/1000 < 0) ;
  int tab[4] ;
  intToTab(n,tab) ;
  ordreCroissant(tab) ;
  big = tabToInt(tab) ;
  small = reverseTabToInt(tab) ;
  diff = big - small ;
  printf("big : %d, small : %d, diff : %d\n", big, small, diff) ;
  return 0 ;
}
    



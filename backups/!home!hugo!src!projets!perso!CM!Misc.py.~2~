def minimize_image(img, maxsize):
    size = img.size
    while size[0] > maxsize[0] or size[1] > maxsize[1] :
        if size[0] > maxsize[0] : size = maxsize[0], size[1]
        elif size[1] > maxsize[1] : size = size[0], maxsize[1]
    img.thumbnail(size)


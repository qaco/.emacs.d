package protocol.field ;

import exception.RuleBrokenException ;
import exception.UnknownResultException ;

public class IdField extends Field {

    public IdField(byte[] myid) throws UnknownResultException {
        super(myid) ;
    }

    public IdField(String myid) {
        super(myid) ;
    }
    
    protected void checkRules() throws UnknownResultException {
        this.checkSize(FieldVals.MAX_ID_SIZE) ;
        this.checkAllAscii() ;
    }
}        

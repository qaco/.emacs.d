#include <stdlib.h>
#include <check.h>
#include "../misc/word.h"

void add_setup(void) {
  full = construct_word("hello", strlen("hello")) ;
  empty = construct_empty_word() ;
}

void add_teardown(void) {
  destruct_word(full) ;
  destruct_word(empty) ;
}

START_TEST(test_construct_empty_word) {
  char *dest ;
  int size ;

  size = get_size_word(empty) ;
  dest = malloc(sizeof(char)*2) ;
  *dest = 'a' ;
  *(dest + 1) = '\0' ;
  get_content_word(empty, dest) ;
  ck_assert_int_eq(size, 0) ;
  ck_assert_str_eq(dest, "a") ;
  free(dest) ;
}
END_TEST

TCase* word_add_case(void) {
  TCase* tc_add ;

  tc_add = tcase_create("Word add") ;
  tcase_add_checked_fixture(tc_add, add_setup, add_teardown) ;
  tcase_add_test(tc_add, ) ;
  return tc_constr ;
}

package protocol.feedback ;
import client.src.ServerRequest;
import client.src.ConnexionRequest;
import exception.* ;
import protocol.field.* ;
import main.MainVals ;

public class SomeList implements Feedback {
    IdField id ;

    public SomeList(String myid) throws UnknownResultException {
        this.id = new IdField(myid) ;
    }
    
    public String toString() {
        return
            FeedbackVals.SOME_LIST + MainVals.SEP +
            this.id.toString() + MainVals.EOF ;
    }

    public void exec(ServerRequest c) {
	System.out.println("[- "+this.id.toString()+"]");
    }
    public void exec(ConnexionRequest c) {}  
}

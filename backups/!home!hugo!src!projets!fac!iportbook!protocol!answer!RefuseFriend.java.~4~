package protocol.answer ;

import protocol.feedback.AckFriend ;
import protocol.knock.NoFriendKnock ;
import service.User ;
import java.util.List ;
import java.io.IOException ;

public class RefuseFriend implements Answer {
    
    public void exec(User want, User rep) throws IOException {
        rep.sendTCP(new AckFriend()) ;
        want.sendUPD(new NoFriendKnock(want.howManyFlows())) ;
    }

    public String toString() {
        return AnswerVals.NO_FRIEND + AnswerVals.EOF ;
    }
}

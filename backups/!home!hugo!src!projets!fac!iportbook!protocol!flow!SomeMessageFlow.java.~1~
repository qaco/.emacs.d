package protocol.command ;

public class SomeMessage extends Command {

    private int num ;
    private String mess ;

    public SomeMessage (String myauthor, String mynum, String mymess) {
        super(myauthor) ;
        this.num = Integer.parseInt(mynum) ;
        if (mymess.length() <= 200)
            this.mess = mymess ;
        else
            this.mess = mymess.substring(0, 200) ;
    }

    public SomeMessage (String author, int mynum, String mymess) {
        super(author) ;
        this.num = mynum ;
        if (mymess.length() <= 200)
            this.mess = mymess ;
        else
            this.mess = mymess.substring(0, 200) ;
    }

    public String toString() {
        String mynum = String.valueOf(this.num) ;
        return
            CommandVals.SOME_MESSAGE + " " +
            mynum + " " + this.mess + CommandVals.EOF  ;
    }
}

JC = javac
CC = gcc
CFLAGS = -Wall -Werror -g

JUNIT_PATH = /usr/share/java/junit4.jar
PROTOCOL_TEST_DIR = protocol/tests
SERVER_TEST_DIR = service/tests
CLIENT_TEST_DIR = client/tests
MAIN_CLIENT_SRC = MainClient.java
MAIN_TEST_SRC = Tests.java
MAIN_SERVER_SRC = MainServer.java
MAIN_HACKER_SRC = MainHacker.java

PROMOTER_SOURCES = promoter/src/promoter.c promoter/src/main.c promoter/src/news.c promoter/src/ad.c promoter/src/ip_handler.c
PROMOTER_OBJS = $(PROMOTER_SOURCES:%.c=%.o)


all: server user hacker promoteur

server: 
	$(JC) -cp $(shell pwd) $(MAIN_SERVER_SRC)

user: 
	$(JC) -cp $(shell pwd) $(MAIN_CLIENT_SRC)

hacker: 
	$(JC) -cp $(shell pwd) $(MAIN_HACKER_SRC)

tests:
	make -C $(PROTOCOL_TEST_DIR)
# make -C $(SERVER_TEST_DIR)
# make -C $(CLIENT_TEST_DIR)
	$(JC) -cp $(JUNIT_PATH):$(shell pwd) $(MAIN_TEST_SRC)

promoteur : $(PROMOTER_OBJS)
	$(CC) $(CFLAGS) -o $@ $^

%.o : %.c
	$(CC) $(CFLAGS) -o $@ -c $<

src/main.o : promoter/src/promoter.h
src/promoter.o : promoter/src/news.h promoter/src/ad.h promoter/src/ip_handler.h


clean:
	find . -name '*.class' -delete
	find . -name '*.o' -delete
	rm promoter

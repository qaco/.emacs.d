open Builder;;

(* Liste des couleurs présentes dans un tableau *)
let array_to_list a_colors =
  let colors = ref [] in
  for i = 0 to (Array.length a_colors) - 1 do
    match a_colors.(i) with
    | Some c -> if not (List.mem c !colors) then colors := c::!colors;
    | None -> ()
  done; !colors

(* Extraction des couleurs d'un voronoi sous la forme d'un tableau. *)
let extract_colors vor =
  let arr = ref (Array.make (Array.length vor.seeds) None) in
  for i = 0 to ((Array.length vor.seeds) - 1) do
    match vor.seeds.(i) with
    | s -> !arr.(i) <- s.c
  done;
  !arr

(* Renvoie fnc sans choix pour les régions pré-coloriées et avec tous *)
(* les choix possibles pour les autres. *)    
let rec existence i a_colors l_colors =
  (* Associe toutes les couleurs à la seed i. *)
  let rec make_exist_list i l_colors = match l_colors with
    | [] -> []
    | c::t -> (true, (i, c))::make_exist_list i t in
  (* Stocke les régions pré-coloriées et génère les coloriages pour *)
  (* les autres.*)
  match i with
  | a when (i = Array.length a_colors) -> []
  | a -> match a_colors.(i) with
         | Some c -> [(true, (i, c))]::existence (i+1)
                                                 a_colors
                                                 l_colors
         | None -> (make_exist_list i l_colors)::existence (i+1)
                                                           a_colors
                                                           l_colors

let unicity a_colors l_colors = 
  let rec make_unique_list_aux i cols1 cols2 = match cols1 with
    | [c1] -> if i = 0 then [] else make_unique_list (i - 1) l_colors
    | c1::c2::t1 ->
       begin
         match cols2 with
         | [] -> make_unique_list_aux i (c2::t1) t1
         | c3::t2 -> [(false, (i, c1));
                      (false, (i, c3))]::make_unique_list_aux i cols1 t2
       end
    | _ -> failwith "make_unique_list_aux n'a pas ete appele correctement"
  and make_unique_list i l_colors = match l_colors with
    | [] -> []
    | c::t -> make_unique_list_aux i l_colors t
  in make_unique_list (Array.length a_colors) l_colors

(* Renvoie fnc interdisant aux régions adjacentes d'avoir la même *)
(* couleur. *)
let adjacence l_colors adj_mat =
  (* Interdit aux seeds i et j d'avoir la même couleur. *)
  let rec make_color_list cons_list i j l_colors = match l_colors with
    | [] -> !cons_list
    | c::t -> [(false, (i, c));
               (false, (j, c))]::make_color_list cons_list i j t in
  let cons_list = ref []
  in for i = 0 to (Array.length adj_mat) - 1 do
       for j = i + 1 to (Array.length adj_mat) - 1 do
         if adj_mat.(i).(j) then
           cons_list := make_color_list cons_list i j l_colors
       done
     done;
     !cons_list

(* Renvoie fnc obligeant l'existence, l'unicité et le respect des *)
(* règles d'adjacence. *)
let produce_constraints a_colors adj_mat =
  let l_colors = array_to_list a_colors
  in (existence 0 a_colors l_colors)
     @(unicity a_colors l_colors)
     @(adjacence l_colors adj_mat)

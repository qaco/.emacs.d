#include <gtk/gtk.h>
#include "game.h"

static Joueur* humain ;
static GCond data_cond ;
static GMutex data_mutex ;




void my_loop(Joueur** joueurs) {

  for(int i = 0 ; ; i++) {

    if (*(joueurs + i) != humain)
      printf("joueur %d joue\n", i) ;
    else {
      g_mutex_lock(&data_mutex) ;
      while(!0)
	g_cond_wait(&data_cond, &data_mutex) ;
      g_mutex_unlock(&data_mutex) ;
    }

    if (i == 5)
      i = 0 ;
  }
}





void he_is_the_human(Joueur* joueur) {
  humain = joueur ;
}

gboolean cb_click_on_tile (GtkWidget *event_box,
			   GdkEvent  *event,
			   gpointer data) {
  if (1) { // condition pour pouvoir jouer le coup à implémenter
    move_joueur(humain, event_box) ;
    g_cond_signal(&data_cond) ;
    return TRUE ;
  }
  else
    return FALSE ;
}

gboolean test_click_on_tile (GtkWidget *event_box,
			     GdkEvent  *event,
			     gpointer data) {
  int x,y ;
  GtkWidget
    *stack = gtk_widget_get_parent (event_box),
    *grid = gtk_widget_get_parent(stack) ;
  GValue gval = G_VALUE_INIT ;

  g_value_init (&gval, G_TYPE_INT);
  
  gtk_container_child_get_property ((GtkContainer*)grid,
				    stack,
				    "left-attach",
				    &gval);
  x = g_value_get_int (&gval);
  gtk_container_child_get_property ((GtkContainer*)grid,
				    stack,
				    "top-attach",
				    &gval);
  y = g_value_get_int (&gval);
  
  printf("%d,%d,%c\n", x,y,*((char*)data)) ;

  return TRUE ;
}

#define GRAPH_TITLE "netgraph"
#define FILE_EXT ".dot"
#define GRAPH_PATH "netgraph.dot"

int crawl (char* first_url, const int depth)
{
  DbId id ;
  Word *url = construct_word(first_url, strlen(first_url)) ;
  WordList *urls_tocrawl = construct_empty_wordlist() ;
  WordDict *netgraph = construct_empty_worddict() ;
  
  dotfile_to_graph(netgraph, GRAPH_PATH) ;
  add_word_wordlist(urls_tocrawl, url) ;
  curl_global_init(CURL_GLOBAL_ALL);
  opendb(&id) ;
  for (int i = 1 ; i <= depth && get_length_wordlist(urls_tocrawl) ; i++) {
    printf("Profondeur %d\n", i) ;
    process_whole_depth(urls_tocrawl, netgraph, &id) ;
  }
  closedb(&id) ;
  destruct_wordlist(urls_tocrawl) ;
  graph_to_dotfile(netgraph, GRAPH_PATH) ;
  curl_global_cleanup();
  destruct_word(url) ;
  destruct_worddict(netgraph) ;
  return EXIT_SUCCESS ;
}

int dotfile_to_graph(WordDict *netgraph, const char* path)
{
  Word* raw_dot ;
  int ret = EXIT_SUCCESS ;
  WordDict* smooth_graph ;
  FILE* dotfile ;
  
  /* On stocke le contenu du fichier dans buffer. */
  dotfile = fopen(path, "rb");
  if (dotfile == NULL) {
    clear_worddict(netgraph) ;
    ret = EXIT_FAILURE ;
  }
  else {
    /* On génère le dictionnaire. */
    raw_dot = file_to_word(dotfile) ;
    smooth_graph = dot_to_worddict(raw_dot) ;
    addall_worddict(netgraph, smooth_graph) ;
    /* On libère les ressources. */
    destruct_worddict(smooth_graph) ;
    fclose(dotfile);
  }

  return ret ;
}

int graph_to_dotfile(const WordDict* netgraph, const char* path)
{
  int ret = EXIT_SUCCESS ;
  /* Construction de la représentation dot. */
  Word *title = construct_word(GRAPH_TITLE, strlen(GRAPH_TITLE)) ;
  Word *raw_dot = worddict_to_dot(title, netgraph) ;
  destruct_word(title) ;
  /* Écriture de la représentation dot dans le fichier. */
  FILE *dotfile = fopen(path, "w") ;
  if (dotfile == NULL)
    ret = EXIT_FAILURE ;
  else {
    print_word(raw_dot, dotfile) ;
    destruct_word(raw_dot) ;
    fclose(dotfile) ;
  }

  return ret ;
}

void process_whole_depth(WordList* urls_tocrawl, WordDict* netgraph, DbId* id)
{
  WordList* next_depth = construct_empty_wordlist() ;
  do {
    Word* current_url = construct_empty_word() ;
    WordList *urls_parsed = construct_empty_wordlist() ;
    pop_word_wordlist(current_url, urls_tocrawl) ;
    if (is_in_worddict(current_url, netgraph))
      get_value_worddict(urls_parsed, netgraph, current_url) ;
    else {
      process_single_url(current_url, urls_parsed, id) ;
      add_line_worddict(netgraph, current_url, urls_parsed) ;
      print_word(current_url, stdout) ;
      printf(" crawlée/indexée\n") ;
    }
    prepare_next_depth(urls_parsed, netgraph, next_depth) ;
    destruct_wordlist(urls_parsed) ;
    destruct_word(current_url) ;
  } while (get_length_wordlist(urls_tocrawl)) ;
  addall_wordlist(urls_tocrawl, next_depth) ;
  destruct_wordlist(next_depth) ;
}

void prepare_next_depth(WordList *urls_parsed, WordDict *netgraph, WordList* next_depth)
{
  for (int i = 0 ; i < get_length_wordlist(urls_parsed) ; i++) {
    Word *tmp_word = construct_empty_word() ;
    get_word_wordlist(tmp_word, urls_parsed, i) ;
    add_word_wordlist(next_depth, tmp_word) ;
    destruct_word(tmp_word) ;
  }
}

void process_single_url(Word* current_url, WordList* urls_parsed, DbId* id)
{
  WordList *words_parsed = construct_empty_wordlist() ;
  Word* raw_text = construct_empty_word() ;
  crawl_to_ram(current_url, raw_text) ;
  parse(raw_text, current_url, words_parsed, urls_parsed) ;
  destruct_word(raw_text) ;
  dataprocess(id, words_parsed, current_url);
  destruct_wordlist(words_parsed) ;
}

int crawl_to_ram(Word *tocrawl, Word* text)
{
  int ret = EXIT_SUCCESS ;
  int sizeword = get_size_word(tocrawl) ;
  char* myurl = malloc(sizeof(char)*(sizeword + 1)) ;
  clear_word(text) ;
  get_content_word(tocrawl, myurl) ;
  *(myurl + sizeword) = '\0' ;
  if (strncmp(myurl, "file://", strlen("file://")) == 0)
    crawl_local(myurl + strlen("file://"), text) ;
  else
    crawl_distant(myurl, text) ;
  free(myurl) ;
  return ret ;
}

int crawl_local(char* path, Word* text)
{
  FILE* file ;
  int ret = EXIT_SUCCESS ;
  file = fopen(path, "rb") ;
  if (file == NULL) {
    ret = EXIT_FAILURE ;
    fprintf(stderr, "%s abandonnée\n", path) ;
  }
  else {
    Word* raw_html = file_to_word(file) ;
    append_word(text, raw_html) ;
    destruct_word(raw_html) ;
    fclose(file) ;
  }
  return ret ;
}

static size_t
WriteMemoryCallback(void *contents, size_t size, size_t nmemb, void *userp)
{
  size_t realsize = size * nmemb;
  Word *mem = (Word *)userp;
  add_chars_word(mem, contents, realsize) ;
  return realsize;
}

int crawl_distant(char* myurl, Word *text)
{
  int ret = EXIT_SUCCESS ;
  Word *chunk = construct_empty_word() ;
  CURL *curl_handle;
  CURLcode res;
  curl_handle = curl_easy_init();
  curl_easy_setopt(curl_handle, CURLOPT_URL, myurl);
  curl_easy_setopt(curl_handle, CURLOPT_WRITEFUNCTION, WriteMemoryCallback);
  curl_easy_setopt(curl_handle, CURLOPT_WRITEDATA, (void *)chunk);
  curl_easy_setopt(curl_handle, CURLOPT_USERAGENT, "libcurl-agent/1.0");
  res = curl_easy_perform(curl_handle);
  if(res != CURLE_OK) {
    ret = EXIT_FAILURE ;
    fprintf(stderr, "%s abandonnée\n", myurl) ;
  }
  else
    append_word(text, chunk) ;
  destruct_word(chunk) ;
  curl_easy_cleanup(curl_handle);
  return ret ;
}











  


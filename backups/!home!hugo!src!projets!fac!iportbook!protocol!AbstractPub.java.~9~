package protocol ;

import protocol.field.* ;
import exception.* ;

public class AbstractPub {
    
    protected IpDiffField ip ;
    protected PortField port ;
    protected MessField message ;

    public AbstractPub(String i, String p, String m) throws UnknownResultException {
        this.ip = new IpDiffField(i) ;
        this.port = new PortField(p) ;
        this.message = new MessField(m) ;
    }
}
            

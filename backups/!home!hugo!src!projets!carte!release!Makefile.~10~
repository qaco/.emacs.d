OC=ocamlc
LINKS=graphics.cma
EXEC=coloriage
SRC=sat_solver.ml voronoi.ml examples.ml
OBJ=$(SRC:.ml=.cmo)

all: $(EXEC)

$(EXEC) : $(OBJ)
	$(OC) -o $@ $(LINKS) $^

voronoi.cmo: voronoi.ml voronoi.cmi sat_solver.cmi
	$(OC) -c $<

sat_solver.cmo: sat_solver.ml sat_solver.cmi
	$(OC) -c $<

examples.cmo: examples.ml voronoi.cmi
	$(OC) -c $<

%.cmi: %.mli
	$(OC) -o $@ -c $<

clean :
	rm -rf *.cmo *.cmi

mrproper : clean
	rm -rf $(EXEC)

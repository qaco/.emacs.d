#include <stdio.h>
#include <stdlib.h>
#include "miroir.h"

int main(int argc, char* argv[]) {
  FILE* source ;
  FILE* image ;

  argv++ ;
  argc-- ;

  switch (argc) {
  case 0 :
    fputs("Il faut donner au moins un argument !\n", stderr) ;
    exit(EXIT_FAILURE) ;
    break ;
  case 1 :
    source = fopen(*argv, "r") ;
    image = stdout ;
    break ;
  default :
    source = fopen(*argv, "r") ;
    image = fopen(*(argv+1), "w") ;
    break ;
  }
  miroir(source,image) ;
  fclose(source) ;
  if (argc > 1)
    fclose(image) ;
}

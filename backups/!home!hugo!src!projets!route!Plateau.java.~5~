import java.util.List ;

public class Plateau {
    private Case[][] cases = new Case[Data.NBCASES][Data.NBCASES] ;

    public Plateau() {
	for (int i = 0 ; i < Data.NBCASES ; i++)
	    for (int j = 0 ; j < Data.NBCASES ; j++)
		cases[i][j] = new Case(j,i) ;
    }

    public Case getCase(int x, int y) {
	return cases[y][x] ;
    }

    public void industrialiserPlateau(List<Joueur> players) {
	
	int joueursParCote = players.size()/2 ;
	int casesParJoueur = Data.NBCASES/joueursParCote -2 ;
	int offset = (Data.NBCASES - (casesParJoueur * joueursParCote + joueursParCote - 1) - 2)/2 ;
	int c = 1 + offset ;
	int p = 0 ;

	for (int i = 0 ; i < joueursParCote ; i++) {
	    for (int j = 0 ; j < casesParJoueur ; j++) { 
		industrialiserCase(c, 0, players.get(i)) ;
		players.get(i).pushStart(cases[0][c]) ;
		industrialiserCase(c, Data.NBCASES - 1, players.get(i)) ;
		players.get(i).pushGoal(cases[Data.NBCASES - 1][Data.NBCASES -c]) ;
		c++ ;
	    }
	    p++ ;
	    c++ ;
	}
	c = 1 + offset ;
	for (int i = 0 ; i < joueursParCote ; i++) {
	    for (int j = 0 ; j < casesParJoueur ; j++) {

		industrialiserCase(0,c, players.get(i+p)) ;
		players.get(i+p).pushStart(cases[c][0]) ;
		industrialiserCase(Data.NBCASES - 1,c, players.get(i+p)) ;
		players.get(i+p).pushGoal(cases[c][Data.NBCASES - 1]) ;
		c++ ;
	    }
	    c++ ;
	}
	    
    }
    
    public void industrialiserCase(int x, int y, Joueur j) {
	cases[y][x] = new Ville(x,y,j) ;
    }

    public String toString() {
	String s = new String() ;
	for (int i = 0 ; i < Data.NBCASES ; i++) {
	    for (int c = 0 ; c < 3 ; c++) {
		switch(c) {
		case 0 :
		    for (int j = 0 ; j < Data.NBCASES ; j++) {
			s += " " ;
			try {
			    s += cases[i][j].getRoute(Data.TOP).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
			s += " " ;
		    }
		    s += "\n" ;
		    break ;
		case 1 :
		    for (int j = 0 ; j < Data.NBCASES ; j++) {
			try {
			    s += cases[i][j].getRoute(Data.LEFT).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
			
			s+= cases[i][j].toString() ;

			try {
			    s += cases[i][j].getRoute(Data.RIGHT).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
		    }
		    s += "\n" ;
		    break ;
		case 2 :
		    for (int j = 0 ; j < Data.NBCASES ; j++) {
			s += " " ;
			try {
			    s += cases[i][j].getRoute(Data.BOTTOM).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
			s += " " ;
		    }
		    s += "\n" ;
		    break ;	    
		}
	    }
	}
	return s ;
    }
}

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <curl/curl.h>

#include "word.h"
#include "wordlist.h"

static size_t
WriteMemoryCallback(void *contents, size_t size, size_t nmemb, void *userp)
{
  Word *mem = (Word *)userp;

  *mem = construct_word(contents, nmemb) ;
 
  return nmemb ;
}
 
static int
url_to_ram(Word tocrawl, Word* text)
{
  char* myurl = get_cstring_word(tocrawl) ;
  Word chunk;
  CURL *curl_handle;
  CURLcode res;
  int ret = 0 ;

  curl_handle = curl_easy_init();
  curl_easy_setopt(curl_handle, CURLOPT_URL, myurl);
  curl_easy_setopt(curl_handle, CURLOPT_WRITEFUNCTION, WriteMemoryCallback);
  curl_easy_setopt(curl_handle, CURLOPT_WRITEDATA, (void *)&chunk);
  curl_easy_setopt(curl_handle, CURLOPT_USERAGENT, "libcurl-agent/1.0");
  res = curl_easy_perform(curl_handle);
  if(res != CURLE_OK) {
    fprintf(stderr, "curl_easy_perform() failed: %s\n",
            curl_easy_strerror(res));
    ret-- ;
  }
  else
    *text = chunk ;
  curl_easy_cleanup(curl_handle);
 
  return ret ;
}

int crawl (const char* first_url)
{
  Word text ;
  Word tmp_url = construct_word(first_url, strlen(first_url)) ;
  WordList mylist = build_wordlist(tmp_url) ;

  curl_global_init(CURL_GLOBAL_ALL);

  while (!is_empty_wordlist(mylist)) {
    tmp_url = pop_word_wordlist(&mylist) ;
    url_to_ram(tmp_url, &text) ;
    destruct_word(&tmp_url) ;
    printf("%zu bytes retrieved\n", get_size_word(text)) ;
    /* Appeler le parser ici et boucler tant qu'il y a des URL */
  }
  
  curl_global_cleanup();

  return 0 ;
}

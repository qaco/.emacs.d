package protocol.knock ;

import exception.UnknownResultException ;

public class KnockFactory {
    
    public Knock create (byte[] notif) throws UnknownResultException {
        if (notif.length <= KnockVals.NUM_BYTES)
            throw new UnknownResultException() ;
        switch(notif[0]) {
        case KnockVals.FRIENDSHIP_CODE :
            return new FriendshipKnock(notif[1], notif[2]) ;
        case KnockVals.FRIENDOK_CODE :
            return new OkFriendKnock(notif[1], notif[2]) ;
        case KnockVals.FRIENDNO_CODE :
            return new NoFriendKnock(notif[1], notif[2]) ;
        case KnockVals.MESSAGE_CODE :
            return new MessageKnock(notif[1], notif[2]) ;
        case KnockVals.FLOO_CODE :
            return new FlooKnock(notif[1], notif[2]) ;
        case KnockVals.PUBLICITY_CODE :
            return new PublicityKnock(notif[1], notif[2]) ;
        default : throw new UnknownResultException() ;
        }
    }
}

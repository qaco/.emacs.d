/* Le premier argument stocké depuis la ligne de commande est le nom du
   programme lui-même. On le néglige en décalant le pointeur argv d'un
   objet et en décrémentant le compteur d'arguments. */

--argc;
++argv;

/* L'évaluation continue tant qu'il reste des arguments et à condition que le
   premier caractère de l'argument soit "-" (désigne une option).
*/
while (argc > 0 && *argv[0] == '-')
  {
    /*
      Pointeur vers l'argument en cours de traitement minus le "-" initial.
    */
    char const *temp = argv[0] + 1;
    size_t i;

    /* Vérifie que les options sont valides ; sinon, commence l'exécution du
       programme vanilla.
    */

    for (i = 0; temp[i]; i++)  // tourne tant que temp[i] différent de 0
      switch (temp[i])
	{
	case 'e': case 'n':    // les différentes options valides
	  break;
	default:
	  goto just_echo;
	}

    if (i == 0)
      goto just_echo;

    /* All of the options in TEMP are valid options to ECHO.
       Handle them. */
    while (*temp)
      switch (*temp++)
	{
	case 'e':
	  do_v9 = true;
	  break;

	case 'E':
	  do_v9 = false;
	  break;

	case 'n':
	  display_return = false;
	  break;
	}

    argc--;
    argv++;
  }

just_echo:

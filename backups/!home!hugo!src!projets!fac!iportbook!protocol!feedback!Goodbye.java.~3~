package protocol.feedback ;

import main.MainVals ;
import client.src.ServerRequest;
import client.src.ConnexionRequest;

public class Goodbye implements Feedback {
    public String toString() {
        return FeedbackVals.GOODBYE + MainVals.EOF ;
    }
    
    public void exec(ServerRequest sr) {
	System.out.println("[Goodbye.]");
	sr.setStatus(false);
    }  

    public void exec(ConnexionRequest cr) {
	System.out.println("[Inscription refusée.]");
	cr.setStatus(false);
    }  
}

package protocol.command ;

import exception.* ;
import protocol.ProtocolFactory ;
import java.util.Arrays ;
import java.io.InputStream ;
import java.io.IOException ;
import main.MainVals ;

public class AnonFactory extends ProtocolFactory {

    public Anon create(InputStream in) throws UnknownResultException,
                                         IOException {
        byte[][] raw_arr = this.readStream(in) ;
        return this.create(raw_arr) ;
    }
    
    private Anon create(byte[][] raw_arr) throws UnknownResultException {
        String code = this.extractCode(raw_arr) ;
        byte[][] params = Arrays.copyOfRange(raw_arr,1,raw_arr.length) ;
        byte[] mess ;

        try {
            switch (code) {
            case AnonVals.REGISTRATION:
                return new Registration(params[0], params[1], params[2]) ;
            case AnonVals.CONNECTION :
                return new Connection(params[0], params[1]) ;
            case AnonVals.PUB:
                mess = this.joinArray(params, 2) ;
                return new Pub(params[0], params[1], mess) ;
            default :
                throw new UnknownCommandException("anon", code) ;
            }
        } catch (ArrayIndexOutOfBoundsException e) {
            throw new TooFewArgsException(code,
                                          String.valueOf(params.length)) ;
        }
    }
}


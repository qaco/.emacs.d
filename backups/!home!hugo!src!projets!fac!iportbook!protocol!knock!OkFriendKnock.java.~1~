package protocol.knock ;

public class OkFriendKnock extends Knock {
    
    public OkFriendKnock(int flows) {
        super(flows) ;
    }

    public OkFriendKnock(byte mylow, byte myhigh) {
        super(mylow, myhigh) ;
    }

    public byte getCode() {
        return KnockVals.FRIENDOK_CODE ;
    }

    public String popUp() {
        return KnockVals.FRIENDOK_MESS;
    }
}

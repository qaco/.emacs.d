
#include <sys/types.h>
#include <dirent.h>
#include <unistd.h>
#include <string.h>
#include "treedir.h"

#define CHILDREN_MAX 1024
#define SIZE_PATH 1024

node* new_node(const char* name) {
  int namesize = strlen(name) ;
  node* res = malloc(sizeof(node)) ;
  res->name = malloc(sizeof(char)*namesize) ;
  strcpy(res->name, name) ;
  res->nb_children = 0 ;
  res->children = malloc(sizeof(node)*CHILDREN_MAX) ;
  return res ;
}

void delete_node(node* nd) {
  free(res->name) ;
  free(res->children) ;
  free(res) ;
}

int new_child(node *current, const char* name) {
  if (res->nb_children >= CHILDREN_MAX - 1)
      return -1 ;
  *(res->children + res->nb_children++) = new_node(name) ;
  return 0 ;
}


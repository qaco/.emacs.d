node* build_from_path(const char* path) {
  char* new_path ;
  node* res = new_node(path) ;
  DIR* current ;
  struct dirent* tmp ;

  current = opendir(path) ;

  do {
    tmp = readdir(current) ;
    new_path = malloc(sizeof(char)*SIZE_PATH) ;
    strcpy(new_path, path) ;
    strcat(new_path, "/") ;
    strcat(new_path, tmp->d_name) ;
      
    if (tmp != NULL && tmp->d_type == DT_DIR)
      (res->children + res->nb_children++) = build_from_path(new_path) ;
    else if (tmp != NULL)
      new_child(res, new_path) ;

    free(new_path) ;
      
  }
  return res ;
}

node* build_from_current_file() {
  node* res ;
  char* path = malloc(sizeof(char)*SIZE_PATH) ;
  getcwd(path, DIRECTORY_LENGTH) ;
  res = build_from_path(path) ;
  free(path) ;
}
    
  
  

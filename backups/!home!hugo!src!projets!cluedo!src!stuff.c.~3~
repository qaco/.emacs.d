#include <stdlib.h>
#include <gtk/gtk.h>
#include "stuff.h"

Joueur* construct_joueur(Perso perso, GtkWidget* image) {
  Joueur *joueur = malloc(sizeof(Joueur)) ;
  joueur->mon_perso = perso ;
  joueur->pion = image ;
  return joueur ;
}

int can_move_joueur(Joueur* j, GtkWidget* event_box, char info) {
  return 1 ;
}

void move_joueur(Joueur* j, GtkWidget* event_box) {
  GtkWidget
    *src = gtk_widget_get_parent(j->pion),
    *dest = gtk_widget_get_parent(event_box) ;

  g_object_ref(j->pion) ;
  gtk_container_remove ((GtkContainer*) src, j->pion);
  gtk_overlay_add_overlay((GtkOverlay*)dest, j->pion) ;
}

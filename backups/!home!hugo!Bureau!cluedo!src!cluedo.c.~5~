#include <stdio.h>
#include <stdlib.h>
#include <gtk/gtk.h>
#include "gen.h"
#include "view.h"

#define MAP_SIZE 24

int main(int argc, char* argv[]) {
  char** mymap = map(MAP_SIZE) ;
  GtkWidget* window;
  GtkWidget* table ;

  gtk_init(&argc,&argv);
  
  window = conf_window(MAP_SIZE) ;
  table = fill_window(window, MAP_SIZE, mymap) ;
  
  gtk_widget_show_all(window);
  gtk_main();
  
}

import Misc, Root
from PIL import Image, ImageDraw, ImageFont

MARGIN_RATIO = 30

def factory(cmd, planesize, frame, text, font, color):
    options = { Misc.NAIVE_SLOGAN : NaiveSlogan,
                Misc.BOTTOM_SLOGAN : BottomSignedSlogan }
    return options[cmd](planesize, frame, text, font, color)

class AbstractSlogan(Root.Place):
    def __init__(self, planesize, frame, text, font, color):
        super().__init__(planesize, frame.point, frame.size)
        self.frame = frame
        self.lines = text.split("\n")
        self.sfont = font
        self.color = color
        self.fontsize = 0
        
    def is_signed(self):
        raise NotImplementedError()

    def set_text(self, text):
        self.lines = text.split("\n")

    def stamp_img(self, img):
        tostamp = img.copy()
        font = ImageFont.truetype(self.sfont, self.fontsize)
        draw = ImageDraw.Draw(tostamp, 'RGBA')
        # point_tmp = self.point
        offsety = 0
        for line in self.lines:
            size_tmp = draw.textsize(line, font)
            offsetx = self.point[0] + int((self.size[0] - size_tmp[0])/2)
            point_tmp = offsetx, self.point[1] + offsety
            draw.text(point_tmp, line, self.color, font)
            offsety += size_tmp[1]
        # dessin du cadre
        # o_point = self.point[0] + self.size[0], self.point[1] + self.size[1]
        # draw.rectangle([self.point, o_point], None, (0,0,0))
        return tostamp

    def process_position(self):
        mpoint, msize = self.process_margin(self.frame)
        self.point = mpoint
        fsize, tsize = self.process_sizes(msize, self.lines, self.sfont)
        self.fontsize = fsize
        if fsize > 0:
            self.size = tsize
            self.finalize_layout()
        else :
            self.size = msize
    
    # On rétrécit un peu le cadre pour que le texte ne touche pas les bords.
    def process_margin(self, frame):
        offset = frame.size[0]/MARGIN_RATIO
        point = int(frame.point[0] + offset), int(frame.point[1] + offset)
        size = int(frame.size[0] - offset*2), int(frame.size[1] - offset*2)
        return point, size

    def process_sizes(self, max_size, lines, font_path):
        fontsize = 0
        textsize = 0,0
        img_tmp = Image.new('RGBA', max_size, (0,0,0))
        draw = ImageDraw.Draw(img_tmp, 'RGBA')
        issmall = max([len(line) for line in lines]) > 0
        while issmall :
            fontsize_tmp = fontsize + 1
            font = ImageFont.truetype(font_path, fontsize_tmp)
            textw, texty = 0, 0
            for line in lines :
                incsize = draw.textsize(line, font)
                textw, texty = max(textw, incsize[0]), texty + incsize[1]
            issmall = textw < max_size[0] and texty < max_size[1]
            if issmall:
                fontsize = fontsize_tmp
                textsize = textw, texty
        return fontsize, textsize
            
    def finalize_layout(self):
        raise NotImplementedError()

class NaiveSlogan(AbstractSlogan):
    def __init__(self, planesize, frame, text, font, color):
        super().__init__(planesize, frame, text, font, color)

    def is_signed(self):
        return False

    # L'espace vide est réparti pour moitié en haut et en bas du slogan.
    def finalize_layout(self):
        offsetx = int((self.frame.size[0] - self.size[0])/2)
        offsety = int((self.frame.size[1] - self.size[1])/2)
        self.point = self.frame.point[0] + offsetx, self.frame.point[1] + offsety

class SignedSlogan(AbstractSlogan):
    def __init__(self, planesize, frame, text, font, color):
        super().__init__(planesize, frame, text, font, color)
        self.free_area = None

    def is_signed(self):
        return True
    
class BottomSignedSlogan(SignedSlogan):
    def __init__(self, planesize, frame, text, font, color):
        super().__init__(planesize, frame, text, font, color)

    # L'espace vide est réparti en cinq cinquièmes :
    # - Un cinquième au-dessus du slogan
    # - Le slogan
    # - Un cinquième au-dessous du slogan
    # - Deux cinquièmes réservés au logo
    # - Un cinquième au-dessous du logo
    def finalize_layout(self):
        blank_space = self.frame.size[1] - self.size[1]
        b_fifth = int(blank_space/5)
        self.point = self.point[0], self.frame.point[1] + b_fifth
        free_corner = self.piont[0], self.point[1] + self.size[1] + b_fifth
        free_size = self.frame.size[0], b_fifth*2
        self.free_area = Root.Frame(self.upper_size, free_corner, free_size)


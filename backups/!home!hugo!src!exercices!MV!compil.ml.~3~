(* open MyrtheAST *)
(* open Mv *)

let repr : value -> int = function
  | Bool true -> 1
  | Bool false -> 0
  | Int i -> i

let rec compil = function
  | Const v ->
     [Consti (repr v)]
  | Unop (Succ, e) ->
     (compil e) @ [Push; Consti 1; Addi]
  | Binop (Plus, e1, e2) ->
     (compil e1) @ [Push] @ (compil e2) @ [Addi]
  | Binop (Eq, e1, e2) ->
     (compil e1) @ [Push] @ (compil e2) @ [Eqi]
  | If (e1, e2, e3) ->
     let l1 = compil e1 in
     let l2 = compil e2 in
     let l3 = compil e3 in
     (* Si le test est vrai, goto l2 *)
     l1 @ [BranchIf (List.length l3+2)]
     (* Le test est faux, exécution de l3 puis goto end *)
     @ l3 @ [Branch (List.length l2+1)]
     (* Éxécution de l2 *)
     @ l2
  | Caseof(e1, l, e2) ->
     let pivot = compil e1 in
     let gen_test (couple:value*expression) : instr list = 
       let expr = compil (snd couple) in
       (compil (Binop (Eq, pivot, fst couple))) @
         [BranchIf 1; Branch (List.length expr+1)] @
           expr in
     let tests = List.flatten (List.map gen_tests l) in
     tests @ (compil e2)
  | _ -> failwith "Students, this is your job !"



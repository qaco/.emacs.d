package protocol.answer ;

import exception.* ;
import protocol.ProtocolFactory ;
import java.util.Arrays ;
import java.io.InputStream ;
import java.io.IOException ;
import main.MainVals ;

public class AnswerFactory extends ProtocolFactory {

    public Answer create(InputStream in) throws UnknownResultException,
                                           IOException {
        byte[][] raw_arr = this.readStream(in) ;
        return this.create(raw_arr) ;
    }
    
    private Answer create(byte[][] raw_arr) throws UnknownResultException {
        String code = this.extractCode(raw_arr) ;
        byte[][] params = Arrays.copyOfRange(raw_arr,1,raw_arr.length) ;
        
        switch (code) {
        case AnswerVals.OK_FRIEND :
            return new AcceptFriend() ;
        case AnswerVals.NO_FRIEND :
            return new RefuseFriend() ;
        default :
            throw new UnknownCommandException(code, "answer") ;
        }
    }
}


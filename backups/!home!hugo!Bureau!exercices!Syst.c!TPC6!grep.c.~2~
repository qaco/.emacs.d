#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define LIGNE_MAX 80

int main(int argc, char* argv[]) {

  argv++ ;
  argc-- ;
  char* expression ;
  char* entree ;
  char* sortie ;
  char* display = malloc(sizeof(char)*LIGNE_MAX+1) ;
  char tmp ;
  int i ;

  switch(argc) {
  case 2 :
    expression = *argv ;
    entree = *(argv + 1) ;
  case 3 :
    sortie = *(argv + 2) ;
    break ;
  default :
    exit(EXIT_FAILURE) ;
    break ;
  }

  FILE* cobaye = fopen(entree, "r") ;
  do {
    for (i = 0 ; i < LIGNE_MAX ; i++) {
      tmp = fgetc(cobaye) ; // plante ici
      if (tmp == '\n' || tmp == EOF) break ;
      else *(display+i) = tmp ;
    }
    *(display+i) = '\0' ;
    if (strstr(display, expression) != NULL)
      printf("%s\n",display) ;
  } while (tmp != EOF) ;
}

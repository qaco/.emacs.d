package protocol.command ;
import exception.UnknownResultException ;

import main.MainVals ;
import exception.* ;
import service.User ;
import protocol.AbstractFirstMessage ;
import protocol.field.Field ;
import protocol.flow.* ;
import protocol.feedback.* ;
import protocol.knock.MessageKnock ;
import java.util.List ;
import java.util.ArrayList ;
import java.io.Reader ;
import java.io.InputStream ;
import java.io.IOException ;

public class FirstMessage extends AbstractFirstMessage implements Command {

    public FirstMessage (byte[] i, byte[] n) throws UnknownResultException {
        super(i, n) ;
    }
    
    public FirstMessage (String i, String n) {
        super(i, n) ;
    }

    public FirstMessage (String i, int n) {
        super(i, n) ;
    }

    public void exec(User myuser, List<User> allusers) throws IOException,
                                                              UnknownResultException {
        synchronized(allusers) {
            String myname = this.id.toString() ;
            if (myuser.isAFriend(myname)) {
                User target = myuser.getFriend(myname) ;
                List<Flow> f = this.getMessages(myuser) ;
                target.pushFlows(f) ;
                target.sendUDP(new MessageKnock(target.howManyFlows())) ;
                myuser.sendTCP(new MessageTransmitted()) ;
                this.describeMessageTransmitted() ;
            }
            else {
                myuser.sendTCP(new MessageNotTransmitted()) ;
                throw new NotExecutableException("FirstMess",
                                                 myname + " not a friend") ;
            }
        }
    }

    private List<Flow> getMessages(User myuser) throws UnknownResultException,
                                                       IOException {
        List<Flow> flow = new ArrayList<Flow>() ;
        String target = myuser.getFriend(this.id.toString()).getId() ;
        SomeMessageFactory f = new SomeMessageFactory() ;
        flow.add(new FirstMessageFlow(myuser.getId(), this.num.getInt())) ;
        for (int i = 0 ; i < this.num.getInt() ; i++) {
            SomeMessage m = f.create(myuser.getInputStream()) ;
            flow.add(0, new SomeMessageFlow(m.getNum(), m.getMess()));
            this.describeReceivedPart(i) ;
        }
        return flow ;
    }

    public byte[] toBytes() {
        Field[] fields = { this.id, this.num } ;
        return Field.makeSentence(CommandVals.FIRST_MESSAGE, fields) ;
    }
    
    public String toString() {
        String mynum = String.valueOf(this.num) ;
        return
            CommandVals.FIRST_MESSAGE + " " +
            this.id.toString() + " " + this.num.toString() + MainVals.EOF ;
    }

    private void describeMessageTransmitted() {
        MainVals.describe("Message transmitted to " + this.id.toString()) ;
    }

    private void describeReceivedPart(int c) {
        MainVals.describe("Received part " +
                          String.valueOf(c) + "/" + this.toString()) ;
    }
}

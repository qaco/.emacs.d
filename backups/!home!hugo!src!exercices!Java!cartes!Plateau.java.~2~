import java.util.List ;
import java.util.ArrayList ;

public class Plateau {
    private Pioche pioche ;
    private Carte talon ;
    private int aPayer = 0 ;

    public Plateau() {
	pioche = new Pioche() ;
	do {
	    talon = pioche.piocher() ;
	    if (talon.isCarteSpeciale())
		pioche.rangerEnFin(talon) ;
	} while (talon.isCarteSpeciale()) ;
    }

    public int getAPayer() {
	return this.aPayer ;
    }
    
    public void coup(Carte c) throws CoupInterditException {
	if (c.getValeur() == 8) {
	    if (aPayer == 0)
		talon = new Carte(c.getSigne, talon.getValeur()) ;
	    else
		throw new CoupInterditException
		    ("Impossible de changer la couleur : "
		     + aPayer + " à payer") ;
	}

	if (this.talon.sameSigne(c) || this.talon.sameValeur(c)) {
	    switch (c.getValeur()) {
	    case 10 :
		throw new RejouerException("Vous devez rejouer") ;
		break ;
	    case 2 :
		aPayer += 2 ;
		throw new NePayePasException() ;
		break ;
	    }
	}
	else
	    throw new CoupInterditException("Signe et/ou valeur "
					    + "différents du talon") ;
    }

    public List<Carte> payer() {
	List<Carte> res = new ArrayList<Carte>() ;
	for (int i = 0 ; i < aPayer ; i++)
	    res.add(poche.piocher()) ;
	return res ;
    }

    public Carte piocher() {
	return pioche.piocher() ;
    }

    public String toString() {
	return "Talon : " + talon.toString() + "\n" ;
    }
}
    

package protocol.field ;

import exception.RuleBrokenException ;
import exception.UnknownResultException ;

public class MessField extends Field {

    public MessField(byte[] mymess) throws UnknownResultException {
        super(mymess) ;
    }

    public MessField(String mymess) {
        super(mymess) ;
    }
    
    protected void checkRules() throws UnknownResultException {
        this.checkSize(FieldVals.MAX_MSG_SIZE) ;
        this.checkAllAscii() ;
    }
        

package protocol.flow ;
import main.MainVals ;
import exception.* ;
import client.src.ServerRequest;
import java.io.IOException ;

public class FlooMessageFlow implements Flow {

    private String mess ;
    private String id ;

    public FlooMessageFlow (String i,String m) throws UnknownResultException {
        this.id = i ;
        this.mess = m ;
        if (this.mess.length() > MainVals.MAX_MSG_SIZE)
            throw new RuleBrokenException("mess > 200", "FlooFlow") ;
        if (this.id.length() > MainVals.MAX_ID_SIZE)
            throw new RuleBrokenException("id > 8", "FlooFlow") ;
    }

    public void exec(ServerRequest c) throws IOException { 
	System.out.println("[Vous avez été innondé par "+this.id+"]");
	System.out.println("-- "+this.mess);
    }

    public String toString() {
        return
            FlowVals.FLOO_MESSAGE + " " + this.id + " " + this.mess +
            MainVals.EOF ;
    }
}

#include <check.h>
#include <stdlib.h>
#include "../misc/word.h"
#include "../misc/wordlist.h"
#include "../misc/worddict.h"

WordDict *mydict ;
Word *mydot, *title ;

void dot_worddict_setup(void) {
  Word* first = construct_word(strlen("digraph test {\n"),
                               "digraph test {\n") ;
  Word* second = construct_word(strlen("rire\n"), "rire\n") ;
  Word* third = construct_word(strlen("rire -> haha\n"),
                               "rire -> haha\n") ;
  Word* fourth = construct_word(strlen("rire -> hihi\n"),
                                "rire -> hihi\n") ;
  Word* fifth = construct_word(strlen("}\n"), "}\n") ;
  mydot = construct_word(0, NULL) ;
  append_word(mydot, first) ;
  append_word(mydot, second) ;
  append_word(mydot, third) ;
  append_word(mydot, fourth) ;
  append_word(mydot, fifth) ;
  destruct_word(first) ;
  destruct_word(second) ;
  destruct_word(third) ;
  destruct_word(fourth) ;
  destruct_word(fifth) ;
  
  WordList *values = build_empty_wordlist() ;
  Word *key = construct_word(strlen("rire"), "rire") ;
  add_charseq_wordlist(values, "haha", strlen("haha")) ;
  add_charseq_wordlist(values, "hihi", strlen("hihi")) ;
  mydict = construct_empty_worddict() ;
  add_line_worddict(mydict, key, values) ;
  destruct_wordlist(values) ;
  destruct_word(key) ;

  title = construct_word(strlen("test"), "test") ;
}

void dot_worddict_teardown(void) {
  destruct_worddict(mydict) ;
  destruct_word(mydot) ;
}

START_TEST(test_worddict_to_dot) {
  Word* newdot ;
  int test ;

  newdot = worddict_to_dot(title, mydict) ;
  test = compare_word(mydot, newdot) == 0 ;
  ck_assert_int_eq(test, 1) ;
}
END_TEST

START_TEST(test_dot_to_worddict) {
  WordDict* newdict ;
  int test ;

  newdict = dot_to_worddict(mydot) ;
  test = is_equal_worddict(mydict, newdict) ;
  ck_assert_int_eq(test, 1) ;
}
END_TEST

TCase* worddict_dot_case(void) {
  TCase* tc_dot ;

  tc_dot = tcase_create("WordDict dot") ;
  tcase_add_checked_fixture(tc_dot,
                            dot_worddict_setup,
                            dot_worddict_teardown) ;
  tcase_add_test(tc_dot, test_worddict_to_dot) ;
  tcase_add_test(tc_dot, test_dot_to_worddict) ;
  return tc_dot ;
}

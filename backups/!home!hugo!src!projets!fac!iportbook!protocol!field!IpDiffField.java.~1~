package protocol.field ;

import exception.UnknownResultException ;
import exception.RuleBrokenException ;

public class IpDiffField extends Field {

    public IPDiffField (byte[] myip) {
        super(myip) ;
    }
    
    public IpDiffField(String myip) {
        StringBuffer refined = new StringBuffer(myip) ;
        if (myip.length() > ProtocoVals.IPDIFF_SIZE)
            throw new IllegalArgumentException() ;
        else if (myip.length() < ProtocoVals.IPDIFF_SIZE) {
            for (int i = 0 ; i < ProtocoVals.IPDIFF_SIZE - tmp.length() ; i++)
                refined.append(FieldVals.JAM_IPDIFF) ;
        }
        super(refined.toString()) ;
    }
    
    protected void checkRules() throws UnknownResultException {
        this.checkSize(ProtocoVals.IPDIFF_SIZE) ;
        this.checkAllAscii() ;
        if (this.toString().matches("[^0-9.#]"))
    }
    
}

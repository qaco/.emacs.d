public class Registration implements Protocol {
    
    private String id ;
    private int port ;
    private int mdp ;
    
    public Registration (String myid,
                         String myport,
                         String mymdp) throws ParseException {
        this.id = myid ;
        try {
            this.port = Integer.parseInt(myport) ;
            this.mdp = Integer.parseInt(mymdp) ;
        } catch (NumberException e) {
            this.port = -1 ;
            this.mdp = -1 ;
        }
    }

    public String toString() {
        String myport = String.valueOf(this.port) ;
        String mymdp = String.valueOf(this.mdp) ;
        return
            "REGIS " +
            this.id + " " + myport + " " + mymdp +
            "+++" ;
    }
}

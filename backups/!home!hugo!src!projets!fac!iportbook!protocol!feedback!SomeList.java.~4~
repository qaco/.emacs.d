package protocol.feedback ;
import client.src.ServerRequest;
import exception.* ;
import main.MainVals ;

public class SomeList implements Feedback {
    String id ;

    public SomeList(String myid) throws UnknownResultException {
        this.id = myid ;
        if (this.id.length() > MAINVALS.ID_SIZE)
            throw new RuleBroken() ;
    }
    
    public String toString() {
        return
            FeedbackVals.SOME_LIST + FeedbackVals.SEP +
            this.id + FeedbackVals.EOF ;
    }

    public void exec(ServerRequest c) {
	System.out.println("[- "+this.id+"]");
    }  
}

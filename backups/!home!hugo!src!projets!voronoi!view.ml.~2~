open Array;;
open Graphics;;
open Voronoi;;
  
(* Vérifie si le point (j,i) de la matrice des régions est adjacent à un point *)
(* de valeur différente. *)
let is_border matrix i j =
  ( i - 1 < 0 || matrix.(i).(j) != matrix.(i-1).(j))
  || ( j - 1 < 0 || matrix.(i).(j) != matrix.(i).(j-1))
  || ( i + 1 > (length matrix) - 1
       || matrix.(i).(j) != matrix.(i+1).(j))
  || ( j + 1 > (length matrix) - 1
       || matrix.(i).(j) != matrix.(i).(j + 1))

(* À partir de la matrice des régions (ie matrice de pixels) et du *)
(* diagramme, affiche à l'écran le diagramme colorié. La fenêtre *)
(* graphique doit être lancée avant. *)
let draw_voronoi matrix diagramme =
  for i = 0 to (length matrix) - 1 do
    for j = 0 to (length matrix.(i)) - 1 do
      if ((diagramme.seeds.(matrix.(i).(j)).y = i
           && diagramme.seeds.(matrix.(i).(j)).x = j)) then
        (set_color black ; fill_circle j i 2)
      else if (is_border matrix i j) then
        (set_color black ; plot j i)
      else
        (match diagramme.seeds.(matrix.(i).(j)).c with
         | None -> (set_color white ; plot j i)
         | Some(c) -> (set_color c ; plot j i))
    done
  done

(* À partir d'un indice de seed, de la matrice des régions (ie matrice de *)
(* pixels) et du diagramme, met à jour la couleur de la région à l'écran. *)
(* La fenêtre graphique doit être lancée avant. *)
let draw_region iseed matrix diagramme =
  for i = 0 to (length matrix) - 1 do
    for j = 0 to (length matrix.(i)) - 1 do
      if (matrix.(i).(j) = iseed) then
        if ((diagramme.seeds.(matrix.(i).(j)).y = i
             && diagramme.seeds.(matrix.(i).(j)).x = j)) then
          (set_color black ; fill_circle j i 2)
        else if (is_border matrix i j) then
          (set_color black ; plot j i)
        else
          (match diagramme.seeds.(matrix.(i).(j)).c with
           | None -> (set_color white ; plot j i)
           | Some(c) -> (set_color c ; plot j i))
    done
  done

(* Affiche le texte donné en paramètre dans la couleur donnée en paramètre *)
(* (black ou red) dans l'une des deux zones prévues à cet effet. *)
let dd s c =
  set_color white;
  begin
    match c with
    | col when c = black ->
       fill_rect 0 850 900 50;
       moveto 50 (size_y () - 40);
       set_color black
    | col when c = red ->
       fill_rect 0 800 900 50;
       moveto 100 (size_y () - 80);
       set_color red
    | _ -> clear_graph ()
  end;
  draw_string s

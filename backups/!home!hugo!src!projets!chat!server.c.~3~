#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <fcntl.h>

int main(int argc, char* argv[]) {
  char* pseudo = malloc(sizeof(char)*1000) ;
  int server = mkfifo("patron", O_WRONLY) ;
  read(server, pseudo, 4) ;
  *(pseudo + 4) = '\0' ;
  printf("%s\n", pseudo) ;
}

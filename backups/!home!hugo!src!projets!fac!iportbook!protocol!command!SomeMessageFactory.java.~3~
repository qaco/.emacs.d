package protocol.command ;

import exception.* ;
import protocol.ProtocolFactory ;
import java.util.Arrays ;
import java.io.Reader ;
import java.io.IOException ;
import main.MainVals ;

public class SomeMessageFactory extends ProtocolFactory {

    public SomeMessage create(Reader in) throws UnknownResultException,
                                                IOException {
        String p = ProtocolFactory.readStream(in) ;
        return this.create(p) ;
    }
    
    public SomeMessage create(String text) throws UnknownResultException {
        String cmds[] ;

        if (!this.isSuffixRight(text))
            throw new BadSuffixException() ;
        
        cmds = this.getCmds(text) ;

        try {
            switch (cmds[0]) {
            case CommandVals.SOME_MESSAGE:
                String[] tail = Arrays.copyOfRange(cmds, 2, cmds.length) ;
                String mess = String.join(" ", tail) ;
                return new SomeMessage(cmds[1], mess) ;
            default :
                throw new UnknownCommandException("somemessage", cmds[0]) ;
            }
        } catch (ArrayIndexOutOfBoundsException e) {
            throw new TooFewArgsException(cmds[0],
                                          String.valueOf(cmds.length)) ;
        }
    }
}


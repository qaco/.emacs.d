package protocol.fromclient ;
import protocol.* ;
public class Connection implements Protocol {

    private String id ;
    private int mdp ;

    public Connection (String myid, String mymdp) {
        this.id = myid ;
        this.mdp = Integer.parseInt(mymdp) ;
    }

    public Connection (String myid, int mymdp) {
        this.id = myid ;
        this.mdp = mymdp ;
    }

    public String toString() {
        String mymdp = String.valueOf(this.mdp) ;
        return "CONNE " + this.id + " " + mymdp + "+++" ;
    }
}
        

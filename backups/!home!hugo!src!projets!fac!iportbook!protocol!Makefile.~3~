JC = javac

JUNIT_PATH = /usr/share/java/junit4.jar
FS_PATH = feedback/
FC_PATH = command/
CODE_PATHS = $(FS_PATH):$(FC_PATH)
TESTS_PATH = tests/
TARGET_PATH = class/
FS_SRC = $(addprefix $(FS_PATH),$(wildcard *.java))
FC_SRC = $(addprefix $(FC_PATH),$(wildcard *.java))
TESTS_SRC = $(addprefix $(TESTS_PATH),CommandFactoryTest.java FeedbackFactoryTest.java TestRunner.java)

test: $(TARGET_PATH)/TestRunner.class

$(TARGET_PATH)/TestRunner.class: $(FS_SRC) $(FC_SRC) $(TESTS_SRC)
	$(JC) -cp $(JUNIT_PATH):$(shell pwd)/../ -d $(TARGET_PATH) $^

clean:
	rm -r $(TARGET_PATH)*

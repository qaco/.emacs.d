    }

    public void setStatus(boolean b) {
	this.status = b;
    }

    public String getId() {
	return this.id;
    }
    public int getUdp() {
	return this.udp;
    }
    public int getMdp() {
	return this.mdp;
    }
    public Socket getSo() {
	return this.so;
    }
}

#include <check.h>
#include "word_construction_case.h"
#include "word_comparison_case.h"
#include "word_subword_case.h"
#include "wordlist_accessor_case.h"
#include "wordlist_comparison_case.h"
#include "wordlist_split_case.h"
#include "worddict_accessor_case.h"
#include "worddict_dot_case.h"
#include "crawler_crawl_case.h"
#include "parser_parse_case.h"
#include "crawler_graphdot_case.h"

Suite *word_suite(void) {
  TCase *tc_constr, *tc_comp, *tc_sub ;
  Suite *s ;

  tc_constr = word_construction_case() ;
  tc_comp = word_comparison_case() ;
  tc_sub = word_subword_case() ;

  s = suite_create("Word") ;
  suite_add_tcase(s, tc_constr) ;
  suite_add_tcase(s, tc_comp) ;
  suite_add_tcase(s, tc_sub) ;

  return s ;
}

Suite *wordlist_suite(void) {
  TCase *tc_acc, *tc_comp, *tc_split ;
  Suite *s ;

  tc_comp = wordlist_comparison_case() ;
  tc_acc = wordlist_accessor_case() ;
  tc_split = wordlist_split_case() ;
  s = suite_create("WordList") ;
  suite_add_tcase(s, tc_acc) ;
  suite_add_tcase(s, tc_comp) ;
  suite_add_tcase(s, tc_split) ;

  return s ;
}

Suite *worddict_suite(void) {
  TCase *tc_acc, *tc_dot ;
  Suite *s ;
  
  tc_acc = worddict_accessor_case() ;
  tc_dot = worddict_dot_case() ;
  s = suite_create("WordDict") ;
  suite_add_tcase(s, tc_acc) ;
  suite_add_tcase(s, tc_dot) ;

  return s ;
}

Suite *crawler_suite(void) {
  TCase *tc_crawl, *tc_graphdot ;
  Suite *s ;

  tc_crawl = crawler_crawl_case() ;
  tc_graphdot = crawler_graphdot_case() ;
  s = suite_create("Crawler") ;
  suite_add_tcase(s, tc_crawl) ;
  suite_add_tcase(s, tc_graphdot) ;

  return s ;
}
  
Suite *parser_suite(void) {
    TCase *tc_parse ;
    Suite *s ;

    tc_parse = parser_parse_case() ;
    s = suite_create("Parser") ;
    suite_add_tcase(s, tc_parse) ;
    return s ;
}

int main() {
  Suite* w = word_suite() ;
  Suite* wl = wordlist_suite() ;
  Suite* wd = worddict_suite() ;
  Suite* crawl = crawler_suite() ;
  Suite* pa = parser_suite() ;
  SRunner* runner ;

  runner = srunner_create(w) ;
  srunner_add_suite(runner, wl) ;
  srunner_add_suite(runner, wd) ;
  srunner_add_suite(runner, crawl) ;
  srunner_add_suite(runner, pa) ;

  srunner_run_all(runner, CK_NORMAL) ;

  srunner_free(runner) ;

  return 0 ;
}
  
  
  

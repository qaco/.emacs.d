package protocol.command ;

import main.MainVals ;
import java.io.IOException ;
import service.User ;
import protocol.flow.Flow ;
import java.util.List ;

public class Consultation implements Command {

    public void exec(User myuser, List<User> allusers) throws IOException {
        Flow f = myuser.popFlow() ;
        myuser.sendTCP(f) ;
        f.treatAnswer(myuser, allusers) ;
        this.describeFlowPopped(myuser.getId()) ;
    }
    
    public String toString() {
        return CommandVals.CONSULTATION + CommandVals.EOF ;
    }

    private void describeFlowPopped(String dest) {
        MainVals.describe("Flow sent to " + dest) ;
    }
}
        

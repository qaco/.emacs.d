package protocol.knock ;

import exception.UnknownResultException ;

public class NoFriendKnock extends Knock {
    
    public NoFriendKnock(int flows) {
        super(flows) ;
    }

    public NoFriendKnock(byte mylow, byte myhigh) throws UnknownResultException {
        super(mylow, myhigh) ;
    }

    protected byte getCode() {
        return KnockVals.FRIENDNO_CODE ;
    }

    protected String popUp() {
        return KnockVals.FRIENDNO_MESS;
    }
}

package protocol.tests ;

import exception.UnknownResultException ;
import protocol.command.* ;
import static org.junit.Assert.* ;
import org.junit.Test;
import org.junit.Before;

public class CommandFactoryTest {

    private CommandFactory pf ;

    @Before
    public final void setCommandFactoryUp() {
        this.pf = new  CommandFactory() ;
    }

    @Test
    public final void testAskFriendBuild() {
        String tmp = "FRIE? toto+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }


package protocol.fromserver ;

import protocol.* ;

public class FromServerFactory {
    public FromServer create(String text) {
        FromServer res = null ;
        String suffix = text.substring(text.length() - 3, text.length()) ;
        if (suffix.compareTo("+++") == 0) {
            String signifiant = text.substring(0, text.length() - 3) ;
            String cmds[] = signifiant.split(" ") ;
            switch (cmds[0]) {
            case "FRIE>+++" :
                res = new AskFriendOK() ;
                break ;
            case "FRIE<+++" :
                res = new AskFriendNO() ;
                break ;
            case "FLOO>+++" :
                res = new FlooDone() ;
                break ;
            case "GOBYE+++" :
                res = new Goodbye() ;
                break ;
            case "HELLO+++" :
                res = new Hello() ;
                break ;
            case "MESS>+++" :
                res = new MessageTransmitted() ;
                break ;
            case "MESS<+++" :
                res = new MessageNotTransmitted() ;
                break ;
            case "WELCO+++" :
                res = new AskFriendOK() ;
                break ;
            }
        }
        return res ;
    }
}

package protocol.command ;

import exception.UnknownResultException ;
import java.util.Arrays ;

public class SomeMessage {

    public static boolean isSomeMessage(String input) {
        int suf_size = CommandVals.EOF.length() ;
        String signifiant = input.substring(0, input.length() - suf_size) ;
        String[] parts = signifiant.split(CommandVals.SEP) ;
        try {
            Integer.parseInt(parts[1]) ;
        } catch (NumberFormatException | ArrayIndexOutOfBoundsException e) {
            return false ;
        }
        return parts[0].equals(CommandVals.SOME_MESSAGE) && parts.length > 1 ;
    }
    
    public static int extractNum(String input) throws UnknownResultException {
        if (!SomeMessage.isSomeMessage(input))
            throw new UnknownResultException() ;
        String[] parts = input.split(CommandVals.SEP) ;
        return Integer.parseInt(parts[1]) ;
    }
    
    public static String extractMess(String input)
        throws UnknownResultException {
        if (!SomeMessage.isSomeMessage(input))
            throw new UnknownResultException() ;
        String mess ;
        int suf_size = CommandVals.EOF.length() ;
        String signifiant = input.substring(0, input.length() - suf_size) ;
        String[] parts = signifiant.split(CommandVals.SEP) ;
        if (parts.length > 1) {
            String[] tail = Arrays.copyOfRange(parts, 2, parts.length) ;
            mess = String.join(CommandVals.SEP, tail) ;
        }
        else
            mess = new String() ;
        return mess ;
    }
    
    private int num ;
    private String mess ;

    public SomeMessage (int mynum, String mymess) {
        this.num = mynum ;
        if (mymess.length() <= 200)
            this.mess = mymess ;
        else
            this.mess = mymess.substring(0, 200) ;
    }

    public int getNum() {
        return this.num ;
    }

    public String getMess() {
        return this.mess ;
    }

    public String toString() {
        String mynum = String.valueOf(this.num) ;
        return
            CommandVals.SOME_MESSAGE + " " +
            mynum + " " + this.mess + CommandVals.EOF  ;
    }
}

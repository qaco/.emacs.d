(* open "examples.cmo" ;; *)

module Variables = struct
  type t = (int * Graphics.color)
  let compare x y = match x, y with
    | ((x1, x2), (y1, y2)) ->
       if x1 < y1 then (-1)
       else if x1 > y1 then 1
       else if x2 < y2 then (-1)
       else if x2 > y2 then 1
       else 0
end;;

module Sat = Sat_solver.Make(Variables) ;;

let shuffle examples =
  let nd = List.map (fun c -> (Random.bits (), c)) examples in
  let sond = List.sort compare nd in
  List.map snd sond

let myvor = shuffle Examples.examples ;;
let matrix = Builder.regions_voronoi (Builder.taxicab) (List.hd myvor) ;;
let adj = Builder.adjacences_voronoi myvor matrix ;;
let tab = Computer.extract_colors (List.hd myvor) ;;
let constraints = Computer.produce_constraints tab adj ;;
let result = Sat.solve constraints ;;
let final_vor = Computer.solve_vor result myvor ;;
let final_matrix = Builder.regions_voronoi taxicab final_vor ;;

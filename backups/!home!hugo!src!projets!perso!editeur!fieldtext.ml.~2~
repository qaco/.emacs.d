open Graphics
open String

(* type origin = int*int *)
(* type size = int*int *)
(* type location = origin*size *)
(* type fieldtext = location*int*string*string *)

(* ======================================================================= *)
(* CONSTRUCTEUR *)
(* ======================================================================= *)

let fieldtext_build myorigin mywidth title =
  let mysize = text_size "h" in
  let myheight = (snd mysize)*2 in
  ((myorigin,(mywidth, myheight)), 0, "", title)
  
(* ======================================================================= *)
(* GETTERS *)
(* ======================================================================= *)

(* Teste si le point désigné par coord est dans le fieldtext. *)
let coord_matches_fieldtext coord field = match field with
  | (loc, _, _, _) -> coord_is_in coord loc

(* Renvoie les coordonnées de la première lettre du texte. *)
let get_text_orig field = match field with
  | (((x,y),_), _, _, _) -> let mysize = text_size "h" in
                            (x + (fst mysize), y + (snd mysize)/2)

(* Renvoie les coordonnées du titre. *)
let get_title_orig field = match field with
  | (((x,y),(_,h)), _, _, _) -> let mysize = text_size "h" in
                                (x, y + h + (snd mysize)/2)

(* ======================================================================= *)
(* SETTERS : NAVIGATION *)
(* ======================================================================= *)

(* Recule le curseur du fieldtext d'une lettre. *)
let fieldtext_back myfield = match myfield with
  | (loc, cur, tex, tit) -> if cur > 0 then (loc, cur - 1, tex, tit)
                       else myfield

(* Avance le curseur du fieldtext d'une lettre. *)
let fieldtext_forward myfield = match myfield with
  | (loc, cur, tex, tit) -> if cur < length tex then (loc, cur + 1, tex, tit)
                              else myfield

(* Place le curseur du fieldtext à la fin du texte saisi. *)
let fieldtext_tail myfield = match myfield with
  | (loc, _, tex, tit) -> (loc, length tex, tex, tit)

(* Place le curseur du fieldtext sur la lettre au point désigné par coord. *)
let match_fieldtext_with_coord field coord =
  (* Indique si coord désigne le texte ou le cadre englobant. *)
  let coord_matches_text coord field = match field with
    | (((x,y), (w,h)), _, tex, _) ->
       coord_is_in coord ((x,y),(w,h))
       && coord_is_in coord ((get_text_orig field), text_size tex) in
  (* Teste les lettres l'une après l'autre et met à jour le curseur lorsque *)
  (* l'une d'entre elles est désignée par coord. *)
  let rec char_by_char field coord i = match field with
    | (loc, cur, text, tit) ->
       if coord_matches_text coord (loc, cur, (sub text 0 i), tit) then
         (loc, i - 1, text, tit)
       else char_by_char field coord (i+1) in
  if coord_matches_text coord field then char_by_char field coord 0
  else fieldtext_tail field

(* ======================================================================= *)
(* SETTERS : ÉDITION *)
(* ======================================================================= *)

(* Saisit une lettre et incrémente le curseur. *)
let fieldtext_type myfield mychar = match myfield with
  | (loc, cur, tex, tit) -> if (cur >= length tex) then
                         (loc, cur + 1, tex^(Char.escaped mychar), tit)
                       else 
                         let beg = sub tex 0 (cur + 1) in
                         let newbeg = beg ^ (Char.escaped mychar) in
                         let fin = sub tex (cur + 1) ((length tex) - cur - 1) in
                         (loc, cur + 1, newbeg ^ fin, tit)

(* Efface une lettre et décrémente le curseur. *)
let fieldtext_del myfield = match myfield with
  | (loc, cur, tex, tit) -> let beg = sub tex 0 (cur - 1)  in
                              let fin = sub tex cur (length tex - cur) in
                              (loc, cur - 1, beg ^ fin, tit)

(* ======================================================================= *)
(* INTERACTION *)
(* ======================================================================= *)

(* Met à jour l'affichage du champ de texte. *)
let fieldtext_draw myfield withcursor = 
  let rec text_draw coord text cursor i =
    if i < length text && i != cursor then
      (* Affiche une lettre. *)
      begin
        let current_char = sub text i 1 in
        let size = text_size current_char in
        moveto (fst coord) (snd coord) ;
        set_color black ;
        draw_string current_char ;
        text_draw ((fst coord + fst size), snd coord) text cursor (i+1)
      end
    else if withcursor && i = cursor then
      begin
        if (i >= length text) then
          (* Affiche le curseur seul. *)
          begin
            let size = text_size "h" in
            set_color black ;
            fill_rect (fst coord) (snd coord) (fst size) (snd size) ;
          end
        else
          (* Affiche le curseur sur une lettre. *)
          begin
            let current_char = sub text i 1 in
            let size = text_size current_char in
            set_color black ;
            fill_rect (fst coord) (snd coord) (fst size) (snd size) ;
            set_color white ;
            moveto (fst coord) (snd coord) ;
            draw_string current_char ;
            text_draw ((fst coord + fst size), snd coord) text cursor (i+1)
          end
      end
    else
      (* Il n'y a plus rien à afficher *)
      () in
  match myfield with
  |(((x,y), (w,h)), cur, tex,tit) ->
    let tcoord = get_title_orig myfield in
    set_color white ;
    fill_rect x y w h ;
    set_color black ;
    draw_rect x y w h ;
    moveto (fst tcoord) (snd tcoord) ;
    draw_string tit ;
    text_draw (get_text_orig myfield) tex cur 0

(* Reçoit et applique les instructions de l'utilisateur. *)
let rec fieldtext_interaction field =
  let stat = wait_next_event [Key_pressed;Button_down] in
  if (stat.button) then
    let coord = (stat.mouse_x, stat.mouse_y) in
    if coord_matches_fieldtext coord field then
      let new_field = match_fieldtext_with_coord field coord in
      fieldtext_draw new_field true ;
      fieldtext_interaction new_field
    else
      ()
  else
    begin
      if (stat.key = '\b') then
        (* del *)
        let new_field = fieldtext_del field in
        fieldtext_draw new_field true ;
        fieldtext_interaction new_field
      else if (stat.key = '4') then
        (* déplacement à gauche *)
        let new_field = fieldtext_back field in
        fieldtext_draw new_field true ;
        fieldtext_interaction new_field
      else if (stat.key = '6') then
        (* déplacement à droite *)
        let new_field = fieldtext_forward field in
        fieldtext_draw new_field true ;
        fieldtext_interaction new_field
      else
        (* touche normale *)
        let new_field = fieldtext_type field stat.key in
        fieldtext_draw new_field true ;
        fieldtext_interaction new_field
    end
  ;;
  
  open_graph " 900x900" ;;
  let field = fieldtext_build (400,400) 80 "bisou" ;;
  fieldtext_draw field true ;;
  fieldtext_interaction field ;;
  close_graph ;;

  

#include <stdio.h>
#include <stdlib.h>

#include "word.h"
#include "wordlist.h"

/**
 * \fn WordList build_wordlist(Word myword)
 * \brief Construit une WordList.
 * \param myword Le premier Word de la WordList.
 * \return La nouvelle WordList.
 */
WordList build_wordlist(Word myword)
{
  WordList res ;
  Cell content ;
  
  content.word = myword ;
  content.next = NULL ;
  res.head = malloc(sizeof(Cell)) ;
  *(res.head) = content ;
  res.length = 1 ;
  return res ;
}

/**
 * \fn WordList build_empty_wordlist()
 * \brief Construit une WordList vide.
 * \return La nouvelle WordList.
 */
WordList build_empty_wordlist()
{
  WordList res ;
  Cell content ;
  
  content.word = construct_null_word() ;
  content.next = NULL ;
  res.head = malloc(sizeof(Cell)) ;
  *(res.head) = content ;
  res.length = 0 ;
  return res ;
}

int next_wordlist(WordList* mylist)
{
  if (mylist->length > 1) {
    mylist->head = mylist->head->next ; // fuite mémoire de l'ancienne tete
    return 0 ;
  }
  else
    return -1 ;
}

/**
 * \fn size_t get_length_wordlist(const WordList mylist)
 * \brief Renvoie la taille de la WordList.
 * \param mylist La liste dont on veut connaître la taille.
 * \return La taille de la WordList.
 */
size_t get_length_wordlist(const WordList mylist)
{
  return mylist.length ;
}

/**
 * \fn Word get_word_wordlist(WordList mylist, int index)
 * \brief Renvoie le Word situé à un certain indice de la WordList.
 * \param mylist La liste dont on veut extraire un Word.
 * \param index L'index du Word que l'on veut extraire.
 * \return Le Word que l'on a extrait.
 */
Word get_word_wordlist(WordList mylist, const int index)
{
  if (index < 0 || index >= mylist.length)
    return construct_null_word() ;

  for (int i = 0 ; i < index ; i++)
    next_wordlist(&mylist) ;
  return mylist.head->word ;
}

/**
 * \fn int is_empty_wordlist(const WordList mylist)
 * \brief Teste si une WordList est vide.
 * \param mylist La WordList à tester.
 * \return O si la WordList est vide, >0 sinon.
 */
int is_empty_wordlist(const WordList mylist)
{
  return mylist.length == 0 ;
}

/**
 * \fn Word pop_word_wordlist(WordList* mylist)
 * \brief Extrait et supprime le premier Word de la WordList (FIFO).
 * \param mylist La WordList dont extraire le premier Word.
 * \return Le premier Word de la WordList.
 */
Word pop_word_wordlist(WordList* mylist)
{
  if (is_empty_wordlist(*mylist))
    return construct_null_word() ;

  Word res = mylist->head->word ;
  Cell* tmpcell = mylist->head ;
  next_wordlist(mylist) ;
  free(tmpcell) ;
  return res ;
}

/**
 * \fn int set_word_wordlist(WordList *mylist, Word myword)
 * \brief Modifie le premier Word de la WordList.
 * \param mylist La WordList dont modifier le premier Word.
 * \param myword Le Word à placer en tête de la WordList.
 * \return -1 si échec.
 */
int set_word_wordlist(WordList *mylist, const int index, Word myword)
{
  if (index < 0 || index >= mylist->length)
    return -1 ;

  Cell* frstbkp = mylist->head ;
  
  for (int i = 0 ; i < index ; i++)
    next_wordlist(mylist) ;
  destruct_word(&mylist->head->word) ;
  mylist->head->word = myword ;
  mylist->head = frstbkp ;
  return 0 ;
}

/**
 * \fn int append_wordlist(WordList* dest, WordList* src)
 * \brief Ajoute une WordList à l'autre.
 * \param dest La WordList à laquelle une autre WordList sera ajoutée.
 * \param src La WordList qui sera ajoutée à une autre WordList.
 * \return -1 si échec.
 */
int append_wordlist(WordList* dest, WordList* src)
{
  Cell* frstbkp = dest->head ;
  int lim = dest->length ;

  if (is_empty_wordlist(*dest))
    *dest = *src ;
  else {
    for (int i = 0 ; i < lim-1 ; i++)
      next_wordlist(dest) ;
    dest->head->next = src->head ;
    dest->length += src->length ;
    dest->head = frstbkp ;
  }
    
  return 0 ;
}

/**
 * \fn int destruct_wordlist(WordList mylist)
 * \brief Libère la mémoire mobilisée par une WordList.
 * \param mylist La list dont on n'a plus besoin.
 * \return -1 si échec.
 */
int destruct_wordlist(WordList* mylist)
{
  int lim = mylist->length ;

  for (int i = 0 ; i < lim ; i++) {
      Cell* frstbkp = mylist->head ;
      next_wordlist(mylist) ;
      destruct_word(&frstbkp->word) ;
      free(frstbkp) ;
    }
  mylist->length = -1 ;

  return 0 ;
}

/**
 * \fn int print_wordlist(WordList mylist, FILE* stream)
 * \brief Imprime une WordList dans un fichier.
 * \param mylist La WordList à imprimer.
 * \param stream Le fichier dans lequel imprimer la WordList (peut être stdout).
 * \return -1 si échec.
 */
int print_wordlist(WordList mylist, FILE* stream)
{
  int lim = mylist.length ;

  fprintf(stream, "[ ") ;
  for (int i = 0 ; i < lim ; i++) {
    print_word(mylist.head->word, stream) ;
    fprintf(stream, ", ") ;
    next_wordlist(&mylist) ;
  }

  return 0 ;
}
    

import Root,Shutter,Slogan, Paint
from PIL import Image

IMG_MAX = 1200, 630

class Canvas:
    
    def __init__(self, img_path, shut_cmd, shut_col,
                 text_cmd, text_font, text_col):
        self.img = None
        self.shutter = None
        self.slogan = None

        self.img = Image.open(img_path)
        self.img = self.img.convert('RGBA')
        if self.img.size[0] > IMG_MAX[0] or self.img.size[1] > IMG_MAX[1] :
            self.img.thumbnail(IMG_MAX)
        
        self.shutter = Shutter.factory(shut_cmd, self.img.size, shut_col)
        self.shutter.process_position()

        frame = self.shutter.clone_place()
        self.slogan = Slogan.factory(text_cmd, self.img.size, frame,
                                     "", text_font, text_col)
        self.slogan.process_position()

        self.logo = Paint.EmptyLogo()

    def change_orientation(self, cmd):
        color = self.shutter.color
        self.shutter = Shutter.factory(cmd, self.img.size, color)
        self.shutter.process_position()
        self.slogan.frame = self.shutter.clone_place()
        self.slogan.process_position()
        if self.slogan.is_signed():
            self.logo.replace(self.slogan.free_area)
            self.logo.process_position()
        
    def change_text(self, text):
        self.slogan.set_text(text)
        self.slogan.process_position()
        if self.slogan.is_signed():
            self.logo.replace(self.slogan.free_area)
            self.logo.process_position()

    def change_font(self, path):
        self.slogan.sfont = path
        self.slogan.process_position()
            
    def layout_text(self, cmd_text):
        planesize = self.slogan.plane_size
        frame = self.slogan.frame
        text = "\n".join(self.slogan.lines)
        font = self.slogan.sfont
        color = self.slogan.color
        self.slogan = Slogan.factory(cmd_text, planesize, frame,
                                     text, font, color)
        self.slogan.process_position()
        
    def generate_logo(self, path):
        self.logo = Paint.ActualLogo(self.slogan.free_area, path)
        self.logo.process_position()
        
    def unsign_text(self):
        self.layout_text(Slogan.NAIVE_SLOGAN)
        self.logo = Paint.EmptyLogo()

    def sign_text_bottom(self, path):
        self.layout_text(Slogan.BOTTOM_SLOGAN)
        self.generate_logo(path)

    def merge_calcs(self) :
        res = self.shutter.stamp_img(self.img)
        res = self.slogan.stamp_img(res)
        res = self.logo.stamp_img(res)
        return res



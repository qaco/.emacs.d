#include "data_container.h"
#include <unistd.h>
#include <stdlib.h>
#include <string.h>


int create_word_data(struct word_data **wdata, Word *word, size_t *struct_size) {
  int wordsize = get_size_word(word) ;
  char* wordmem = malloc(sizeof(char)*wordsize) ;
  get_content_word(word, wordmem) ;
    *struct_size = sizeof(struct word_data) - 1 + wordsize * sizeof(char);
    *wdata = malloc(*struct_size);
    if (*wdata == NULL) return EXIT_FAILURE;
    memcpy(&((*wdata)->word)[0], wordmem, wordsize);
    return EXIT_SUCCESS;
}

void free_word_data(struct word_data *wdata) {
    free(wdata);
}

int create_url_data(struct url_data **udata, Word *url, size_t *struct_size) {
  int urlsize = get_size_word(url) ;
  char* urlmem = malloc(sizeof(char)*urlsize) ;
  get_content_word(url, urlmem) ;
    *struct_size = sizeof(struct url_data) - 1 + url->size * sizeof(char);
    *udata = malloc(*struct_size);
    if (*udata == NULL) return EXIT_FAILURE;
    memcpy(&((*udata)->url)[0], urlmem, urlsize);
    return EXIT_SUCCESS;
}

void free_url_data(struct url_data *udata) {
    free(udata);
}

int create_pair_data(struct pair_data **pdata, uint64_t word_id,
                     uint64_t url_id, size_t *struct_size) {
    *struct_size = sizeof(struct pair_data);
    *pdata = malloc(*struct_size);
    if (*pdata == NULL) return EXIT_FAILURE;
    (*pdata)->word_id = word_id;
    (*pdata)->url_id = url_id;
    (*pdata)->nb_occurence = -1;
    return EXIT_SUCCESS;
}

void free_pair_data(struct pair_data *pdata) {
    free(pdata);
}

int create_word_data_list(struct word_data_list **wdata_list) {
    *wdata_list = malloc(sizeof(struct word_data_list));
    if (*wdata_list == NULL) {
        return EXIT_FAILURE;
    }
    (*wdata_list)->wdata = NULL;
    (*wdata_list)->next_word_data_list = NULL;
    return EXIT_SUCCESS;
}

int add_wdata_clone_to_list(struct word_data_list *wdata_list,
                            uint64_t wdata_key, struct word_data *wdata,
                            size_t wdata_size) {
    int ret;
    int is_head;
    struct word_data_list *new_wdata_list;
    if (wdata_list->wdata == NULL) {
        new_wdata_list = wdata_list;
        is_head = 1;
    } else {
        ret = create_word_data_list(&new_wdata_list);
        if (ret == EXIT_FAILURE) {
            return ret;
        }
        new_wdata_list->next_word_data_list = wdata_list->next_word_data_list;
        wdata_list->next_word_data_list = new_wdata_list;
        is_head = 0;
    }
    new_wdata_list->wdata = malloc(wdata_size);
    if (new_wdata_list->wdata == NULL) {
        if (!is_head) free_word_data_list(new_wdata_list);
        return EXIT_FAILURE;
    }
    memcpy(new_wdata_list->wdata, wdata, wdata_size);
    new_wdata_list->wdata_size = wdata_size;
    new_wdata_list->wdata_key = wdata_key;
    return EXIT_SUCCESS;
}

int add_word_data_list(struct word_data_list *wdata_list, Word *word) {
    int ret;
    int is_head;
    struct word_data_list *new_wdata_list;
    if (wdata_list->wdata == NULL) {
        new_wdata_list = wdata_list;
        is_head = 1;
    } else {
        ret = create_word_data_list(&new_wdata_list);
        if (ret == EXIT_FAILURE) {
            return ret;
        }
        new_wdata_list->next_word_data_list = wdata_list->next_word_data_list;
        wdata_list->next_word_data_list = new_wdata_list;
        is_head = 0;
    }
    ret = create_word_data(&(new_wdata_list->wdata), word,
                           &(new_wdata_list->wdata_size));
    if (ret == EXIT_FAILURE) {
        if (!is_head) free_word_data_list(new_wdata_list);
        return EXIT_FAILURE;
    }
    return EXIT_SUCCESS;
}

void free_word_data_list(struct word_data_list *wdata_list) {
    struct word_data_list *next;
    for (next = wdata_list->next_word_data_list;
         wdata_list == NULL;
         wdata_list = next) {
        next = wdata_list->next_word_data_list;
        if (wdata_list->wdata != NULL) {
            free_word_data(wdata_list->wdata);
        }
        free(wdata_list);
    }
}


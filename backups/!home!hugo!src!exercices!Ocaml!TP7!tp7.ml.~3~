type player = Red | Yellow ;;
type cell = Empty | Pawn of player ;;
type outcome = Draw | Open | Win of player ;;
type board = cell array array ;;

let init:board = Array.make_matrix 7 6 Empty ;;

let rec play b p c = 
  if (Array.length b = 0 || b.(0).(c) != Empty) then
    failwith "Colonne pleine"
  else if (Array.length b = 1 || b.(1).(c) != Empty) then
    b.(0).(c) <- Pawn(p)
  else play (Array.sub b 1 ((Array.length b) -1)) p c
;;
  
let eval plat =
  let rec compute x y b =
    if (Array.length b <= y) then
      if (Array.exists (fun t -> Array.exists (fun el -> el = Empty) t) b)
      then Open
      else Draw
    else if (Array.length b.(y) <= x) then compute 0 (y+1) b
    else if (b.(y).(x) = Empty &&
	       ((Array.length b > y + 3 
		 && b.(y).(x) = b.(y+1).(x)
		 && b.(y).(x) = b.(y+2).(x)
		 && b.(y).(x) = b.(y+3).(x)) ||
		  (Array.length b.(y) > x + 3 
		   && b.(y).(x) = b.(y).(x+1)
		   && b.(y).(x) = b.(y).(x+2)
		   && b.(y).(x) = b.(y).(x+3)) ||
		    (Array.length b > y + 3 && Array.length b.(y) > x + 3 
		     && b.(y).(x) = b.(y+1).(x+1)
		     && b.(y).(x) = b.(y+2).(x+2)
		     && b.(y).(x) = b.(y+3).(x+3)) ||
		      (0 <= y - 3 && Array.length b.(y) > x + 3 
		       && b.(y).(x) = b.(y+1).(x-1)
		       && b.(y).(x) = b.(y+2).(x-2)
		       && b.(y).(x) = b.(y+3).(x-3)))) then
      (match (b.(y).(x)) with
       | Empty -> failwith "bug"
       | Pawn(p) -> Win(p))
    else compute (x+1) y b
  in compute 0 0 plat ;;
  
  play init Red 3 ;;
  init ;;
    Array.sub init 1 ((Array.length init) -1) ;;

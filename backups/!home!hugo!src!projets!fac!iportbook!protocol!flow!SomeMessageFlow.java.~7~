package protocol.flow ;

import main.MainVals ;
import client.src.ServerRequest;
import java.io.IOException ;
import protocol.field.* ;
import exception.* ;

public class SomeMessageFlow implements Flow {

    private NumMessField num ;
    private MessField mess ;

    public SomeMessageFlow (byte[] mynum, byte[] mymess) throws UnknownResultException {
        this.num = new NumMessField(mynum) ;
        this.mess = new MessField(mymess) ;
    }
    
    public SomeMessageFlow (String mynum, String mymess) {
        this.num = new NumMessField(mynum) ;
        this.mess = new MessField(mymess) ;
    }
    
    public SomeMessageFlow (int mynum, String mymess) {
        this.num = new NumMessField(mynum) ;
        this.mess = new MessField(mymess) ;
    }

    public void exec(ServerRequest c) throws IOException { 
	System.out.println(this.num.toString()+"- "+this.mess.toString());
    }

    public String toString() {
        return
            FlowVals.SOME_MESSAGE + " " +
            this.num.toString() + " " + this.mess.toString() + MainVals.EOF  ;
    }
}

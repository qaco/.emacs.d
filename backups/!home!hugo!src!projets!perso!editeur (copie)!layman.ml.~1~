open Graphics
open List
open Geom
open Fieldtext

type location = (int*int)*(int*int)
type fieldtext = ((int*int)*(int*int))*int*string*string
type component = None | Fieldtext of fieldtext
type container = ((int*int)*(int*int))*color*((int*int)*component) list

let container_build orig size =
  let mygrey = rgb 211 211 211 in
  ((orig,size), mygrey, [])
  
let remove_component cont comp = match comp with
  | None -> cont
  | Fieldtext(f) -> match cont with
                    | (loc, back, comps) -> let orig = get_origin f in
                                            let new_comps = remove_assoc orig comps in
                                            (loc, back, new_comps)

let get_component cont coord = match cont with
  | (_, _, comps) ->
     try
       assoc coord comps
     with | Not_found -> None

let add_comp cont comp = match cont with
  | (loc, back, comps) -> match comp with
                          | None -> cont (* exception *)
                          | Fieldtext(f) ->
                             let orig = get_origin f in
                             (loc, back, ((orig,Fieldtext(f))::comps))

let add_comp cont comp = match cont with
  | (loc, back, comps) -> match comp with
                          | None -> cont (* exception *)
                          | Fieldtext(f) ->
                             let fieldloc = get_loc f in
                             (loc, back, ((fieldloc,Fieldtext(f))::comps))

let refresh_cont cont comp =
  let minus = remove_component cont comp in
  add_comp minus comp
                       
let draw_container cont =
  let rec draw_components l_components = match l_components with
    | [] -> ()
    | h::t ->
       begin
        match h with
        | None -> draw_components t (* exception *)
        | Fieldtext(f) -> fieldtext_draw f false ; draw_components t
       end in
  match cont with
  | (((x,y),(w,h)), back, comps) ->
     set_color back ;
     fill_rect x y w h ;
     let l = map (fun pair -> snd pair) comps in
     draw_components l
  
let rec container_interaction cont =
  let rec select_comp cont coord =
    let comp = get_component cont coord in
    match comp with
    | None -> (* (cont, coord) *) failwith "hé non"
    | Fieldtext(f) -> let ret = fieldtext_interaction f in
                      let new_cont = refresh_cont cont (Fieldtext(fst ret)) in 
                      select_comp new_cont (snd ret) in
  
  let stat = wait_next_event [Button_down] in
  match cont with
  | (loc, _, _) -> let ret = select_comp cont (stat.mouse_x, stat.mouse_y) in
                   if coord_is_in (snd ret) loc then
                     container_interaction (fst ret)
                   else
                     ret
           
  

  

                                   

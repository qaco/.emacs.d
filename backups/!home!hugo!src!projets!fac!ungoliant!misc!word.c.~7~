struct Word {
  char *memory;
  size_t size;
} ;

Word* clone_word(const Word* toclone)
{
  Word* res = malloc(sizeof(Word)) ;
  res->memory = malloc(sizeof(char)*(toclone->size)) ;
  memcpy(res->memory,toclone->memory, toclone->size) ;
  res->size = toclone->size ;
  return res ;
}

Word* construct_word(const size_t n, const char* src)
{
  Word* res = malloc(sizeof(Word)) ;
  if (!n)
    res->memory = NULL ;
  else {
    res->memory = malloc(sizeof(char) * n) ;
    memcpy(res->memory, src, sizeof(char)*n) ;
  }
  res->size = n ;
  return res ;
}

int clear_word(Word* myword)
{
  if (myword->size > 0) {
    free(myword->memory) ;
    myword->memory = NULL ;
    myword->size = 0 ;
    return EXIT_SUCCESS ;
  }
  else
    return EXIT_FAILURE ;
}

int get_content_word(const Word* src, char* dest)
{
    memcpy(dest, src->memory, src->size*sizeof(char)) ;
    return EXIT_SUCCESS ;
}

size_t get_size_word(const Word* myword)
{
  return myword->size ;
}

int compare_word(const Word* word1, const Word* word2)
{
  /* Le nombre de caractères qui seront testés, c'est à dire la taille du
     mot le plus court. */
  size_t length ;
  if (word1->size >= word2->size)
    length = word2->size ;
  else
    length = word1->size ;
  /* Le test des caractères. */
  for (int i = 0 ; i < length ; i++) {
    char leftchar = *(word1->memory + i) ;
    char rightchar = *(word2->memory + i) ;
    
    if (leftchar < rightchar)
      return -1 ;
    else if (leftchar > rightchar)
      return 1 ;
  }
  /* Si les caractères testés ne permettent pas de décider, soit le mot le
     plus long est le plus grand est le plus long, soit ils sont de même
     longueur et sont donc égaux. */
  if (word1->size < word2->size)
    return -1 ;
  else if (word1->size > word2->size)
    return 1 ;
  else
    return 0 ;
}

int get_sub_word(Word* dest, const Word* src, const int start, const int end)
{
  if (start < 0 || end > src->size - 1 || start > end)
    return EXIT_FAILURE ;
  else {
    int new_size = end - start ;
    char* raw_sub = malloc(sizeof(char)*new_size) ;
    memcpy(raw_sub, src->memory + start, sizeof(char)*new_size) ;
    clear_word(dest) ;
    add_chars_word(dest, raw_sub, new_size) ;
    free(raw_sub) ;
    return EXIT_SUCCESS ;
  }
}

int locate_sub_word(const Word* myword, const Word* sub, const int start)
{
  if (sub->size <= myword->size - start) {
    Word* tmp = construct_word(0, NULL) ;
    for (int i = start ; i < myword->size - sub->size ; i++) {
      int test ;
      get_sub_word(tmp, myword, i, i + sub->size) ;
      test = compare_word(sub, tmp) == 0 ;

      clear_word(tmp) ;
      if (test)
        return i ;
    }
    destruct_word(tmp) ;
  }
  return -1 ;
}


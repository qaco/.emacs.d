int cut_sub_word(Word *myword, const Word *sub)
{
  int count = 0 ;
  int start = 0 ;
  while (start >= 0 && start + sub->size < myword->size) {
    int index = locate_sub_word(myword, sub, 0) ;
    if (index >= 0) {
      memmove(myword->memory + start + index,
              myword->memory + start + index + sub->size,
              myword->size - start - index - sub->size) ;
      myword->size -= sub->size ;
      count++ ;
    }
    start = index ;
  }
  return count ;
}

void add_chars_word(Word* dest, const char* seq, const size_t nb)
{
  dest->memory = realloc(dest->memory, dest->size + nb + 1) ;
  memcpy(&(dest->memory[dest->size]), seq, nb);
  dest->size += nb ;
  dest->memory[dest->size] = 0;
}

void append_word(Word* dest, Word* src)
{
  add_chars_word(dest, src->memory, src->size) ;
}

void destruct_word(Word* myword)
{
  free(myword->memory) ;
  free(myword) ;
}

int print_word(const Word* myword, FILE* stream)
{
  for (int i = 0 ; i < myword->size ; i++)
    if (fprintf(stream, "%c", *(myword->memory + i)) < 0)
      return EXIT_FAILURE ;
  return EXIT_SUCCESS ;
}

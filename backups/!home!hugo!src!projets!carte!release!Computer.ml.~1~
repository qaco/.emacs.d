module Computer =
  struct
    
    let rec existence i a_colors =
      let rec make_exist_list i l_colors = match l_colors with
        | [] -> []
        | c::t -> (true, (i, c))::make_exist_list i t
      and array_to_list a_colors =
        let colors = ref [] in
        for i = 0 to (length a_colors) - 1 do
          match a_colors.(i) with
          | Some c -> if not (List.mem c !colors) then colors := c::!colors;
          | None -> ()
        done; !colors
      in match i with
      | a when (i = length a_colors) -> []
      | a -> let l_colors = array_to_list a_colors
             in match a_colors.(i) with
                | Some c -> [(true, (i, c))]::existence (i + 1)
                | None -> (make_exist_list i l_colors)::existence (i + 1) ;;
    
  end

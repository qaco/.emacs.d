type instr = Push | Pop | Consti of int | Addi | Ori | Eqi
             | Acc of int | Popi of int | Branch of int | BranchIf of int

(* some examples *)
let ex1 = [| Consti(3) ; Push ; Consti(2) ; Addi |] 
let ex2 = [| Push ; Addi ; Push ; Addi ; Push ; Consti(3) ; Addi |]
let ex3 = [| Consti(3) ; Pop ; Push |]
let ex4 = [| Consti(1) ; Push ; Consti(2) ; Push ; Consti(3) ; Push ; Acc(1) ; Popi(2) |]
let ex5 = [| Consti(3) ; Push ; BranchIf(5) ; Consti(-1) ; Addi ; Push ; Branch(-4) ; Popi(1) |]
let ex6 = [| BranchIf(0) |]
let ex7 = [| Popi(-3) |]

type state = {
    mutable acc: int; (*accumulateur*)
    code: instr array; (*programme*)
    mutable pc: int; (*indice instruction suivante*)
    stack: int array; (*pile*)
    mutable sp: int; (*indice du sommet de la pile*)
  }

(*creation etat initial d'un programme*)
let init (p : instr array) : state = {
    acc = 52; (*valeur au hasard*)
    code = p;
    pc = 0;
    stack = Array.make 50 47;  (*valeur 47 au hasard*)
    sp = -1;  (*pile vide*)
  }

(*pretty printer*)
let string_of_instr (i:instr) : string = match i with
  | Push -> "Push"
  | Pop -> "Pop"
  | Consti(x) -> "Consti "^string_of_int(x)
  | Addi -> "Addi"
  | Ori -> "Ori"
  | Eqi -> "Eqi"
  | Acc(x) -> "Acc "^string_of_int(x)
  | Popi(x) -> "Popi "^string_of_int(x)
  | Branch(x) -> "Branch "^string_of_int(x)
  | BranchIf(x) -> "BranchIf "^string_of_int(x)

let string_of_state (s:state) =
  let tok = "pc:"^string_of_int(s.pc)^", acc:"^string_of_int(s.acc) in
  if s.sp > -1 then tok^", pile:"^string_of_int(s.stack.(s.sp))
  else tok^", pile:vide"
	     				     
let exec (m : state) : state =
  while m.pc < Array.length m.code do
    print_endline(string_of_instr(m.code.(m.pc))) ;
    begin
      match m.code.(m.pc) with
      | Push ->
	 m.sp <- m.sp+1;
	 m.stack.(m.sp) <- m.acc
      | Pop ->
	 m.acc <- m.stack.(m.sp);
	 m.sp <- m.sp-1
      | Consti n ->
	 m.acc <- n
      | Addi ->
	 m.acc <- m.stack.(m.sp) + m.acc;
	 m.sp <- m.sp-1
      | Ori ->
	 m.acc <- if m.stack.(m.sp)=0 && m.acc=0 then 0 else 1;
	 m.sp <- m.sp-1
      | Eqi ->
	 m.acc <- if m.stack.(m.sp)=m.acc then 1 else 0;
	 m.sp <- m.sp-1
      | Acc n ->
         m.acc <- if m.sp + n < Array.length m.stack && m.sp + n >= 0 then
                    m.stack.(m.sp + n)
                  else failwith "Stack overflow"
      | Popi n ->
         m.sp <- if m.sp + n < Array.length m.stack && m.sp + n >= 0 then
                   m.sp + n
                 else failwith "Stack overflow"
      | Branch n ->
         m.pc <- if m.pc + n < Array.length m.code && m.pc + n >= 0 then
                   m.pc + n
                 else failwith "No code here"
      | BranchIf n ->
         if m.acc=1 then
           if m.pc + n < Array.length m.code && m.pc + n >= 0 then
             m.pc <- m.pc + n
           else failwith "No code here"
    end;
    print_endline(string_of_state(m)) ;
    m.pc <- m.pc+1;
  done; m	   
             
assemblage/disassemblage
let assemble (p: instr array) : string =
  let b = String.create (Array.length p) in
  for i = 0 to Array.length p-1 do
    String.set b i
	( match p.(i) with
	  | Push -> Char.chr 0
	  | Addi -> Char.chr 1
	  | Eqi -> Char.chr 2
	  | Ori -> Char.chr 3
	  | Consti n ->
	     assert (n  < 32) ;
	     Char.chr (4 + n lsl 3)
	  | Pop -> Char.chr 5
	)
  done; b

let disassemble (b: string) : instr array =
  let p = Array.make (String.length b) Push in
  for i = 0 to String.length b-1 do
    p.(i) <- match Char.code (String.get b i) with
	     | 0 -> Push
	     | 1 -> Addi
	     | 2 -> Eqi
	     | 3 -> Ori
	     | n when (n mod 8 = 4) -> Consti (n lsr 3)
	     | 5 -> Pop
	     | _ -> failwith "invalid byte-code"
  done; p


	    

CC=gcc
CFLAGS=-std=gnu99 -Wall -Werror -g
EXEC=ungoliant

all: test

test: test.o word.o wordlist.o 
	$(CC) -o $@ $^ 

word.o: word.c word.h
	$(CC) $(CFLAGS) -o $@ -c $<

wordlist.o: wordlist.c wordlist.h word.o
	$(CC) $(CFLAGS) -o $@ -c $<

test.o: test.c word.o wordlist.o
	$(CC) $(CFLAGS) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf ungoliant

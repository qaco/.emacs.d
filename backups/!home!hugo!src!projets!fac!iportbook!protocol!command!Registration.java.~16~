package protocol.command ;

import main.MainVals ;
import exception.* ;
import service.User ;
import protocol.feedback.Welcome ;
import protocol.feedback.Goodbye ;
import java.net.Socket ;
import java.io.OutputStream ;
import java.io.OutputStreamWriter ;
import java.io.Writer ;
import java.io.IOException ;
import java.util.List ;

public class Registration implements Anon {
    
    private String id ;
    private int port ;
    private int mdp ;
    
    public Registration (String i, String p, String m) throws UnknownResultException {
        this.id = i ;
        try {
            this.port = Integer.parseInt(p) ;
        } catch (NumberFormatException e) {
            throw new WrongTypeException("port", p, "int") ;
        }
        try {
            this.mdp = Integer.parseInt(m) ;
        } catch (NumberFormatException e) {
            throw new WrongTypeException("password", m, "int") ;
        }
        this.checkRules() ;
    }

    public Registration (String i,int p,int m) {
        this.id = i ;
        this.port = p ;
        this.mdp = m ;
        try {
            this.checkRules() ;
        } catch (RuleBrokenException e) {
            throw new IllegalArgumentException() ;
        }
    }

    public String getId() {
        return this.id ;
    }
    
    public void exec(Socket so, List<User> allusers)
        throws UnknownResultException, IOException {
        for (User guy : allusers) {
            if (this.id.equals(guy.getId())) {
                Writer w = new OutputStreamWriter(so.getOutputStream()) ;
                w.write((new Goodbye()).toString()) ;
                w.flush() ;
                throw new NotExecutableException("Registration",
                                                 this.id + " yet registered");
            }
        }
        User myuser = new User(so, this.id, this.port, this.mdp) ;
        myuser.sendTCP(new Welcome()) ;
        allusers.add(myuser) ;
        this.describeRegistrationSuccess() ;
    }
        
    public String toString() {
        String myport = String.valueOf(this.port) ;
        String mymdp = String.valueOf(this.mdp) ;
        return
            AnonVals.REGISTRATION + " " +
            this.id + " " + myport + " " + mymdp + MainVals.EOF ;
    }

    private  void checkRules() throws RuleBrokenException {
        if (this.port > MainVals.MAX_UDP || this.port < 0)
            throw new RuleBrokenException("Registration",
                                          "port too big or to small") ;
        if (this.mdp > MainVals.MAX_MDP || this.mdp < 0)
            throw new RuleBrokenException("Registration",
                                          "password too big or to small") ;
        if (this.id.length() > MainVals.MAX_ID_SIZE)
            throw new RuleBrokenException("Registration", "id > 8") ;
    }

    private void describeRegistrationSuccess() {
        MainVals.describe("Registration success : [id:" + this.id +
                          "] [password:" + String.valueOf(this.mdp) +
                          "] [udp:" + String.valueOf(this.port) + "]") ;
    }
}

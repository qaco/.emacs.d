package protocol ;

import main.MainVals ;
import exception.* ;

public class AbstractPub {
    protected byte ip[] = new byte[4] ;
    protected int port ;
    protected String message ;

    public AbstractPub(byte[] i,int p,String m) {
        this.ip = i ;
        this.port = p ;
        this.message = m ;
        try {
            this.checkRules() ;
        } catch (RuleBrokenException e) {
            throw new IllegalArgumentException() ;
        }
    }

    public AbstractPub(String i, String p, String m) throws UnknownResultException {
        try {
            this.ip = i.getBytes() ;
        } catch (NumberFormatException e) {
            throw new WrongTypeException("ip address", i, "byte[]") ;
        }
        try {
            this.port = Integer.parseInt(p) ;
        } catch (NumberFormatException e) {
            throw new WrongTypeException("port", p, "int") ;
        }
        this.message = m ;
        this.checkRules() ;
    }

    private void checkRules() throws RuleBrokenException {
        if (this.ip.length < 9 || this.ip.length > 16)
            throw new RuleBrokenException("Pub", "wrong ip length") ;
        if (this.message.length() > MainVals.MAX_PUB_SIZE)
            throw new RuleBrokenException("Pub", "mess > 200") ;
    }
}
            

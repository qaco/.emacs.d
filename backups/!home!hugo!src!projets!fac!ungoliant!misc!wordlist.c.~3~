#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "word.h"
#include "wordlist.h"

WordList build_wordlist(const Word myword)
{
  WordList newlist ;
  newlist.allocated = 2 ;
  newlist.sequence = malloc(sizeof(Word)*newlist.allocated) ;
  *(newlist.sequence) = clone_word(myword) ;
  newlist.length = 1 ;
  return newlist ;
}

WordList build_empty_wordlist()
{
  WordList newlist ;
  newlist.allocated = 1 ;
  newlist.sequence = malloc(sizeof(Word)*newlist.allocated) ;
  newlist.length = 0 ;
  return newlist ;
}

WordList clone_wordlist(const WordList toclone) {
  WordList res ;
  res.length = toclone.length ;
  res.allocated = toclone.allocated ;
  res.sequence = malloc(sizeof(Word)*res.allocated) ;
  for (int i = 0 ; i < toclone.length ; i++)
    *(res.sequence + i) = *(toclone.sequence + i) ;
  return res ;
}

size_t get_length_wordlist(const WordList mylist)
{
  return mylist.length ;
}

int get_word_wordlist(Word* dest, const WordList mylist, const int index)
{
  if (index < 0 || index >= mylist.length)
    return EXIT_FAILURE ;
  *(dest) = clone_word(*(mylist.sequence + index)) ;
  return EXIT_SUCCESS ;
}

int pop_word_wordlist(Word* dest, WordList* mylist)
{
  if (mylist->length <= 0)
    return EXIT_FAILURE ;
  *(dest) = clone_word(*(mylist->sequence)) ;
  destruct_word(mylist->sequence) ;
  memmove(mylist->sequence,
          mylist->sequence + 1,
          sizeof(Word)*(mylist->length - 1)) ;
  mylist->length-- ;
  /* if (mylist->length < mylist->allocated/4) { */
  /*   mylist->sequence = realloc(mylist->sequence, */
  /*                              sizeof(Word)*(mylist->allocated/2)) ; */
  /*   mylist->allocated /= 2 ; */
  /* } */
  return EXIT_SUCCESS ;
}

void add_word_wordlist(WordList* dest, Word myword)
{
  if (dest->length >= dest->allocated - 1) {
    dest->sequence = realloc(dest->sequence,
                             sizeof(Word)*(dest->allocated*2)) ;
    dest->allocated *= 2 ;
  }
  *(dest->sequence + dest->length) = clone_word(myword) ;
  dest->length++ ;
}

void addall_wordlist(WordList* dest, WordList* src)
{
  for (int i = 0 ; i < src->length ; i++)
    add_word_wordlist(dest, *(src -> sequence + i)) ;
}

void destruct_wordlist(WordList* mylist)
{
  for (int i = 0 ; i < mylist->length ; i++)
    destruct_word(mylist->sequence + i) ;
  free(mylist->sequence) ;
}

int print_wordlist(WordList mylist, FILE* stream)
{
  fprintf(stream, "[ ") ;
  for (int i = 0 ; i < mylist.length ; i++) {
    print_word(*(mylist.sequence + i), stream) ;
    if (i < mylist.length - 1)
      fprintf(stream, ", ") ;
  }
  fprintf(stream, " ]\n") ;
  return EXIT_SUCCESS ;
}
    

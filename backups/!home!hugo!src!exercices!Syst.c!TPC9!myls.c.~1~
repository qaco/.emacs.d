#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

#define SIZE_PATH 1024

int main (int argc, char* argv[]) {
  char* path = malloc(sizeof(char)*SIZE_PATH) ;
  int l ;
  DIR* current ;
  struct dirent* tmp ;
  
  argc -- ;
  argv++ ;

  if (!strcmp(*argv, "-l"))
    l = 1 ;

  getcwd(path, SIZE_PATH) ;
  current = opendir(path) ;
  do {
    tmp = readdir(current) ;
    if (tmp != NULL) {
      printf("%s\n", tmp->d_name) ;
    }
  } while (tmp != NULL) ;
}

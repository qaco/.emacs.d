package protocol ;

import exception.RuleBrokenException ;

public class MessField extends Field {

    public MessField(byte[] mymess) throws RuleBrokenException {
        super(mymess) ;
    }

    public MessField(String mymess) {
        super(mymess) ;
    }
    
    protected void checkRules() throws RuleBrokenException {
        if (this.id.length > ProtocolVals.MAX_MSG_SIZE) {
            throw new RuleBrokenException("Messfield",
                                          this.toString() + " too long") ;
        }
        for (int i = 0 ; i < this.field.length ; i++) {
            if (this.field[i] < 0) {
                String tmp = String.valueOf(this.field[i]) ;
                throw new RuleBrokenException("IdField",
                                              tmp + " non ascii char") ;
            }
        }
        
    }
        

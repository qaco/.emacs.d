CC=gcc
CFLAGS=-std=c99 -Wall
GTKLINK=`pkg-config --cflags --libs gtk+-2.0`
EXEC=cluedo
SRC=control.c load_media.c gen.c cluedo.c
OBJ=$(SRC:.c=.o)

all : $(EXEC)

$(EXEC) : $(OBJ)
	$(CC) -o $@ $^ $(GTKLINK)

cluedo.o : cluedo.c gen.h control.h
	$(CC) $(CFLAGS) -o $@ -c $< $(GTKLINK)

gen.o : gen.c load_media.h
	$(CC) $(CFLAGS) -o $@ -c $< $(GTKLINK)

load_media.o : load_media.c
	$(CC) -o $@ -c $< $(CFLAGS) $(GTKLINK)

control.o : control.c
	$(CC) -o $@ -c $< $(CFLAGS) $(GTKLINK)	

clean :
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

#ifndef GAME
#define GAME



typedef enum { MOUTARDE, OLIVE, VIOLET, PERVENCHE, ROSE, LEBLANC } Perso ;
typedef enum { CHANDELIER, CLE, CORDE, MATRAQUE, POIGNARD, REVOLVER, } Arme ;
typedef enum { COULOIR, CUISINE, BAL, VERANDA, MANGER, BILLARD,
	       BIBLIOTHEQUE, SALON, HALL, BUREAU } Piece ;
typedef enum { PERSO, ARME, PIECE } Alibi_type ;

typedef union {
  Perso perso ;
  Arme arme ;
  Piece piece ;
} Alibi ;

typedef struct {
  Alibi alibi ;
  Alibi_type alibi_type ;
  GtkWidget* figure ;
} Carte ;

typedef struct {
  Perso mon_perso ;
  GtkWidget* pion ;
} Joueur ;

Joueur* construct_joueur(Perso perso, GtkWidget* image) ;
void destruct_joueur(Joueur* j) ;

int can_move_joueur(Joueur* j, GtkWidget* event_box, char info) ;
void move_joueur(Joueur* j, GtkWidget* event_box) ;

#endif

/**
 * \file build.h
 * \brief Fonctions de construction et de manipulation de chaînes.
 */
#ifndef BUILD

#define BUILD

#define T_IN "HELO"
#define T_OK "OKOK"
#define T_NO "BADD"
#define T_PUB "BCST"
#define T_PRIV "PRVT"
#define T_LIST "LIST"
#define T_SHUT "SHUT"
#define T_DBG "DEBG"
#define T_FILE "FILE"
#define T_BYE "BYEE"

/**
 * \fn char* int_to_string(const int offset, const long int nb)
 * \brief Retourne la représentation en n caractères d'un entier.
 * \param offset Le nombre de caractères de la chaîne à retourner.
 * \param nb L'entier à représenter en caractères.
 * \return La représentation de l'entier sous forme de chaîne.
 */
char* int_to_string(const int offset, const long int nb) ;
/**
 * \fn char* add_a_string (char** init, const char *toadd)
 * \brief Ajoute une chaîne à une autre de manière à respecter le protocole.
 * \param init Le pointeur sur la chaîne de destination.
 * \param toadd La chaîne à concaténer.
 * \return La concaténation des deux chaînes respectant le protocole.
 */
char* add_a_string (char** init, const char *toadd) ;
/**
 * \fn int extract_string (char** dest, char* string)
 * \brief Extrait le texte d'une chaîne respectant le protocole.
 * \param dest Le pointeur sur la chaîne de destination.
 * \param string La chaîne dont on extrait le texte.
 * \return La taille totale (nombre + texte) de la chaîne traitée.
 */
int extract_string (char** dest, char* string) ;
/**
 * \fn int extract_int (char* string)
 * \brief Extrait un entier respectant le protocole.
 * \param string Le message dont on extrait l'entier.
 * \return L'entier extrait.
 */
int extract_int (char* string) ;
/**
 * \fn char* build_msg(const int client,const char* typem,...)
 * \brief Construit une chaîne respectant le protocole.
 * \param client Indique si on construit une chaîne pour le client.
 * \param typem Le type du message à construire.
 * \param ... Arguments permettant de construire la chaîne du type demandé,
 * à fournir dans l'ordre prévu par le protocole après le type.
 * \return Le message respectant le protocole.
 */
char* build_msg(const int client, const char* typem, ...) ;
/**
 * \fn char* string_realloc(char* ptr, size_t size)
 * \brief Empêche le programme de continuer en cas de problème avec realloc.
 * \param ptr Le pointeur sur le bloc mémoire à réallouer.
 * \param size La taille à assigner au nouveau bloc mémoire.
 * \return Le pointeur sur le nouveau bloc mémoire.
 */
char* string_realloc(char *ptr, const size_t size) ;
/**
 * \fn char *string_copy(const char *string)
 * \brief Simplification de la copie d'une chaîne.
 * \param string La chaîne à copier.
 * \return La chaîne résultant de la copie.
 */
char *string_copy(const char *string) ;
/**
 * \fn char *get_substring(const char *string, const int beginIndex, const int endIndex)
 * \brief Retourne la sous chaîne d'une chaîne delimitee par 2 indices.
 * \param string La chaîne dont on veut extraire une sous-chaîne.
 * \param beginIndex L'indice de début de la sous-chaîne.
 * \param endIndex L'indice de fin de la sous-chaîne.
 * \return La sous-chaîne résultant de l'opération.
 */
char *get_substring(const char *string, const int beginIndex, const int endIndex) ;

#endif

#!/bin/bash

DIR="/home/hugo/Images/Wallpapers/Favoris"
CUR=$(gsettings get org.mate.background picture-filename | sed "s/'//g")
PIC=$(ls $DIR | shuf -n1)
CMPL=$DIR/$PIC
while test "$CMPL" == "$CUR"
do
    PIC=$(ls $DIR | shuf -n1)
    CMPL=$DIR/$PIC
done
gsettings set org.mate.background picture-filename "$CMPL"

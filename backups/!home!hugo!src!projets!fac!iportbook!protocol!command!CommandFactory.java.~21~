package protocol.command ;

import exception.* ;
import protocol.ProtocolFactory ;
import java.util.Arrays ;
import java.io.InputStream ;
import java.io.IOException ;
import main.MainVals ;

public class CommandFactory extends ProtocolFactory {

    public Command create(InputStream in) throws UnknownResultException,
                                            IOException {
        byte[][] raw_arr = this.readStream(in) ;
        String code = this.extractCode(raw_arr) ;
        byte[][] smooth_arr = Arrays.copyOfRange(raw_arr,1,raw_arr.length) ;
        return this.create(code, smooth_arr) ;
    }
    
    private Command create(String code, byte[][] params) throws UnknownResultException {
        byte[] mess ;
        
        try {
            switch (code) {
            case CommandVals.ASK_FRIEND :
                return new AskFriend(params[0]) ;
            case CommandVals.FIRST_MESSAGE :
                return new FirstMessage(params[0], params[1]) ;
            case CommandVals.FLOO_MESSAGE :
                mess = this.joinArray(params, 0) ;
                return new FlooMessage(mess) ;
            case CommandVals.SEE_LIST :
                return new SeeList() ;
            case CommandVals.CONSULTATION :
                return new Consultation() ;
            case CommandVals.DECONNECTION :
                return new Deconnection() ;
            default :
                throw new UnknownCommandException(code, "command") ;
            }
        } catch (ArrayIndexOutOfBoundsException e){
            throw new TooFewArgsException(code,
                                          String.valueOf(params.length)) ;
        }
    }
}


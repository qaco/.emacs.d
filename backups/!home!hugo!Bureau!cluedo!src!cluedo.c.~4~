#include <stdio.h>
#include <stdlib.h>
#include <gtk/gtk.h>
#include "gen.h"
#include "view.h"

#define MAP_PATH "../ressources/conf/map.cluedo"
#define MAP_SIZE 24

int main(int argc, char* argv[]) {
  char** mymap = map(MAP_PATH, MAP_SIZE) ;
  GtkWidget* window;
  GtkWidget*** buttons ;

  gtk_init(&argc,&argv);
  
  window = conf_window(MAP_SIZE) ;
  buttons = fill_window(window, MAP_SIZE, mymap) ;
  
  gtk_widget_show_all(window);
  gtk_main();
  
  for (int i = 0 ; i < MAP_SIZE ; i++)
    printf("%s\n", *(mymap + i)) ;
}

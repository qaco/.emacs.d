let exec (m : state) : state =
  while m.pc < Array.length m.code do
    begin
      match m.code.(m.pc) with
      | Push ->
	 m.sp <- m.sp+1;
	 m.stack.(m.sp) <- m.acc
      | Pop ->
	 m.acc <- m.stack.(m.sp);
	 m.sp <- m.sp-1
      | Consti n ->
	 m.acc <- n
      | Addi ->
	 m.acc <- m.stack.(m.sp) + m.acc;
	 m.sp <- m.sp-1
      | Ori ->
	 m.acc <- if m.stack.(m.sp)=0 && m.acc=0 then 0 else 1;
	 m.sp <- m.sp-1
      | Eqi ->
	 m.acc <- if m.stack.(m.sp)=m.acc then 1 else 0;
	 m.sp <- m.sp-1
    end;
    m.pc <- m.pc+1;
  done; m	   
             
(*assemblage/disassemblage*)
let assemble (p: instr array) : bytes =
  let b = Bytes.create (Array.length p) in
  for i = 0 to Array.length p-1 do
    Bytes.set b i
	( match p.(i) with
	  | Push -> Char.chr 0
	  | Addi -> Char.chr 1
	  | Eqi -> Char.chr 2
	  | Ori -> Char.chr 3
	  | Consti n ->
	     assert (n  < 32) ;
	     Char.chr (4 + n lsl 3)
	  | Pop -> Char.chr 5
	)
  done; b

let disassemble (b: bytes) : instr array =
  let p = Array.make (Bytes.length b) Push in
  for i = 0 to Bytes.length b-1 do
    p.(i) <- match Char.code (Bytes.get b i) with
	     | 0 -> Push
	     | 1 -> Addi
	     | 2 -> Eqi
	     | 3 -> Ori
	     | n when (n mod 8 = 4) -> Consti (n lsr 3)
	     | 5 -> Pop
	     | _ -> failwith "invalid byte-code"
  done; p


	    

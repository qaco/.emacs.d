#include <stdlib.h>
#include <check.h>
#include "../ungoliant.h"

START_TEST(reset) {
  int ret ;
  char *prog = malloc(sizeof(char)*(strlen("ungoliant") + 1)) ;
  char *opt = malloc(sizeof(char)*(strlen("-r") + 1)) ;
  strcpy(prog, "ungoliant") ;
  strcpy(opt, "-r") ;
  char* myargs[2] ;
  myargs[0] = prog ;
  myargs[1] = opt ;
  
  ret = cmds(2, myargs) ;
  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
}
END_TEST

TCase* acceptance_case(void) {
  TCase* tc_acceptance ;

  tc_acceptance = tcase_create("Acceptance") ;

  tcase_add_test(tc_acceptance, reset) ;
  return tc_acceptance ;
}

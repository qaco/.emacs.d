#include <unistd.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <pthread.h>
#include "messages.h"
#include "aux.h"

void* thread_lecture (void *arg)
{
  user* avatar = (user*)arg ;
  while(1)
    {
      receive_msg(avatar->pseudo, avatar->tube) ;
    }
}
  
void *thread_ecriture(void *arg)
{
  user* avatar = (user*)arg ;
  while(1)
    {
      send_msg(avatar->pseudo, avatar->id, avatar->tube) ;
    }
}

void main_loop(char* tube_server)
{
  int server, client ;
  user avatar ;
  pthread_t sender, receiver ;

  /* Tant que le pseudo existe déjà, l'utilisateur doit en saisir un nouveau.*/
  do {
    avatar.pseudo = get_input("Pseudo>") ;
  }
  while (access(avatar.pseudo, F_OK ) == 0 ) ;

  /* On récupère le tube du serveur et on crée celui de l'utilisateur, avec des
     droits maximaux pour les tests. */
  server = open(tube_server, S_IRWXU | S_IRWXG | S_IRWXO) ;
  client = mkfifo(avatar.pseudo, S_IRWXU | S_IRWXG | S_IRWXO) ;
  
  avatar.id = connexion(server,client, avatar.pseudo, avatar.pseudo) ;

  avatar.tube = server ;
  pthread_create(&receiver, NULL, thread_lecture, &avatar) ;
  avatar.tube = client ;
  pthread_create(&sender, NULL, thread_ecriture, &avatar) ;
}

int main(int argc, char* argv[]) {
  main_loop("patron") ;

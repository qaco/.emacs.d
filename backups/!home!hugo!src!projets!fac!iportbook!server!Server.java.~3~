    public void requestList(String src) {
        Socket dest = connected.get(src) ;
        Writer out = new OutPutStreamWriter(dest.getOutputStream()) ;
        int num = connected.size() ;
        Feedback fb = new FirstList(num) ;
        out.write(fb.toString()) ;
        out.flush() ;
        for(String name : connected) {
            fb = new SomeList(name) ;
            out.write(fb.toString()) ;
            out.flush() ;
        }
    }

    public void disconnect(String src) {
        Socket doomed = connected.get(src) ;
        doomed.close() ;
        connected.remove(src) ;
    }
    

    public void listenConnected(String src) {
        while (connected.containsKey(src)) {
            Socket ear = connected.get(src) ;
            Reader in = new InputStreamReader(ear.getInputStream()) ;
            String sb = new StringBuffer() ;
            CommandFactory cf = new CommandFactory() ;
            while(!sb.toString().contains(CommandVals.EOF))
                sb.append((char)in.read()) ;
            cf.create(src, sb.toString()) ;
            // exécution de la commande
        }
    }
        
        

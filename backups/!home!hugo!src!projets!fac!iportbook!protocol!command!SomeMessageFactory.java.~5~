package protocol.command ;

import exception.* ;
import protocol.ProtocolFactory ;
import java.util.Arrays ;
import java.io.InputStream ;
import java.io.IOException ;
import main.MainVals ;

public class SomeMessageFactory extends ProtocolFactory {

    public SomeMessage create(InputStream in) throws UnknownResultException,
                                                IOException {
        byte[][] raw_arr = this.readStream(in) ;
        String code = this.extractCode(raw_arr) ;
        byte[][] smooth_arr = Arrays.copyOfRange(raw_arr,1,raw_arr.length) ;
        return this.create(code, smooth_arr) ;
    }
    
    private SomeMessage create(String code, byte[][] params) throws UnknownResultException {
        byte[] mess ;

        try {
            switch (code) {
            case CommandVals.SOME_MESSAGE:
                mess = this.joinArray(params, 1) ;
                return new SomeMessage(params[0], mess) ;
            default :
                throw new UnknownCommandException("somemessage", code) ;
            }
        } catch (ArrayIndexOutOfBoundsException e) {
            throw new TooFewArgsException(code,
                                          String.valueOf(params.length)) ;
        }
    }
}


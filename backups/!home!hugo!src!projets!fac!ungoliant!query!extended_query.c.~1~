WordList* tokens_andor
(char *input_tokens[], int input_size, int index, WordList* (*f)(WordList*, WordList*)) {
    WordList *arg1, *arg2 ;
    arg1 = db_request(input_tokens[index]);
    arg2 = db_request(input_tokens[index + 1]);
    return (*f)(arg1, arg2) ;
}

WordList* tokens_handling(char *input_tokens[], int input_size, int index) {
    if (input_size == 1) {
	if (strcmp(input_tokens[index], TRAIN) == 0 ) {
	    query_misc_hub(input_tokens, EASTER_TRAIN);
	    return build_empty_wordlist();
	}
	else
	    return db_request(input_tokens[index]);
    }
    else if (input_size == 2
	     && (strcmp(input_tokens[index], TO_LETTERS) == 0 )) {
	query_misc_hub(input_tokens, EASTER_TOLETTERS);
	return build_empty_wordlist();
    }
    else if (input_size == 4 
	     && (strcmp(input_tokens[index], EQUALS) == 0 )) {
	query_misc_hub(input_tokens, EASTER_CALCULATOR);
	return build_empty_wordlist();
    }
    else {
	if (input_size == 3) {
	    if( strcmp(input_tokens[index], AND_TOKEN) == 0 ) {
		return tokens_andor(input_tokens, input_size, index + 1, intersect);
	    }
	    else if( strcmp(input_tokens[index], OR_TOKEN) == 0 ) {
		return tokens_andor(input_tokens, input_size, index + 1, union_);
	    }
	}
	else {
	    WordList *res = build_empty_wordlist();
	    for (int i = 0; i < input_size-1; i++) {
		WordList *l1 = db_request(input_tokens[i]) ;
		WordList *l2 = db_request(input_tokens[i+1]) ;
		if (i == 0) res = intersect(l1, l2);
		else res = intersect(res, l2);
	    }
	    return res;
	}
    }
    return build_empty_wordlist();
}

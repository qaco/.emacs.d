            if size[0] > size[1] : size = IMG_MAX_WIDTH, size[1]
            else : size = size[0], IMG_MAX_HEIGHT
            self.main_img.thumbnail(size)
            size = (self.main_img.width, self.main_img.height)

    def set_mask(self):
        self.onion.append(mask())
        self.imask = len(self.onion) - 1
        self.onion[self.imask].bottomize_golden_ratio(self.img.size)

    def set_slogan(self,mytext):
        if self.islogan > -1 :
            self.onion[self.islogan] = slogan(self.onion[self.imask], mytext)
        else :
            self.onion.append(slogan(self.onion[self.imask], mytext))
            self.islogan = len(self.onion) - 1
        self.onion[self.islogan] = slogan(self.onion[self.imask], mytext)
        self.onion[self.islogan].write_biggest(mytext, self.onion[self.imask])

    def merge_calcs(self) :
        for calc in self.onion :
            self.img = Image.alpha_composite(self.img, calc.img)
        

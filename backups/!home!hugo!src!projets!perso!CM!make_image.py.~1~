#! /usr/bin/env python3

import sys
from math import sqrt
from PIL import Image, ImageDraw, ImageFont

# Constantes image
IMG_MAX_WIDTH = 1200
IMG_MAX_HEIGHT = 630
# OPACITY = 204
MASK_OPACITY = 230
PHI = (1+sqrt(5))/2
FONT_PATH="fonts/Ubuntu-B.ttf"
OFFSET_RATIO = 30
TRANS_COLOR = (255, 255, 255, 0)

class calc:
    def __init__(self):
        self.img = None
        self.corner = None
        self.size = None

class mask(calc):
    def __init__(self):
        self.color = (0, 0, 0, MASK_OPACITY)

    def bottomize_golden_ratio(self, upper_size):
        self.corner = 0, int(upper_size[1]/PHI)
        self.size = upper_size[0], upper_size[1] - self.corner[1]
        self.img = Image.new('RGBA', upper_size, TRANS_COLOR)
        draw = ImageDraw.Draw(self.img, 'RGBA')
        draw.rectangle([self.corner, self.img.size], self.color)
        
class slogan(calc):
    def __init__(self, mycalc, mytext):
        self.text = None
        self.font = None
        self.color = (255,255,255)

    def write_biggest(self, mytext, mycalc) :
        self.text = mytext
        self.img = Image.new('RGBA', mycalc.img.size, TRANS_COLOR)
        # Positionnement du slogan
        offset = max(mycalc.size[0], mycalc.size[1])/OFFSET_RATIO
        self.corner = int(mycalc.corner[0] + offset), int(mycalc.corner[1] + offset)
        max_size = int(mycalc.size[0] - offset*2), int(mycalc.size[1] - offset*2)
        # Récupération du pinceau
        draw = ImageDraw.Draw(self.img, 'RGBA')
        # Détermination de la taille de fonte et instanciation de la fonte
        fontsize = 0
        test = True
        while test:
            fontsize += 1
            self.font = ImageFont.truetype(FONT_PATH, fontsize)
            stringsize = draw.textsize(self.text, self.font)
            test = stringsize[0] < max_size[0] and stringsize[1] < max_size[1]
            stringsize = draw.textsize(self.text, self.font)
        # Centrage du texte
        self.size = draw.textsize(self.text, self.font)
        xcorn = mycalc.corner[0] + (mycalc.size[0] - self.size[0])/2
        ycorn = mycalc.corner[1] + (mycalc.size[1] - self.size[1])/2
        self.corner = int(xcorn), int(ycorn)
        print(self.corner)
        # Dessin du slogan
        draw.text(self.corner, self.text, self.color, self.font)
            

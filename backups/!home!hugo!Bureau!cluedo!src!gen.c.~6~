#include <stdlib.h>
#include <stdio.h>
#include <gtk/gtk.h>

#define TILEMAP_PATH "../ressources/images/allmap.jpg"
#define TEXTMAP_PATH "../ressources/conf/map.cluedo"
#define TILE_SIZE 20
#define V_TILES = 24
#define H_TILES = 24

char** gen_text_map(const int cote) {
  char tmp ;
  FILE* file = fopen(MAP_PATH, "r") ;
  char** res = malloc(cote*sizeof(char*)) ;
  for (int i = 0 ; i < cote ; i++)
    *(res+i) = malloc(cote*sizeof(char)+1) ;
  int i = 0, j = 0 ;
  do {
    tmp = fgetc(file) ;
    if (tmp == '\n') {
      *(*(res + i) + j) = '\0' ;
      i++ ;
      j = 0 ;
    }
    else {
      *(*(res + i) + j) = tmp ;
      j++ ;
    }
  } while (i < cote - 1 || j < cote) ;
  fclose(file) ;
  
  return res ;
}

GtkWidget*** get_tile_map() {
  PixBuf* tmp ;
  GError* gerror = NULL ;
  PixBuf* all_tiles = gdk_pixbuf_new_from_file_at_scale (ALLMAP_PATH,
							 TILE_SIZE*V_TILES,
							 TILE_SIZE*H_TILES,
							 FALSE, &gerror);
  if(!tmp) {
    printf("error message: %s\n", gerror->message);
    exit(1);
  }
  GtkWidget*** array_tiles = malloc(V_TILES*sizeof(GtkWidget**)) ;
  for (int i = 0 ; i < V_TILES ; i++)
    *(array_tiles + i) = malloc(H_TILES*sizeof(GtkWidget*)) ;
  for (int i = 0 ; i < V_TILES ; i++) {
    for (int j = 0 ; j < H_TILES ; j++) {
      tmp = gdk_pixbuf_new_subpixbuf (all_tiles,
				      j*TILE_SIZE,
				      i*TILE_SIZE,
				      TILE_SIZE,
				      TILE_SIZE);
      *(*(array_tiles + i) + j) = gtk_image_new_from_pixbuf(tmp) ;
    }
  }
  return array_tiles ;
}

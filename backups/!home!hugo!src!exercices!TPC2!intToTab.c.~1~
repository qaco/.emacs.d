#include <stdio.h>

void intToTab(int n, int tab[]) {
  if (n/1000 <= 9 && n/1000 > 0) {
    tab[0] = n/1000 ;
    tab[1] = n/100 - tab[0] * 10 ;
    tab[2] = n/10 - (tab[0] * 100 + tab[1] * 10) ;
    tab[3] = n - (tab[0] * 1000 + tab[1] * 100 + tab[2] * 10) ;
  }
}

int main() {
  int n = 1234 ;
  int tab[4] ;
  intToTab(n,tab) ;
  for (int i = 0 ; i < 4 ; i++)
    printf("%d", tab[i]) ;
  printf("\n") ;
}
    

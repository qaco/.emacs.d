CC=gcc
CFLAGS=-std=gnu99 -Wall -Werror -g
CLINKS=-lcurl -ldb
EXEC=ungoliant

all: ungoliant

ungoliant: word.o wordlist.o parser.o db_manager.o crawler.o ungoliant.o
	$(CC) -o $@ $^ $(CLINKS)

word.o: word.c word.h
	$(CC) $(CFLAGS) -o $@ -c $<

wordlist.o: wordlist.c wordlist.h word.o
	$(CC) $(CFLAGS) -o $@ -c $<

parser.o: parser.c parser.h word.o wordlist.o
	$(CC) $(CFLAGS) -o $@ -c $<

db_manager.o: db_manager.c db_manager.h word.o wordlist.o
	$(CC) $(CFLAGS) -o $@ -c $< $(CLINKS)

crawler.o: crawler.c crawler.h word.o wordlist.o parser.o db_manager.o
	$(CC) $(CFLAGS) -o $@ -c $< $(CLINKS)

ungoliant.o: ungoliant.c crawler.h crawler.c
	$(CC) $(CFLAGS) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf ungoliant

import protocol.feedback.* ;
import static org.junit.Assert.* ;
import org.junit.Test;
import org.junit.Before;

public class FeedbackFactoryTest {

    private FeedbackFactory pf ;

    @Before
    public final void setUp() {
        this.pf = new FeedbackFactory() ;
    }

    @Test
    public final void testAskFriendOKBuild() {
        String tmp = "FRIE>+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }
    
    @Test
    public final void testAskFriendNOBuild() {
        String tmp = "FRIE<+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

    @Test
    public final void testFlooDoneBuild() {
        String tmp = "FLOO>+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

    @Test
    public final void testGoodbyeBuild() {
        String tmp = "GOBYE+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

    @Test
    public final void testHelloBuild() {
        String tmp = "HELLO+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

    @Test
    public final void testMessageTransmittedBuild() {
        String tmp = "MESS>+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

    @Test
    public final void testMessageNotTransmittedBuild() {
        String tmp = "MESS<+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

    @Test
    public final void testWelcomeBuild() {
        String tmp = "WELCO+++" ;
        Protocol p = this.pf.create(tmp) ;
        assertEquals(tmp, p.toString()) ;
    }

}

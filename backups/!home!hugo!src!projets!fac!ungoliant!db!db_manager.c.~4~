int add_pair_data(DbId *id, struct pair_data *pdata) {
    int ret;
    DB *pair_dbp;
    DBT key, data;
    uint64_t url_index;

    ret = word_url_pair_exists(id, pdata);

    if (ret == PAIR_EXISTS) {
        return EXIT_SUCCESS;
    } else if (ret != NOT_PAIR_EXISTS) {
        return EXIT_FAILURE;
    }

    pair_dbp = id->pair_dbp;

    memset(&key, 0, sizeof(key));
    memset(&data, 0, sizeof(data));

    url_index = id->next_pair_index++;
    key.data = &url_index;
    key.size = sizeof(url_index);
    data.data = pdata;
    data.size = sizeof(struct pair_data);
    // TODO voir pour les MACROS
    if ((ret = pair_dbp->put(pair_dbp, NULL, &key, &data, 0)) == 0) {
        /* printf("db: %lu: pair key stored.\n", *(uint64_t *)key.data); */
    } else {
        pair_dbp->err(pair_dbp, ret, "DB->put");
        return EXIT_FAILURE;
    }

    return EXIT_SUCCESS;
}

int add_data(DbId *id, struct word_data *wdata, size_t word_data_size,
             struct url_data *udata, size_t url_data_size,
             struct pair_data *pdata, size_t pair_data_size) {
    int ret;
    uint64_t url_id;
    uint64_t word_id;

    ret = add_url_data(id, &url_id, udata, url_data_size);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    ret = add_word_data(id, &word_id, wdata, word_data_size);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    pdata->word_id = word_id;
    pdata->url_id = url_id;

    ret = add_pair_data(id, pdata);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    return EXIT_SUCCESS;
}

int add_pair(DbId *id, Word *word, Word *url) {
    int ret;
    struct word_data *wdata;
    struct url_data *udata;
    struct pair_data *pdata;
    size_t wdata_size;
    size_t udata_size;
    size_t pair_data_size;

    ret = create_word_data(&wdata, word, &wdata_size);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    ret = create_url_data(&udata, url, &udata_size);
    if (ret == EXIT_FAILURE) {
        free_word_data(wdata);
        return EXIT_FAILURE;
    }

    ret = create_pair_data(&pdata, -1, -1, &pair_data_size);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    pdata->nb_occurence = 1;

    ret = add_data(id, wdata, wdata_size,
                   udata, udata_size,
                   pdata, pair_data_size);
    if (ret == EXIT_FAILURE) {
        free_pair_data(pdata);
        free_url_data(udata);
        free_word_data(wdata);
        return EXIT_FAILURE;
    }

    free_url_data(udata);
    free_word_data(wdata);
    free_pair_data(pdata);
    return EXIT_SUCCESS;
}



int get_pair_data(DbId *id, struct word_data_list *wdata_list,
                  struct pair_data_list *pdata_list) {
    DB *pair_word_sdbp;
    DBC *dbc;
    DBT key, skey, data;
    int ret, fret;

    pair_word_sdbp = id->pair_word_sdbp;

    memset(&key, 0, sizeof(key));
    memset(&skey, 0, sizeof(skey));
    memset(&data, 0, sizeof(data));

    skey.data = &(wdata_list->wdata_key);
    skey.size = sizeof(wdata_list->wdata_key);

    pair_word_sdbp->cursor(pair_word_sdbp, NULL, &dbc, 0);

    for (ret = dbc->c_pget(dbc, &skey, &key, &data, DB_SET);
         ret == 0;
         ret = dbc->c_pget(dbc, &skey, &key, &data, DB_NEXT_DUP)) {
        fret = add_pdata_clone_to_list(pdata_list, *(uint64_t *)key.data,
                                       (struct pair_data *) data.data,
                                       data.size);
        if (fret != EXIT_SUCCESS) {
            fret = dbc->c_close(dbc);
            return EXIT_FAILURE;
        }
        /* printf("db: %lu: pair key retrieved\n", *(uint64_t *)key.data); */
    }

    ret = dbc->c_close(dbc);
    if (ret != 0) {
        return EXIT_FAILURE;
    }
    return EXIT_SUCCESS;
}

int get_word_data(DbId *id, struct word_data_list *wdata_list) {
    DB *word_sdbp;
    DBT key, skey, data;
    int ret;

    memset(&key, 0, sizeof(key));
    memset(&skey, 0, sizeof(skey));
    memset(&data, 0, sizeof(data));

    skey.data = &(wdata_list->wdata->word[0]);
    skey.size = wdata_list->wdata_size;

    word_sdbp = id->word_sdbp;

    if ((ret = word_sdbp->pget(word_sdbp, NULL, &skey, &key, &data, 0)) == 0) {
        /* printf("word data retrieved: %s.\n", (char *)((struct word_data *)data.data)->word); */
    } else {
        return EXIT_FAILURE;
    }
    wdata_list->wdata_key = *(uint64_t *)(key.data);
    wdata_list->wdata = data.data;
    wdata_list->wdata_size = data.size;
    return EXIT_SUCCESS;
}

int get_url_data(DbId *id, struct url_data_list *udata_list) {
    DB *url_dbp;
    DBT key, data;
    int ret;

    memset(&key, 0, sizeof(key));
    memset(&data, 0, sizeof(data));

    key.data = &(udata_list->udata_key);
    key.size = sizeof(udata_list->udata_key);

    url_dbp = id->url_dbp;
    if ((ret = url_dbp->get(url_dbp, NULL, &key, &data, 0)) == 0) {
        /* printf("url data retrieved: %s.\n", (char *)((struct url_data *)data.data)->url); */
    } else {
        return EXIT_FAILURE;
    }
    ret = add_udata_clone_to_list(udata_list, udata_list->udata_key,
                                  (struct url_data *) data.data, data.size);
    return ret;
}

int get_data(DbId *id, struct url_data_list *udata_list,
             struct word_data_list *wdata_list,
             struct pair_data_list *pdata_list) {
    int ret;
    struct pair_data_list *next;

    ret = get_word_data(id, wdata_list);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    ret = get_pair_data(id, wdata_list, pdata_list);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    for (; pdata_list != NULL; pdata_list = next) {
        next = pdata_list->next_pair_data_list;
        udata_list->udata_key = pdata_list->pdata->url_id;
        ret = get_url_data(id, udata_list);
        if (ret != EXIT_SUCCESS) {
            return EXIT_FAILURE;
        }
    }
    return EXIT_SUCCESS;
}

int get_pair(DbId *id, Word *word, WordList *url_list) {

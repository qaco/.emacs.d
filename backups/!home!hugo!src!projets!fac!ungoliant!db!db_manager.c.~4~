    struct url_data_list *next;
    Word* url = construct_word(0, NULL);
    ret = create_pair_data_list(&pdata_list);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }
    ret = create_url_data_list(&udata_list);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }
    ret = create_word_data_list(&wdata_list);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    ret = add_word_data_list(wdata_list, word);
    if (ret == EXIT_FAILURE) {
        return EXIT_FAILURE;
    }

    ret = get_data(id, udata_list, wdata_list, pdata_list);

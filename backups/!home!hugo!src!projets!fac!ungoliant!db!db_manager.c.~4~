int initialize_ids(DbId *id) {
    DB *pair_dbp, *url_dbp, *word_dbp;
    DBT key, data;
    DBC *dbc;
    int ret;

    // INIT PAIR ID
    pair_dbp = id->pair_dbp;

    memset(&key, 0, sizeof(key));
    memset(&data, 0, sizeof(data));

    ret = pair_dbp->cursor(pair_dbp, NULL, &dbc, 0);
    if (ret != 0) {
        ret = dbc->c_close(dbc);
        return EXIT_FAILURE;
    }

    ret = dbc->c_get(dbc, &key, &data, DB_LAST);
    if (ret == DB_NOTFOUND) {
        id->next_pair_index = 0;
    } else if (ret != 0) {
        ret = dbc->c_close(dbc);
        return EXIT_FAILURE;
    } else {
        id->next_pair_index = *(uint64_t *)(key.data) + 1;
    }

    /* printf("pair id: %lu\n", id->next_pair_index); */

    ret = dbc->c_close(dbc);
    if (ret != 0) {
        return EXIT_FAILURE;
    }

    // INIT URL ID
    url_dbp = id->url_dbp;

    memset(&key, 0, sizeof(key));
    memset(&data, 0, sizeof(data));

    ret = url_dbp->cursor(url_dbp, NULL, &dbc, 0);
    if (ret != 0) {
        ret = dbc->c_close(dbc);
        return EXIT_FAILURE;
    }

    ret = dbc->c_get(dbc, &key, &data, DB_LAST);
    if (ret == DB_NOTFOUND) {
        id->next_url_index = 0;
    } else if (ret != 0) {
        ret = dbc->c_close(dbc);
        return EXIT_FAILURE;
    } else {
        id->next_url_index = *(uint64_t *)(key.data) + 1;
    }

    /* printf("url id: %lu\n", id->next_url_index); */

    ret = dbc->c_close(dbc);
    if (ret != 0) {
        return EXIT_FAILURE;
    }

    // INIT WORD ID
    word_dbp = id->word_dbp;

    memset(&key, 0, sizeof(key));
    memset(&data, 0, sizeof(data));

    ret = word_dbp->cursor(word_dbp, NULL, &dbc, 0);
    if (ret != 0) {
        ret = dbc->c_close(dbc);
        return EXIT_FAILURE;
    }

    ret = dbc->c_get(dbc, &key, &data, DB_LAST);
    if (ret == DB_NOTFOUND) {
        id->next_word_index = 0;
    } else if (ret != 0) {
        ret = dbc->c_close(dbc);
        return EXIT_FAILURE;
    } else {
        id->next_word_index = *(uint64_t *)(key.data) + 1;
    }

    /* printf("word id: %lu\n", id->next_word_index); */

    ret = dbc->c_close(dbc);
    if (ret != 0) {
        return EXIT_FAILURE;
    }

    return EXIT_SUCCESS;
}

int urlw_callback(DB *dbp, const DBT *key, const DBT *data, DBT *skey) {
    struct url_data *udata;

    udata = data->data;

    skey->data = &(udata->url)[0];
    skey->size = data->size - (sizeof(struct url_data) - 1);

    return EXIT_SUCCESS;
}

int wordw_callback(DB *dbp, const DBT *key, const DBT *data, DBT *skey) {
    struct word_data *wdata;

    wdata = data->data;

    skey->data = wdata->word;
    skey->size = data->size - (sizeof(struct word_data) - 1);

    return EXIT_SUCCESS;
}

int pair_wordw_callback(DB *dbp, const DBT *key, const DBT *data, DBT *skey) {
    struct pair_data *pdata;

    pdata = data->data;

    skey->data = &(pdata->word_id);
    skey->size = sizeof(pdata->word_id);

    return EXIT_SUCCESS;
}

int pair_urlw_callback(DB *dbp, const DBT *key, const DBT *data, DBT *skey) {
    struct pair_data *pdata;

    pdata = data->data;

    skey->data = &(pdata->url_id);
    skey->size = sizeof(pdata->url_id);

    return EXIT_SUCCESS;
}

int opendb(DbId *id) {
    DB_ENV *dbenv;
    DB *pair_dbp, *pair_word_sdbp, *pair_url_sdbp, *url_dbp, *url_sdbp,
        *word_dbp, *word_sdbp;
    int ret, t_ret;

    //////////////////////////////////////////////////////////////
    // Create the directory for the database if it doesn't exit //
    //////////////////////////////////////////////////////////////

    struct stat st = {0};
    if (stat(DB_ENV_DIR, &st) == -1) {
        mkdir(DB_ENV_DIR, 0700);
    }

    ////////////////////////////////////////////
    // Create and open handle for environment //
    ////////////////////////////////////////////

    if ((ret = db_env_create(&dbenv, DB_ENV_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_env_create: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }

    /*
     * Place to configure database
     */

    if ((ret = dbenv->open(dbenv, DB_ENV_DIR, DB_ENV_OPEN_FLAGS, DB_ENV_OPEN_MODE)) != 0) {
        fprintf(stderr, "db_env_open: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }

    id->dbenv = dbenv;

    ///////////////////////////////////////////
    // Create and open handle for pair table //
    ///////////////////////////////////////////

    if ((ret = db_create(&pair_dbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create pair table: %s\n", db_strerror(ret));
        // TODO voir si je dois gerer la valeur de retour de closedb ou utiliser
        // une autre fonction
        closedb(id);
        return EXIT_FAILURE;
    }

    /*
     * Place to configure pair primary table
     */

    if ((ret = pair_dbp->open(pair_dbp, DB_OPEN_TXN,
                              DB_PAIR_PRIMARY_OPEN_NAME,
                              DB_OPEN_DATABASE,
                              DB_OPEN_DTYPE,
                              DB_OPEN_FLAGS,
                              DB_OPEN_FILE_RIGHTS)) != 0) {
        pair_dbp->err(pair_dbp, ret, "%s", DB_PAIR_PRIMARY_OPEN_NAME);
        if ((t_ret = pair_dbp->close(pair_dbp, 0)) != 0 && ret == 0) {
            ret = t_ret;
        }
        return EXIT_FAILURE;
    }

    id->pair_dbp = pair_dbp;

    /////////////////////////////////////////////////////////////////////
    // Create, open and associate handle for secondary pair word table //
    /////////////////////////////////////////////////////////////////////

    if ((ret = db_create(&pair_word_sdbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create url secondary table: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }
    //
    // Place to configure secondary pair table
    //
    ret = pair_word_sdbp->set_flags(pair_word_sdbp, DB_DUP);
    if (ret != 0) {
        return EXIT_FAILURE;
    }
    //
    // end configure
    //

    if ((ret = pair_word_sdbp->open(pair_word_sdbp, DB_OPEN_TXN,
                               DB_PAIR_SECONDARY_WORD_OPEN_NAME,
                               DB_OPEN_DATABASE,
                               DB_OPEN_DTYPE,
                               DB_OPEN_FLAGS,
                               DB_OPEN_FILE_RIGHTS)) != 0) {
        pair_word_sdbp->err(pair_word_sdbp, ret, "%s", DB_PAIR_SECONDARY_WORD_OPEN_NAME);
        if ((t_ret = pair_word_sdbp->close(pair_word_sdbp, 0)) != 0 && ret == EXIT_SUCCESS) {
            ret = t_ret;
        }
        return EXIT_FAILURE;
    }

    if((ret = pair_dbp->associate(pair_dbp, DB_ASSOCIATE_TXNID, pair_word_sdbp,
                                  pair_wordw_callback,
                                  DB_ASSOCIATE_FLAGS)) != 0) {
        pair_dbp->err(pair_dbp, ret, "%s", DB_PAIR_SECONDARY_WORD_OPEN_NAME);
        return EXIT_FAILURE;
    }

    id->pair_word_sdbp = pair_word_sdbp;

    ////////////////////////////////////////////////////////////////////
    // Create, open and associate handle for secondary pair url table //
    ////////////////////////////////////////////////////////////////////

    if ((ret = db_create(&pair_url_sdbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create url secondary table: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }
    //
    // Place to configure secondary pair table
    //
    ret = pair_url_sdbp->set_flags(pair_url_sdbp, DB_DUP);
    if (ret != 0) {
        return EXIT_FAILURE;
    }
    //
    // end configure
    //

    if ((ret = pair_url_sdbp->open(pair_url_sdbp, DB_OPEN_TXN,
                               DB_PAIR_SECONDARY_URL_OPEN_NAME,
                               DB_OPEN_DATABASE,
                               DB_OPEN_DTYPE,
                               DB_OPEN_FLAGS,
                               DB_OPEN_FILE_RIGHTS)) != 0) {
        pair_url_sdbp->err(pair_url_sdbp, ret, "%s", DB_PAIR_SECONDARY_URL_OPEN_NAME);
        if ((t_ret = pair_url_sdbp->close(pair_url_sdbp, 0)) != 0 && ret == EXIT_SUCCESS) {
            ret = t_ret;
        }
        return EXIT_FAILURE;
    }

    if((ret = pair_dbp->associate(pair_dbp, DB_ASSOCIATE_TXNID, pair_url_sdbp,
                                  pair_urlw_callback,
                                  DB_ASSOCIATE_FLAGS)) != 0) {
        pair_dbp->err(pair_dbp, ret, "%s", DB_PAIR_SECONDARY_URL_OPEN_NAME);
        return EXIT_FAILURE;
    }

    id->pair_url_sdbp = pair_url_sdbp;

    //////////////////////////////////////////////////
    // Create and open handle for primary url table //
    //////////////////////////////////////////////////

    if ((ret = db_create(&url_dbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create url primary table: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }

    /*
     * Place to configure url primary table
     */

    if ((ret = url_dbp->open(url_dbp, DB_OPEN_TXN,
                             DB_URL_PRIMARY_OPEN_NAME,
                             DB_OPEN_DATABASE,
                             DB_OPEN_DTYPE,
                             DB_OPEN_FLAGS,
                             DB_OPEN_FILE_RIGHTS)) != 0) {
        url_dbp->err(url_dbp, ret, "%s", DB_URL_PRIMARY_OPEN_NAME);
        if ((t_ret = url_dbp->close(url_dbp, 0)) != 0 && ret == 0)
            ret = t_ret;
        return EXIT_FAILURE;
    }

    id->url_dbp = url_dbp;

    ///////////////////////////////////////////////////////////////
    // Create, open and associate handle for secondary url table //
    ///////////////////////////////////////////////////////////////

    if ((ret = db_create(&url_sdbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create url secondary table: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }

    /*
     * Place to configure url secondary table
     */

    if ((ret = url_sdbp->open(url_sdbp, DB_OPEN_TXN,
                              DB_URL_SECONDARY_OPEN_NAME,
                              DB_OPEN_DATABASE,
                              DB_OPEN_DTYPE,
                              DB_OPEN_FLAGS,
                              DB_OPEN_FILE_RIGHTS)) != 0) {
        url_sdbp->err(url_sdbp, ret, "%s", DB_URL_SECONDARY_OPEN_NAME);
        if ((t_ret = url_sdbp->close(url_sdbp, 0)) != 0 && ret == EXIT_SUCCESS) {
            ret = t_ret;
        }
        return EXIT_FAILURE;
    }

    if((ret = url_dbp->associate(url_dbp, DB_ASSOCIATE_TXNID, url_sdbp,
                                 urlw_callback, DB_ASSOCIATE_FLAGS)) != 0) {
        url_dbp->err(url_dbp, ret, "%s", DB_URL_SECONDARY_OPEN_NAME);
        return EXIT_FAILURE;
    }

    id->url_sdbp = url_sdbp;

    ///////////////////////////////////////////////////
    // Create and open handle for primary word table //
    ///////////////////////////////////////////////////

    if ((ret = db_create(&word_dbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create url primary table: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }

    /*
     * Place to configure word primary table
     */

    if ((ret = word_dbp->open(word_dbp, DB_OPEN_TXN,
                              DB_WORD_PRIMARY_OPEN_NAME,
                              DB_OPEN_DATABASE,
                              DB_OPEN_DTYPE,
                              DB_OPEN_FLAGS,
                              DB_OPEN_FILE_RIGHTS)) != 0) {
        word_dbp->err(word_dbp, ret, "%s", DB_WORD_PRIMARY_OPEN_NAME);
        if ((t_ret = word_dbp->close(word_dbp, 0)) != 0 && ret == 0)
            ret = t_ret;
        return EXIT_FAILURE;
    }

    id->word_dbp = word_dbp;

    /////////////////////////////////////////////////////
    // Create and open handle for secondary word table //
    /////////////////////////////////////////////////////

    if ((ret = db_create(&word_sdbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create url secondary table: %s\n", db_strerror(ret));
        return EXIT_FAILURE;
    }

    /*
     * Place to configure word secondary table
     */

    if ((ret = word_sdbp->open(word_sdbp, DB_OPEN_TXN,
                               DB_WORD_SECONDARY_OPEN_NAME,
                               DB_OPEN_DATABASE,
                               DB_OPEN_DTYPE,
                               DB_OPEN_FLAGS,
                               DB_OPEN_FILE_RIGHTS)) != 0) {
        word_sdbp->err(word_sdbp, ret, "%s", DB_WORD_SECONDARY_OPEN_NAME);
        if ((t_ret = word_sdbp->close(word_sdbp, 0)) != 0 && ret == EXIT_SUCCESS) {
            ret = t_ret;
        }
        return EXIT_FAILURE;
    }

    if((ret = word_dbp->associate(word_dbp, DB_ASSOCIATE_TXNID, word_sdbp,
                                 wordw_callback, DB_ASSOCIATE_FLAGS)) != 0) {
        word_dbp->err(word_dbp, ret, "%s", DB_WORD_SECONDARY_OPEN_NAME);
        return EXIT_FAILURE;
    }

    id->word_sdbp = word_sdbp;

    initialize_ids(id);
    // TODO initialize word_id and url_id at 0 each or check database

    return EXIT_SUCCESS;
}


int closedb(DbId *id)
{
    int ret;

    if ((ret = id->pair_url_sdbp->close(id->pair_url_sdbp, 0)) != 0) {
        perror("ERROR closing pair_url_sdbp");
        return EXIT_FAILURE;
    }
    if ((ret = id->pair_word_sdbp->close(id->pair_word_sdbp, 0)) != 0)
        return EXIT_FAILURE;
    if ((ret = id->pair_dbp->close(id->pair_dbp, 0)) != 0)
        return EXIT_FAILURE;
    if ((ret = id->url_sdbp->close(id->url_sdbp, 0)) != 0)
        return EXIT_FAILURE;
    if ((ret = id->url_dbp->close(id->url_dbp, 0)) != 0)
        return EXIT_FAILURE;
    if ((ret = id->word_sdbp->close(id->word_sdbp, 0)) != 0)
        return EXIT_FAILURE;
    if ((ret = id->word_dbp->close(id->word_dbp, 0)) != 0)
        return EXIT_FAILURE;
    if ((ret = (id->dbenv)->close(id->dbenv, 0)) != 0)
        return EXIT_FAILURE;
    return ret;
}

int word_url_pair_exists(DbId *id, struct pair_data *pdata) {
    DB *pair_url_sdbp;
    DBT pkey, skey, data;
    DBC *sdbc;
    int ret;

    pair_url_sdbp = id->pair_url_sdbp;

    memset(&pkey, 0, sizeof(pkey));
    memset(&skey, 0, sizeof(skey));
    memset(&data, 0, sizeof(data));

    skey.data = &(pdata->url_id);
    skey.size = sizeof(pdata->url_id);

    pair_url_sdbp->cursor(pair_url_sdbp, NULL, &sdbc, 0);

    for (ret = sdbc->c_pget(sdbc, &skey, &pkey, &data, DB_SET);
         ret == 0;
         ret = sdbc->c_pget(sdbc, &skey, &pkey, &data, DB_NEXT_DUP)) {
        if (((struct pair_data *)data.data)->word_id == pdata->word_id) {
            ret = sdbc->c_close(sdbc);
            if (ret != EXIT_SUCCESS) {
                return EXIT_FAILURE;
            }
            return PAIR_EXISTS;
        }
    }

    ret = sdbc->c_close(sdbc);
    if (ret != 0) {
        return EXIT_FAILURE;
    }

    return NOT_PAIR_EXISTS;
}


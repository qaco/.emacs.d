package service ;

import java.util.List ;
import java.util.LinkedList ;
import java.net.Socket ;
import java.net.InetAddress ;
import java.net.DatagramSocket ;
import java.net.DatagramPacket ;
import java.io.IOException ;
import protocol.flow.Flow ;
import protocol.flow.NoFlow ;
import protocol.knock.Knock ;
import exception.UnknownResultException ;

public class User extends Contact {

    public static boolean ListContainsUser(List<User> u, String n) {
        for (User guy : u)
            if (guy.getId().equals(n))
                return true ;
        return false ;
    }
    
    public static User getUserFromList(String n, List<User> u) {
        for (User guy : u)
            if (guy.getId().equals(n))
                return guy ;
        throw new IllegalArgumentException() ;
    }
    
    private Socket socket ;
    private int udp ;
    private String id ;
    private int password ;
    private List<User> friends ;
    private List<Flow> flows ;

    public User(Socket so, String myid, int myudp, int pass) {
        super(so) ;
        this.udp = myudp  ;
        this.id = myid ;
        this.password = pass ;
        this.friends = new LinkedList<User>() ;
        this.flows = new LinkedList<Flow>() ;
    }

    // GETTERS

    public String getId() {
        return this.id ;
    }

    public int getPassword() {
        return this.password ;
    }

    public List<User> getFriends() {
        return this.friends ;
    }

    public User getFriend(String name)  {
        if (User.ListContainsUser(this.friends, name))
            return User.getUserFromList(name, this.friends) ;
        else
            throw new IllegalArgumentException() ;
    }

    public int howManyFriends() {
        return this.friends.size() ;
    }

    public boolean isAFriend(String name) {
        return User.ListContainsUser(this.friends, name) ;
    }

    public int howManyFlows() {
        return this.flows.size() ;
    }

    // SETTERS
    
    public boolean addFriend(User fri) {
        if (this.friends.contains(fri))
            return false ;
        else {
            this.friends.add(fri) ;
            return true ;
        }
    }

    public void removeFriend(String fri) {
        for (User guy : this.friends) {
            if (guy.getId().equals(fri)) {
                this.friends.remove(guy) ;
                break ;
            }
        }
    }

    public void pushFlow(Flow f) {
        this.flows.add(f) ;
    }

    public void pushFlows(List<Flow> f) {
        this.flows.addAll(f) ;
    }

    // COMMUNICATION

    // LIFO
    public Flow popFlow() {
        Flow res ;
        if (this.flows.isEmpty())
            res = new NoFlow() ;
        else {
            res = this.flows.get(this.flows.size() - 1) ;
            this.flows.remove(this.flows.size() - 1) ;
        }
        return res ;
    }

    public void sendTCP(Flow fl) throws IOException {
        this.sendString(fl.toString()) ;
    }

    public void sendUDP(Knock k) throws IOException {
        DatagramSocket dgs = new DatagramSocket() ;
        InetAddress a = this.socket.getInetAddress() ;
        byte data[] = k.getArray() ;
        DatagramPacket dgp = new DatagramPacket(data, data.length,
                                                a, this.udp) ;
        dgs.send(dgp) ;
    }
    
    // OVERRIDE
    
    public boolean equals(Object obj) {
        if (obj instanceof User)
            return this.getId().equals(((User)obj).getId()) ;
        else
            return false ;
    }
}
        
    
    
    


    

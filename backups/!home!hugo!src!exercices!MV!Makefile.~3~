CAMLC=ocamlc
EXEC=test
SRC=mv.ml myrtheAST.ml myrthe.ml test.ml
OBJ=$(SRC:.ml=.cmo)

all: $(EXEC)

$(EXEC) : $(OBJ)
	$(CAMLC) -o $@ $^

test.cmo: test.ml mv.cmo
	$(CAMLC) -c $<

myrtheAST.cmo: myrtheAST.ml
	$(CAMLC) -c $<

mv.cmo: mv.ml
$(CAMLC) -c $<

mv.cmo: mv.ml
	$(CAMLC) -c $<

clean :
	rm -rf *.cmx
	rm -rf *.cmi
	rm -rf *.cmo
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

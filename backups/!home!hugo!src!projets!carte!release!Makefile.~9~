OC=ocamlc
LINKS=graphics.cma
EXEC=coloriage
SRC=sat_solver.ml Builder.ml Computer.ml examples.ml
OBJ=$(SRC:.ml=.cmo)

all: $(EXEC)

$(EXEC) : $(OBJ)
	$(OC) -o $@ $(LINKS) $^

Builder.cmo: Builder.ml Builder.cmi
	$(OC) -c $<

sat_solver.cmo: sat_solver.ml Builder.cmi sat_solver.cmi
	$(OC) -c $<

examples.cmo: examples.ml
	$(OC) -c $<

Computer.cmo: Computer.ml Computer.cmi Builder.cmi sat_solver.cmi
	$(OC) -c $<

%.cmi: %.mli
	$(OC) -o $@ -c $<

clean :
	rm -rf *.cmo *.cmi

mrproper : clean
	rm -rf $(EXEC)

void main_loop(char* tube_server)
{
  int signal, server, client ;
  user avatar ;
  /* pthread_t receiver ; */
  
 init:
  /* Tant que le pseudo existe, l'utilisateur doit en saisir un nouveau,
     puis on crée le tube de l'utilisateur.*/
  avatar.pseudo = get_input("Pseudo>") ;
  while (access(avatar.pseudo, F_OK ) == 0 )
    {
      free(avatar.pseudo) ;
      avatar.pseudo = get_input("Pseudo>") ;
    }
  mkfifo(avatar.pseudo, S_IRWXU | S_IRWXG | S_IRWXO) ;
  
  /* On récupère les tubes du serveur et du client, on les connecte. */
  server = open(tube_server, O_WRONLY) ;
  if (server == -1)
    fprintf(stderr,"Échec du branchement: %s\n", strerror(errno)) ;
  client = open(avatar.pseudo, O_RDONLY) ;
  avatar.id = connexion(server,client, avatar.pseudo, avatar.pseudo) ;
  close(client) ;

  /* pthread_create(&receiver, NULL, thread_lecture, &avatar) ; */
 next:
  client = open(avatar.pseudo, O_RDONLY) ;
  signal = receive_msg(avatar.pseudo, client) ;
  close(client) ;
  switch(signal)
    {
    case -1: goto end ; break ;  // commande d'extinction reçue
    case 0: goto init ; break ;  // commande de déconnexion reçue
    default: goto next ; break ; // rien de particulier : on continue
    }
 end:
  printf("Fin du programme.\n") ;
}

int main(int argc, char* argv[])
{
  main_loop("patron") ;
  return 1 ;
}

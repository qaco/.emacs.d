package protocol.command ;

import java.io.IOException ;
import service.User ;
import protocol.feedback.Goodbye ;
import java.util.List ;

public class Deconnection implements Command {

    // pas besoin de allusers
    public void exec(User myuser, List<User> allusers) throws IOException {
        myuser.sendTCP(new Goodbye()) ;
        myuser.disconnect() ;
    }
    
    public String toString() {
        return CommandVals.DECONNECTION + CommandVals.EOF ;
    }
}
        

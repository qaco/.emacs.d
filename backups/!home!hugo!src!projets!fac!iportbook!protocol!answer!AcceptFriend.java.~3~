package protocol.command ;

import protocol.feedback.AckFriend ;
import protocol.knock.OkFriendKnock ;
import service.User ;
import java.util.List ;
import java.io.IOException ;

public class AcceptFriend implements Answer {
    
    public void exec(User want, List<User> rep) throws IOException {
        want.addFriend(rep) ;
        rep.addFriend(want) ;
        rep.sendTCP(new AckFriend()) ;
        want.sendUPD(new OkFriendKnock(want.howManyFlows())) ;
    }

    public String toString() {
        return AnswerVals.OK_FRIEND + AnswerVals.EOF ;
    }
}

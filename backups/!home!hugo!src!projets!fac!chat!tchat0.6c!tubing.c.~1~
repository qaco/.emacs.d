#define INVIT "> "
#define CMD_QUIT "quit"
#define CMD_PRIVATE "private to"
#define CMD_SHUT "shut"
#define CMD_DBG "debg"
#define CMD_LIST "list"
#define CMD_FILE "send to"
#define NOCODE -1

int afterok ;
pthread_cond_t condition = PTHREAD_COND_INITIALIZER;
pthread_mutex_t mutex = PTHREAD_MUTEX_INITIALIZER;

/**
 * \fn int take_msg(int fd_read, char **saisie)
 * \brief Récupère un message dans un tube.
 * \param fd_read Le descripteur du tube où on veut récupérer un message.
 * \param saisie Le pointeur sur la chaîne où on va stocker le message.
 * \return La taille du message récupéré.
 */
int take_msg(int fd_read, char **saisie)
{
  int total_size ;
  char* suffix ;
  char* preffix = malloc(sizeof(char)*(NB_SIZE + 1)) ;

  /* Réception du préfixe numérique. */
  read(fd_read, preffix, NB_SIZE) ;
  *(preffix + NB_SIZE) = '\0' ;
  total_size = atoi(preffix) ;

  /* Réception du reste de la chaîne. */
  suffix = malloc(sizeof(char)*(total_size - NB_SIZE + 1)) ;
  read(fd_read, suffix, total_size - NB_SIZE) ;
  *(suffix + total_size - NB_SIZE ) = '\0' ;

  /* Concaténation des deux parties. */
  *saisie = malloc(sizeof(char)*(total_size + 1)) ;
  strcpy(*saisie, preffix) ;
  strcat(*saisie, suffix) ;

  free(preffix) ;
  free(suffix) ;
  return total_size ;
}

/**
 * \fn int take_msg(int fd_read, char **saisie)
 * \brief Récupère un message et appelle la fonction correspondante.
 * \param mydata Les données du client nécessaires à la réception de messages.
 * \return >1 pour continuer à tchatter, 0 pour se déconnecter, -1 pour éteindre
 * le serveur.
 */
int receive_msg (data mydata)
{
  char *saisie, *disp ;
  int res = 1 ;
  int fd_read = open(mydata.tube_client, O_RDONLY) ;

  take_msg(fd_read, &saisie) ;

  if (memcmp(saisie + NB_SIZE, T_OK, strlen(T_OK)) == 0)
    {
      ping(mydata.inbox) ;
      pthread_mutex_lock (&mutex); 
      pthread_cond_signal (&condition);
      afterok = atoi(saisie + NB_SIZE + TYPE_SIZE) ;
      pthread_mutex_unlock (&mutex);
    }
  else if (strcmp(saisie + NB_SIZE, T_NO) == 0)
    {
      fail(mydata.inbox) ;
      pthread_mutex_lock (&mutex); 
      pthread_cond_signal (&condition);
      afterok = NOCODE ;
      pthread_mutex_unlock (&mutex);
    }
  else if (memcmp(saisie + NB_SIZE, T_BYE, strlen(T_BYE)) == 0)
    {
      logout(mydata.pseudo, mydata.inbox) ;
      res = 0 ;
    }
  else if (memcmp(saisie + NB_SIZE, T_LIST, strlen(T_LIST)) == 0)
    receive_list(saisie, fd_read, mydata.inbox) ;
  else if (memcmp(saisie + NB_SIZE, T_FILE, strlen(T_FILE)) == 0)
    receive_file(saisie, fd_read, mydata.inbox) ;
  else if (memcmp(saisie + NB_SIZE, T_PUB, strlen(T_PUB)) == 0)
    receive_txt(mydata.pseudo, saisie, 1, mydata.inbox) ;
  else if (memcmp(saisie + NB_SIZE, T_PRIV, strlen(T_PRIV)) == 0)
    receive_txt(mydata.pseudo, saisie, 0, mydata.inbox) ;
  else if (memcmp(saisie + NB_SIZE, T_SHUT, strlen(T_SHUT)) == 0)
    {
      shut(saisie, mydata.inbox) ;
      res = -1 ;
    }

  free(saisie) ;
  close(fd_read) ;
  
  return res ;
}

static void send_private(data mydata, char* friend_pseudo, char* name)
{
  int fd_write ;
  char* msg = build_msg(1, NB_SIZE, T_PRIV, mydata.id, friend_pseudo, name) ;
  free(friend_pseudo) ;
  fd_write = open(mydata.tube_server, O_WRONLY) ;
  write(fd_write, msg, strlen(msg)) ;
  close(fd_write) ;
  pthread_mutex_lock(&mutex); 
  pthread_cond_wait (&condition, &mutex); 
  pthread_mutex_unlock(&mutex);
  free(msg) ;
}

static void send_file(data mydata, char* friend_pseudo, char* text)
{
  long size_file, afaire ;
  FILE* myfile = fopen(text, "r") ;
  int ret, fd_write ;
  char* part = malloc(sizeof(char)*(PART_SIZE + 1)) ;
  char* msg ;

  /* Construction et écriture du premier message. */
  fseek(myfile, 0, SEEK_END) ;
  size_file = ftell(myfile) ;
  rewind(myfile) ;      
  msg = build_msg(1, NB_SIZE, T_FILE, 0, mydata.id, friend_pseudo,
                  size_file, text) ;
  fd_write = open(mydata.tube_server, O_WRONLY) ;
  write(fd_write, msg, strlen(msg)) ;
  close(fd_write) ;
  free(msg) ;

  /* On attend que le thread de réception ait reçu l'id de transfert. */
  pthread_mutex_lock(&mutex); 
  pthread_cond_wait(&condition, &mutex);
  pthread_mutex_unlock(&mutex);

  if (afterok != NOCODE)
    {
      /* Calcul et envoi des tronçons de fichier. */
      afaire = size_file/PART_SIZE ;
      if (size_file % PART_SIZE != 0)
        afaire++ ;
      fd_write = open(mydata.tube_server, O_WRONLY) ;
      for (int i = 1 ; i <= afaire ; i++)
        {
          ret = fread(part, sizeof(char), PART_SIZE, myfile) ;
          *(part + ret) = '\0' ;
          msg = build_msg(1, NB_SIZE, T_FILE, i, afterok, part) ;
          write(fd_write, msg, strlen(msg)) ;
          free(msg) ;
        }
      close(fd_write) ;
    }
}

/**
 * \fn void send_msg(data mydata)
 * \brief Saisit, construit et envoie un message dans le tube du serveur.
 * \param mydata Les données du client nécessaires à l'envoi de messages.
 */
void send_msg(data mydata)
{
  char* input = get_input(INVIT, mydata.outbox) ;
  char* msg ;
  int fd_write ;
  int is_private =
    strlen(input) > strlen(CMD_PRIVATE) &&
    memcmp(input, CMD_PRIVATE, strlen(CMD_PRIVATE)) == 0 ;
  int is_file =
    strlen(input) > strlen(CMD_FILE) &&
    memcmp(input, CMD_FILE, strlen(CMD_FILE)) == 0 ;

  if (is_private || is_file)
    {
      int start, end ;
      char *location, *friend_pseudo, *text ;

      if (is_private)
        start = strlen(CMD_PRIVATE) + 1 ;
      else
        start = strlen(CMD_FILE) + 1 ;
      location = strchr(input + start, ' ') ;
      end = location - input ;
      friend_pseudo = malloc(sizeof(char)*(end-start)) ;
      text = input + end + 1 ;
      memcpy(friend_pseudo, input + start, end - start) ;
      *(friend_pseudo + end - start) = '\0' ;

      if (is_private)
        send_private(mydata, friend_pseudo, text) ;
      else
        send_file(mydata, friend_pseudo, text) ;
    }
  else
    {
      /* quit */
      if(strcmp(input, CMD_QUIT) == 0)
        msg = build_msg(1, NB_SIZE, T_BYE, mydata.id) ;
      /* extinction */
      else if(strcmp(input, CMD_SHUT)==0)
        msg = build_msg(1, NB_SIZE, T_SHUT, mydata.id) ;
      /* debug */
      else if(strcmp(input, CMD_DBG)==0)
        msg = build_msg(1, NB_SIZE, T_DBG) ;
      /* list */
      else if(strcmp(input, CMD_LIST)==0)
        msg = build_msg(1, NB_SIZE, T_LIST, mydata.id) ;
      /* message public */
      else
        msg = build_msg(1, NB_SIZE, T_PUB, mydata.id, input) ;
  
      fd_write = open(mydata.tube_server, O_WRONLY) ;
      write(fd_write, msg, strlen(msg)) ;
      close(fd_write) ;
      free(msg) ;
    }

  free(input) ;
}

/**
 * \fn void connexion(data* mydata)
 * \brief Connecte le client du serveur et initialise les données du client.
 * \param mydata Le pointeur sur les données à initialiser.
 */
void connexion(data* mydata)
{
  char *request, *answer ;
  int fd_write, fd_read ;
  
  do {
    /* Saisie et envoi des informations de connexion */
    int ret ;
    do {
      get_login(&mydata->pseudo, &mydata->tube_client, mydata->outbox) ;
      ret = mkfifo(mydata->tube_client, S_IRWXU | S_IRWXG | S_IRWXO) ;
      if (ret == -1)
        fail(mydata->inbox) ;
    } while(ret == -1) ;
    request = build_msg(1, NB_SIZE, T_IN, mydata->pseudo, mydata->tube_client) ;
    fd_write = open(mydata->tube_server, O_WRONLY) ;
    write(fd_write, request, strlen(request)) ;
    free(request) ;
    close(fd_write) ;

    /* Réception et traitement de l'id. */
    fd_read = open(mydata->tube_client, O_RDONLY) ;
    take_msg(fd_read, &answer) ;
    close(fd_read) ;
    if (memcmp(answer + NB_SIZE, T_OK, strlen(T_OK)) == 0)
      {
        mydata->id = atoi(answer + NB_SIZE + TYPE_SIZE) ;
        free(answer) ;
      }
  } while(memcmp(answer + NB_SIZE, T_NO, strlen(T_NO)) == 0) ;
}

/**
 * \fn void deconnexion(data* mydata)
 * \brief Libère les ressources allouées aux données du client.
 * \param mydata Le pointeur sur les données à libérer.
 */
void deconnexion(data* mydata)
{
  unlink(mydata->tube_client) ;
  free(mydata->pseudo) ;
  free(mydata->tube_client) ;
}

#include <math.h>
#include <stdlib.h>

int is_empty(FILE* cobaye) {
  int res ;
  res = (fgetc(cobaye) == EOF) ;
  fseek(cobaye, -1, SEEK_CUR) ;
  return res ;
}

int characters_in_int(int num) { //
  return (int)((ceil(log10(num))+1)*sizeof(char)) ;
}

char* int_to_string(int num) { //
  int size = characters_in_int(num) ;
  char *str = malloc(size) ;
  sprintf(str, "%d", num);
  return str ;
}

int how_many_lines(FILE* cobaye) { //
  char tmp ;
  int bkp = ftell(cobaye) ;
  int c = 0 ;
  rewind(cobaye) ;
  if (!is_empty(cobaye)) {
    c++ ;
    while (tmp != EOF) {
      tmp = fgetc(cobaye) ;
      if (tmp == '\n')
	c++ ;
    }
    fseek(cobaye, bkp, SEEK_SET) ;
  }
  return c ;
}

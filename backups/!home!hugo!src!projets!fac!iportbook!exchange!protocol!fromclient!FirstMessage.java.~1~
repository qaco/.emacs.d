package com.protocol.fromclient
public class FirstMessage implements Protocol {

    private String id ;
    private int num ;

    public FirstMessage (String myid, String mynum) {
        this.id = myid ;
        this.num = Integer.parseInt(mynum) ;
    }

    public FirstMessage (String myid, int mynum) {
        this.id = myid ;
        this.num = mynum ;
    }

    public String toString() {
        String mynum = String.valueOf(this.num) ;
        return "MESS? " + this.id + " " + mynum + "+++" ;
    }
}

#! /usr/bin/env python3

import Control, View, Slogan, Shutter
from gi.repository import Gtk

SHUT_COL = (0,0,0)
SHUT_ALPHA = 80
TEXT_COL = (255, 255 , 255)
FONT_PATH = "/usr/share/fonts/truetype"

HEIGHT = 600
PARAM_WIDTH = 300

def main():
    fonts = Control.FontsInfo(FONT_PATH)
    init = Control.InitState(Shutter.BOTTOM_SHUTTER,
                             SHUT_COL, SHUT_ALPHA, False,
                             Slogan.NAIVE_SLOGAN, TEXT_COL)
    # dépendance à supprimer : window devrait être le seul à utiliser init,
    # apres quoi motherboard en consulte les valeurs
    control = Control.Motherboard(init, fonts)
    window = View.Console(HEIGHT, PARAM_WIDTH)
    window.init_values(init)
    window.add_controler(control)
    window.show_all()
    Gtk.main()

main()

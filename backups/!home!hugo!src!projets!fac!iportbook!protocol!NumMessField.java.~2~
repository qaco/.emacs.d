package protocol ;

import exception.* ;

public class NumMessField extends NumStringField {

    public NumMessField(byte[] myport) throws UnknownResultException {
        super(myport) ;
    }

    public NumMessField(int myport) {
        super(myport, ProtocolVals.NUMMESS_SIZE) ;
    }

    protected void checkRules() throws UnknownResultException {
        String tmp = this.toString() ;
        try {
            int val = this.getInt() ;
            if (val < 0)
                throw new RuleBrokenException("NumMessField", tmp + " < 0");
        } catch (NumberFormatException e) {
            throw new WrongTypeException("NumMessField", tmp, "int") ;
        }
    }
}
        

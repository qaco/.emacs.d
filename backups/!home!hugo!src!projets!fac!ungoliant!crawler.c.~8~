static size_t
WriteMemoryCallback(void *contents, size_t size, size_t nmemb, void *userp)
{
  size_t realsize = size * nmemb;
  Word *mem = (Word *)userp;
  add_chars_word(mem, contents, realsize) ;
 
  return realsize;
}

static int
url_to_ram(Word tocrawl, Word* text)
{
  char* myurl = get_cstring_word(tocrawl) ;
  Word chunk = construct_empty_word() ;
  CURL *curl_handle;
  CURLcode res;
  int ret = 0 ;

  curl_handle = curl_easy_init();
  curl_easy_setopt(curl_handle, CURLOPT_URL, myurl);
  curl_easy_setopt(curl_handle, CURLOPT_WRITEFUNCTION, WriteMemoryCallback);
  curl_easy_setopt(curl_handle, CURLOPT_WRITEDATA, (void *)&chunk);
  curl_easy_setopt(curl_handle, CURLOPT_USERAGENT, "libcurl-agent/1.0");
  res = curl_easy_perform(curl_handle);
  if(res != CURLE_OK) {
    fprintf(stderr, "curl_easy_perform() failed %d: %s\n",
            (int) res, curl_easy_strerror(res));
    *text = construct_empty_word() ;
    ret-- ;
  }
  else
    *text = chunk ;
  curl_easy_cleanup(curl_handle);

  return ret ;
}

int crawl (const char* first_url)
{
  Word smooth_url = construct_word(first_url, strlen(first_url)) ;
  WordList mylist = build_wordlist(smooth_url) ;

  curl_global_init(CURL_GLOBAL_ALL);

  while (!is_empty_wordlist(mylist)) {
    WordList text_parser = build_empty_wordlist() ;
    WordList url_parser = build_empty_wordlist() ;
    Word tmp_url = pop_word_wordlist(&mylist) ;
    Word text ;

    url_to_ram(tmp_url, &text) ;
    printf("%zu bytes retrieved\n", get_size_word(text)) ;
    printf("\n") ;
    print_word(text, stdout) ;
    parse(text, tmp_url, &text_parser, &url_parser) ;

    do {
      Word tmp_word ;
      tmp_word = pop_word_wordlist(&text_parser) ;
      /* TODO : Ici màj de l'index */
      destruct_word(&tmp_word) ;
    } while (!is_empty_wordlist(text_parser)) ;
    destruct_word(&tmp_url) ;

    addall_wordlist(&mylist, &url_parser) ;
    destruct_wordlist(&url_parser) ;
  }

  curl_global_cleanup();

  return 0 ;
}

JC = javac

JUNIT_PATH = /usr/share/java/junit4.jar
PROTOCOL_PATH = protocol/
FS_PATH = protocol/fromserver/
FC_PATH = protocol/fromclient/
CODE_PATHS = $(PROTOCOL_PATH):$(FS_PATH):$(FC_PATH)
TESTS_PATH = tests/
PROTOCOL_SRC = $(addprefix $(PROTOCOL_PATH),$(wildcard *.java))
FS_SRC = $(addprefix $(FS_PATH),$(wildcard *.java))
FC_SRC = $(addprefix $(FC_PATH),$(wildcard *.java))
TESTS_SRC = $(addprefix $(TESTS_PATH),ProtocolFactoryTest.java TestRunner.java)

TestRunner.class: $(PROTOCOL_SRC) $(FS_SRC) $(FC_SRC) $(TESTS_SRC)
	# $(JC) -cp $(JUNIT_PATH):$(CODE_PATHS) $^
	$(JC) -cp $(JUNIT_PATH):$(shell pwd) $^

clean:
	$(RM) $(PROTOCOL_PATH)*.class
	$(RM) $(FS_PATH)*.class
	$(RM) $(FC_PATH)*.class
	$(RM) $(TESTS_PATH)*.class

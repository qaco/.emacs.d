open MyrtheAST
open Mv

let repr : value -> int = function
  | Bool true -> 1
  | Bool false -> 0
  | Int i -> i

let rec compil = function
  | Const v ->
     [Consti (repr v)]
  | Unop (Succ, e) ->
     (compil e) @ [Push; Consti 1; Addi]
  | Binop (Plus, e1, e2) ->
     (compil e1) @ [Push] @ (compil e2) @ [Addi]
  | Binop (Times, e1, e2) ->
     (compil e1) @ [Push] @ (compil e2) @ [Multi]
  | Binop (Eq, e1, e2) ->
     (compil e1) @ [Push] @ (compil e2) @ [Eqi]
  | Binop (Leq, e1, e2) ->
     (compil e1) @ [Push] @ (compil e2) @ [Leqi]
  | If (e1, e2, e3) ->
     let l1 = compil e1 in
     let l2 = compil e2 in
     let l3 = compil e3 in
     l1 @ [BranchIf (List.length l3+1)] @
     l3 @ [Branch (List.length l2+1)] @
     l2
  | Caseof(e1, l, e2) ->
     (* Génère le code qui teste (et exécute) un label. *)
     let gen_test (couple : expression*expression) : instr list =
       let instr_cond = compil (Binop(Eq, e1, fst couple)) in
       let instr_code = compil (snd couple) in
       (* Si l'accumulateur est à 1, on a déjà un résultat. *)
       [BranchIf (List.length instr_cond + 1)] @
         (* Si le label ne correspond pas au switch, on n'exécute *)
          (* pas le code.*)
         instr_cond @ [BranchIf 1] @
           [Branch (List.length instr_code + 2)] @
             (* On exécute le code, on empile le résultat et on met *)
             (* l'accumulateur à 1 pour indiquer qu'on a un résultat. *)
             instr_code @ [Push; Consti 1] in
     let tests = List.flatten (List.map gen_test l) in
     let instr_else = compil e2 in
     (* On écrit la liste de tests en mettant préalablement l'accumulateur *)
     (* à 0. *)
     [Consti 0] @ tests @
       (* Si on n'a pas de résultat, on exécute le else et on empile son *)
        (* résultat. *)
       [BranchIf (List.length instr_else + 1)] @ instr_else @ [Push] @
         (* On dépile le résultat de la série de tests. *)
         [Pop]
  | _ -> failwith "this is your job, student !"



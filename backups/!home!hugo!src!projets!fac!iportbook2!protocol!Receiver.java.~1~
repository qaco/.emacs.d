package protocol ;

import exception.* ;
import java.util.Arrays ;
import exception.UnknownResultException ;
import java.nio.charset.Charset ;
import main.MainVals ;

public class Receiver {
    protected byte[] raw ;
    protected byte sep = MainVals.BSEP ;
    protected byte[] suffix = MainVals.BEOF ;

    public Receiver() { super() ; }
    
    public Receiver(byte[] data) {
        super() ;
        this.raw = data ;
    }

    public byte[] getData() {
        return this.raw ;
    }

    public byte[] nthArgToEnd(int num) throws UnknownResultException {
        int counter = 0 ;
        for (int i = 0 ; i < this.raw.length ; i++) {
            if (this.raw[i] == this.sep)
                counter++ ;
            if (counter == num)
                return Arrays.copyOfRange(this.raw, i+1, raw.length) ;
        }
        throw new TooFewArgsException("mess",
                                      String.valueOf(raw.length)) ;
    }
            
    
    public String extractCode() {
        byte[][] cmd = this.splitInput() ;
        return new String(cmd[0], Charset.forName("US-ASCII")) ;
    }
    
    public byte[][] splitInput() {
        int numsp = 0 ;
        int spi[] ;
        int spcount = 0 ;
        byte[][] res ;

        // setup
        for (int i = 0 ; i < this.raw.length ; i++)
            if (this.raw[i] == this.sep)
                numsp++ ;
        spi = new int[numsp] ;
        res = new byte[numsp - 1][] ;
        for (int i = 0 ; i < this.raw.length ; i++)
            if (this.raw[i] == this.sep)
                spi[spcount++] = i ;

        for (int i = 0 ; i < spi.length - 1 ; i++) {
            int start ;
            int end ;
            int mysize ;
            if (i == 0) start = 0 ;
            else start = spi[i-1] + 1 ;
            if (i == spi.length - 1) end = spi.length ;
            else end = spi[i] ;
            mysize = end - start ;
            res[i] = new byte[mysize] ;
            for (int j = 0 ; j < mysize ; j++)
                res[i][j] = this.raw[start+j] ;
        }
        return res ;
    }
}

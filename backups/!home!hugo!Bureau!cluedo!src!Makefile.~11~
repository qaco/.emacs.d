CC=gcc
CFLAGS=-std=c99 -Wall
GTKLINK=`pkg-config --cflags --libs gtk+-2.0`
EXEC=cluedo
SRC=control.c gen.c cluedo.c
OBJ=$(SRC:.c=.o)

all : $(EXEC)

$(EXEC) : $(OBJ)
	$(CC) -o $@ $^ $(GTKLINK)

cluedo.o: cluedo.c gen.h control.h

%.o: %.c
	$(CC) -o $@ -c $< $(CFLAGS) $(GTKLINK)

clean :
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

package protocol ;

import exception.* ;

public abstract class AbstractFirstMessage {

    protected String id ;
    protected int num ;

    public AbstractFirstMessage (String myid, String mynum) {
        this.id = myid ;
        try {
            this.num = Integer.parseInt(mynum) ;
            this.checkRules() ;
        } catch (NumberFormatException | RuleBrokenException e) {
            throw new IllegalArgumentException() ;
        }
    }

    public AbstractFirstMessage (String myid, int mynum)
        throws UnknownResultException {
        this.id = myid ;
        this.num = mynum ;
        this.checkRules() ;
    }

    private void checkRules() throws RuleBrokenException {
        if (this.num < 0)
            throw new RuleBrokenException() ;
    }
}

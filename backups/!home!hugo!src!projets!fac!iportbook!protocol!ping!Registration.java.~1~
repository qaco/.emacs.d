package protocol.command ;

public class Registration extends Command {
    
    private String id ;
    private int port ;
    private int mdp ;
    
    public Registration (String author, String myid, String myport, String mymdp) {
        super(author) ;
        this.id = myid ;
        this.port = Integer.parseInt(myport) ;
        this.mdp = Integer.parseInt(mymdp) ;
    }

    public Registration (String author, String myid, int myport, int mymdp) {
        super(author) ;
        this.id = myid ;
        this.port = myport ;
        this.mdp = mymdp ;
    }

    public String toString() {
        String myport = String.valueOf(this.port) ;
        String mymdp = String.valueOf(this.mdp) ;
        return
            CommandVals.REGISTRATION + " " +
            this.id + " " + myport + " " + mymdp + CommandVals.EOF ;
    }
}

package protocol.answer ;

import main.MainVals ;
import protocol.feedback.AckFriend ;
import protocol.knock.NoFriendKnock ;
import service.User ;
import java.util.List ;
import java.io.IOException ;

public class RefuseFriend implements Answer {
    
    public void exec(User want, User rep) throws IOException {
        this.describeFriendship(want.getId(), rep.getId()) ;
        rep.sendTCP(new AckFriend()) ;
        want.sendUDP(new NoFriendKnock(want.howManyFlows())) ;
    }

    public String toString() {
        return AnswerVals.NO_FRIEND + MainVals.EOF ;
    }

    private void describeFriendship(String want, String rep) {
        MainVals.describe(rep + " refuses " + want + "as friend") ;
    }
}

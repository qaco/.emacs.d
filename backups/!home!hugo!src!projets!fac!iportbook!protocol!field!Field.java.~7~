package protocol.field ;

import java.nio.charset.Charset ;
import exception.UnknownResultException ;
import exception.RuleBrokenException ;

public abstract class Field {

    private static boolean checkForbidden(byte[] myfield) {
        int numplus = 0 ;
        for (int i = 0 ; i < myfield.length ; i++) {
            switch(myfield[i]) {
            case 32: return true ;
            case 43: numplus++ ;
            default: numplus = 0 ;
            }
            if (numplus == 3)
                return true ;
        }
        return false ;
    }
    
    protected byte[] field ;

    public Field() { super() ; }
    
    public Field(byte[] myfield) throws UnknownResultException {
        if (checkForbidden(myfield))
            throw new RuleBrokenException("Field", "Forbidden character") ;
        this.field = myfield ;
        this.checkRules() ;
    }

    public Field(String myfield) {
        byte[] bfield = myfield.getBytes(Charset.forName("US-ASCII")) ;
        if (checkForbidden(bfield))
            throw new IllegalArgumentException() ;
        this.field = bfield ;
        try { this.checkRules() ; } catch (UnknownResultException e) {
            throw new IllegalArgumentException() ;
        }
    }

    public byte[] addBefore(byte[] pref) {
        byte[] res = new byte[pref.length + this.field.length] ;
        for (int i = 0 ; i < pref.length ; i++)
            res[i] = pref[i] ;
        for (int i = pref.length ; i < res.length ; i++)
            res[i] = this.field[i] ;
        return res ;
    }
        
    public byte[] toBytes() {
        return this.field ;
    }

    public String toString() {
        return new String(this.field, Charset.forName("US-ASCII")) ;
    }

    protected void checkSize(int max) throws UnknownResultException {
        if (this.field.length > max)
            throw new RuleBrokenException("Field",
                                          this.toString() + " too long");
    }

    protected void checkAllAscii() throws UnknownResultException {
        for (int i = 0 ; i < this.field.length ; i++) {
            if (this.field[i] < 0) {
                String tmp = String.valueOf(this.field[i]) ;
                throw new RuleBrokenException("IdField",
                                              tmp + " non ascii char") ;
            }
        }
    }
    
    protected abstract void checkRules() throws UnknownResultException ;


    
}

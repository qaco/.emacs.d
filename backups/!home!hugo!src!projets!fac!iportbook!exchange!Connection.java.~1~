public class Connection implements Protocol {

    private String id ;
    private int mdp ;

    public Connection (String myid, String mymdp) throws ParseException {
        this.id = myid ;
        try {
            this.mdp = Integer.parseInt(mymdp) ;
        } catch (NumberException e) {
            throw new ParseException() ;
        }
    }

    public String getRepresentation() {
        String mymdp = String.valueOf(this.mdp) ;
        return "CONNE " + this.id + " " + mymdp + "+++" ;
    }
        

int add_word_occurence(Word *word, struct word_data_list *wdata_list, 
		       struct pair_data_list *pdata_list) {
    struct word_data_list *w_next;
    struct pair_data_list *p_next;
    size_t w_size;
    Word *checked;
    w_next = wdata_list;
    p_next = pdata_list;
    while(w_next != NULL) {
        if (w_next->wdata != NULL) {
	    w_size = w_next->wdata_size - sizeof(struct word_data) + 1;
            checked = construct_word(w_size, (char *)w_next->wdata->word);
	    if (compare_word(word, checked) == 0) {
		p_next->pdata->nb_occurence += 1 ;
		destruct_word(checked);
		return EXIT_SUCCESS;
	    }
	    destruct_word(checked);
        }
        w_next = w_next->next_word_data_list;
        p_next = p_next->next_pair_data_list;
    }
    add_word_data_list(wdata_list, word);
    add_pair_data_list(pdata_list, -1, -1);
    /* pdata_list->next_pair_data_list->pair_data->nb_occurence = 1; */
    return EXIT_SUCCESS;
}

int word_data_list_initializer(WordList *words, struct word_data_list *wdata_list, 
			       struct pair_data_list *pdata_list) {
    Word *w;
    for (int i = 0 ; i < get_length_wordlist(words) ; i++) {
	w = construct_word(0, NULL);
	get_word_wordlist(w, words, i);
	add_word_occurence(w, wdata_list, pdata_list);
	destruct_word(w);
    }
    return EXIT_SUCCESS;
}

int dataprocess(DbId *id, WordList *words, Word *url) {
    struct word_data_list *wdata_list;
    struct url_data_list *udata_list;
    struct pair_data_list *pdata_list;

    if ((create_word_data_list(&wdata_list) == EXIT_FAILURE)
	|| (create_url_data_list(&udata_list) == EXIT_FAILURE)
	|| (create_pair_data_list(&pdata_list) == EXIT_FAILURE))
	return EXIT_FAILURE;

    if (add_url_data_list(udata_list, url) == EXIT_FAILURE)
	return EXIT_FAILURE;

    if (word_data_list_initializer(words, wdata_list, pdata_list) == EXIT_FAILURE)
	return EXIT_FAILURE;
    
    while(wdata_list != NULL) {
	add_data(id, wdata_list, udata_list, pdata_list);
        wdata_list = wdata_list->next_word_data_list;
        pdata_list = pdata_list->next_pair_data_list;
    }
    return EXIT_SUCCESS ;
}

public class FriendshipNO implements Flow {
    private String id ;

    public FriendshipNO(String myid) throws UnknownResultException {
        this.id = myid ;
        if (this.id.length() > MainVals.MAX_ID_SIZE)
            throw new RuleBrokenException() ;
    }

    public void exec(ServerRequest c) throws IOException { 
	System.out.println("["+this.id+" ne souhaite pas être ami avec vous.]");
    }

    public String toString() {
        return FlowVals.FRIENDSHIP_NO + " " + this.id + MainVals.EOF ;
    }
}

    @Test
    public final void testAskFriendOKBuild() {
        String tmp = "FRIE>+++" ;
        try {
            Feedback p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }
    

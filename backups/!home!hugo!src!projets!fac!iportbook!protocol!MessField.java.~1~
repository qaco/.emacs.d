package protocol ;

import exception.RuleBrokenException ;

public class IdField extends Field {

    public IdField(byte[] myid) throws RuleBrokenException {
        super(myid) ;
    }

    public IdField(String myid) {
        super(myid) ;
    }
    
    
    protected void checkRules() throws RuleBrokenException {
        if (this.id.length > ProtocolVals.MAX_ID_SIZE) {
            throw new RuleBrokenException("Idfield",
                                          this.toString() + " too long") ;
        }
        for (int i = 0 ; i < this.field.length ; i++) {
            if (this.field[i] < 0) {
                String tmp = String.valueOf(this.field[i]) ;
                throw new RuleBrokenException("IdField",
                                              tmp + " non ascii char") ;
            }
        }
        
    }
        

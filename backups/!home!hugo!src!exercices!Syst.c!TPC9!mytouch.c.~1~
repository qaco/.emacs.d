#include <stdio.h>
#include <unistd.h>
#include <sys/stat.h>
#include <fcntl.h>

int main(int argc, char* argv[]) {
  int descripteur ;
  mode_t mode = S_IRUSR | S_IWUSR | S_IRGRP | S_IROTH;
  
  argc-- ;
  argv++ ;

  if (!argc) {
    printf("touch: opérande de fichier manquant\n") ;
    return EXIT_FAILURE ;
  }

  while (argc--) {
    if(access(*(argv + argc - 1), F_OK)) { // n'existe pas
      descripteur = creat(*(argv + argc - 1), mode) ;
      futimens(descripteur, NULL) ;
      close(descripteur) ;
    }
    else { // existe
      utimensat(AT_FDCW, *(argv + argc - 1), NULL, 0) ;
    }

    argv++ ;
  }

  return 0 ;
}

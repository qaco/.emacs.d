import re

def read_html_content(name):
    myhtml = open(name,"r")
    mytext = myhtml.read()
    mylist = re.split("[<>/]", mytext)
    myhtml.close()
    return " ".join(mylist)

def print_url(name):
    myhtml = open(name,"r")
    mytext = myhtml.read()
    myhtml.close()
    myurls = [ url[6:-1] for url in re.findall("href=\"http://[^\"]*\"", mytext)]
    [ print(url) for url in myurls ]

def print_domain(name):
    myhtml = open(name,"r")
    mytext = myhtml.read()
    myhtml.close()
    myurls = [ url[6:-1] for url in re.findall("href=\"http://[^\"]*\"", mytext)]
    mydomains = [ url.rsplit(".",1)[1].split("/")[0] for url in myurls ]
    [ print(domain) for domain in mydomains ]

def print_without_comments(name):
    myhtml = open(name,"r")
    mytext = myhtml.read()
    myhtml.close()
    print(re.sub("<!--.*-->", "", mytext, 0))

def list_korw():
    myfile = open("educ.txt")
    mytext = myfile.read()
    myfile.close()
    return [ word[1:-1] for word in re.findall("\s[a-zA-Z]*[kw][a-zA-Z]*\s",mytext) ]

def list_19():
    myfile = open("educ.txt")
    mytext = myfile.read()
    myfile.close()
    return re.findall("18[0-9]{2}",mytext)

def list_aimer():
    myfile = open("educ.txt")
    mytext = myfile.read()
    myfile.close()
    return re.findall("aim[a-z]*(?= .)",mytext)


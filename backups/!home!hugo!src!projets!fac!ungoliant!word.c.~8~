/**
 * \file word.h
 * \brief Fonctions associées au type Word.
 * \details Le type Word représente une chaîne de caractères.
 * \author Hugo Pompougnac
 * \version 1.0
 * \date 17/02/2017
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "word.h"

/**
 * \fn Word construct_word(const char *src, size_t n)
 * \brief Construit un Word.
 * \param src Les caractères du Word.
 * \param n La taille du Word.
 * \return Le nouveau Word.
 */
Word construct_word(const char *src, const size_t n)
{
  Word res ;

  res.memory = malloc(sizeof(char) * n) ;
  memcpy(res.memory, src, sizeof(char) * n) ;
  res.size = n ;
  res.allocated = n ;

  return res ;
}

/**
 * \fn Word construct_empty_word()
 * \brief Construit un Word vide.
 * \return Le nouveau Word.
 */
Word construct_empty_word()
{
  Word res ;

  res.memory = malloc(sizeof(char)) ;
  res.size = 0 ;
  res.allocated = 1 ;

  return res ;
}

/**
 * \fn Word construct_null_word()
 * \brief Construit un Word null.
 * \return Le nouveau Word.
 */
Word construct_null_word()
{
  Word res ;

  res.memory = NULL ;
  res.size = 0 ;
  res.allocated = 0 ;

  return res ;
}

/**
 * \fn int is_null_word(const Word myword)
 * \brief Teste si un Word est null.
 * \param myword Le Word à tester.
 * \return 1 si null, 0 sinon.
 */
int is_null_word(const Word myword)
{
  return myword.allocated == 0 ;
}

/**
 * \fn char get_char_word(const Word myword, const int index)
 * \brief Extrait un caractère d'un Word.
 * \param myword Le Word duquel extraire un caractère.
 * \param index Le caractère (représenté par son index) à extraire.
 * \return Le caractère extrait.
 */
char get_char_word(const Word myword, const int index)
{
  char res ;

  if (index < myword.size)
    res = *(myword.memory + index) ;
  else
    res = -1 ;

  return res ;
}

/**
 * \fn char char* get_cstring_word(const Word myword)
 * \brief Fournit la représentation en string C d'un Word.
 * \param myword Le Word à représenter en string C.
 * \return La représentation du Word.
 */
char* get_cstring_word(const Word myword)
{
  char* res = malloc(sizeof(char)*(myword.size + 1)) ;

  for (int i = 0 ; i < myword.size ; i++)
    *(res + i) = get_char_word(myword, i) ;
  *(res + myword.size) = '\0' ;

  return res ;
}

/**
 * \fn size_t get_size_word(const Word myword)
 * \brief Extrait la taille d'un Word.
 * \param myword Le Word duquel extraire la taille.
 * \return La taille du Word.
 */
size_t get_size_word(const Word myword)
{
  return myword.size ;
}

/**
 * \fn int destruct_word(Word* myword)
 * \brief Détruit un Word.
 * \param myword Le Word à détruire.
 * \return -1 en cas d'échec.
 */
int destruct_word(Word* myword)
{
  if (!is_null_word(*myword)) {
    free(myword->memory) ;
    *myword = construct_null_word() ;
  }

  return 0 ;
}

/**
 * \fn int add_char_word(Word* myword, const char mychar)
 * \brief Ajoute un caractère à la fin d'un Word.
 * \param myword Le Word auquel ajouter un caractère.
 * \param mychar Le caractère à ajouter.
 * \return -1 en cas d'échec.
 */
int add_char_word(Word* myword, const char mychar)
{
  if (is_null_word(*myword))
    return -1 ;

  if (myword->size >= myword->allocated) {
    myword->memory = realloc(myword->memory, myword->allocated*2) ;
    myword->allocated *= 2 ;
  }
  *(myword->memory + myword->size) = mychar ;
  myword->size++ ;

  return 0 ;
}

/**
 * \fn int insert_char_word(Word* myword, const char mychar, const int index)
 * \brief Insère un caractère dans un Word.
 * \param myword Le Word dans lequel insérer un caractère.
 * \param mychar Le caractère à insérer.
 * \param index L'index où insérer le caractère.
 * \return -1 en cas d'échec.
 */
int insert_char_word(Word* myword, const char mychar, const int index)
{
  char *tmp ;

  if (is_null_word(*myword) || index >= myword->size)
    return -1 ;

  if (myword->size >= myword->allocated) {
    tmp = malloc(myword->allocated*2) ;
    myword->allocated *= 2 ;
  }
  else
    tmp = malloc(myword->allocated) ;

  memcpy(tmp, myword->memory, sizeof(char)*index) ;
  *(tmp + index) = mychar ;
  memcpy(tmp + index + 1,
         myword->memory + index,
         myword->size - sizeof(char)*(index-1)) ;
  free(myword->memory) ;
  myword->memory = tmp ;
  myword->size++ ;

  return 0 ;
}

/**
 * \fn int remove_char_word(Word* myword, const int index)
 * \brief Supprime un caractère dans un Word.
 * \param myword Le Word duquel supprimer un caractère.
 * \param index Le caractère (représenté par son index) à supprimer.
 * \return -1 en cas d'échec.
 */
int remove_char_word(Word* myword, const int index)
{
  char* tmp ;

  if (is_null_word(*myword) || index >= myword->size)
    return -1 ;

  if (myword->size <= myword->allocated/4) {
    tmp = malloc(myword->allocated/2) ;
    myword->allocated /= 2 ;
  }
  else
    tmp = malloc(myword->allocated) ;

  memcpy(tmp, myword->memory, sizeof(char)*index) ;
  memcpy(tmp + index,
         myword->memory + index + 1,
         myword->size - sizeof(char)*(index + 1)) ;
  free(myword->memory) ;
  myword->memory = tmp ;
  myword->size-- ;

  return 0 ;
}

/**
 * \fn int print_word(Word myword, FILE* stream)
 * \brief Imprime un Word dans un fichier.
 * \param myword Le Word à imprimer.
 * \param stream Le fichier dans lequel imprimer le Word (peut être stdout).
 * \return -1 en cas d'échec.
 */
int print_word(const Word myword, FILE* stream)
{
  for (int i = 0 ; i < myword.size ; i++)
    if (fprintf(stream, "%c", *(myword.memory + i)) < 0)
      return -1 ;
  fprintf(stream, "\n") ;
  return 0 ;
}

import java.util.ArrayList ;

public class Main {
    public static void main(String[] args) {
	Plateau p = new Plateau() ;
	ArrayList<Joueur> players = new ArrayList<Joueur>() ;

	for (int i = 0 ; i<Data.NBJOUEURS ; i++)
	    players.add(new Joueur(p)) ;
	p.industrialiserPlateau(players) ;	    
	Joueur gagnant = null ;
	boolean win = false ;
	boolean notyet = false ;

	while (!win) {
	    for (Joueur courant : players) {
		System.out.println(p) ;
		System.out.println("Tour de " + courant.getId()) ;
		do {
		    try {
			courant.tour() ;
			notyet = false ;
		    } catch (ActionIllegaleException e) {
			System.out.println(e.getMessage()) ;
			notyet = true ;
		    }
		} while (notyet) ;
		if (courant.victoire()) {
		    gagnant = courant ;
		    win = true ;
		}
	    }
	}
	System.out.println(gagnant.getId() + " a gagné") ;
    }
}
	


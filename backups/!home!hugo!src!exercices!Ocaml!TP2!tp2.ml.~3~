(* Ex 1 *)
let rec list_length l = match l with
    | [] -> (0)
    | a::lp -> 1+(list_length lp)
;;
let rec list_produit l = match l with
    | [] -> (1)
    | a::lp -> a*(list_produit lp)
;;
let rec mem i l = match l with
  | [] -> false
  | a::p -> if (i = a) then (true) else mem i p
;;
let rec map f l = match l with
  | [] -> []
  | a::p -> (f a) :: (map f p)
;;
let rec filter cond l = match l with
  | [] -> []
  | a::p -> if (cond a) then a :: (filter cond p) else (filter cond p)
;;
let rec liste_min l = match l with
  | [] -> failwith "liste vide"
  | [a] -> (a)
  | a::p -> min a (liste_min p)
;;
let rec is_sorted l = match l with
  | [] -> true
  | [a] -> true
  | a::b::p -> if a > b then false else is_sorted (b::p)
;;
let rec append l1 l2 = match l1 with
  | [] -> []
  | [a] -> a::l2
  | a::p -> a::(append p l2)
;;
let rec last l = match l with
  | [] -> failwith "liste vide"
  | [a] -> a
  | a::p -> last p
;;
let rec rev l = match l with
  | [] -> []
  | a::p -> (rev p)@[a]
;;

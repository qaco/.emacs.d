package protocol.command ;

import java.util.Arrays ;

public class CommandFactory {
    public Command create(String text) {
        Command res = null ;
        int isuffix = text.length() - CommandVals.EOF.length() ;
        String suffix = text.substring(isuffix, text.length()) ;
        if (suffix.equals(CommandVals.EOF)) {
            String signifiant = text.substring(0, text.length() - 3) ;
            String cmds[] = signifiant.split(" ") ;
            String tail[] ;
            String mess ;
            try {
                switch (cmds[0]) {
                case CommandVals.REGISTRATION :
                    res = new Registration (cmds[1], cmds[2], cmds[3]) ;
                    break ;
                case CommandVals.CONNECTION :
                    res = new Connection(cmds[1], cmds[2]) ;
                    break ;
                case CommandVals.ASK_FRIEND :
                    res = new AskFriend(cmds[1]) ;
                    break ;
                case CommandVals.FIRST_MESSAGE :
                    res = new FirstMessage(cmds[1], cmds[2]) ;
                    break ;
                case CommandVals.SOME_MESSAGE :
                    tail = Arrays.copyOfRange(cmds, 2, cmds.length) ;
                    mess = String.join(" ", tail) ;
                    res = new SomeMessage(cmds[1], mess) ;
                    break ;
                case CommandVals.FLOO_MESSAGE :
                    tail = Arrays.copyOfRange(cmds, 1, cmds.length) ;
                    mess = String.join(" ", tail) ;
                    res = new FlooMessage(mess) ;
                    break ;
                case CommandVals.SEE_LIST :
                    res = new SeeList() ;
                    break ;
                case CommandVals.DECONNECTION :
                    res = new Deconnection() ;
                    break ;
                }
            } catch (RuntimeException e) {
                e.printStackTrace() ;
            }
        }
        return res ;
    }
}


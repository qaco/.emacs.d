package protocol.command ;

public class AskFriend extends Command {
    private String id ;

    public AskFriend (String myauthor, String myid) {
        super(myauthor) ;
        this.id = myid ;
    }

    public String toString() {
        return CommandVals.ASK_FRIEND + " " + this.id + CommandVals.EOF ;
    }
}

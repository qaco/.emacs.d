package protocol.field ;

import exception.* ;

public abstract class NumStringField extends Field {

    private static String numberJammed(int myfield, int size) {
        String tmp = String.valueOf(myfield) ;
        StringBuffer refined = new StringBuffer() ;
        if (tmp.length() > size)
            throw new IllegalArgumentException() ;
        else if (tmp.length() < size) {
            for (int i = 0 ; i < size - tmp.length() ; i++)
                refined.append(FieldVals.JAM_NUMSTRING) ;
        }
        refined.append(tmp) ;
        return refined.toString() ;
    }
    
    public NumStringField(byte[] myfield) throws UnknownResultException {
        super(myfield) ;
    }

    public NumStringField(int myfield, int size) {
        super(numberJammed(myfield, size)) ;
    }

    public int getInt() {
        return Integer.parseInt(this.toString()) ;
    }

    protected void checkSize(int eq) throws UnknownResultException {
        if (this.field.length != eq)
            throw new RuleBrokenException("Field",this.toString()+" too long");
    }
    
    protected void checkRange(int min,int max) throws UnknownResultException {
        String tmp = this.toString() ;
        try {
            int val = this.getInt() ;
            if (val < 0)
                throw new RuleBrokenException("NumString", tmp + " < 0");
        } catch (NumberFormatException e) {
            throw new WrongTypeException("NumString", tmp, "int") ;
        }
    }
}

package protocol.feedback ;

import main.MainVals ;
import exception.* ;
import protocol.ProtocolFactory ;
import java.io.InputStream ;
import java.io.IOException ;
import java.util.Arrays ;

public class FeedbackFactory extends ProtocolFactory {

    public Feedback create(InputStream in) throws UnknownResultException,
                                             IOException {
        byte[][] raw_arr = this.readStream(in) ;
        return this.create(raw_arr) ;
    }
    
    private Feedback create(byte[][] raw_arr) throws UnknownResultException {
        String code = this.extractCode(raw_arr) ;
        byte[][] params = Arrays.copyOfRange(raw_arr,1,raw_arr.length) ;
        try {
            switch (code) {
            case FeedbackVals.ASK_OK :
                return new AskFriendOK() ;
            case FeedbackVals.ASK_NO :
                return new AskFriendNO() ;
            case FeedbackVals.ACK_FR :
                return new AckFriend() ;
            case FeedbackVals.FLOO_DONE :
                return new FlooDone() ;
            case FeedbackVals.GOODBYE :
                return new Goodbye() ;
            case FeedbackVals.HELLO :
                return new Hello() ;
            case FeedbackVals.MESS_TRANSMIT :
                return new MessageTransmitted() ;
            case FeedbackVals.MESS_NOT_TRANSMIT :
                return new MessageNotTransmitted() ;
            case FeedbackVals.WELCOME :
                return new Welcome() ;
            case FeedbackVals.FIRST_LIST :
                return new FirstList(params[0]) ;
            case FeedbackVals.SOME_LIST :
                return new SomeList(params[0]) ;
            case FeedbackVals.PUB_DONE :
                return new PubDone() ;
            default :
                throw new UnknownCommandException(code, "feedback") ;
            }
        } catch (ArrayIndexOutOfBoundsException e) {
            throw new TooFewArgsException(code,
                                          String.valueOf(params.length)) ;
        }
    }
}

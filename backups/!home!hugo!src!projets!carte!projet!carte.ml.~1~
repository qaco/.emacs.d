(* debug fonction *)

let functi e = match e with
  | (b, (t, c)) ->
    if b then print_string "true, ("
    else print_string "false, (";
    print_int t; print_string ", "; print_int c; print_string ")"
;;

let printo listo functo =
  let rec print_list liste functi = match liste with
    | [] -> ()
    | e:: l -> functi e ; print_string "\n" ; print_list l functi
  in
  match listo with
  | Some t -> print_list t functo
  | None -> failwith "tototo"
;;


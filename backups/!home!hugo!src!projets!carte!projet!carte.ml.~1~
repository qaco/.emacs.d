#use "examples.ml";;
let interaction examples =
  open_graph(" 900x900");
  self_init ();
  let dd s c =
    set_color white;
    begin
      match c with
      | col when c = black ->
        fill_rect 0 850 900 50;
        moveto 50 (size_y () - 40);
        set_color black
      | col when c = red ->
        fill_rect 0 800 900 50;
        moveto 100 (size_y () - 80);
        set_color red
      | _ -> clear_graph ()
    end;
    draw_string s in
  let play_one ex =
    let r_ex = ref ex in
    let col_array_i = color_array !r_ex in
    let colors = get_ex_colors col_array_i in
    match (!r_ex).dim with
    | x, y ->
      (* open_graph(" "^(string_of_int x)^"x"^(string_of_int y)); *)
      dd "Calcul de la matrice des regions" black;
      let matrix = regions_voronoi taxicab !r_ex in
      dd "Calcul de la matrice d'adjacences" black;
      let adj = adjacences_voronoi !r_ex matrix in
      let reset_colors () =
        for i = 0 to (length col_array_i) - 1 do
          (!r_ex).seeds.(i) <- {c = col_array_i.(i);
                                x = (!r_ex).seeds.(i).x;
                                y = (!r_ex).seeds.(i).y;}
        done in
      let show_solution () =
        let col_arr = color_array !r_ex in
        let constraints = produce_constraints col_arr adj colors in
        let result = Sat.solve constraints in
        dd "Affichage d'une solution" black;
        match result with
        | Some a ->
          let final_res = get_result result in
          r_ex := solve_vor final_res !r_ex;
          draw_voronoi matrix !r_ex
        | None ->
          dd "Cet carte n'a pas de solution. On retourne a la carte de base" red;
          reset_colors ();
          let col_arr_i = color_array !r_ex in
          let constraints_i = produce_constraints col_arr_i adj colors in
          let result_i = Sat.solve constraints_i in
          let final_res_i = get_result result_i in
          r_ex := solve_vor final_res_i !r_ex;
          draw_voronoi matrix !r_ex in
      let rec choose_color () =
        let rec get_col () =
          dd "Cliquez sur une case qui possede la couleur que vous voulez \
              utiliser" black;
          let em = wait_next_event[Button_down] in
          let ex = em.mouse_x and ey = em.mouse_y in
          let mx, my = match !r_ex.dim with a, b -> a, b in
          if (ex < mx && ey < my) then
            let seed_num = matrix.(ey).(ex) in
            match (!r_ex).seeds.(seed_num).c with
            | Some col -> Some col
            | None ->
              dd "Une couleur vide n'est pas une couleur" red;
              get_col ()
          else
            begin
              dd "Vous ne pouvez pas choisir une couleur a l'exterieur du cadre" red;
              get_col ()
            end in
        let col = get_col () in
        dd "Cliquez sur la region a colorier" black;
        let em = wait_next_event[Button_down] in
        let x = em.mouse_x and y = em.mouse_y in
        (* let print_shit = print_int x; print_string ", "; print_int y in *)
        let seed_num = matrix.(y).(x) in
        if (col_array_i.(seed_num) = None) then
          (* print_shit; *)
          begin
            (!r_ex).seeds.(seed_num) <- {c = col;
                                         x = (!r_ex).seeds.(seed_num).x;
                                         y = (!r_ex).seeds.(seed_num).y};
          end
        else
          dd "Vous ne pouvez pas recolorier une couleur de base" red
      in
      let rec erase_color () =
        dd "Choisissez une region a supprimer (cliquez)" black;
        let em = wait_next_event[Button_down] in
        let x = em.mouse_x and y = em.mouse_y in
        let seed_num = matrix.(y).(x) in
        if (col_array_i.(seed_num) = None) then
          begin
            (!r_ex).seeds.(seed_num) <- {c = None;
                                         x = (!r_ex).seeds.(seed_num).x;
                                         y = (!r_ex).seeds.(seed_num).y};
            dd "Region supprimer" red
          end
        else
          begin
            dd "Vous ne pouvez pas supprimer une couleur qui existe de base" red;
            erase_color ()
          end
      in
      let rec choose_action () =
        (* TODO Modifier cette partie pour que ce soit seulement visuel. cliquable *)
        (* Bon j'ai trop de chose a changer pour ce que ca va apporter... *)
        (* Je vais pas le faire. Vas y si t'es motiver mais je pense que ca *)
        (* vaut pas trop le coup *)
        dd "Choisissez une action : 'c' pour colorier une case; 'd' pour \
            supprimer une case coloriez; 's' pour afficher une solution" black;
        let ek = wait_next_event[Key_pressed] in
        match ek.key with
        | 'c' -> choose_color
        | 'd' -> erase_color
        | 's' -> show_solution
        | _ -> choose_action () in
      let is_complete () =
        let col_arr = color_array !r_ex in
        let constraints = produce_constraints col_arr adj colors in
        let result = Sat.solve constraints in
        let final_res = get_result result in
        let new_vor = solve_vor final_res !r_ex in
        let new_col_arr = color_array new_vor in
        let comp = ref true in
        for i = 0 to (length col_arr) - 1 do
          if not (new_col_arr.(i) = col_arr.(i)) then
            comp := false
        done;
        !comp in
      while not (is_complete ()) do
        draw_voronoi matrix !r_ex;
        choose_action () ();
        dd "" red
      done;
      draw_voronoi matrix !r_ex in
  let rec play_again () =
    dd "Voulez vous rejouer ? (y/n)" black;
    let ek = wait_next_event[Key_pressed] in
    match ek.key with
    | 'y' -> true
    | 'n' -> false
    | _ ->
      dd "Vous devez appuyer sur 'y' ou 'n' (oui ou non)" red;
      play_again () in
  let rec play_all exs = match exs with
    | [] ->
      dd "Partie finie !" black;
      let _ = wait_next_event [Button_down; Key_pressed] in
      close_graph ();
    | ex::l ->
      play_one ex;
      dd "Carte terminee" red;
      if play_again () then
        if not (l = []) then
          begin
            clear_graph ();
            play_all l
          end
        else close_graph () in
  let shuffle d =
    let nd = List.map (fun c -> (Random.bits (), c)) d in
    let sond = List.sort compare nd in
    List.map snd sond in
  play_all (shuffle examples);
;;


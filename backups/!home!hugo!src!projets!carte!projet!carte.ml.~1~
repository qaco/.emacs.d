module Variables = struct
  type t = (int * Graphics.color)
  let compare x y = match x, y with
    | ((x1, x2), (y1, y2)) ->
      if x1 < y1 then (-1)
      else if x1 > y1 then 1
      else if x2 < y2 then (-1)
      else if x2 > y2 then 1
      else 0
end;;


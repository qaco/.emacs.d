let get_ex_colors color_arr =
  let colors = ref [] in
  for i = 0 to (length color_arr) - 1 do
    match color_arr.(i) with
    | Some c -> if not (List.mem c !colors) then colors := c::!colors;
    | None -> ()
  done;
  !colors
;;

let produce_constraints color_array adj_mat colors =
  let rec make_exist_list i cols = match cols with
    | [] -> []
    | c::t -> (true, (i, c))::make_exist_list i t in
  let rec exist_constraints i = match i with
    | a when (i = length color_array) -> []
    | a -> match color_array.(i) with
      | Some c -> [(true, (i, c))]::exist_constraints (i + 1)
      | None -> (make_exist_list i colors)::exist_constraints (i + 1) in
  let rec make_unique_list_aux i cols1 cols2 = match cols1 with
    | [c1] ->
      if i = 0 then []
      else make_unique_list (i - 1) colors
    | c1::c2::t1 ->
      begin
        match cols2 with
        | [] -> make_unique_list_aux i (c2::t1) t1
        | c3::t2 -> [(false, (i, c1));
                     (false, (i, c3))]::make_unique_list_aux i cols1 t2
      end
    | _ -> failwith "make_unique_list_aux n'a pas ete appele correctement"
  and make_unique_list i cols = match cols with
    | [] -> []
    | c::t -> make_unique_list_aux i cols t in
  let rec unique_constraints () =
    make_unique_list (length color_array) colors
  in
  let rec make_color_list cons_list i j cols = match cols with
    | [] -> !cons_list
    | c::t -> [(false, (i, c));
               (false, (j, c))]::make_color_list cons_list i j t in
  let adj_constraints =
    let cons_list = ref [] in
    for i = 0 to (length adj_mat) - 1 do
      for j = i + 1 to (length adj_mat) - 1 do
        if adj_mat.(i).(j) then
          cons_list := make_color_list cons_list i j colors
      done
    done;
    !cons_list
  in (exist_constraints 0)@(unique_constraints ())@adj_constraints
;;

let color_array vor =
  let arr = ref (Array.make (length vor.seeds) None) in
  for i = 0 to ((length vor.seeds) - 1) do
    match vor.seeds.(i) with
    | s -> !arr.(i) <- s.c
  done;
  !arr
;;

let solve_vor solution vor =
  let seed_arr = ref (make (length vor.seeds) { c=None; x=0; y=0 }) in
  let rec solve_vor_rec sol = match sol with
    | [] -> seed_arr
    | (b, (i, col))::tl ->
      if b then
        !seed_arr.(i) <- { c=Some col; x=vor.seeds.(i).x; y=vor.seeds.(i).y };
      solve_vor_rec tl in
  { dim=vor.dim ; seeds = !(solve_vor_rec solution)}
;;

let get_result res = match res with
  | Some a -> a
  | None -> failwith "Il y a un probleme insoluble dans la liste"
;;



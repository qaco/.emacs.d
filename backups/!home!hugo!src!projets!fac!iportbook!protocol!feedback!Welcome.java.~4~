package protocol.feedback ;

import protocol.field.Field ;
import client.src.ConnexionRequest;
import client.src.ServerRequest;
import main.MainVals ;

public class Welcome implements Feedback {
    
 
    public void exec(ConnexionRequest cr) {
	System.out.println("[Bienvenue !]");
	cr.setStatus(true);
    }
    public void exec(ServerRequest cr) {}

    public byte[] toBytes() {
        return Field.makeSentence(FeedbackVals.OK_FRIEND, new Field[0]) ;
    }
    
    public String toString() {
        return FeedbackVals.WELCOME + MainVals.EOF ;
    }

}

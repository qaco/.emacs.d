type player = Red | Yellow ;;
type cell = Empty | Pawn of player ;;
type outcome = Draw | Open | Win of player ;;
type board = cell array array ;;

let init:board = Array.make_matrix 7 6 Empty ;;

let play b p c = 
  if (Array.length b = 0 || b.(0).(c) != Empty) then
    failwith "Colonne pleine"
  else if (Array.length b = 1 || b.(1).(c) != Empty) then
    b.(0).(c) <- Pawn(p)
  else play (Array.sub b 1 ((Array.length b) -1)) p c
;;
    
  play init Red 3 ;;
  init ;;
    Array.sub init 1 ((Array.length init) -1) ;;

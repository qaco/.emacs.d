package client.src;

import exception.UnknownResultException ;
import java.util.Scanner;
import java.io.PrintWriter;
import java.io.InputStream;
import java.io.InputStreamReader;
import java.io.IOException;
import java.nio.channels.SocketChannel;
import java.nio.ByteBuffer;
import java.net.ConnectException;
import java.net.InetSocketAddress;
import main.MainVals ;

import protocol.feedback.Feedback;
import protocol.feedback.FeedbackFactory;
import protocol.command.Connection;
import protocol.command.Registration;

public class ConnexionRequest {

    private String id, udp, mdp;
    private boolean status;
    private int serverSocket = MainVals.serverport;
    private String serverAddr = "localhost";
    private SocketChannel soch;
    InetSocketAddress hostAddress;
    private Scanner sc;

    public ConnexionRequest() {
	this.status = false;
	this.sc = new Scanner(System.in);
	try {
	    this.hostAddress = new InetSocketAddress(this.serverAddr, this.serverSocket);
	    this.soch = SocketChannel.open(hostAddress);
	} catch (IOException e) {
	    System.out.println("[Connection au serveur impossible.]");
	}
    }

    public boolean client_connexion() throws IOException {
	if (this.soch == null ) {
	    return false ;
	} else {
	    try {
		Connexion con = new Connexion();
		con.exec();
		this.id = con.getId();
		this.mdp = con.getMdp();
		this.udp = con.getUdp();
		Connection connect = new Connection(this.id, this.mdp);
		byte [] message = connect.toBytes();
		ByteBuffer buffer = ByteBuffer.wrap(message);
		this.soch.write(buffer) ;
		
		FeedbackFactory fbackfactory = new FeedbackFactory();
		Feedback fback = fbackfactory.create(this.soch);
		fback.exec(this);	    
		if (this.status == false) {
		    this.soch.close();
		}
		return this.status;
	    } catch (UnknownResultException e) {
		System.out.println("[Requête inconnue du serveur.]");
	    } 	
	    this.soch.close();
	    return false;
	}
    }


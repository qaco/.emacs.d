CAMLC=ocamlc
CAMLOPT=ocamlopt
LINKS=graphics.cma
LINKSOPT=graphics.cmxa
EXEC=coloriage
SRC=examples.ml sat_solver.ml voronoi.ml view.ml interaction.ml main.ml 
OBJ=$(SRC:.ml=.cmo)
OBJOPT=$(SRC:.ml=.cmx)

all: $(EXEC)

opt: $(EXEC).opt

$(EXEC) : $(OBJ)
	$(CAMLC) -o $@ $(LINKS) $^

$(EXEC).opt : $(OBJOPT)
	$(CAMLOPT) -o $@ $(LINKSOPT) $^

main.cmo: main.ml examples.cmo interaction.cmo voronoi.cmo
	$(CAMLC) -c $<

main.cmx: main.ml examples.cmx interaction.cmx voronoi.cmx
	$(CAMLOPT) -c $<

interaction.cmo: interaction.ml interaction.cmi voronoi.cmo
	$(CAMLC) -c $<

interaction.cmx: interaction.ml interaction.cmi voronoi.cmx
	$(CAMLOPT) -c $<

voronoi.cmo: voronoi.ml voronoi.cmi sat_solver.cmo
	$(CAMLC) -c $<

voronoi.cmx: voronoi.ml voronoi.cmi sat_solver.cmx
	$(CAMLOPT) -c $<

sat_solver.cmo: sat_solver.ml sat_solver.cmi
	$(CAMLC) -c $<

sat_solver.cmx: sat_solver.ml sat_solver.cmi
	$(CAMLOPT) -c $<

examples.cmo: examples.ml voronoi.cmo
	$(CAMLC) -c $<

examples.cmx: examples.ml voronoi.cmx
	$(CAMLOPT) -c $<

view.cmo: view.ml view.cmi voronoi.cmo
	$(CAMLC) -c $<

view.cmx: view.ml view.cmi voronoi.cmx
	$(CAMLOPT) -c $<

%.cmi: %.mli
	$(CAMLC) -o $@ -c $<

clean :
	rm -rf *.cmx
	rm -rf *.cmi
	rm -rf *.cmo
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)
	rm -rf $(EXEC).opt

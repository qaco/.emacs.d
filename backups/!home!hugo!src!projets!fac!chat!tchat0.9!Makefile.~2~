CC=gcc
CFLAGS=-std=gnu99 -Werror -g
CPIPE=-DPIPE_SERVER=\"/tmp/PipeServer\"
CSIZES=-DNB_SIZE=4 -DTYPE_SIZE=4 -DPART_SIZE=256

all : tchatche tchatche_serveur

tchatche: interact.o tubing.o build.o client.o
	$(CC) -o $@ $^ -lncurses -lpthread

tchatche_serveur: tchatche_serveur.o traitement_serveur.o divers_serveur.o array_list.o build.o
	$(CC) -o $@ $^

interact.o: interact.c build.h build.c tubing.h tubing.c
	$(CC) $(CFLAGS) $(CSIZES) -o $@ -c $<

tubing.o: tubing.c tubing.h tubing.c build.h build.c interact.h interact.c
	$(CC) $(CFLAGS) $(CSIZES) -o $@ -c $<

build.o: build.c
	$(CC) $(CFLAGS) $(CSIZES) -o $@ -c $<

client.o: client.c
	$(CC) $(CFLAGS) $(CPIPE) -o $@ -c $<

divers_serveur.o: divers_serveur.c divers_serveur.h build.h build.c array_list.h array_list.c
	$(CC) $(CFLAGS) -o $@ -c $<

array_list.o: array_list.c array_list.h array_list.c
	$(CC) $(CFLAGS) -o $@ -c $<

traitement_serveur.o: traitement_serveur.c divers_serveur.h divers_serveur.c build.h build.c array_list.h array_list.c
	$(CC) $(CFLAGS) $(CPIPE) $(CSIZES) -o $@ -c $<

tchatche_serveur.o: tchatche_serveur.c traitement_serveur.h traitement_serveur.c build.h build.c array_list.h array_list.c
	$(CC) $(CFLAGS) $(CPIPE) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf client server

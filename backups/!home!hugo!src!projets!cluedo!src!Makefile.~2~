CC=gcc
CFLAGS=-std=c99 -Wall
GTKLINK=`pkg-config --cflags --libs gtk+-3.0`
EXEC=cluedo
SRC=stuff.c callback.c gen.c cluedo.c
OBJ=$(SRC:.c=.o)

all : $(EXEC)

$(EXEC) : $(OBJ)
	$(CC) -o $@ $^ $(GTKLINK)

cluedo.o: gen.h callback.h

gen.o: stuff.h callback.h

callback.o: stuff.h

%.o: %.c
	$(CC) -o $@ -c $< $(CFLAGS) $(GTKLINK)

clean :
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

#! /usr/bin/env python3

import os.path, Control, View, Slogan, Shutter
from gi.repository import Gtk

SHUT_COL = (0,0,0)
SHUT_ALPHA = 80
TEXT_COL = (255, 255 , 255)
FONT_PATH = "/usr/share/fonts/truetype"

HEIGHT = 600
PARAM_WIDTH = 300

def list_directory(path):  
    fichier=[]  
    for root, dirs, files in os.walk(path):  
        for i in files:  
            fichier.append(os.path.join(root, i))  
    return fichier

def pathslist_to_filedict(l_paths):
    mydict = dict()
    for path in l_paths:
        without_path = path.split("/")[-1]
        dotsep_list = without_path.split(".")
        del(dotsep_list[-1])
        cleanfont = ".".join(dotsep_list)
        mydict[cleanfont] = path
    return mydict

def main():
    lfonts = list_directory(FONT_PATH)
    dfonts = pathslist_to_filedict(lfonts)

    control = Control.Motherboard(Shutter.BOTTOM_SHUTTER,SHUT_COL, SHUT_ALPHA,
                                  Slogan.NAIVE_SLOGAN, TEXT_COL, dfonts)
    window = View.Window(HEIGHT, PARAM_WIDTH)
    window.add_controler(control)
    window.show_all()
    Gtk.main()

main()

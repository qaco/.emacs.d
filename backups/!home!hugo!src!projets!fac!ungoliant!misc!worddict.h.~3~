#ifndef WORDDICT
#define WORDDICT

typedef struct {
  Word key ;
  WordList values ;
} Page ;

typedef struct {
  Page *pages ;
  size_t length ;
  size_t allocated ;
} WordDict ;

WordDict construct_empty_worddict() ;
int get_value(WordList* values, WordDict* mydict, Word myword) ;
void add_line_worddict(WordDict* mydict, Word myword, WordList mylist) ;
int remove_key_worddict(WordDict* mydict, Word myword) ;
int is_in_worddict(const Word myword, const WordDict mydict) ;
int print_worddict(WordDict mydict, FILE* stream) ;

#endif

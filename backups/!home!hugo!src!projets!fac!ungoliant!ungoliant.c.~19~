#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <ctype.h>
#include "crawl/crawler.h"
#include "query/query_engine.h"

#define CRAWLER_FLAG "-c"
#define QUERY_FLAG "-q"

static int is_number(char* string)
{
  for (int i = 0 ; i < strlen(string) ; i++)
    if (!isdigit(*(string + i)))
      return 0 ;
  return 1 ;
}

static void help(void) {
  fprintf(stderr, "SYNOPSIS\n") ;
  fprintf(stderr, "ungoliant [CMDS]\n\n") ;
  fprintf(stderr, "CMD1\n-q keyword\n") ;
  fprintf(stderr, "-> recherche le keyword dans les pages crawlées.\n") ;
  fprintf(stderr, "CMD2\n-c url depth\n") ;
  fprintf(stderr, "-> crawle l'url et les url vers lesquelles elle pointe") ;
  fprintf(stderr, " jusqu'à la profondeur depth.\n") ;
}

int main (int argc, char* argv[])
{
  int ret = EXIT_SUCCESS ;

  argc-- ;
  argv++ ;

  if (!argc)
    help() ;
  while (argc && ret == EXIT_SUCCESS) {
    if (strcmp(*argv, QUERY_FLAG) == 0 &&
        argc >=2) {
      ret = queries_input(*(argv + 1)) ;
      argc -= 2 ;
      argv += 2 ;
    }
    else if (strcmp(*argv, CRAWLER_FLAG) == 0 &&
             argc >= 3 &&
             is_number(*(argv + 2))) {
      int depth = atoi(*(argv + 2)) ;
      ret = crawl(*(argv + 1), depth) ;
      argc -= 3 ;
      argv += 3 ;
    }
    else {
      help() ;
      break ;
    }
  }
  return ret ;
}

package protocol.flow ;

import exception.UnknownResultException ;
import protocol.AbstractPub ;

public class PubFlow extends AbstractPub implements Flow {
    public PubFlow(byte[] i, int p, String m) throws UnknownResultException {
        super(i, p, m) ;
    }

    public PubFlow(String i,String p,String m) throws UnknownResultException {
        super(i, p, m) ;
    }

    public String toString() {
        return
            FlowVals.PUB + MainVals.SEP +
            new String(this.ip) + MainVals.SEP +
            String.valueOf(this.port) + MainVals.SEP +
            this.message + MainVals.EOF ;
    }
}

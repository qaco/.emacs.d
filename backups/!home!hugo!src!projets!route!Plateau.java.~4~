    public String toString() {
	String s = new String() ;
	for (int i = 0 ; i < Data.NBCASES ; i++) {
	    for (int c = 0 ; c < 3 ; c++) {
		switch(c) {
		case 0 :
		    for (int j = 0 ; j < Data.NBCASES ; j++) {
			s += " " ;
			try {
			    s += cases[i][j].getRoute(Data.TOP).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
			s += " " ;
		    }
		    s += "\n" ;
		    break ;
		case 1 :
		    for (int j = 0 ; j < Data.NBCASES ; j++) {
			try {
			    s += cases[i][j].getRoute(Data.LEFT).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
			
			s+= cases[i][j].toString() ;

			try {
			    s += cases[i][j].getRoute(Data.RIGHT).toString() ;
			} catch (NoRouteException e) {
			    s += " " ;
			}
		    }
		    s += "\n" ;
		    break ;
		case 2 :
		    for (int j = 0 ; j < Data.NBCASES ; j++) {

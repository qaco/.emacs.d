package protocol.knock ;

import exception.UnknownResultException ;

public class FlooKnock extends Knock {
    
    public FlooKnock(int flows) throws UnknownResultException {
        super(flows) ;
    }

    public FlooKnock(byte mylow, byte myhigh) throws UnknownResultException {
        super(mylow, myhigh) ;
    }

    protected byte getCode() {
        return KnockVals.FLOO_CODE ;
    }

    protected String popUp() {
        return KnockVals.FLOO_MESS;
    }
}

#include <stdlib.h>
#include <stdio.h>
#include <sys/types.h>
#include <dirent.h>
#include <sys/stat.h>
#include <unistd.h>
#include <string.h>
#include "treedir.h"

#define CHILDREN_MAX 1024
#define SIZE_PATH 1024

node* new_node(const char* name) {
  int namesize = strlen(name) ;
  node* res = malloc(sizeof(node)) ;
  res->name = malloc(sizeof(char)*namesize) ;
  strcpy(res->name, name) ;
  res->nb_children = 0 ;
  return res ;
}

void delete_node(node* nd) {
  free(nd->name) ;
  free(nd) ;
}

int new_child(node *current, const char* name) {

  // erreur s'il n'y a plus de place dans l'arbre
  if (current->nb_children >= CHILDREN_MAX - 1)
      return -1 ;
  // on cree le node et on le place en tete d'une nouvelle liste
  node* nouveau = new_node(name) ;
  list_node* liste = malloc(sizeof(list_node)) ;
  liste->n = nouveau ;
  // s'il n'y a pas d'enfants, on branche directement la nouvelle liste
  if (current->nb_children == 0)
    current->children = liste ;
  // s'il y a des enfants
  else {
    list_node* tmp ;
    // on recupere un pointeur sur le dernier element de la liste
    tmp = current->children ;
    for (int i = 0 ; i < current->nb_children - 1 ; i++)
      tmp = tmp->next ;
    // on y branche la nouvelle liste
    tmp->next = liste ;
  }
  
  current->nb_children++ ;
  return 0 ;
}

void print_tree(char *prefix, node* current) {
  char* nveau_pref ;
  list_node* suivant ;
  
  if (strlen(prefix) != 0)
    strcat(prefix, ":") ;
  printf("%s%s\n", prefix, current->name) ;

  /* On parcourt la liste des enfants : s'il n'y en a pas, on ne rentre
     pas dans la boucle*/
  for (int i = 0 ; i < current->nb_children ; i++) {
    if (i == 0)
      suivant = current->children ;
    else
      suivant = suivant->next ;
    /* Pour chaque enfant, on construit son nom, qui est aussi le
       prefixe de ses enfants */
    nveau_pref = malloc(sizeof(char)*SIZE_PATH) ;
    strcpy(nveau_pref, prefix) ;
    strcat(nveau_pref, current->name) ;
    /* Et on appelle récursivement la fonction pour traiter ses propres
       enfants */
    print_tree(nveau_pref,suivant->n) ;
    free(nveau_pref) ;
  }
}

static node* get_last_child(node* current) {
    if (current->children->n == NULL)
      return NULL ;
    else {
      list_node* tmp ;
      tmp = current->children ;
      for (int i = 0 ; i < current->nb_children - 1 ; i++)
	tmp = tmp->next ;
      return tmp->n ;
    }
}

static char* current_name() {
  char* path = malloc(sizeof(char)*SIZE_PATH) ;
  char* res = malloc(sizeof(char)*SIZE_PATH) ;
  struct stat buf ;
  ino_t inoeud ;
  DIR* parentdir ;
  struct dirent* tmp ;
  
  getcwd(path, SIZE_PATH) ;
  stat(path, &buf) ;
  inoeud = buf.st_ino ;
  chdir("../") ;
  getcwd(path, SIZE_PATH) ;
  parentdir = opendir(path) ;
  do {
    tmp = readdir(parentdir) ;
    if (tmp != NULL && tmp->d_ino == inoeud) {
      strcpy(res, tmp->d_name) ;
      chdir(res) ;
    }
  } while (tmp != NULL) ;
  closedir(parentdir) ;
  free(path) ;
  return res ; ;
}

static void build_from_path(node* parent, char* path) {
  node* enfant ;
  char *rec_path ;
  DIR* current ;
  struct dirent* tmp ;

  current = opendir(path) ;

  do {
    tmp = readdir(current) ;

    if (tmp != NULL &&
	strcmp(tmp->d_name, ".") && strcmp(tmp->d_name, "..")) {
      new_child(parent, tmp->d_name) ; 
      
      if (tmp->d_type == DT_DIR) {
	/* On fabrique le chemin du sous-dossier */
	rec_path = malloc(sizeof(char)*SIZE_PATH) ;
	strcpy(rec_path, path) ;
	strcat(rec_path, "/") ;
	strcat(rec_path, tmp->d_name) ;

	/* On récupère le node correspondant au sous-dossier et on
	   explore ce dernier */
	enfant = get_last_child(parent) ;
	build_from_path(enfant, rec_path) ;
	
	free(rec_path) ;
	}
    }  
  } while (tmp != NULL) ;

  closedir(current) ;
}
  
node* build_from_current_file() {
  char* name = current_name() ;
  node* res = new_node(name) ;
  char* path = malloc(sizeof(char)*SIZE_PATH) ;

  getcwd(path, SIZE_PATH) ;
  build_from_path(res, path) ;
  free(path) ;
  return res ;
}
    



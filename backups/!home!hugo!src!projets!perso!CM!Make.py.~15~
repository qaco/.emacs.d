import Root,Shutter,Slogan, Paint
from PIL import Image

IMG_MAX = 1200, 630

class Canvas:
    
    def __init__(self, img_path, shut_cmd, shut_col, text_cmd, text_font, text_col):
        self.img = None
        self.shutter = None
        self.slogan = None

        self.img = Image.open(img_path)
        self.img = self.img.convert('RGBA')
        if self.img.size[0] > IMG_MAX[0] or self.img.size[1] > IMG_MAX[1] :
            self.img.thumbnail(IMG_MAX)
        
        self.shutter = Shutter.factory(shut_cmd, self.img.size, shut_col)
        self.shutter.process_position()

        frame = self.shutter.clone_place()
        self.slogan = Slogan.factory(text_cmd, self.img.size, frame, "", text_font, text_col)
        self.slogan.process_position()

        self.logo = None
        
    def change_orientation(self, shutter_cmd):
        mycolor = self.shutter.color
        self.shutter = Shutter.factory(shutter_cmd, self.img.size, mycolor)
        self.shutter.process_position()
        self.slogan.frame = self.shutter.clone_place()
        self.slogan.process_position()
        if self.slogan.is_signed():
            self.logo = Paint.Logo(self.slogan.logo_area, self.logo.path)
            self.logo.process_position()
        
    def sign_text(self, cmd_text, logo_path=None):
        planesize = self.slogan.planesize
        frame = self.slogan.frame
        text = "\n".join(self.slogan.lines)
        font = self.slogan.sfont
        color = self.slogan.color
        self.slogan = Slogan.factory(cmd_text, planesize, frame,
                                     text, font, color)
        self.slogan.process_position()
        if self.slogan.is_signed():
            if logo_path == None: raise ValueError()
            self.logo = Paint.Logo(self.slogan.logo_area, logo_path)
            self.logo.process_position()
        
    def merge_calcs(self) :
        res = self.shutter.stamp_img(self.img)
        res = self.slogan.stamp_img(res)
        if self.slogan.is_signed():
            res = self.logo.stamp_img(res)
        return res



int print_wordlist(WordList mylist, FILE* stream)
{
  WordList tmp = mylist ;
  fprintf(stream, "[ ") ;
  while (tmp.next != NULL) {
    print_word(tmp.word, stream) ;
    fprintf(stream, ", ") ;
    tmp = *(tmp.next) ;
  }
  print_word(tmp.word, stream) ;

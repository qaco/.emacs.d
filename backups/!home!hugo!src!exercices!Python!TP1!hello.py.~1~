def somme_bete(x) :
  """
  Permet de faire une somme bete de 1 à x (for loop)
  """
  sum = 0
  for i in range(x+1) :
    sum = sum+i
  return sum

def somme_rapide(x) :
  """
  Permet de faire une somme rapide de x : (x*(x+1))//2
  """
  return (x*(x+1))//2


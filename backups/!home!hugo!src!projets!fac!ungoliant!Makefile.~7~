CC=gcc
CFLAGS=-std=gnu99 -Wall -Werror -g
PARSEFLAGS=-I/usr/include/libxml2/
CLINKS=-lcurl -ldb
PARSELINKS=-lxml2
EXEC=ungoliant

all: ungoliant

ungoliant: db_manager.o word.o wordlist.o parser.o crawler.o ungoliant.o
	$(CC) -o $@ $^ $(CLINKS) $(PARSELINKS)

query_engine.o: query_engine.c query_engine.h word.o wordlist.o db_manager.o
	$(CC) $(CFLAGS) -o $@ -c $<

word.o: word.c word.h
	$(CC) $(CFLAGS) -o $@ -c $<

wordlist.o: wordlist.c wordlist.h word.o
	$(CC) $(CFLAGS) -o $@ -c $<

parser.o: parser.c parser.h word.o wordlist.o
	$(CC) $(CFLAGS) $(PARSEFLAGS) -o $@ -c $< $(PARSELINKS)

db_manager.o: db_manager.c db_manager.h word.o wordlist.o
	$(CC) $(CFLAGS) -o $@ -c $< $(CLINKS)

crawler.o: crawler.c crawler.h word.o wordlist.o parser.o
	$(CC) $(CFLAGS) -o $@ -c $< $(CLINKS)

ungoliant.o: ungoliant.c crawler.h crawler.c
	$(CC) $(CFLAGS) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf ungoliant

#include <check.h>
#include <stdlib.h>
#include "../misc/word.h"

Word *whole ;

void subword_setup(void) {
  whole = construct_word(strlen("how are you ?"), "how are you ?") ;
}

void subword_teardown(void) {
  destruct_word(whole) ;
}

START_TEST(test_get_subword_correct) {
  Word *sub ;
  int start = 2 ;
  int end = 6 ;
  int ret ;
  char *raw_whole, *raw_sub ;

  raw_whole = malloc(sizeof(char)*(get_size_word(whole) + 1)) ;
  get_content_word(whole, raw_whole) ;
  sub = construct_word(0, NULL) ;
  ret = get_sub_word(sub, whole, start, end) ;
  raw_sub = malloc(sizeof(char)*(get_size_word(sub) + 1)) ;
  get_content_word(sub, raw_sub) ;

  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(*(raw_whole + start), *raw_sub) ;
  ck_assert_int_eq(*(raw_whole + end - 1), *(raw_sub + end - start - 1)) ;

  free(raw_whole) ;
  free(raw_sub) ;
  destruct_word(sub) ;
}
END_TEST

START_TEST(test_get_subword_outofbounds) {
  int min, max, nonsense ;
  
  min = get_sub_word(NULL, whole, -1, 2) ;
  max = get_sub_word(NULL, whole, 0, 100) ;
  nonsense = get_sub_word(NULL, whole, 2, 1) ;

  ck_assert_int_eq(min, EXIT_FAILURE) ;
  ck_assert_int_eq(max, EXIT_FAILURE) ;
  ck_assert_int_eq(nonsense, EXIT_FAILURE) ;
}
END_TEST

START_TEST(test_locate_subword_isin) {
  Word *sub ;
  int ret ;

  sub = construct_word(strlen("are"), "are") ;
  ret = locate_sub_word(whole, sub, 0) ;

  ck_assert_int_eq(ret, 4) ;

  destruct_word(sub) ;
}
END_TEST

START_TEST(test_locate_subword_isout) {
  Word *sub ;
  int ret ;

  sub = construct_word(strlen("bye"), "bye") ;
  ret = locate_sub_word(whole, sub, 0) ;

  ck_assert_int_eq(ret, -1) ;

  destruct_word(sub) ;
}
END_TEST

START_TEST(test_cut_subword_isin) {
  Word *sub, *aim ;
  int test ;

  aim = construct_word(strlen("how you ?"), "how you ?") ;
  sub = construct_word(strlen("are "), "are ") ;
  cut_sub_word(whole, sub) ;
  test = compare_word(aim, whole) == 0 ;

  ck_assert_int_eq(test, 1) ;
}
END_TEST

START_TEST(test_cut_subword_isout) {
  Word *sub, *aim ;
  int test ;

  aim = construct_word(strlen("how are you ?"), "how are you ?") ;
  sub = construct_word(strlen("baba"), "baba") ;
  cut_sub_word(whole, sub) ;
  test = compare_word(aim, whole) == 0 ;

  ck_assert_int_eq(test, 1) ;
}
END_TEST

TCase* word_subword_case(void) {
  TCase* tc_sub ;

  tc_sub = tcase_create("Subword") ;
  tcase_add_checked_fixture(tc_sub, subword_setup, subword_teardown) ;
  tcase_add_test(tc_sub, test_get_subword_correct) ;
  tcase_add_test(tc_sub, test_get_subword_outofbounds) ;
  tcase_add_test(tc_sub, test_locate_subword_isin) ;
  tcase_add_test(tc_sub, test_locate_subword_isout) ;
  tcase_add_test(tc_sub, test_cut_subword_isin) ;
  tcase_add_test(tc_sub, test_cut_subword_isout) ;
  return tc_sub ;
}

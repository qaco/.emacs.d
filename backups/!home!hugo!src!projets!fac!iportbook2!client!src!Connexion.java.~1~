package client.src;

import java.util.NoSuchElementException;
import java.util.Scanner;

public class Connexion {

    private String id, udp, mdp;
    private Scanner sc;

    public Connexion() {
	this.sc = new Scanner(System.in);
    }

    public String formated_udp(int udp) {	
	try {
	    return String.format("%04d", udp);
	} catch (Exception e) {
	    System.out.println("[Problème au formatage.]");
	}
	return "";
    }

    public int getUDPPort(String id) {
	int hash = 7;
	for (int i = 0; i < id.length() ; i++) {
	    hash = hash*3 + id.charAt(i);
	}
	return hash%9999;
    }

    private boolean mdp_verification(String mdp_) {
	int mdp = Integer.parseInt(mdp_);
	if (mdp < 0 || mdp > 65535) {
	    System.out.println("[Le mot de passe est compris entre 0 et 65535.]");
	    return false;
	} else {
	    return true;
	}
    }

    private boolean id_verification(String id) {
	boolean isalphanum = id.matches("^[a-zA-Z0-9]*$");
	if (id.length() == 0 || id.length() > 8 || !isalphanum) {
	    System.out.println(id.length()+" "+isalphanum);
	    System.out.println("[L'identifiant doit contenir au plus 8 caractères alphanumériques.]");
	    return false;
	}
	else {
	    return true;
	}
    }

    private boolean connexion_verification(String id, String mdp) {
	return mdp_verification(mdp) &&
	    id_verification(id); 
    }

    public void connexion_input() {
	int verif_mdp, verif_udp;
    
	try {
	    System.out.print("-- identifiant (max. 8 caractères): ");
	    this.id = this.sc.nextLine();
	    System.out.print("-- mot de passe (entre 0 et 65535) : ");
	    this.mdp = this.sc.nextLine();	    

	    if(connexion_verification(this.id, this.mdp)) {
		this.udp = formated_udp(getUDPPort(id));
	    } else { 
		System.out.println("[Veuillez recommencer.]");
		connexion_input();		
	    }
	} catch (NoSuchElementException e1) {
	    System.out.println("[Merci d'entrer id et mot de passe.]");
	    connexion_input();
	} catch (NumberFormatException e2) {
	    System.out.println("[Le mot de passe doit etre un nombre.]");
	    connexion_input();
	} catch (Exception e3) {
	    System.out.println("Exception client : ");
	    e3.printStackTrace();
	}
    }

    public String getId() {
	return this.id;
    }
    public String getUdp() {
	return this.udp;
    }
    public String getMdp() {
	return this.mdp;
    }

    public void exec() {
	connexion_input();
    }

}

package com.protocol.fromclient ;
public class SomeMessage implements Protocol {

    private int num ;
    private String mess ;

    public SomeMessage (String mynum, String mymess) {
        this.num = Integer.parseInt(mynum) ;
        if (mymess.length() <= 200)
            this.mess = mymess ;
        else
            this.mess = mymess.substring(0, 200) ;
    }

    public SomeMessage (int mynum, String mymess) {
        this.num = mynum ;
        if (mymess.length() <= 200)
            this.mess = mymess ;
        else
            this.mess = mymess.substring(0, 200) ;
    }

    public String toString() {
        String mynum = String.valueOf(this.num) ;
        return "MENUM " + mynum + " " + this.mess + "+++" ;
    }
}

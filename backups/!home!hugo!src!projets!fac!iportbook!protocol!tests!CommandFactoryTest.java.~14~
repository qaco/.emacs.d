package protocol.tests ;

import exception.UnknownResultException ;
import protocol.command.* ;
import static org.junit.Assert.* ;
import org.junit.Test;
import org.junit.Before;

public class CommandFactoryTest {

    private CommandFactory pf ;

    @Before
    public final void setCommandFactoryUp() {
        this.pf = new  CommandFactory() ;
    }

    @Test
    public final void testAskFriendBuild() {
        String tmp = "FRIE? toto+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            // e.printStackTrace() ;
            fail() ;
        }
    }

    @Test(expected=UnknownResultException.class)
    public final void testAskIdTooLong() throws UnknownResultException {
        String tmp = "FRIE? tototototo+++" ;
        this.pf.create(tmp) ;
    }

    @Test(expected=UnknownResultException.class)
    public final void testAskIdEmpty() throws UnknownResultException {
        String tmp = "FRIE? +++" ;
        this.pf.create(tmp) ;
    }
        
    @Test
    public final void testFirstMessageBuild() {
        String tmp = "MESS? toto 12+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }

    @Test(expected=UnknownResultException.class)
    public final void testFirstMessageInfOne() throws UnknownResultException {
        String tmp = "MESS? toto -12+++" ;
        this.pf.create(tmp) ;
    }

    @Test(expected=UnknownResultException.class)
    public final void testFirstMessageNotInt() throws UnknownResultException {
        String tmp = "MESS? toto haha+++" ;
        this.pf.create(tmp) ;
    }

    @Test
    public final void testSomeMessageBuild() {
        String tmp = "MENUM 2 hello how are you+++" ;
        try {
            int num = SomeMessage.extractNum(tmp) ;
            String mess = SomeMessage.extractMess(tmp) ;
            SomeMessage m = new SomeMessage(num, mess) ;
            assertEquals(tmp, m.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }

    @Test
    public final void testSomeMessageEmpty() {
        String tmp = "MENUM 2 +++" ;
        try {
            int num = SomeMessage.extractNum(tmp) ;
            String mess = SomeMessage.extractMess(tmp) ;
            SomeMessage m = new SomeMessage(2, "") ;
            assertEquals(tmp, m.toString()) ;
        } catch (UnknownResultException e) {
            e.printStackTrace() ;
            fail() ;
        }
    }

    @Test(expected=UnknownResultException.class)
    public final void testSomeMessageInfOne() throws UnknownResultException {
        String tmp = "MENUM -2 hello how are you+++" ;
        this.pf.create(tmp) ;
    }

    @Test(expected=UnknownResultException.class)
    public final void testSomeMessageNotInt() throws UnknownResultException {
        String tmp = "MENUM haha hello how are you+++" ;
        this.pf.create(tmp) ;
    }

    @Test(expected=UnknownResultException.class)
    public final void testSomeMessageTooLong() throws UnknownResultException {
        StringBuffer a = new StringBuffer() ;
        for (int i = 0 ; i < 400 ; i++)
            a.append('a') ;
        String tmp = "MENUM 2 " + a.toString() + "+++" ;
        this.pf.create(tmp) ;
    }

    @Test
    public final void testFlooMessageBuild() {
        String tmp = "FLOO? hello how are you+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }

    @Test(expected=UnknownResultException.class)
    public final void testFlooMessageTooLong() throws UnknownResultException {
        StringBuffer a = new StringBuffer() ;
        for (int i = 0 ; i < 400 ; i++)
            a.append('a') ;
        String tmp = "FLOO? " + a.toString() + "+++" ;
        this.pf.create(tmp) ;
    }

    @Test
    public final void testSeeListBuild() {
        String tmp = "LIST?+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }

    @Test
    public final void testConsultationBuild() {
        String tmp = "CONSU+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }
    
    @Test
    public final void testDeconnectionBuild() {
        String tmp = "IQUIT+++" ;
        try {
            Command p = this.pf.create(tmp) ;
            assertEquals(tmp, p.toString()) ;
        } catch (UnknownResultException e) {
            fail() ;
        }
    }
}

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "word.h"

Word construct_word(const char *src, const size_t n)
{
  Word res ;

  res.memory = malloc(sizeof(char)*n) ;
  memcpy(res.memory, src, sizeof(char)*n) ;
  res.size = n ;
  res.allocated = n ;

  return res ;
}

Word construct_empty_word()
{
  Word res ;

  res.memory = malloc(sizeof(char)) ;
  res.size = 0 ;
  res.allocated = 1 ;

  return res ;
}

Word construct_null_word()
{
  Word res ;

  res.memory = NULL ;
  res.size = 0 ;
  res.allocated = 0 ;

  return res ;
}

int is_null_word(Word myword)
{
  return myword.allocated == 0 ;
}

char get_char_word(const Word myword, const int index)
{
  char res ;
  
  if (index < myword.size)
    res = *(myword.memory + index) ;
  else
    res = -1 ;

  return res ;
}

char* get_cstring_word(const Word myword)
{
  char* res = malloc(sizeof(char)*(myword.size + 1)) ;

  for (int i = 0 ; i < myword.size ; i++)
    *(res + i) = get_char_word(myword, i) ;
  *(res + myword.size) = '\0' ;

  return res ;
}

size_t get_size_word(const Word myword)
{
  return myword.size ;
}

int destruct_word(Word* myword)
{
  if (!is_null_word(*myword)) {
    free(myword->memory) ;
    *myword = construct_null_word() ;
  }

  return 0 ;
}

int add_char_word(Word* myword, const char mychar)
{
  if (is_null_word(*myword))
    return -1 ;
  
  if (myword->size >= myword->allocated) {
    myword->memory = realloc(myword->memory, myword->allocated*2) ;
    myword->allocated *= 2 ;
  }
  *(myword->memory + myword->size) = mychar ;
  myword->size++ ;

  return 0 ;
}

int insert_char_word(Word* myword, const char mychar, const int index)
{
  char *tmp ;

  if (is_null_word(*myword) || index >= myword->size)
    return -1 ;
    
  if (myword->size >= myword->allocated) {
    tmp = malloc(myword->allocated*2) ;
    myword->allocated *= 2 ;
  }
  else
    tmp = malloc(myword->allocated) ;

  memcpy(tmp, myword->memory, sizeof(char)*index) ;
  *(tmp + index) = mychar ;
  memcpy(tmp + index + 1,
         myword->memory + index,
         myword->size - sizeof(char)*(index-1)) ;
  free(myword->memory) ;
  myword->memory = tmp ;
  myword->size++ ;

  return 0 ;
}

int remove_char_word(Word* myword, const int index)
{
  char* tmp ;

  if (is_null_word(*myword) || index >= myword->size)
    return -1 ;

  if (myword->size <= myword->allocated/4) {
    tmp = malloc(myword->allocated/2) ;
    myword->allocated /= 2 ;
  }
  else
    tmp = malloc(myword->allocated) ;

  memcpy(tmp, myword->memory, sizeof(char)*index) ;
  memcpy(tmp + index,
         myword->memory + index + 1,
         myword->size - sizeof(char)*(index + 1)) ;
  free(myword->memory) ;
  myword->memory = tmp ;
  myword->size-- ;

  return 0 ;
}

int print_word(Word myword, FILE* stream)
{
  for (int i = 0 ; i < myword.size ; i++)
    if (fprintf(stream, "%c", *(myword.memory + i)) < 0)
      return -1 ;
  fprintf(stream, "\n") ;
  return 0 ;
}

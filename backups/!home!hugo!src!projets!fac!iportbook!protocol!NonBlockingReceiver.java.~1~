package protocol ;

public class NonBlockingReceiver extends AbstractReceiver {

    public AbstractReceiver(byte mysep, byte[] mysuf) {
        super(mysep, mysuf) ;
    }

    protected byte[][] readStream(SocketChannel so) throws UnknownResultException {
        ByteBuffer buf = ByteBuffer.allocate(300) ;
        int bytesread = so.read(buf);
        byte[] raw = buf.array() ;
        byte[][] res ;
        int isuf = this.findSuffix() ;
        if (isuf < 0)
            throw new UnknownResultException("suffixe illégal") ;
        raw = Arrays.copyOfRange(raw, 0, raw.length - suffix.length) ;
        
        res = this.splitInput(raw, 32) ;
        return res ;
    }

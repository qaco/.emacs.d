#define _XOPEN_SOURCE
#define _GNU_SOURCE

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <time.h>
#include <limits.h>

#define SIZE_PATH 1024
#define SIZE_DATE 19
#define S_TO_N 1000000000
#define FORMAT "%C%y-%m-%dT%H:%M:%S"

int main(int argc, char* argv[]) {
  int descripteur ;
  mode_t mode = S_IRUSR | S_IWUSR | S_IRGRP | S_IROTH ;
  int a = 0, m = 0, d = 0 ;
  struct timespec tab[2] ;
  struct tm date ;
  char* temp ;
  char* format ;
  char* ret ;
  
  argc-- ;
  argv++ ;

  while(argc > 0 && *argv[0] == '-') {
    temp = argv[0] + 1;
    size_t i;
    for (i = 0 ; temp[i] ; i++) {
      switch(temp[i]) {
      case 'a' :
	a = 1 ;
	break ;
      case 'm' :
	m = 1 ;
	break ;
      case 'd' :
	d = 1 ;
	break ;
      default :
	goto execution ;
	break ;
      }
    }
    argc-- ;
    argv++ ;
  }
      
 execution :

  if (d) {
    temp = argv[0] ;
    format = malloc(sizeof(char)*SIZE_DATE) ;
    strcpy(format, FORMAT) ;
    ret = strptime(temp, format, &date) ;
    if (ret == NULL) {
      perror("date : informations incorrectes") ;
      exit(EXIT_FAILURE) ;
    }
    printf("sec %d\nmin %d\nhour %d\n",
	   date.tm_sec, date.tm_min, date.tm_hour) ;
    printf("day %d\nmon %d\nyear %d\n",
	   date.tm_mday, date.tm_mon, date.tm_year) ;
    
    tab[0].tv_sec = mktime(&date) ;
    tab[1].tv_sec = mktime(&date) ;
    if (tab[0].tv_sec == -1) {
      perror("date : informations incorrectes") ;
      exit(EXIT_FAILURE) ;
    }

    argc-- ;
    argv++ ;
  }
  else {
    tab[0].tv_nsec = UTIME_NOW ;
    tab[1].tv_nsec = UTIME_NOW ;
  }
  
  if (!a)
    tab[0].tv_nsec = UTIME_OMIT ;
  if (!m)
    tab[1].tv_nsec = UTIME_OMIT ;

  if (!argc) {
    perror("touch: opérande de fichier manquant") ;
    return EXIT_FAILURE ;
  }
  
  while (argc) {
    if(access(*(argv + argc - 1), F_OK)) { // n'existe pas
      descripteur = creat(*(argv + argc - 1), mode) ;
      futimens(descripteur, tab) ;
      close(descripteur) ;
    }

    else { // existe 
      utimensat(AT_FDCWD, *(argv + argc - 1), tab, 0) ;
    }

    argc-- ;
    argv++ ;
  }

  return 0 ;
}

public abstract class AbstractReceiver {
    private byte[] raw ;

    protected byte[][] splitInput(byte sep) {
        int numsp = 0 ;
        int spi[] ;
        int spcount = 0 ;
        byte[][] res ;

        // setup
        for (int i = 0 ; i < data.length ; i++)
            if (data[i] == sep)
                numsp++ ;
        spi[i] = new int[numsp] ;
        res = new byte[numsp - 1] ;
        for (int i = 0 ; i < data.length ; i++)
            if (data[i] == sep)
                spi[spcount++] = i ;

        for (int i = 0 ; i < spi.length - 1 ; i++) {
            int start ;
            int end ;
            int mysize ;
            if (i == 0) start = 0 ;
            else start = spi[i-1] + 1 ;
            if (i == spi.length - 1) end = spi.length ;
            else end = spi[i] ;
            mysize = end - start ;
            res[i] = new byte[mysize] ;
            for (int j = 0 ; j < mysize ; j++)
                res[i][j] = data[start+j] ;
        }
        return res ;
    }

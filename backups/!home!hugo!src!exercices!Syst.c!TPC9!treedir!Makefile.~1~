CC=gcc
CFLAGS=-std=gnu99 -Wall
EXEC=main
SRC=treedir.c main.c
OBJ=$(SRC:.c=.o)

all : $(EXEC)

main : $(OBJ)
	$(CC) -o $@ $^

main.o : treedir.h

treedir.o : treedir.h

%.o: %.c
	$(CC) $(CFLAGS) -o $@ -c $<

check-syntax:
	gcc -o nul -S ${CHK_SOURCES}

clean :
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

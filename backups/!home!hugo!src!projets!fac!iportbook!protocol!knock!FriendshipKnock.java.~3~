package protocol.knock ;

import exception.UnknownResultException ;

public class FriendshipKnock extends Knock {
    
    public FriendshipKnock(int flows) throws UnknownResultException {
        super(flows) ;
    }

    public FriendshipKnock(byte mylow, byte myhigh) throws UnknownResultException {
        super(mylow, myhigh) ;
    }

    protected byte getCode() {
        return KnockVals.FRIENDSHIP_CODE ;
    }

    protected String popUp() {
        return KnockVals.FRIENDSHIP_MESS;
    }
}

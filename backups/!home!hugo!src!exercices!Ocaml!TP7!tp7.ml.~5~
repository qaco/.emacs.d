open Array ;;
open Graphics ;;

type player = Red | Yellow ;;
type cell = Empty | Pawn of player ;;
type outcome = Draw | Open | Win of player ;;
type board = cell array array ;;

let init:board = make_matrix 7 6 Empty ;;

let rec play b p c = 
  if (length b = 0 || b.(0).(c) != Empty) then
    failwith "Colonne pleine"
  else if (length b = 1 || b.(1).(c) != Empty) then
    (b.(0).(c) <- Pawn(p) ; 0)
  else 1 + (play (sub b 1 ((length b) -1)) p c)
;;
  
let eval plat =
  let rec compute x y b =
    if (length b <= y) then
      if (exists (fun t -> exists (fun el -> el = Empty) t) b)
      then Open
      else Draw
    else if (length b.(y) <= x) then compute 0 (y+1) b
    else if (b.(y).(x) != Empty &&
	       ((length b > y + 3 
		 && b.(y).(x) = b.(y+1).(x)
		 && b.(y).(x) = b.(y+2).(x)
		 && b.(y).(x) = b.(y+3).(x)) ||
		  (length b.(y) > x + 3 
		   && b.(y).(x) = b.(y).(x+1)
		   && b.(y).(x) = b.(y).(x+2)
		   && b.(y).(x) = b.(y).(x+3)) ||
		    (length b > y + 3 && length b.(y) > x + 3 
		     && b.(y).(x) = b.(y+1).(x+1)
		     && b.(y).(x) = b.(y+2).(x+2)
		     && b.(y).(x) = b.(y+3).(x+3)) ||
		      (0 <= y - 3 && length b.(y) > x + 3 
		       && b.(y).(x) = b.(y+1).(x-1)
		       && b.(y).(x) = b.(y+2).(x-2)
		       && b.(y).(x) = b.(y+3).(x-3)))) then
      (match (b.(y).(x)) with
       | Empty -> failwith "bug"
       | Pawn(p) -> Win(p))
    else compute (x+1) y b
  in compute 0 0 plat ;;


let draw_empty_board() =
  let rec manage_circles x y =
    if (y + 100 > 700) then ()
    else if (x + 100 > 600) then manage_circles 0 (y+100)
    else (fill_circle (x+50) (y+50) 40 ;
	  manage_circles (x+100) y)
  in set_color (rgb 0 0 255) ;
     fill_rect 0 0 600 700 ;
     set_color (rgb 255 255 255) ;
     manage_circles 0 0
;;

let draw_symbol i j p =
  let rec change_color pl = match pl with
    | Red -> set_color (rgb 255 0 0)
    | Yellow -> set_color (rgb 255 215 0)
  in change_color p ;
     fill_circle (j * 100 + 50) (i * 100 + 50) 40
;;

let rec next_move b p =
  let e = wait_next_event[Button_down] in
  let x = e.mouse_x in
  if (b.(0).(x/100) != Empty) then next_move b p
  else x/100
;;

let main() =
  open_graph(" 600x700") ;
  draw_empty_board() ;
  let init:board = make_matrix 7 6 Empty in
      while (eval init = Open) do
	let col = next_move init Red in
	draw_symbol (play init Red col) col Red ;
	if (eval init = Open) then
	  let col = next_move init Yellow in
	   draw_symbol (play init Yellow col) col Yellow
      done ; close_graph()
;;

  main() ;;

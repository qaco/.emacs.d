void handle_FILE(char *sub_message) { // DATA MESSAGES UNCHECKED
  int series_nb, id_writer, index, i, recipient_index, id_transfer, length, fd, fd_server;
  char *formated_message, *validation_message;
  long int file_size, message_nb, i_long;
  Str *recipient_user_name, *file_name;

  printf("FILE : %s\n", sub_message);

  sscanf(sub_message, "%4d", &series_nb);

  if (series_nb != 0) {
    printf("FAILURE: First series number %d does not match\n", series_nb);
    return;
  }
  printf("-Series number: %d\n", series_nb);

  sub_message = &sub_message[4];

  sscanf(sub_message, "%4d", &id_writer);

  if ((index = get_client_index(id_writer)) == -1) {
    printf("FAILURE: Client (ID)%d does not exist\n", id_writer);
    return;
  }
  printf("-ID: %d\n", id_writer);

  sub_message = &sub_message[4];

  if ((recipient_user_name = create_Str(sub_message)) == NULL) {
    printf("PROTOCOL_ERROR <|-|-|> Recipient username length\n");
    return;
  }

  recipient_index = -1;
  for (i = 0; i < get_size(); i++)
    if (!strcmp(get_element(i)->user_name, recipient_user_name->str)) {
      recipient_index = i;
      break;
    }

  if (recipient_index == -1) {
    fd = open(get_element(index)->pipe_name, O_WRONLY);
    write(fd, "0008" TYPE_3, 8);
    close(fd);

    printf("FAILURE: Client AS '%s' does not exist\n", recipient_user_name->str);

    free_Str(recipient_user_name);
    return;
  }
  
  printf("-Recipient username: %s / Length: %d\n", recipient_user_name->str, recipient_user_name->len);

  sub_message = &sub_message[4+recipient_user_name->len];

  sscanf(sub_message, "%8ld", &file_size);
  
  printf("-File size: %ld\n", file_size);

  sub_message = &sub_message[4];

  if ((file_name = create_Str(sub_message)) == NULL) {
    printf("PROTOCOL_ERROR <|-|-|> File name length\n");
    return;
  }
  printf("-File name: %s / Length: %d\n", file_name->str, file_name->len);

  id_transfer = get_new_transfer_id();

  // ----------- Envoi du message OKOK a l'envoyeur ----------- //
  validation_message = malloc(13*sizeof(char));
  strcpy(validation_message, "0012" TYPE_2);
  strcpy_number_to_string(&validation_message[8], id_transfer);
  fd = open(get_element(index)->pipe_name, O_WRONLY);
  write(fd, validation_message, 12);
  close(fd);
  
  length = 28+file_name->len;
  formated_message = malloc((length+1)*sizeof(char));

  // ----------- Envoi du message FILE, demarrant le transfert du fichier, au destinataire ------------ //
  strcpy_number_to_string(formated_message, length);
  strcat(formated_message, TYPE_9 "0000");
  strcpy_number_to_string(&formated_message[12], id_transfer);
  sprintf(&formated_message[16], "%08ld", file_size);
  formated_message[20] = '\0';
  strcat(formated_message, file_name->str);
 
  fd = open(get_element(recipient_index)->pipe_name, O_WRONLY);
  write(fd, formated_message, length);
  /* close(fd);

  printf("SUCCESS: File from client (ID)%d USING '%s' AS '%s' starting to transfer to client (ID)%d USING '%s' AS '%s'\n",
	 get_element(index)->id, get_element(index)->pipe_name, get_element(index)->user_name,
	 get_element(i)->id, get_element(i)->pipe_name, get_element(i)->user_name);

  free_Str(file_name);

  message_nb = file_size/256+1;

  length = 16+256;
  formated_message = string_realloc(&formated_message, length+1);
  formated_message[length] = '\0';

  fd_server = open(PIPE_SERVER, O_RDONLY);
  for (i_long = 0; i_long < message_nb; i++) {
    read(fd_server, formated_message, length);
    printf("-Computing %ld/%ld\n", i_long, message_nb);
    write(fd, formated_message, length);
  }
  close(fd_server);
  close(fd);

  printf("SUCCESS: File transfered\n");

  free_Str(recipient_user_name);
  free(validation_message);
  free(formated_message);
}

Str *create_Str(char *sub_message) {
  Str *string = malloc(sizeof(Str *));

  sscanf(sub_message, "%4d", &string->len);
  if (string->len > strlen(&sub_message[4])) {
    free(string);
    return NULL;
  }
  string->str = get_substring(sub_message, 4, string->len+4);

  return string;
}

void free_Str(Str *string) {
  free(string->str);
  free(string);
}

void strcpy_number_to_string(char *string, int n) {
  sprintf(string, "%04d", n);
  string[4] = '\0';
}

char *get_substring(char *string, int beginIndex, int endIndex) {
  int len = endIndex-beginIndex;
  char *buffer = malloc((len+1)*sizeof(char));

  strncpy(buffer, &string[beginIndex], len);
  buffer[len] = '\0';

  return buffer;
}

int get_new_client_id() {return (new_client_id++)%9999;}

int get_new_transfer_id() {return (new_transfer_id++)%9999;}

int get_client_index(int id) {
  int i;
  for (i = 0; i < get_size(); i++)
    if (get_element(i)->id == id)
      return i;
  return -1;
}

void connect_new_client(int id, char *user_name, char *pipe_name) {
  Client *new_client = malloc(sizeof(Client *));
  new_client->id = id;
  new_client->user_name = user_name;
  new_client->pipe_name = pipe_name;
  add_element_last(new_client);
}

void disconnect_client(int index) {
  Client *client = remove_element(index);
  free(client->user_name);
  free(client->pipe_name);
  free(client);
}

char *string_realloc(char **ptr, size_t size) {
  char *new_ptr;

  while ((new_ptr = realloc(*ptr, size)) == NULL);

  return new_ptr;
}

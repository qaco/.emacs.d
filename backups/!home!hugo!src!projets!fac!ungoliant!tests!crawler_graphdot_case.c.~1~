#include <check.h>
#include <stdio.h>
#include <stdlib.h>
#include "../crawl/crawler.h"

WordDict *netgraph ;
Word *dot_text ;

void crawler_graphdot_setup(void) {
  Word* key = construct_word(strlen("url"), "url") ;
  WordList* values = build_empty_wordlist() ;
  add_charseq_wordlist(values, "truc", strlen("truc")) ;
  add_charseq_wordlist(values, "machin", strlen("machin")) ;
  add_charseq_wordlist(values, "bidule", strlen("bidule")) ;
  netgraph = construct_empty_worddict() ;
  add_line_worddict(netgraph, key, values) ;

  dot_text = construct_word(strlen("digraph netgraph {\n"),
                            "digraph netgraph {\n") ;
  add_chars_word(dot_text, "url\n", strlen("url\n")) ;
  add_chars_word(dot_text, "url -> truc\n", strlen("url -> truc\n")) ;
  add_chars_word(dot_text, "url -> machin\n", strlen("url -> machin\n")) ;
  add_chars_word(dot_text, "url -> bidule\n", strlen("url -> bidule\n")) ;
  add_chars_word(dot_text, "}\n", strlen("}\n")) ;
}

void crawler_graphdot_teardown(void) {
  destruct_worddict(netgraph) ;
  destruct_word(dot_text) ;
}

START_TEST(test_graphtodot) {
  int ret, test ;
  FILE* dotfile ;
  Word* end_dot ;
  Word* title ;
  Word* raw_dot ;
  size_t file_size ;
  char* buffer ;
  
  ret = graph_to_dotfile(netgraph, "netgraph.dot") ;

  dotfile = fopen("netgraph.dot", "rb");
  fseek(dotfile, 0, SEEK_END);
  file_size = ftell(dotfile);
  fseek(dotfile, 0, SEEK_SET);
  buffer = malloc(file_size + 1);
  fread(buffer, file_size, 1, dotfile);
  *(buffer + file_size) = 0;
  end_dot = construct_word(file_size, buffer) ;

  title = construct_word(strlen("netgraph"), "netgraph") ;
  raw_dot = worddict_to_dot(title, netgraph) ;

  test = compare_word(raw_dot, end_dot) ;

  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(test, 0) ;

  destruct_word(end_dot) ;
  destruct_word(title) ;
  destruct_word(raw_dot) ;
  fclose(dotfile) ;
  remove("netgraph.dot") ;
  free(buffer) ;
}
END_TEST

START_TEST(test_dottograph) {
  int test, ret ;
  WordDict* dest = construct_empty_worddict() ;

  graph_to_dotfile(netgraph, "netgraph.dot") ;
  ret = dotfile_to_graph(dest, "netgraph.dot") ;
  test = is_equal_worddict(dest, netgraph) ;

  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(test, 1) ;
  
  destruct_worddict(dest) ;
}
END_TEST

TCase* crawler_graphdot_case(void) {
  TCase* tc_graphdot ;

  tc_graphdot = tcase_create("Crawler graphdot") ;
  tcase_add_checked_fixture(tc_graphdot,
                            crawler_graphdot_setup,
                            crawler_graphdot_teardown) ;
  tcase_add_test(tc_graphdot, test_graphtodot) ;
  tcase_add_test(tc_graphdot, test_dottograph) ;
  return tc_graphdot ;
}

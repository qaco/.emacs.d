#include <check.h>
#include <stdlib.h>
#include "../misc/wordlist.h"
#include "../misc/word.h"

WordList* mylist ;
Word *first, *second, *third, *dest ;

void accessor_wordlist_setup(void) {
  mylist = construct_empty_wordlist() ;
  first = construct_word("hello", strlen("hello")) ;
  second = construct_word("bye", strlen("bye")) ;
  third = construct_word("haha", strlen("haha")) ;
  dest = construct_empty_word() ;
}

void accessor_wordlist_teardown(void) {
  destruct_wordlist(mylist) ;
  destruct_word(first) ;
  destruct_word(second) ;
  destruct_word(third) ;
  destruct_word(dest) ;
}

START_TEST(test_get_word_correct) {
  int ret, test ;

  add_word_wordlist(mylist, first) ;
  add_word_wordlist(mylist, second) ;
  add_word_wordlist(mylist, third) ;

  ret = get_word_wordlist(dest, mylist, 0) ;
  test = compare_word(dest, first) == 0 ;
  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(test, 1) ;

  ret = get_word_wordlist(dest, mylist, 1) ;
  test = compare_word(dest, second) == 0 ;
  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(test, 1) ;

  ret = get_word_wordlist(dest, mylist, 2) ;
  test = compare_word(dest, third) == 0 ;
  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(test, 1) ;
}
END_TEST

START_TEST(test_get_word_outofbounds) {
  int ret ;

  ret = get_word_wordlist(NULL, mylist, -1) ;
  ck_assert_int_eq(ret, EXIT_FAILURE) ;
  ret = get_word_wordlist(NULL, mylist, 1) ;
  ck_assert_int_eq(ret, EXIT_FAILURE) ;
}
END_TEST

START_TEST(test_pop_word_empty) {
  int ret ;
  ret = pop_word_wordlist(NULL, mylist) ;
  ck_assert_int_eq(ret, EXIT_FAILURE) ;
}
END_TEST

START_TEST(test_pop_word_notempty) {
  int ret, test, initsize, endsize ;

  add_word_wordlist(mylist, first) ;
  initsize = get_length_wordlist(mylist) ;
  
  ret = pop_word_wordlist(dest, mylist) ;
  endsize = get_length_wordlist(mylist) ;
  test = compare_word(first, dest) == 0 ;
  
  ck_assert_int_eq(ret, EXIT_SUCCESS) ;
  ck_assert_int_eq(test, 1) ;
  ck_assert_int_eq(initsize, endsize + 1) ;
}
END_TEST

START_TEST(test_addall_wordlist) {
  WordList *yourlist ;
  int test ;

  add_word_wordlist(mylist, first) ;
  add_word_wordlist(mylist, second) ;
  add_word_wordlist(mylist, third) ;
  yourlist = construct_empty_wordlist() ;
  add_word_wordlist(yourlist, first) ;
  add_word_wordlist(yourlist, second) ;
  add_word_wordlist(yourlist, third) ;
  addall_wordlist(mylist, yourlist) ;

  get_word_wordlist(dest, mylist, 3) ;
  test = compare_word(dest, first) == 0 ;
  ck_assert_int_eq(test, 1) ;

  get_word_wordlist(dest, mylist, 4) ;
  test = compare_word(dest, second) == 0 ;
  ck_assert_int_eq(test, 1) ;

  get_word_wordlist(dest, mylist, 5) ;
  test = compare_word(dest, third) == 0 ;
  ck_assert_int_eq(test, 1) ;

  destruct_wordlist(yourlist) ;
} END_TEST

TCase* wordlist_accessor_case(void) {
  TCase* tc_acc ;

  tc_acc = tcase_create("WordList accessors") ;
  tcase_add_checked_fixture(tc_acc,
                            accessor_wordlist_setup,
                            accessor_wordlist_teardown) ;
  tcase_add_test(tc_acc, test_get_word_correct) ;
  tcase_add_test(tc_acc, test_get_word_outofbounds) ;
  tcase_add_test(tc_acc, test_pop_word_empty) ;
  tcase_add_test(tc_acc, test_pop_word_notempty) ;
  tcase_add_test(tc_acc, test_addall_wordlist) ;

  return tc_acc ;
}

package protocol.command ;

import protocol.field.* ;
import main.MainVals ;
import exception.UnknownResultException ;

public class SomeMessage {

    private NumMessField num ;
    private MessField mess ;

    public SomeMessage (int mynu, String mymess) {
        this.num = new NumMessField(mynu) ;
        this.mess = new MessField(mymess) ;
    }

    public SomeMessage (String mynu, String mymess) {
        this.num = new NumMessField(mynu) ;
        this.mess = new MessField(mymess) ;
    }

    public int getNum() {
        return this.num.getInt() ;
    }

    public String getMess() {
        return this.mess.toString() ;
    }

    public String toString() {
        return
            CommandVals.SOME_MESSAGE + " " +
            this.num.toString() + " " + this.mess.toString() + MainVals.EOF  ;
    }
}

#include <stdlib.h>
#include <gtk/gtk.h>

#define C_SIZE 20

void OnDestroy(GtkWidget *pWidget, gpointer pData) {
    gtk_main_quit();
}

GtkWidget*** fill_window(GtkWidget* window, const int num_cells, char** map) {
  GtkWidget* vbox ;
  GtkWidget* hbox ;
  GtkWidget*** buttons = malloc(num_cells*sizeof(GtkWidget**)) ;
  for (int i = 0 ; i < num_cells ; i++)
    *(buttons+i) = malloc(num_cells*sizeof(GtkWidget*)) ;
  char etiquette[2] ;
  etiquette[1] = '\0' ;
  
  vbox = gtk_vbox_new(TRUE, 0);
  gtk_container_add(GTK_CONTAINER(window), vbox);

  for (int i = 0 ; i < num_cells ; i++) {
    hbox = gtk_hbox_new(TRUE, 0);
    for (int j = 0 ; j < num_cells ; j++) {
      etiquette[0] = map[i][j] ;
      *(*(buttons+i) + j) = gtk_button_new_with_label(etiquette) ;
      gtk_box_pack_start(GTK_BOX(hbox), *(*(buttons+i)+j), TRUE, TRUE, 0);
    }
    gtk_box_pack_start(GTK_BOX(vbox), hbox, TRUE, TRUE, 0);
  }
  return buttons ;
}

  

GtkWidget* conf_window(const int num_cells) {
  GtkWidget *window;
  int width = num_cells * C_SIZE ;
  int height = width ;

  window = gtk_window_new(GTK_WINDOW_TOPLEVEL);

  gtk_window_set_position(GTK_WINDOW(window), GTK_WIN_POS_CENTER);
  gtk_window_set_default_size(GTK_WINDOW(window), height, width);
  g_signal_connect(G_OBJECT(window), "destroy", G_CALLBACK(OnDestroy), NULL);
  return window ;
}




package protocol ;

import exception.UnknownResultException ;

public abstract class AbstractFirstMessage {

    protected String id ;
    protected int num ;

    public AbstractFirstMessage (String myid, String mynum)
        throws UnknownResultException {
        this.id = myid ;
        try {
            this.num = Integer.parseInt(mynum) ;
        } catch (NumberFormatException e) {
            throw new UnknownResultException() ;
        }
        if (this.illegalAttributes())
            throw new UnknownResultException() ;
    }

    public AbstractFirstMessage (String myid, int mynum)
        throws UnknownResultException {
        this.id = myid ;
        this.num = mynum ;
        if (this.illegalAttributes())
            throw new UnknownResultException() ;
    }

    private boolean illegalAttributes() {
        return this.num < 0 ;
    }
}

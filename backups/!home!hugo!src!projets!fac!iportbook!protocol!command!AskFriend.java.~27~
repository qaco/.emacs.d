package protocol.command ;

import main.MainVals ;
import exception.* ;
import service.User ;
import protocol.feedback.* ;
import protocol.field.* ;
import protocol.flow.AskFriendFlow ;
import protocol.knock.FriendshipKnock ;
import java.util.List ;
import java.io.IOException ;

public class AskFriend implements Command {
    private IdField id ;

    public AskFriend (byte[] myid) throws UnknownResultException {
        this.id = new IdField(myid) ;
    }
    
    public AskFriend (String myid) {
        this.id = new IdField(myid) ;
    }

    public void exec(User one, List<User> all) throws UnknownResultException,
                                                      IOException {
        String myid = this.id.toString() ;
        if (!one.isAFriend(myid)) {
            User target = null ;
            Feedback confirm ;
            for (User guy : all)
                if (guy.getId().equals(myid))
                    target = guy ;
            if (target == null) {
                one.sendTCP(new AskFriendNO()) ;
                throw new NotExecutableException("AskFriend",
                                                 myid + " does not exist");
            }
            else if (target.isBlocking(one)) {
                one.sendTCP(new AskFriendNO()) ;
                throw new NotExecutableException("AskFriend",
                                                 myid + " is blocked");
            }
            else {
                one.sendTCP(new AskFriendOK()) ;
                target.pushFlow(new AskFriendFlow(one.getId())) ;
                target.sendUDP(new FriendshipKnock(target.howManyFlows())) ;
                this.describeAskTransmitted(one.getId()) ;
            }
        }
        else {
            one.sendTCP(new AskFriendNO()) ;
            throw new NotExecutableException("AskFriend",
                                             myid + " is a friend yet");
        }
    }

    public byte[] toBytes() {
        Field[] fields = { this.id } ;
        return Field.makeSentence(CommandVals.ASK_FRIEND, fields) ;
    }
    
    public String toString() {
        return
            CommandVals.ASK_FRIEND + " " + this.id.toString() +
            MainVals.EOF ;
    }

    private void describeAskTransmitted(String whoasks) {
        MainVals.describe(this.id.toString()+" asked for friend by "+whoasks) ;
    }
}

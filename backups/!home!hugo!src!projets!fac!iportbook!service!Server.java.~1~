package service ;

import java.net.ServerSocket ;
import java.net.Socket ;
import java.io.Reader ;
import java.io.InputStream ;
import java.io.InputStreamReader ;
import java.io.IOException ;
import java.lang.Thread ;
import java.lang.Runnable ;
import java.util.List ;
import java.util.LinkedList ;

import exception.UnknownResultException ;
import protocol.ProtocolFactory ;
import protocol.command.AnonFactory ;
import protocol.command.Anon ;
import protocol.command.CommandFactory ;
import protocol.command.Command ;

public class Server {

    private ServerSocket mainsocket ;
    private List<User> allusers ;

    public Server(int port) throws IOException {
        this.mainsocket = new ServerSocket(port) ;
        this.allusers = new LinkedList<User>() ;
    }
    
    public void mainLoop() throws IOException {
        int i = 1 ;
        while (true) {
            Socket s = this.mainsocket.accept() ;
            Thread t = new Thread(new UserLife(s, i)) ;
            t.start() ;
            i++ ;
        }
    }
    
    class UserLife implements Runnable {

        private Socket so ;
        private int id ;

        public UserLife(Socket s, int myid) {
            this.so = s ;
            this.id = myid ;
        }
        
        public void run() {
            try {
                Reader r = new InputStreamReader(this.so.getInputStream()) ;
                User user = this.connectionLoop(r) ;
                this.interactionLoop(user) ;
            } catch (IOException e) {
                System.out.println("Communication " + String.valueOf(this.id) +
                                   " aborted") ;
            }
        }

        private User connectionLoop(Reader r) throws IOException {
            User user = null ;
            boolean firststep = true ;
            AnonFactory af = new AnonFactory() ;
            while (firststep) {
                Anon a = null ;
                boolean badcommand = true ;
                while (badcommand) {
                    String text = ProtocolFactory.readStream(r, "+++") ;
                    try {
                        a = af.create(text) ;
                        synchronized(allusers) {
                            a.exec(this.so, allusers) ;
                        }
                    } catch (UnknownResultException e) {
                        System.out.println("Bad command in com " +
                                           String.valueOf(this.id)) ;
                        badcommand = false ;
                    }
                }
                try {
                    user = User.getUserFromList(a.getId(), allusers) ;
                    firststep = false ;
                } catch (UnknownResultException e) {
                }
            }
            return user ;
        }

        private void interactionLoop(User user) throws IOException {
            boolean userhere = true ;
            Reader r = null ;
            synchronized(allusers) {
                try {
                    r = user.getReader() ;
                } catch (IOException e) {
                    userhere = false ;
                }
            }
            while (userhere) {
                CommandFactory cf = new CommandFactory() ;
                try {
                    synchronized(allusers) {
                        String text = ProtocolFactory.readStream(r, "+++") ;
                        Command cmd = cf.create(text) ;
                        cmd.exec(user, allusers) ;
                        userhere = user.isConnected() ;
                    }
                } catch (UnknownResultException e) {
                    System.out.println("Bad command from user " +
                                       user.getId()) ;
                }
            }
        }
    }
}

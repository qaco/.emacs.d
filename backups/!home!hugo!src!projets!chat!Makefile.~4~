CC=gcc
CFLAGS=-std=gnu99 -Wall -g
CLINKS=-lpthread
CLIENT=client
SERVER=server
CSRC=client.c aux.c messages.c
COBJ= $(CSRC:.c=.o)
SSRC=server.c aux.c
SOBJ= $(SSRC:.c=.o)

all : $(CLIENT) $(SERVER)

$(CLIENT) : $(COBJ)
	$(CC) $(CLINKS) -o $@ $^

$(SERVER) : $(SOBJ)
	$(CC) $(CLINKS) -o $@ $^	

client.o : messages.c messages.h aux.c aux.h

messages.o : aux.c aux.h

%.o: %.c
	$(CC) $(CFLAGS) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf $(EXEC)

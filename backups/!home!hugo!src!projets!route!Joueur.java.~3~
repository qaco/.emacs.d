import java.util.Scanner ;

public class Joueur {
    private static int numJoueur = 0 ;
    private Plateau plat ;
    private int id ;
    private boolean win = false ; // changer quand la bonne route est posee

    public Joueur (Plateau p) {
	this.plat = p ;
	switch(numJoueur) {
	case 0 :
	    this.id = Data.PLAYER1 ;
	    break ;
	case 1 :
	    this.id = Data.PLAYER2 ;
	    break ;
	}
	numJoueur++ ;
    }

    public int getId() {
	return this.id ;
    }
    
    public boolean victoire() {
	return this.win ;
    }

    public void tour() throws ActionIllegaleException {
	Coordinates depart = new Coordinates(0,0) ;
	Coordinates arrivee = new Coordinates(0,0) ;
	boolean stop = false ;
	do {
	    try {
		System.out.println("Indiquer la case dont part la route") ;
		depart = saisie() ;
		System.out.println("Indiquer la case ou arrive la route") ;
		arrivee = saisie() ;
	    } catch (MauvaiseSaisieException e) {
		System.out.println(e.getMessage()) ;
		stop = true ;
	    }
	} while (stop) ;
	if (!actionLegale(depart, arrivee))
	    throw new ActionIllegaleException("Action interdite !\n") ;
	action(depart, arrivee) ;

    }

    private Coordinates saisie() throws MauvaiseSaisieException {
	Scanner sc = new Scanner(System.in) ;
	int x ;
	int y ;
	System.out.println("Coordonnee sur l'axe X") ;
	x = sc.nextInt() ;
	x-- ;
	if (x < 0 || x >= Data.NBCASES)
	    throw new MauvaiseSaisieException("Mauvaise saisie !\n") ;
	System.out.println("Coordonnee sur l'axe Y") ;
	y = sc.nextInt() ;
	y-- ;
	if (y < 0 || y >= Data.NBCASES)
	    throw new MauvaiseSaisieException("Mauvaise saisie !\n") ;
	return new Coordinates(x,y) ;
    }

    private void action(Coordinates depart, Coordinates arrivee) {
	Case un = this.plat.getCase(depart.getX(), depart.getY()) ;
	Case deux = this.plat.getCase(arrivee.getX(), arrivee.getY()) ;
	
	if (depart.getX() > arrivee.getX()) {
	    un.put(Data.LEFT, this.id) ;
	    deux.put(Data.RIGHT, this.id) ;
	}
	else if (depart.getX() < arrivee.getX()) {
	    un.put(Data.RIGHT, this.id) ;
	    deux.put(Data.LEFT, this.id) ;
	}
	else if (depart.getY() > arrivee.getY()) {
	    un.put(Data.TOP, this.id) ;
	    deux.put(Data.BOTTOM, this.id) ;
	}
	else if (depart.getY() < arrivee.getY()) {
	    un.put(Data.BOTTOM, this.id) ;
	    deux.put(Data.TOP, this.id) ;
	}
    }

    private boolean actionLegale(Coordinates depart, Coordinates arrivee) {
	Case un = this.plat.getCase(depart.getX(), depart.getY()) ;
	Case deux = this.plat.getCase(arrivee.getX(), arrivee.getY()) ;
	int c = 0 ;
	boolean res = true ;
	
	if (depart.getX() == arrivee.getX() + 1) {
	    c++ ;
	    res = un.isFree(Data.LEFT,this.id) && deux.isFree(Data.RIGHT, this.id) ;
	}
	if (depart.getX() + 1 == arrivee.getX()) {
	    c++ ;
	    res = un.isFree(Data.RIGHT,this.id) && deux.isFree(Data.LEFT, this.id) ;
	}
	if (depart.getY() == arrivee.getY() + 1) {
	    c++ ;
	    res = un.isFree(Data.TOP,this.id) && deux.isFree(Data.TOP, this.id) ;
	}
	if (depart.getY() + 1 == arrivee.getY()) {
	    c++ ;
	    res = un.isFree(Data.BOTTOM,this.id) && deux.isFree(Data.BOTTOM, this.id) ;
	}
	return res && (c==1) ;
    }
}

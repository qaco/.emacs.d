import main.MainVals ;
import protocol.command.Connection ;
import protocol.feedback.* ;
import protocol.field.FieldVals ;
import exception.UnknownResultException ;
import java.util.Scanner ;
import java.net.Socket ;
import java.net.UnknownHostException ;
import java.io.InputStream ;
import java.io.OutputStream ;
import java.io.IOException ;


public class MainHacker {
    public static void main(String[] args) {

        try {
            if (args.length > 2)
                hack(args[1], Integer.parseInt(args[2])) ;
            else {
                System.out.println("Connexion par défaut : localhost " +
                                   String.valueOf(MainVals.SERVERPORT)) ;
                hack("localhost", MainVals.SERVERPORT) ;
            }
        } catch (NumberFormatException e) {
            System.out.println("Le port doit être un nombre.") ;
        } catch (UnknownHostException e) {
            System.out.println("L'url est inconnue.") ;
        } catch (IOException e) {
            System.out.println("Il y a eu un problème de connexion.") ;
        }
    }

    private static void hack(String h, int p) throws IOException {
        Scanner sc = new Scanner(System.in) ;
        boolean found = false ;
        boolean quit = false ;
        
        while(!found && !quit) {
            String login ;
            do {
                System.out.print("[login/quit] : ") ;
                login = sc.nextLine() ;
            } while (login.length() > FieldVals.MAX_ID_SIZE) ;
            if (login.equals("quit"))
                quit = true ;
            for (int i = 0; i <= FieldVals.MAX_MDP && !found && !quit; i++) {
                Socket so = new Socket(h, p) ;
                OutputStream output = so.getOutputStream() ;
                InputStream input = so.getInputStream() ;
                Connection connec = new Connection(login, i) ;
                output.write(connec.toBytes()) ;
                output.flush() ;

                FeedbackFactory ff = new FeedbackFactory() ;
                try {
                    Feedback feed = ff.create(input) ;
                    if (feed instanceof Hello) {
                        System.out.println("password : " +
                                           String.valueOf(i)) ;
                        found = true ;
                    }
                } catch (UnknownResultException e) {
                    System.out.println("Comportement inattendu du serveur.");
                }
                try { so.close() ; } catch (IOException e) {}
            }
            if (!found && !quit)
                System.out.println(login + " n'existe pas.") ;
        }
    }
}

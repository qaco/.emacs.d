
import Misc,Root,Shutter,Slogan, Paint
from PIL import Image

class Canvas:
    def __init__(self):
        self.img = None
        self.onion = []
        self.shutteri = -1
        self.slogani = -1
        self.logoi = -1
        
    def set_img(self, path):
        self.img = Image.open(path)
        self.img = self.img.convert('RGBA')
        Misc.minimize_image(self.img, (Misc.IMG_MAX[0], Misc.IMG_MAX[1]))

    def set_slogan(self,mytext):
        myshutter = self.onion[self.shutteri]
        myframe = Root.Frame(self.img.size, myshutter.corner, myshutter.size)
        myslogan = Slogan.BiggestSlogan(myframe)
        self.onion.append(myslogan)
        self.slogani = len(self.onion) - 1
        myslogan.text = mytext
        myslogan.permits_logo = True # ça ne marche pas quand on met à true ensuite
        myslogan.set_in_space()
        myslogan.process_img()

    def set_shutter(self):
        myshutter = Shutter.BottomShutter(self.img.size)
        self.onion.append(myshutter)
        self.shutteri = len(self.onion) - 1
        myshutter.set_in_space()
        myshutter.process_img()
        if self.slogani > -1 :
            set_slogan(self.onion[self.slogani].text)

    def set_logo(self,slogo):
        myslogan = self.onion[self.slogani]
        # myslogan.permits_logo = True
        # myslogan.set_in_space()
        # myslogan.process_img()
        mylogo = Paint.Logo(slogo, myslogan.logo_area)
        self.onion.append(mylogo)
        self.logoi = len(self.onion) - 1
        mylogo.set_in_space()
        mylogo.process_img()
        
    def merge_calcs(self) :
        for calc in self.onion :
            self.img = Image.alpha_composite(self.img, calc.img)



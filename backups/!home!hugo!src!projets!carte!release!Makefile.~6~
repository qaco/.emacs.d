OC=ocamlc
EXEC=coloriage
SRC=sat_solver.ml Builder.ml Computer.ml
OBJ=$(SRC:.ml=.cmo)

all: $(EXEC)

$(EXEC) : $(OBJ)
	$(OC) -o $@ $^

examples.cmo: examples.ml
	$(OC) -c $<

Computer.cmo: Computer.ml Computer.cmi Builder.cmo
	$(OC) -c $<

%.cmo: %.ml %.cmi
	$(OC) -c $<

%.cmi: %.mli
	$(OC) -o $@ -c $<

clean :
	rm -rf *.cmo *.cmi

mrproper : clean
	rm -rf $(EXEC)

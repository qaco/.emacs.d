CC=gcc
CFLAGS=-std=gnu99 -Werror -g
CLINKS=-lcurl
EXEC=ungoliant

all: ungoliant

ungoliant: crawler.o ungoliant.o
	$(CC) -o $@ $^ $(CLINKS)

crawler.o: crawler.c
	$(CC) $(CFLAGS) -o $@ -c $<

ungoliant.o: ungoliant.c crawler.h crawler.c
	$(CC) $(CFLAGS) -o $@ -c $<

clean :
	rm -rf *.o

mrproper : clean
	rm -rf ungoliant

#include <stdio.h>

char* int_to_string(int num) {
  int size = (int)((ceil(log10(num))+1)*sizeof(char)) ;
  char *str = malloc(size) ;
  sprintf(str, "%d", num);
  return str ;
}

void miroir(FILE* source, FILE* image) {
  char input ;
  char* tmp ;
  int c = 1 ;
  do {
    input = fgetc(source) ;
    fputc(input,image) ;
    if (input == '\n') {
      tmp = int_to_string(c++) ;
      fputs(tmp,image) ;
      free(tmp) ;
      fputc(' ', image) ;
    }
  } while(input != EOF) ;
}
      
      

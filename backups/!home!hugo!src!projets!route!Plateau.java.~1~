public class Plateau {
    private Case[][] cases = new Case[Data.NBCASES][Data.NBCASES] ;

    public Plateau() {
	for (int i = 0 ; i < Data.NBCASES ; i++)
	    for (int j = 0 ; j < Data.NBCASES ; j++)
		cases[i][j] = new Case(j,i) ;
    }

    public Case getCase(int x, int y) {
	return cases[y][x] ;
    }
}

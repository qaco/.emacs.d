package protocol ;

import java.util.Arrays ;
import java.io.IOException ;
import java.nio.ByteBuffer ;

public class NonBlockingReceiver extends DeadReceiver {

    private SocketChannel sock ;
    
    public NonBlockingReceiver(SocketChannel so) {
        super() ;
        this.sock = so ;
    }

    protected void receive() throws UnknownResultException {
        ByteBuffer buf = ByteBuffer.allocate(300) ;
        int bytesread = this.sock.read(buf);
        byte[] tmp = buf.array() ;
        int isuf = -1 ;
        int c = 0 ;
        for (int i = 0 ; i < tmp.length ; i++) {
            if (tmp[i] == this.suffix[i]) c++ ;
            else c = 0 ;
            if (c == this.suffix.length) {
                isuf = i - this.suffix.length ;
                break ;
            }
        }
        if (isuf >= 0)
            this.raw = Arrays.copyOfRange(tmp, 0, isuf) ;
        else
            throw new UnknownResultException("suffixe illégal") ;
    }
}
    

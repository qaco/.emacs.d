package protocol.knock ;

import exception.UnknownResultException ;

public class PublicityKnock extends Knock {
    
    public PublicityKnock(int flows) throws UnknownResultException {
        super(flows) ;
    }

    public PublicityKnock(byte mylow, byte myhigh) throws UnknownResultException {
        super(mylow, myhigh) ;
    }

    protected byte getCode() {
        return KnockVals.PUBLICITY_CODE ;
    }

    protected String popUp() {
        return KnockVals.PUBLICITY_MESS;
    }
}

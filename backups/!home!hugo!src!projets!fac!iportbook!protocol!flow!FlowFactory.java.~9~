package protocol.flow ;

import exception.UnknownResultException ;
import java.util.Arrays ;
import protocol.ProtocolFactory ;
import java.io.Reader ;

public class FlowFactory extends ProtocolFactory {

    protected String getCanonEOF() {
        return FlowVals.EOF ;
    }

    protected String getCanonSep() {
        return FlowVals.SEP ;
    }

    public Flow create(Reader in) throws UnknownResultException {
        try {
            String p = ProtocolFactory.readStream(in, this.getCanonEOF()) ;
            return this.create(p) ;
        } catch(UnknownResultException e) {
            throw e ;
        }
    }
    
    public Flow create(String text) throws UnknownResultException {
        if (this.isSuffixRight(text)) {
            String cmds[] = this.getCmds(text) ;
            String tail[] ;
            String mess ;
            try {
                switch (cmds[0]) {
                case FlowVals.ASK_FRIEND :
                    return new AskFriendFlow(cmds[1]) ;
                case FlowVals.FIRST_MESSAGE :
                    return new FirstMessageFlow(cmds[1], cmds[2]) ;
                case FlowVals.SOME_MESSAGE :
                    tail = Arrays.copyOfRange(cmds, 2, cmds.length) ;
                    mess = String.join(" ", tail) ;
                    return new SomeMessageFlow(cmds[1], mess) ;
                case FlowVals.FLOO_MESSAGE :
                    tail = Arrays.copyOfRange(cmds, 2, cmds.length) ;
                    mess = String.join(" ", tail) ;
                    return new FlooMessageFlow(cmds[1], mess) ;
                case FlowVals.FRIENDSHIP_NO :
                    return new FriendshipNO(cmds[1]) ;
                case FlowVals.FRIENDSHIP_OK :
                    return new FriendshipOK(cmds[1]) ; 
		case FlowVals.PROM :
                    tail = Arrays.copyOfRange(cmds, 3, cmds.length) ;
                    mess = String.join(" ", tail) ;
                    return new PromFlow(cmds[1], cmds[2], mess) ;
                case FlowVals.NO_FLOW :
                    return new NoFlow() ;
                }
            } catch (RuntimeException e) {
                throw new UnknownResultException() ;
            }
        }
        throw new UnknownResultException() ;
    }
}


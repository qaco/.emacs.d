package protocol.command ;

public class FlooMessage extends Command {

    private String mess ;

    public FlooMessage (String myauthor, String mymess) {
        super(myauthor) ;
        if (mymess.length() <= 200)
            this.mess = mymess ;
        else
            this.mess = mymess.substring(0, 200) ;
    }

    public String toString() {
        return CommandVals.FLOO_MESSAGE + " " + this.mess + CommandVals.EOF ;
    }
}

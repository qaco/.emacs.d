#include <stdlib.h>
#include <stdio.h>
#include <gtk/gtk.h>
#include "load_media.h"

#define MAP_PATH "../ressources/conf/map.cluedo"
#define C_SIZE 20
#define FLOOR_PATH "../ressources/images/floor.jpg"
#define BLANK_PATH "../ressources/images/blank.jpg"

char** gen_text_map(const int cote) {
  char tmp ;
  FILE* file = fopen(MAP_PATH, "r") ;
  char** res = malloc(cote*sizeof(char*)) ;
  for (int i = 0 ; i < cote ; i++)
    *(res+i) = malloc(cote*sizeof(char)+1) ;
  int i = 0, j = 0 ;
  do {
    tmp = fgetc(file) ;
    if (tmp == '\n') {
      *(*(res + i) + j) = '\0' ;
      i++ ;
      j = 0 ;
    }
    else {
      *(*(res + i) + j) = tmp ;
      j++ ;
    }
  } while (i < cote - 1 || j < cote) ;
  fclose(file) ;
  
  return res ;
}

GtkWidget*** gen_tile_map(const int num_cells, char** map) {
  GtkWidget*** tiles = malloc(num_cells*sizeof(GtkWidget**)) ;
  for (int i = 0 ; i < num_cells ; i++)
    *(tiles + i) = malloc (num_cells*sizeof(GtkWidget*)) ;
  
  for (int i = 0 ; i < num_cells ; i++) {
    for (int j = 0 ; j < num_cells ; j++) {
      if (map[i][j] == 'o') 
	*(*(tiles + i) + j) = get_tile_img(FLOOR_PATH, C_SIZE) ;
      else 
	*(*(tiles + i) + j) = get_tile_img(BLANK_PATH, C_SIZE) ;
    }
  }
  return tiles ;
}

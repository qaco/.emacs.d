package protocol.answer ;

import exception.* ;
import protocol.ProtocolFactory ;
import java.util.Arrays ;
import java.io.Reader ;
import java.io.IOException ;

public class AnswerFactory extends ProtocolFactory {

    protected String getCanonEOF() {
        return MainVals.EOF ;
    }

    protected String getCanonSep() {
        return MainVals.SEP ;
    }
    
    public Answer create(Reader in) throws UnknownResultException,
                                           IOException {
        String p = ProtocolFactory.readStream(in, this.getCanonEOF()) ;
        return this.create(p) ;
    }
    
    public Answer create(String text) throws UnknownResultException {
        String cmds[] ;
        
        if (!this.isSuffixRight(text))
            throw new BadSuffixException() ;
        
        cmds = this.getCmds(text) ;
        
        switch (cmds[0]) {
        case AnswerVals.OK_FRIEND :
            return new AcceptFriend() ;
        case AnswerVals.NO_FRIEND :
            return new RefuseFriend() ;
        default :
            throw new UnknownCommandException(cmds[0]) ;
        }
    }
}


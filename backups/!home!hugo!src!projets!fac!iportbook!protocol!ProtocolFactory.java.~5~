
package protocol ;

import java.io.Reader ;
import java.io.IOException ;

public abstract class ProtocolFactory {

    public static String readStream(Reader in, String EOF) throws IOException {
        StringBuffer sb = new StringBuffer() ;
        while(!sb.toString().contains("+++")) {
            char c = (char) in.read() ;
            sb.append(c) ;
        }
        return sb.toString() ;
    }
    
    protected abstract String getCanonEOF() ;
    protected abstract String getCanonSep() ;

    protected boolean isSuffixRight(String text) {
        int isuffix = text.length() - this.getCanonEOF().length() ;
        String suffix = text.substring(isuffix, text.length()) ;
        return suffix.equals(this.getCanonEOF()) ;
    }

    protected String[] getCmds(String text) {
        int suf_size = this.getCanonEOF().length() ;
        String signifiant = text.substring(0, text.length() - suf_size) ;
        return signifiant.split(this.getCanonSep()) ;
    }
}

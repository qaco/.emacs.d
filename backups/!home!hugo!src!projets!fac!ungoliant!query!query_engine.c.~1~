int query_word(DbId *id, Word *word, WordList *list) {
    int ret;
    if ((ret = get_pair(id, word, list)) != EXIT_SUCCESS) {
        fprintf(stderr, "Recuperation du mot a echoue :");
        print_word(*word, stderr);
        return EXIT_FAILURE;
    }
    return EXIT_SUCCESS;
}

int queries_manager(char *search) {
    DbId id;
    int ret;
    WordList list;
    Word word;
    if ((ret = opendb(&id)) != EXIT_SUCCESS) {
        fprintf(stderr, "Ouverture de la base plantee\n");
        return ret;
    }
    list = build_empty_wordlist();
    word = construct_word(search, strlen(search));
    if ((ret = query_word(&id, &word, &list)) != EXIT_SUCCESS) {
        return EXIT_FAILURE;
    }
    print_wordlist(list, stdout);
    closedb(&id);
    return EXIT_SUCCESS;
}

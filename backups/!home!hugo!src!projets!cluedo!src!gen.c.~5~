static Piece char_to_room(char code) {
  Piece res ;
  switch(code) {
  case 'o' : res = COULOIR ; break ;
  case 'c' : res = CUISINE ; break ;
  case 'd' : res = BAL ; break ;
  case 'v' : res = VERANDA ; break ;
  case 'm' : res = MANGER ; break ;
  case 'b' : res = BILLARD ; break ;
  case 'l' : res = BIBLIOTHEQUE ; break ;
  case 's' : res = SALON ; break ;
  case 'e' : res = HALL ; break ;
  case 't' : res = BUREAU ; break ;
  default : res = MUR ; break ;
  }
  return res ;
}

static const char* path_sprite_alibi(Alibi alibi, Alibi_type alibi_type) {
  switch (alibi_type) {
  case PERSO :
    switch (alibi.perso) {
    case MOUTARDE : return C_MOUTARDE_PATH ; break ;
    case OLIVE : return C_OLIVE_PATH ; break ;
    case VIOLET : return C_VIOLET_PATH ; break ;
    case PERVENCHE : return C_PERVENCHE_PATH ; break ;
    case ROSE : return C_ROSE_PATH ; break ;
    case LEBLANC : return C_LEBLANC_PATH ; break ;
    default :
      fprintf(stderr, "%d : param error\n", __LINE__) ;
      exit(1) ;
    break ;
    }
  case ARME :
    switch (alibi.arme) {
    case CHANDELIER : return C_CHANDELIER_PATH ; break ;
    case CLE : return C_CLE_PATH ; break ;
    case CORDE : return C_CORDE_PATH ; break ;
    case MATRAQUE : return C_MATRAQUE_PATH ; break ;
    case POIGNARD : return C_POIGNARD_PATH ; break ;
    case REVOLVER : return C_REVOLVER_PATH ; break ;
    default :
      fprintf(stderr, "%d : param error\n", __LINE__) ;
      exit(1) ;
    break ;
    }
  case PIECE :
    switch (alibi.piece) {
    case CUISINE : return C_CUISINE_PATH ; break ;
    case BAL : return C_BAL_PATH ; break ;
    case VERANDA : return C_VERANDA_PATH ; break ;
    case MANGER : return C_MANGER_PATH ; break ;
    case BILLARD : return C_BILLARD_PATH ; break ;
    case BIBLIOTHEQUE : return C_BIBLIOTHEQUE_PATH ; break ;
    case SALON : return C_SALON_PATH ; break ;
    case HALL : return C_HALL_PATH ; break ;
    case BUREAU : return C_BUREAU_PATH ; break ;
    default :
      fprintf(stderr, "%d : param error\n", __LINE__) ;
      exit(1) ;
    break ;
    }
  default :
    fprintf(stderr, "%d : param error\n", __LINE__) ;
    exit(1) ;
    break ;
  }
}
    

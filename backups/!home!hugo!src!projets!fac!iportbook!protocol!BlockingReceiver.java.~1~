package protocol ;

import java.io.InputStream ;
import java.io.IOException ;
import java.util.LinkedList ;

public class BlockingReceiver extends DeadReceiver {

    private InputStream in ;

    public BlockingReceiver(byte mysep, byte[] mysuf, InputStream myin) {
        super(mysep, mysuf) ;
        this.in = myin ;
    }

    protected void receive() throws UnknownResultException {
        byte tmp[] ;
        byte res[][] ;
        int succplus = 0 ;
        LinkedList<Byte> list = new LinkedList<Byte>() ;
        
        while (succplus < 3) {
            byte b = ((byte)in.read()) ;
            list.add(new Byte(b)) ;
            if (b == 43)
                succplus++ ;
            else
                succplus = 0 ;
        }

        tmp = new byte[list.size()] ;

        for (int i = 0 ; i < tmp.length - 3 ; i++)
            tmp[i] = list.get(i).byteValue() ;

        this.raw = tmp ;
        return res ;
    }

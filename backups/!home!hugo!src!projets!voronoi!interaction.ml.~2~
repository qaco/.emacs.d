(* Sélectionne une couleur à la souris. *)
let rec choose_color r_ex matrix adj =
  dd "Cliquez sur une case qui possede la couleur que vous voulez \
      utiliser" black;
  let em = wait_next_event[Button_down] in
  let ex = em.mouse_x and ey = em.mouse_y in
  let mx, my = match !r_ex.dim with a, b -> a, b in
  if (ex < mx && ey < my) then
    let seed_num = matrix.(ey).(ex) in
    match (!r_ex).seeds.(seed_num).c with
    | Some col -> Some col
    | None ->
       dd "Une couleur vide n'est pas une couleur" red;
       choose_color r_ex matrix adj 
  else
    begin
      dd "Vous ne pouvez pas choisir une couleur a l'exterieur du cadre" red;
      choose_color r_ex matrix adj 
    end

(* Applique la couleur col sur la région choisie à la souris par l'utilisateur. *)
let rec apply_color r_ex matrix adj col =
    dd "Cliquez sur la region a colorier" black;
    let em = wait_next_event[Button_down] in
    let x = em.mouse_x and y = em.mouse_y in
    let seed_num = matrix.(y).(x) in
    if (!r_ex.seeds.(seed_num).c = None
        && is_coloriage_legal seed_num adj !r_ex col) then
      begin
        (!r_ex).seeds.(seed_num) <- {c = col;
                                     x = (!r_ex).seeds.(seed_num).x;
                                     y = (!r_ex).seeds.(seed_num).y};
        seed_num
      end
    else
      failwith "Action interdite !"

(* Propose à l'utilisateur de supprimer la couleur d'une région à la souris. *)
let rec erase_color r_ex matrix vor_init =
  dd "Choisissez une region a supprimer (cliquez)" black;
  let em = wait_next_event[Button_down] in
  let x = em.mouse_x and y = em.mouse_y in
  let seed_num = matrix.(y).(x) in
  if (!r_ex.seeds.(seed_num).c = None) then
    begin
      dd "Vous ne pouvez pas choisir le blanc !" red;
      erase_color r_ex matrix vor_init
    end
  else if (vor_init.seeds.(seed_num).c != None) then
    begin
      dd "Cette couleur appartient au coloriage initial !" red;
      erase_color r_ex matrix vor_init
    end
  else 
    begin
      (!r_ex).seeds.(seed_num) <- {c = None;
                                   x = (!r_ex).seeds.(seed_num).x;
                                   y = (!r_ex).seeds.(seed_num).y};
      dd "Region supprimee !" red ;
      seed_num
    end

(* Attend une action de l'utilisateur (au clavier). *)
let rec choose_action r_ex matrix adj vor_init =
  dd "Choisissez une action : 'c' pour colorier une case; 'd' pour \
      supprimer une case coloriee; 's' pour afficher une solution" black;
  let ek = wait_next_event[Key_pressed] in
  dd "" red ;
  match ek.key with
  | 'c' -> let col = choose_color r_ex matrix adj in
           (try
             let myseed = apply_color r_ex matrix adj col in
             draw_region myseed matrix !r_ex
           with | Failure(s) -> dd s red)
  | 'd' -> let myseed = erase_color r_ex matrix vor_init in
           draw_region myseed matrix !r_ex
  | 's' -> (try
              r_ex := compute !r_ex adj ;
              dd "Vous etiez sur la bonne voie !" red ;
            with | Failure(s) -> dd "Vous avez fait fausse route !" red ;
                                 r_ex := compute vor_init adj) ;
           draw_voronoi matrix !r_ex
  | _ -> choose_action r_ex matrix adj vor_init

(* Joue la carte ex passée en paramètre. *)
let play_one ex distance_func =
  (* Teste si la carte passée en paramètre est soluble. *)
  let test_voronoi vor adj =
    try (let _ = compute !vor adj in ()) with
    | Failure(s) -> vor := regen_correct_voronoi !vor adj in
  let r_ex = ref ex in
  match (!r_ex).dim with
  | x, y ->
    dd "Calcul de la matrice des regions..." black;
    let matrix = regions_voronoi distance_func !r_ex in
    dd "Calcul de la matrice d'adjacences..." black;
    let adj = adjacences_voronoi !r_ex matrix in
    dd "Verification du diagramme..." black;
    test_voronoi r_ex adj ;
    draw_voronoi matrix !r_ex;
    let cpy = copy_voronoi !r_ex in
    while not (is_complete !r_ex) do
      (* dd "" red ; *)
      choose_action r_ex matrix adj cpy 
    done;
    draw_voronoi matrix !r_ex ;
    dd "Partie finie ! Appuyer sur une touche" black;
    ignore (wait_next_event[Key_pressed])

(* Joue une liste de cartes. *)
let rec play_all exs distance_func =
  (* Propose de continuer entre deux cartes. *)
  let rec play_again () =
    dd "Voulez vous continuer ? (y/n)" black;
    let ek = wait_next_event[Key_pressed] in
    match ek.key with
    | 'y' -> true
    | 'n' -> false
    | _ ->
       dd "Vous devez appuyer sur 'y' ou 'n' (oui ou non)" red;
       play_again () in
  match exs with
  | [] -> ()
  | [ex] -> play_one ex distance_func
  | ex::l ->
     play_one ex distance_func ;
     if not (l = []) then
       if play_again () then
         begin
           clear_graph ();
           play_all l distance_func
         end

(* Prend une liste et retourne une autre liste melangee *)
let shuffle l =
  let nl = List.map (fun c -> (bits (), c)) l in
  let sond = List.sort compare nl in
  List.map snd sond
;;

(* Lance le jeu suivant les options passées en paramètre : istaxicab indique *)
(* si on utilise taxicab ou euclide pour calculer les distances, israndom *)
(* indique si on génère aléatoirement une carte ou si on utilise celles qui *)
(* sont dans examples.ml, howmany indique le nombre de seeds dans le cas où *)
(* on a choisi la génération aléatoire, size indique la la taille size*size *)
(* de la fenêtre graphique. *)
let monitor istaxicab israndom howmany size =
  self_init() ;
  try
    open_graph (" "^(string_of_int size)^"x"^string_of_int size) ;
    let func_distance = ref euclide in
    if (istaxicab) then func_distance := taxicab ;
      if (israndom) then
        begin
          dd "Generation du nouveau diagramme..." black ;
          let other = gen_correct_voronoi howmany (size-100) (size-100)
                                          !func_distance in
          play_one other !func_distance
        end
      else
        begin
          play_all (shuffle examples) (!func_distance)
        end ;
      close_graph() ;
  with
  | Graphic_failure(s) -> print_string "On abandonne ?\n"

/**
 * \fn static void display_msg(const char* msg, WINDOW* inbox)
 * \brief Affiche un texte dans une fenêtre ncurses.
 * \param msg Le texte à afficher.
 * \param ret Indique s'il faut afficher le message sur une nouvelle ligne
 * \param inbox La fenêtre où afficher le texte.
 */
static void display_msg(const char* msg, const int ret, WINDOW* inbox)
{
  int x, y, maxx, maxy ;

  getmaxyx(inbox,maxy,maxx) ;
  maxy -= 2 ;
  
  getyx(inbox, y, x);
  if (y >= maxy)
    {
      wclear(inbox) ;
      box(inbox, ACS_VLINE, ACS_HLINE);
      y = 0 ;
    }
  if (ret)
    wmove(inbox, ++y, 1) ;
  waddnstr(inbox, msg, COLS - 2);
  wrefresh(inbox) ;
}

/**
 * \fn char* get_input(const char* invit, WINDOW* outbox)
 * \brief Récupère une saisie au clavier dans une fenêtre ncurses.
 * \param invit L'invite indiquant à l'utilisateur qu'il peut saisir son texte.
 * \param outbox La fenêtre où l'utilisateur saisir le texte.
 * \return La chaîne saisie au clavier.
 */
char* get_input(const char* invit, WINDOW* outbox)
{
  int maxx, maxy ;
  char* input = malloc(sizeof(char)*(COLS - strlen(invit) -2)) ;

  getmaxyx(outbox,maxy,maxx) ;
  maxx -= strlen(invit) + 2 ;
  input = malloc(sizeof(char)*maxx) ;
  
  mvwprintw(outbox, 1, 1, invit);
  wmove(outbox, 1 + strlen(invit) + 1, 1) ;
  wrefresh(outbox);

  mvwgetnstr(outbox, 1, 1 + strlen(invit), input, maxx - 1);
  wclear(outbox) ;
  box(outbox, ACS_VLINE, ACS_HLINE);
  wrefresh(outbox);

  return input ;
}

/**
 * \fn void get_login (char** pseudo, char** tube, WINDOW* outbox)
 * \brief Permet à l'utilisateur de saisir son pseudo et le nom du tube du
 * client.
 * \param pseudo Le pointeur sur la chaîne où le pseudo sera stocké.
 * \param tube Le pointeur sur la chaîne où le nom du tube sera stocké.
 * \param outbox La fenêtre où l'utilisateur saisir le texte.
 */
void get_login (char** pseudo, char** tube, WINDOW* outbox)
{
  *pseudo = get_input("Pseudo> ", outbox) ;
  *tube = get_input("Tube> ", outbox) ;
}

/**
 * \fn void receive_txt(const char* mypseudo, char* msg,
 *  const int is_public, WINDOW* inbox)
 * \brief Décode et affiche un message (public ou privé).
 * \param mypseudo Le pseudo de l'utilisateur.
 * \param msg La chaîne à décoder.
 * \param is_public Indique s'il s'agit d'un message public.
 * \param inbox La fenêtre où afficher le message.
 */
void receive_txt(const char* mypseudo, char* msg,
                 const int is_public, WINDOW* inbox)
{
  char *pseudo, *text, *disp ;
  int iops, itext, jump ;
  
  msg += NB_SIZE + TYPE_SIZE ;
  jump = extract_string(&pseudo, msg, NB_SIZE) ;
  msg += jump ;
  iops = strlen(pseudo) ;
  jump = extract_string(&text, msg, NB_SIZE) ;
  msg += jump ;
  itext = strlen(text) ;
  if (is_public)
    {
      disp = malloc(sizeof(char)*(iops + itext + strlen("[] ") + 1)) ;
      sprintf(disp, "[%s] %s", pseudo, text) ;
      display_msg(disp, 1, inbox) ;
      free(disp) ;
    }
  else
    {
      int imyps = strlen(mypseudo) ;
      disp = malloc(sizeof(char)*(iops + imyps + itext +
                                  strlen("[ --> ] " + 1))) ;
      sprintf(disp, "[%s --> %s] %s", pseudo, mypseudo, text) ;
      display_msg(disp, 1, inbox) ;
      free(disp) ;
    }
  free(pseudo) ;
  free(text) ;
}

/**
 * \fn void receive_list(char* first, const int fd_read, WINDOW* inbox)
 * \brief Décode et affiche une liste d'utilisateurs.
 * \param first Le premier message de la liste envoyé par le serveur.
 * \param fd_read Le descripteur du tube du client.
 * \param inbox La fenêtre où afficher la liste.
 */
void receive_list(char* first, const int fd_read, WINDOW* inbox)
{
  int i = 0 ;
  int howmany, jump ;
  char *new_input, *disp, *pseudo ;
  char* numusers = malloc(sizeof(char)*(NB_SIZE + 1)) ;
  
  do
    {
      if (!i)
        {
          strncpy(numusers, first + NB_SIZE + TYPE_SIZE, NB_SIZE) ;
          howmany = atoi(numusers) ;
          free(numusers) ;
        }
      new_input = first + NB_SIZE + TYPE_SIZE + NB_SIZE ;
      jump = extract_string(&pseudo, new_input, NB_SIZE) ;
      new_input += jump ;
      disp = malloc(sizeof(char)*(strlen(pseudo) + strlen("-> ") + 1)) ;
      sprintf(disp, "-> %s", pseudo) ;
      display_msg(disp, 1, inbox) ;
      free(disp) ;
      free(pseudo) ;
      if (i)
        free(first) ;
      if (++i < howmany)
        take_msg(fd_read, &first) ;
    } while (i < howmany) ;
}

void receive_file(char* first, const int fd_read, WINDOW* inbox)

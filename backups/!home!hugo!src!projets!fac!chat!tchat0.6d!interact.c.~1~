}

/**
 * \fn void logout(const char* mypseudo, WINDOW* inbox)
 * \brief Informe l'utilisateur qu'il se déconnecte.
 * \param mypseudo L'utilisateur qui se déconnecte.
 * \param inbox La fenêtre où afficher l'information.
 */
void logout(const char* mypseudo, WINDOW* inbox)
{
  char* disp = malloc(sizeof(char)*(strlen("Bye ") + strlen(mypseudo) + 1)) ;
  
  sprintf(disp, "Bye %s", mypseudo) ;
  display_msg(disp, 1, inbox) ;
  free(disp) ;
}

/**
 * \fn void shut(char* saisie, WINDOW* inbox)
 * \brief Informe l'utilisateur que le serveur a été éteint.
 * \param saisie Le message d'extinction (contenant notamment le pseudo de
 * l'utilisateur qui a éteint le serveur).
 * \param inbox La fenêtre où afficher l'information.
 */
void shut(char* saisie, WINDOW* inbox)
{
  char *pseudo, *disp ;
  int iops ;
  
  extract_string(&pseudo, saisie + NB_SIZE + TYPE_SIZE, NB_SIZE) ;
  iops = strlen(pseudo) ;
  disp = malloc(sizeof(char)*(iops + strlen("Serveur éteint par .") + 1)) ;
  sprintf(disp, "Serveur éteint par %s.", pseudo) ;
  display_msg(disp, 1, inbox) ;
  free(disp) ;
  free(pseudo) ;
}





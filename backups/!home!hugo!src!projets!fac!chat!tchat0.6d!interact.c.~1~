/**
 * \fn void ping(WINDOW* inbox)
 * \brief Signale un retour de la part du serveur.
 * \param inbox La fenêtre où afficher le signal.
 */
void ping(int id, WINDOW* inbox)
{
  char* disp = malloc(strlen("Ping") + strlen("1000") + 1) ;
  sprintf(disp, "Ping %d", id) ;
  display_msg(disp, 1, inbox) ;
}


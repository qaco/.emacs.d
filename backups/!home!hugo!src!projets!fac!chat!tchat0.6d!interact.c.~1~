  /* Récupérer le nom du fichier. */
  extract_string(&name, first, NB_SIZE) ;

  /* Garantir que le fichier n'existe pas déjà. */
  nameto = malloc(strlen("fromuser.") + strlen(name) + 1) ;
  sprintf(nameto, "fromuser.%s", name) ;
  gift = fopen(nameto, "w") ;
  

  /*     sprintf(nameto, "%s%d", name, i) ; */
  /*     gift = fopen(nameto, "r") ; */
  /*   } */
  /* fclose(gift) ; */
  /* gift = fopen(nameto, "w") ; */

  /* Initialiser la loadbar. */
  /* disp = malloc(sizeof(char)*(strlen(nameto) + strlen("Receiving  ") + 1)) ; */
  disp = malloc(sizeof(char)*(strlen(nameto)
                              + strlen("Receiving  ")
                              + strlen(" 10000") + 1)) ;
  sprintf(disp, "Receiving %s %ld ", nameto, llongueur) ;
  display_msg(disp, 1, inbox) ;
  free(name) ;
  /* free(nameto) ; risque de double free, à gérer proprement */
  sleep(1) ;
  
  /* Récupérer le fichier. */
  for (int i = 0 ; i < nb_paquets ; i++)
    {
      take_msg(fd_read, &part) ;
      // todo : vérifier le numéro de série et l'id transfert
      if (i == nb_paquets - 1 && last_oct)
        fwrite(part + (NB_SIZE*3) + TYPE_SIZE, sizeof(char), last_oct, gift) ;
      else

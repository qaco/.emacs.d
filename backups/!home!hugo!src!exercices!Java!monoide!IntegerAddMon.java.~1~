public class IntegerAddMon extends Monoid<Integer> {
    public IntegerAddMon() {
	this.mult = new BinaryOperator<Integer>()
		    { public Integer apply(Integer x, Integer y) {
			return new Integer(x.intValue() + y.intValue()) ; } } ;
	this.unit = new Supplier<Integer>()
		    { public Integer get() {
			    return new Integer(0) ; } } ;
    }
}
			    

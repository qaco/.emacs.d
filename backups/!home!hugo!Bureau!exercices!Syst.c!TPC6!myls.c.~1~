#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

#define DIRECTORY_LENGTH 1024

int main() {
  struct dirent* tmp ;
  DIR* current ;
  char* path = malloc(sizeof(char)*DIRECTORY_LENGTH) ;
  getcwd(path, DIRECTORY_LENGTH) ;
  free(path) ;
  current = opendir(path) ;

  do {
    tmp = readdir(current) ;
    if (tmp != NULL)
      printf("%s\n", tmp->name) ;
  } while (tmp != NULL) ;

  closedir(current) ;
}

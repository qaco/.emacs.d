class FontsInfo:
    def __init__(self, path):
        files = list_directory(path)
        self.names_paths = dict()
        self.families_styles = dict()
        self.families = []
        for path in files:
            f = ImageFont.truetype(path)
            self.names_paths[f.font.family,f.font.style] = path
            if f.font.family in self.families_styles:
                self.families_styles[f.font.family].append(f.font.style)
            else:
                self.families.append(f.font.family)
                self.families_styles[f.font.family] = [f.font.style]
        for key in self.families_styles:
            self.families_styles[key].sort()

    def get_path(self, family, style):
        return self.names_paths[family, style]

    def get_styles(self, family):
        return self.families_styles[family]

    def pick_a_fontpath(self):
        font = self.pick_a_font()
        fontpath = self.names_paths[font]
        return fontpath
        
    def pick_a_font(self):
        if MYFONT in self.families: family = MYFONT
        else: family= self.families[0]
        style = self.pick_a_style(family)
        return family, style

    def pick_a_style(self, family):
        style = self.families_styles[family][0]
        return style

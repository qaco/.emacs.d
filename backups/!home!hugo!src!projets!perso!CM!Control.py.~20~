import gi, os.path, Make, Shutter
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GdkPixbuf, GLib
from PIL import Image, ImageColor, ImageFont

INVISIBLE = (255, 255, 255, 0)
MYFONT = "Ubuntu"
ALPHA_TINT = 122

def list_directory(path):
    fichier=[]  
    for root, dirs, files in os.walk(path):  
        for i in files:  
            fichier.append(os.path.join(root, i))  
    return fichier

def img_to_pixbuf(src, size_max):
    if src.size[0] > size_max[0] or src.size[1] > size_max[1]:
        src.thumbnail(size_max)
    back = Image.new('RGBA', src.size, (255,255,255))
    src = Image.alpha_composite(back, src)
    src = src.convert('RGB')
    w, h = src.size[0], src.size[1]
    data = src.tobytes()
    data = GLib.Bytes.new(data)
    pix = GdkPixbuf.Pixbuf.new_from_bytes(data, GdkPixbuf.Colorspace.RGB,
                                          False, 8, w, h, w * 3)
    return pix

def get_img_filter():
    filter_text = Gtk.FileFilter()
    filter_text.set_name("Images")
    filter_text.add_pattern("*.jpg")
    filter_text.add_pattern("*.png")
    return filter_text

class Motherboard:
    def __init__(self, init, fonts):
        self.window = None
        self.canvas = None
        self.init = init
        self.fonts = fonts
        self.img_loaded = False

    def get_fonts_families(self):
        return self.fonts.families
        
    def refresh_img(self):
        w = self.window.get_size()[0] - self.window.param_width - 50
        h = self.window.get_size()[1] - 50
        paint = self.canvas.merge_calcs()
        pix = img_to_pixbuf(paint, (w,h))
        self.window.img.set_from_pixbuf(pix)

    def refresh_logo(self, logo_path):
        w = int(self.window.param_width/2)
        h = w
        logo = Image.open(logo_path)
        logo = logo.convert('RGBA')
        pix = img_to_pixbuf(logo, (w,h))
        self.window.logo.set_from_pixbuf(pix)
            
    def open_image_clicked(self, button):
        dialog = Gtk.FileChooserDialog("Choisir une image", self.window,
            Gtk.FileChooserAction.OPEN,
            (Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
             Gtk.STOCK_OPEN, Gtk.ResponseType.OK))
        dialog.add_filter(get_img_filter())
        response = dialog.run()
        if response == Gtk.ResponseType.OK:
            path = dialog.get_filename()
            fontpath = self.fonts.pick_a_fontpath()
            if self.window.bg_toggle.get_active():
                shutcol = self.window.get_bgcolor()
            else: shutcol = INVISIBLE
            textcol = self.window.get_textcolor()
            text = self.get_text()
            self.canvas = Make.Canvas(path, self.init.cmd_shut, shutcol,
                                      self.init.cmd_text, text,
                                      fontpath, textcol)
            self.img_loaded = True
            self.refresh_img()
        dialog.destroy()

    def imgcolor_changed(self, button):
        if self.img_loaded: 
            col = self.window.get_imgcolor()
            self.canvas.change_tint(col)
            self.refresh_img()

    def uncolor_img_changed(self, button):
        if self.img_loaded:
            self.canvas.untint()
            self.refresh_img()

    def change_text_typed(self, textbuffer):
        if self.img_loaded :
            self.canvas.change_text(self.get_text())
            self.refresh_img()

    def get_text(self):
        return self.window.text_buf.props.text
        
    def font_changed(self, combobox):
        font = combobox.get_active_text()
        self.window.style_combo.remove_all()
        for style in self.fonts.get_styles(font):
            self.window.style_combo.append_text(style)
        if self.img_loaded:
            path = self.fonts.get_path(font, self.fonts.pick_a_style(font))
            self.canvas.change_font(path)
            self.refresh_img()

    def style_changed(self, combobox):
        if self.img_loaded:
            style = combobox.get_active_text()
            if style != None:
                font = self.window.font_combo.get_active_text()
                path = self.fonts.get_path(font, style)
                self.canvas.change_font(path)
                self.refresh_img()

    def textcolor_changed(self, button):
        if self.img_loaded: 
            self.canvas.slogan.color = self.window.get_textcolor()
            self.refresh_img()

    def texttoup_clicked(self, button):
        if self.img_loaded: 
            self.canvas.change_orientation(Shutter.TOP_SHUTTER)
            self.refresh_img()
            
    def texttodown_clicked(self, button):
        if self.img_loaded: 
            self.canvas.change_orientation(Shutter.BOTTOM_SHUTTER)
            self.refresh_img()

    def texttoleft_clicked(self, button):
        if self.img_loaded: 
            self.canvas.change_orientation(Shutter.LEFT_SHUTTER)
            self.refresh_img()
            
    def texttoright_clicked(self, button):
        if self.img_loaded: 
            self.canvas.change_orientation(Shutter.RIGHT_SHUTTER)
            self.refresh_img()
            
    def bgcolor_changed(self, button):
        if self.img_loaded and self.window.bg_toggle.get_active():
            self.canvas.shutter.color = self.window.get_bgcolor()
            self.refresh_img()

    def switch_bg_toggled(self, button):
        if self.img_loaded: 
            if button.get_active():self.bgcolor_changed(self.window.bgcol_but)
            else:
                self.canvas.shutter.color = INVISIBLE
                self.refresh_img()

    def open_logo_clicked(self, button):
        if self.img_loaded: 
            dialog = Gtk.FileChooserDialog("Choisir un logo", self.window,
                                           Gtk.FileChooserAction.OPEN,
                                           (Gtk.STOCK_CANCEL,
                                            Gtk.ResponseType.CANCEL,
                                            Gtk.STOCK_OPEN,
                                            Gtk.ResponseType.OK))
            dialog.add_filter(get_img_filter())
            response = dialog.run()
            if response == Gtk.ResponseType.OK:
                logo_path = dialog.get_filename()
                self.canvas.sign_text_bottom(logo_path)
                self.refresh_logo(logo_path)
                self.refresh_img()
                dialog.destroy()

    def trash_logo_clicked(self, button):
        self.window.logo.clear()
        self.canvas.unsign_text()
        self.refresh_img()



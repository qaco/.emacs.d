int query_word(DbId *id, Word *word, WordList *url_list) {
    int ret;
    if ((ret = get_pair(id, word, url_list)) != EXIT_SUCCESS) {
        printf("'");
	print_word(word, stdout);
	printf("' not found.\n");
        return EXIT_FAILURE;
    }
    return EXIT_SUCCESS;
}

WordList* query_word_failure(DbId *id, Word *search, WordList *list) {
    struct word_data_list *wdata_list;
    struct word_data_list *next;
    int ret;
    float normalized, limit;
    Word *w;
    size_t si;

    limit = (float)2/5;
    create_word_data_list(&wdata_list);
    ret = get_all_words(id, wdata_list);
    if (ret == EXIT_SUCCESS) {
	for (; wdata_list != NULL; wdata_list = next) {
	    next = wdata_list->next_word_data_list;
	    si = wdata_list->wdata_size - sizeof(struct word_data) + 1;
	    if((char *)wdata_list->wdata->word != NULL) {
		w = construct_word(si, (char *)wdata_list->wdata->word);
		ret = levenshtein(w, search);
		normalized = (float)ret/(float)get_size_word(search); 
		if (normalized <= limit) {
		    printf("'");
		    print_word(w, stdout);
		    printf("' was used instead.\n______________\n\n");
		    return (query_word(id, w, list) == EXIT_SUCCESS) ? 
			list : build_empty_wordlist();
		}
	    }
	}
    }
    else {
	fprintf(stderr, "No words found.\n");
    }
    return build_empty_wordlist();
}

WordList* db_request(char *search) {
    DbId id;
    int ret;
    WordList *list;
    Word *word;
    if ((ret = opendb(&id)) != EXIT_SUCCESS) {
        fprintf(stderr, "Ouverture de la base plantee\n");
        return build_empty_wordlist();
    }
    list = build_empty_wordlist();
    word = construct_word(strlen(search), search);
    if ((ret = query_word(&id, word, list)) != EXIT_SUCCESS) {
	query_word_failure(&id, word, list);
    }
    closedb(&id);
    return list;
}

int queries_input(char *search)
{
    char *search_tokens[MAX_TOKENS];
    int search_size = 0;
    char *token;
    token = strtok(search, " ") ;
    while (token != NULL) {
	search_tokens[search_size] = token;
	token = strtok(NULL, " ") ;
	search_size++;
    }
    WordList* list = tokens_handling(search_tokens, search_size, 0);
    if(get_length_wordlist(list) != 0) {
	printf("Page(s) found:\n");
	print_wordlist(list, stdout);
    }
    return EXIT_SUCCESS;
}

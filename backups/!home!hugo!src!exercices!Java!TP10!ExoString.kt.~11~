import java.util.Scanner ;



class ExoString {
	fun lireChaines(): Array<String> {
		val sc = Scanner(System.`in`) ;
		val tab = Array<String>(10, {i -> ""}) ;
		for (i in 0..9) {
			tab[i] = sc.nextLine() ;
		}
		return tab ;
	}

	fun enMajuscules(tab: Array<String>): Unit {
		for (i in 0..(tab.size - 1))
		tab[i] = tab[i].toUpperCase() ;
	}

	fun afficher(tab: Array<String>): Unit {
		for (item in tab)
		println("${item}") ;
	}
}

fun main (args: Array<String>) {
	val obj = ExoString() ;
	val tab = obj.lireChaines() ;
	obj.enMajuscules(tab) ;
	tab.sort() ;
	obj.afficher(tab) ;
}

type state = {
    mutable acc: int; (*accumulateur*)
    code: instr array; (*programme*)
    mutable pc: int; (*indice instruction suivante*)
    stack: int array; (*pile*)
    mutable sp: int; (*indice du sommet de la pile*)
  }

(*creation etat initial d'un programme*)
let init (p : instr array) : state = {
    acc = 52; (*valeur au hasard*)
    code = p;
    pc = 0;
    stack = Array.make 50 47;  (*valeur 47 au hasard*)
    sp = -1;  (*pile vide*)
  }

(*pretty printer*)
let string_of_instr (i:instr) : string = match i with
  | Push -> "Push"
  | Pop -> "Pop"
  | Consti(x) -> "Consti "^string_of_int(x)
  | Addi -> "Addi"
  | Multi -> "Multi"
  | Ori -> "Ori"
  | Eqi -> "Eqi"
  | Leqi -> "Leqi"
  | Acc(x) -> "Acc "^string_of_int(x)
  | Popi(x) -> "Popi "^string_of_int(x)
  | Branch(x) -> "Branch "^string_of_int(x)
  | BranchIf(x) -> "BranchIf "^string_of_int(x)
  | Comment(s) -> "\n"^s^"\n"

let string_of_state (s:state) =
  let tok = "pc:"^string_of_int(s.pc)^", acc:"^string_of_int(s.acc) in
  if s.sp > -1 then tok^", pile:"^string_of_int(s.stack.(s.sp))
  else tok^", pile:vide"
	     				     
let exec (m : state) : state =
  while m.pc < Array.length m.code do
    print_endline(string_of_instr(m.code.(m.pc))) ;
    begin
      match m.code.(m.pc) with
      | Push ->
	 m.sp <- m.sp+1;
	 m.stack.(m.sp) <- m.acc
      | Pop ->
	 m.acc <- m.stack.(m.sp);
	 m.sp <- m.sp-1
      | Consti n ->
	 m.acc <- n
      | Addi ->
	 m.acc <- m.stack.(m.sp) + m.acc;
	 m.sp <- m.sp-1
      | Ori ->
	 m.acc <- if m.stack.(m.sp)=0 && m.acc=0 then 0 else 1;
	 m.sp <- m.sp-1
      | Eqi ->
	 m.acc <- if m.stack.(m.sp)=m.acc then 1 else 0;
	 m.sp <- m.sp-1
      | Leqi ->
	 m.acc <- if m.stack.(m.sp)<=m.acc then 1 else 0;
	 m.sp <- m.sp-1
      | Multi ->
         m.acc <- m.stack.(m.sp) * m.acc;
         m.sp <- m.sp-1
      | Acc n ->
         m.acc <- if m.sp + n < Array.length m.stack && m.sp + n >= 0 then
                    m.stack.(m.sp + n)
                  else failwith "Stack overflow"
      | Popi n ->
         m.sp <- if m.sp + n < Array.length m.stack && m.sp + n >= 0 then
                   m.sp + n
                 else failwith "Stack overflow"
      | Branch n ->
         m.pc <- if m.pc + n < Array.length m.code && m.pc + n >= 0 then
                   m.pc + n
                 else failwith "No code here"
      | BranchIf n ->
         if m.acc=1 then
           if m.pc + n < Array.length m.code && m.pc + n >= 0 then
             m.pc <- m.pc + n
           else failwith "No code here"
      | Comment s -> ()
    end;
    print_endline(string_of_state(m)) ;
    m.pc <- m.pc+1;
  done; m

(*programme calculant la multiplication*)
let prog_mult =
  (*on commence A=compteur, S={facteur}*)
  (*preparation initiale, avec marker -1*)
  [Push; Consti (-1); Push;                   (*A=-1,         S={-1;compteur;facteur;}*)
   Acc 2; Push; Acc 2; Push;                  (*A=compteur,   S={compteur;facteur;-1;compteur;facteur}*)
   Consti 0;            
   (*lOOP_ADD:           invariant debut boucle A=res,        S={compteur; facteur;....}*)
   Push;                                      (*A=res,        S={res; compteur; facteur; ...}*)
   Consti 0; Push; Acc 2;                     (*A=compteur    S={0; res; compteur; facteur; ...}*)
   Eqi; (let eX_ADD = 13 in BranchIf eX_ADD); (*A=(compteur=0)S={res;compteur;facteur; ...}*)
   Acc 2; Push;                               (*A=facteur     S={facteur;   res;compteur;facteur; ...}*)
   Acc 2; Push; Consti (-1); Addi; Push;      (*A=compteur-1  S={compteur-1;facteur;    res;compteur;facteur; ...}*)
   Acc 1; Push;                               (*A=facteur     S={facteur; compteur-1;facteur; res;compteur;facteur; ...}*)
   Acc 3; Addi;                               (*A=res+facteur S={compteur-1;facteur; ...}*)
   (let lOOP_ADD = -17 in Branch lOOP_ADD);   (*fin de la boucle*)
   (*eX_ADD: invariant fin boucle               A=1           S={res;0;facteur;....;-1;y;z}*)                            
   Pop;         
   (*lOOP_ERASE: invariant debut boucle         A=res         S={x;....;-1;y;z}*)
   Push; Consti (-1); Push;                   (*A=-1          S={-1; res; x;....;-1;y;z}*)
   Acc 2; Eqi;                                (*A=(x=-1)      S={res;x;....;-1;y;z}*)
   (let eX_ERASE=4 in BranchIf eX_ERASE);
   Pop; Popi 1; (let lOOP_ERASE = -8 in Branch lOOP_ERASE);
   (*eX_ERASE: invariant fin boucle             A=(x=-1)      S={res;-1;y;z}*)
   Pop; Popi 3;
   (*invariant fin programme                    A=res          S={}*)
  ]
             
let assemble (p: instr array) : string =
  let set_last_oct s i n =
    String.set s (i+1) (if n >= 0 then Char.chr 0 else Char.chr 1) ;
    String.set s (i+2) (Char.chr (abs n)) in
  let b = String.create (3*(Array.length p)) in
  for i = 0 to Array.length p-1 do
    match p.(i) with
      | Push -> String.set b (i*3) (Char.chr 0)
      | Addi -> String.set b (i*3) (Char.chr 1)
      | Eqi -> String.set b (i*3) (Char.chr 2)
      | Ori -> String.set b (i*3) (Char.chr 3)
      | Consti n -> String.set b (i*3) (Char.chr 4) ; set_last_oct b (i*3) n
      | Pop -> String.set b (i*3) (Char.chr 5)
      | Acc n -> String.set b (i*3) (Char.chr 6) ; set_last_oct b (i*3) n
      | Popi n -> String.set b (i*3) (Char.chr 7) ; set_last_oct b (i*3) n
      | Branch n -> String.set b (i*3) (Char.chr 8) ; set_last_oct b (i*3) n
      | BranchIf n -> String.set b (i*3) (Char.chr 9) ; set_last_oct b (i*3) n
      | Multi -> String.set b (i*3) (Char.chr 10)
      | Leqi -> String.set b (i*3) (Char.chr 11)
      | Comment s -> ()
  done; b

let disassemble (b: string) : instr array =
  let get_value s i =
    if Char.code (String.get s (i+1)) = 0 then Char.code (String.get s (i+2))
    else - Char.code (String.get s (i+2)) in
  let p = Array.make ((String.length b)/3) Push in
  for i = 0 to ((String.length b)/3 - 1) do
    p.(i) <- match Char.code (String.get b (i*3)) with
	     | 0 -> Push
	     | 1 -> Addi
	     | 2 -> Eqi
	     | 3 -> Ori
             | 4 -> Consti(get_value b (i*3))
	     | 5 -> Pop
             | 6 -> Acc(get_value b (i*3))
             | 7 -> Popi(get_value b (i*3))
             | 8 -> Branch(get_value b (i*3))
             | 9 -> BranchIf(get_value b (i*3))
             | 10 -> Multi
             | 11 -> Leqi
	     | _ -> failwith "invalid byte-code"
  done; p


	    

package protocol ;

import java.nio.charset.Charset ;
import exception.UnknownResultException ;
import exception.RuleBrokenException ;

public abstract class Field {

    protected byte[] field ;
    
    public Field(byte[] myfield) throws UnknownResultException {
        int numplus = 0 ;
        for (int i = 0 ; i < myfield.length ; i++) {
            switch(field[i]) {
            case 32: throw new RuleBrokenException("Field", "SPC in field") ;
            case 43: numplus++ ;
            default: numplus = 0 ;
            }
            if (numplus == 3)
                throw new RuleBrokenException("Field", "+++ in field") ;
            this.field = myfield ;
            this.checkRules() ;
        }
    }

    public IdField(String myid) {
        try {
            this(myid.getBytes(Charset.forName("US-ASCII"))) ;
            this.checkRules() ;
        } catch (UnknownResultExcception e) {
            throw new IllegalArgumentException() ;
        }
    }
        
    public byte[] toBytes() {
        return this.field ;
    }

    public String toString() {
        return new String(this.field, Charset.forName("US-ASCII")) ;
    }

    protected abstract void checkRules() throws UnknownResultException ;
}

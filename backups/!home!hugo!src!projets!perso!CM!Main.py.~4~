#! /usr/bin/env python3

import Misc,Make
from PIL import Image

imgpath = "images/lenin.jpg"
shut_col = (0, 0, 0, 230)
text = "VIVENT LES SOVIETS"
font = "fonts/Ubuntu-B.ttf"
logopath = "images/pcf2.png"
work = Make.Canvas()

work.create_img(imgpath)
work.create_shutter(Misc.BOTTOM_SHUTTER, shut_col)
work.apply_slogan_on_shutter(Misc.NAIVE_SLOGAN, text, font, "white")
work.apply_logo_on_text(Misc.BOTTOM_SLOGAN, logopath)
work.merge_calcs()
work.img.show()

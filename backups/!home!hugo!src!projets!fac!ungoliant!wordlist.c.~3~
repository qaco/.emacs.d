int destruct_wordlist(WordList mylist)
{
  WordList tmp = mylist ;
  while (tmp.next != NULL) {
    destruct_word(&tmp.word) ;
    tmp = *(tmp.next) ;
  }
  destruct_word(&tmp.word) ;

  return 0 ;
}

int print_wordlist(WordList mylist, FILE* stream)
{
  WordList tmp = mylist ;
  fprintf(stream, "[ ") ;
  while (tmp.next != NULL) {
    print_word(tmp.word, stream) ;
    fprintf(stream, ", ") ;
    tmp = *(tmp.next) ;
  }
  print_word(tmp.word, stream) ;
  fprintf(stream, " ]\n") ;

  return 0 ;
}
    

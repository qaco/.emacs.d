package protocol.flow ;

import protocol.field.* ;
import main.MainVals ;
import exception.* ;
import client.src.ServerRequest;
import java.io.IOException ;

public class FlooMessageFlow implements Flow {

    private IdField id ;
    private MessField mess ;

    public FlooMessageFlow (byte[] i, byte[] m) throws UnknownResultException {
        this.mess = new MessField(i) ;
        this.id = new IdField(m) ;
    }
    
    public FlooMessageFlow (String i,String m) {
        this.mess = new MessField(i) ;
        this.id = new IdField(m) ;
    }

    public void exec(ServerRequest c) throws IOException { 
	System.out.println("[Vous avez été innondé par "+this.id.toString()+"]");
	System.out.println("-- "+this.mess.toString());
    }

    public byte[] toBytes() {
        Field[] fields = { this.id, this.mess } ;
        return Field.makeSentence(FlowVals.FLOO_MESSAGE, fields) ;
    }
    
    public String toString() {
        return
            FlowVals.FLOO_MESSAGE + " " + this.id.toString() + " " +
            this.mess.toString() + MainVals.EOF ;
    }
}

package protocol.knock ;

import exception.UnknownResultException ;

public class OkFriendKnock extends Knock {
    
    public OkFriendKnock(int flows) {
        super(flows) ;
    }

    public OkFriendKnock(byte mylow, byte myhigh) throws UnknownResultException {
        super(mylow, myhigh) ;
    }

    protected byte getCode() {
        return KnockVals.FRIENDOK_CODE ;
    }

    protected String popUp() {
        return KnockVals.FRIENDOK_MESS;
    }
}

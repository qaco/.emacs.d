#root makefile

PACKAGE = .

SUBDIRS =  \
	protocol \
	protocol/command \
	protocol/feedback \
	protocol/flow \

all:
	@@for p in $(SUBDIRS); do \
		echo '----building ' $(PACKAGE)/$$p; \
		make -C $(PACKAGE)/$$p --no-print-directory all; \
	done

all:
	@@for p in $(SUBDIRS); do \
		echo 'cleaning ' $(PACKAGE)/$$p; \
		make -C $(PACKAGE)/$$p --no-print-directory clean; \
	done

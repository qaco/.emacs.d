public class FirstMessage implements Protocol {

    private String id ;
    private int num ;

    public FirstMessage (String myid, String mynum) throws ParseException {
        this.id = myid ;
        try {
            this.num = Integer.parseInt(mynum) ;
        } catch (NumberException e) {
            this.num = -1 ;
        }
    }

    public String toString() {
        String mynum = String.valueOf(this.num) ;
        return "MESS? " + this.id + " " + mynum + "+++" ;
    }
}

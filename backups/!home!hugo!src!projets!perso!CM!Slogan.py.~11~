import Misc, Root
from PIL import Image, ImageDraw, ImageFont

def factory(cmd, myframe, mytext, myfont, mycolor):
    options = { Misc.NAIVE_SLOGAN : NaiveSlogan,
                Misc.BOTTOM_SLOGAN : BottomSignedSlogan,
                Misc.RIGHT_SLOGAN : RightSignedSlogan }
    return options[cmd](myframe, mytext, myfont, mycolor)

class AbstractSlogan(Root.AbstractCalc):
    def __init__(self, myframe, mytext, myfont, mycolor):
        super().__init__()
        self.frame = myframe
        self.text = mytext
        self.sfont = myfont
        self.color = mycolor
        self.fontsize = None

    def is_signed(self):
        raise NotImplementedError()
        
    # On rétrécit un peu le cadre pour que le texte ne touche pas les bords.
    def process_margin(self):
        fsize = self.frame.size
        fcorner = self.frame.corner
        offset = fsize[0]/Misc.TEXT_RATIO
        self.upper_size = self.frame.upper_size
        self.corner = int(fcorner[0] + offset), int(fcorner[1] + offset)
        self.size = int(fsize[0] - offset*2), int(fsize[1] - offset*2)

    # On récupère la plus grande taille de fonte possible dans les limites du
    # cadre, et la taille correspondante pour le cadre.

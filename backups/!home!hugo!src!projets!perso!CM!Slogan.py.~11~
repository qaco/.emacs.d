    def generate_img(self):
        textlines = self.text.split("\n")
        self.img = Image.new('RGBA', self.frame.upper_size, Misc.TRANSPARENCY)
        font = ImageFont.truetype(self.sfont, self.fontsize)
        draw = ImageDraw.Draw(self.img, 'RGBA')
        # draw.text(self.corner, self.text, self.color, font)
        tmp_corn = self.corner
        for line in textlines:
            draw.text(tmp_corn, line, self.color, font)
            offset = draw.textsize(line, font)
            tmp_corn = tmp_corn[0], tmp_corn[1] + offset[1]
        # dessin du cadre
        other_corn = self.corner[0] + self.size[0], self.corner[1] + self.size[1]
        draw.rectangle([self.corner, other_corn], None, (0,0,0))

class NaiveSlogan(AbstractSlogan):
    def __init__(self, myframe, mytext, myfont, mycolor):
        super().__init__(myframe, mytext, myfont, mycolor)

    def is_signed(self):
        return False
        
    # L'espace vide est réparti pour moitié en haut et en bas du slogan.
    def process_layout(self):
        # On centre verticalement.
        blanky = self.frame.size[1] - self.size[1]
        by_half = int(blanky/2)
        # On centre horizontalement
        blankx = self.frame.size[0] - self.size[0]
        bx_half = int(blankx/2)
        self.corner = self.corner[0] + bx_half, self.frame.corner[1] + by_half

class SignedSlogan(AbstractSlogan):
    def __init__(self, myframe, mytext, myfont, mycolor):
        super().__init__(myframe, mytext, myfont, mycolor)
        self.logo_area = None

    def is_signed(self):
        return True
    
class BottomSignedSlogan(SignedSlogan):
    def __init__(self, myframe, mytext, myfont, mycolor):
        super().__init__(myframe, mytext, myfont, mycolor)

    # L'espace vide est réparti en cinq cinquièmes :
    # - Un cinquième au-dessus du slogan
    # - Le slogan
    # - Un cinquième au-dessous du slogan
    # - Deux cinquièmes réservés au logo
    # - Un cinquième au-dessous du logo
    def process_layout(self):
        blank_space = self.frame.size[1] - self.size[1]
        b_fifth = int(blank_space/5)
        self.corner = self.corner[0], self.frame.corner[1] + b_fifth
        logo_corner = self.corner[0], self.corner[1] + self.size[1] + b_fifth
        logo_size = self.frame.size[0], b_fifth*2
        self.logo_area = Root.Frame(self.upper_size, logo_corner, logo_size)


    def process_size(self):
        self.fontsize = 0
        textlines = self.text.split("\n")
        max_size = self.size
        tmp_img = Image.new('RGBA', self.frame.upper_size, (0,0,0))
        draw = ImageDraw.Draw(tmp_img, 'RGBA')
        issmall = len(self.text) > 0
        while issmall:
            tmp_fontsize = self.fontsize + 1
            tmp_font = ImageFont.truetype(self.sfont, tmp_fontsize)
            tmp_size = (0,0)
            for line in textlines:
                incsize = draw.textsize(self.text, tmp_font)
                tmp_size = max(tmp_size[0], incsize[0]), tmp_size[1] + incsize[1]
            issmall = tmp_size[0] < max_size[0] and tmp_size[1] < max_size[1]
            if issmall:
                self.fontsize = tmp_fontsize
                self.size = tmp_size

    def process_layout(self):
        raise NotImplementedError()
        
    def process_position(self):
        self.process_margin()
        self.process_size()
        self.process_layout()


int add_pair(DbId *id, Word *word, Word *url)
{
    DB *dbp = id->dbp;
    DBT key, data;
    int ret;
    memset(&key, 0, sizeof(key));
    memset(&data, 0, sizeof(data));
    key.data = word->memory;
    key.size = word->size;
    data.data = url->memory;
    data.size = url->size;
    if ((ret = dbp->put(dbp, NULL, &key, &data, 0)) == 0)
        printf("db: %s: key stored.\n", (char *)key.data);
    else {
        dbp->err(dbp, ret, "DB->put");
        exit(ret);
    }
    return 0;
}


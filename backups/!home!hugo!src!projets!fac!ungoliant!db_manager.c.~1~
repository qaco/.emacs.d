/* checker ca plus tard */
/* hashcreate hashtable hashdestroy */
unsigned long hash(unsigned char *str)
{
    unsigned long hash = 5381;
    int c;
    while (c = *str++)
        hash = ((hash << 5) + hash) + c;
    return hash;
}

int opendb(DbId *id, char *db_fname)
{
    DB_ENV *dbenv;
    DB *dbp;
    int ret, t_ret;

    // Create and open handle for DB
    if ((ret = db_env_create(&dbenv, DB_ENV_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_env_create: %s\n", db_strerror(ret));
        exit(ret);
    }

    /*
     * Place to configure database
     */

    if ((ret = dbenv->open(dbenv, DB_ENV_DIR, DB_ENV_OPEN_FLAGS)) != 0) {
        fprintf(stderr, "db_env_open: %s\n", db_strerror(ret));
        exit(ret);
    }

    // Create and open handle for table 1
    if ((ret = db_create(&dbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create: %s\n", db_strerror(ret));
        exit(ret);
    }

    /*
     * Place to configure 1st table
     */

    if ((ret = dbp->open(dbp, DB_OPEN_TXN, DB1_OPEN_NAME, DB_OPEN_DATABASE,
                         DB_OPEN_DTYPE, DB_OPEN_FLAGS, DB_OPEN_FRIGHTS)) != 0) {
        dbp->err(dbp, ret, "%s", DATABASE);
        if ((t_ret = dbp->close(dbp, 0)) != 0 && ret == 0)
            ret = t_ret;
        exit(ret);
    }

    // Create and open handle for table 2
    if ((ret = db_create(&dbp, dbenv, DB_CREATE_FLAGS)) != 0) {
        fprintf(stderr, "db_create: %s\n", db_strerror(ret));
        exit(ret);
    }

    /*
     * Place to configure 2nd table
     */

    if ((ret = dbp->open(dbp, DB_OPEN_TXN, DB2_OPEN_NAME, DB_OPEN_DATABASE,
                         DB_OPEN_DTYPE, DB_OPEN_FLAGS, DB_OPEN_FRIGHTS)) != 0) {
        dbp->err(dbp, ret, "%s", DATABASE);
        if ((t_ret = dbp->close(dbp, 0)) != 0 && ret == 0)
            ret = t_ret;
        exit(ret);
    }
    id->dbp = dbp;
    return 0;
}

int closedb(DbId *id)
{
    int ret;
    if ((ret = id->dbp->close(id->dbp, DB_CLOSE_FLAGS)) != 0)
        exit(ret);
    return 0;
}


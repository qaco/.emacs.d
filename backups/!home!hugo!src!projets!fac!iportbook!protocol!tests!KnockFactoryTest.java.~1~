package protocol.tests ;

import exception.UnknownResultException ;
import protocol.knock.* ;
import static org.junit.Assert.* ;
import org.junit.Test;
import org.junit.Before;

public class KnockFactoryTest {

    private KnockFactory pf ;

    @Before
    public final void setCommandFactoryUp() {
        this.pf = new KnockFactory() ;
    }

   @Test
    public final void intAndBytesConversion() {
        byte expected[] = { 1, 0, 2 } ;
        Knock knock = new FriendshipKnock(512) ;
        assertEquals(512, knock.getNumFlows()) ;
   }
        
    @Test
    public final void testFriendshipKnockBuild() {
        byte expected[] = { 1, 0, 2 } ;
        Knock knock = pf.create({1, 0, 2}) ;
        byte actual[] = knock.getArray();
        assertArrayEquals(expected, actual) ;
    }
}

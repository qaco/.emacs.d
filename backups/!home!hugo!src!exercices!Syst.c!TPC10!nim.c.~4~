#include <stdio.h>
#include <time.h>
#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/file.h>
#include <unistd.h>
#include "misc.h"

#define T1 "/tmp/usr1"
#define T2 "/tmp/usr2"
#define L1 "/tmp/lock1"
#define L2 "/tmp/lock2"
#define INFA 10
#define SUPA 100
#define INFB 2
#define SUPB 9
#define SIZE_PATH 30

int main (int argc, char* argv[]) {
  const mode_t droits = S_IRWXU | S_IRWXG | S_IRWXO ;
  char
    *w_path = malloc(sizeof(char)*SIZE_PATH),
    *r_path = malloc(sizeof(char)*SIZE_PATH) ;
  FILE *lecture, *ecriture, *lock ;
  int a, b,x = 0, id ;
  srand(time(NULL)) ;
  /* VÉRIFICATION DES DÉPENDANCES
     ===================================================================
     Si l'une des dépendances manque, elle est créée. */
  if (access(T1, droits))
    mkfifo(T1, droits) ;
  if (access(T2, droits))
    mkfifo(T2, droits) ;
  if (access(L1, droits))
    creat(L1, droits) ;
  if (access(L2, droits))
    creat(L2, droits) ;
  /* =================================================================== */

  /* TRAITEMENT DES ARGUMENTS
     ===================================================================
     S'il y a un argument et qu'il indique 1 ou 2, id est affecté en
     fonction.  */
  if (--argc) {
    argv++ ;
    if (**argv == '1')
      id = 1 ;
    else if (**argv == '2')
      id = 2 ;
    else
      goto automatique ;
  }
  /* Si l'argument est incorrect ou s'il n'y a pas d'argument,
     l'id est calculée automatiquement. S'il n'y a pas de joueur
     disponible, le programme s'arrête. */
  else {
  automatique :
    lock = fopen(L1, "r") ;
    if (flock(fileno(lock), LOCK_EX | LOCK_NB)) {
      fclose(lock) ;
      lock = fopen(L2, "r") ;
      if (flock(fileno(lock), LOCK_EX | LOCK_NB)) {
  	fclose(lock) ;
  	perror("Aucun joueur disponible") ;
  	exit(EXIT_FAILURE) ;
      }
      else
  	id = 2 ;
    }
    else
      id = 1 ;
    fclose(lock) ;
  }
  printf("[joueur %d]\n", id) ;
  /* =================================================================== */

  /* INIT DU JOUEUR 1
     ===================================================================
     Le joueur 1 tire a et b, les envoie dans le tube, et écoute le tube */
  if (id == 1) {
    
    lock = fopen(L1, "r") ;
    if (flock(fileno(lock), LOCK_EX | LOCK_NB))
      exit(EXIT_FAILURE) ;
    
    strcpy(w_path, T1) ;
    strcpy(r_path, T2) ;
    
    a = rand() % (SUPA - INFA) + INFA ;
    b = rand() % (SUPB - INFB) + INFB ;

    ecriture = fopen(w_path, "w") ;
    int_to_file(a,ecriture) ;
    printf("->a:%d\n",a) ;
    int_to_file(b,ecriture) ;
    printf("->b:%d\n",b) ;
    fclose(ecriture) ;

    lecture = fopen(r_path, "r") ;
    a -= file_to_int(lecture) ;
    printf("<-a:%d\n",a) ;
    fclose(lecture) ;
  }
  /* =================================================================== */

  /* INIT DU JOUEUR 2
     ===================================================================
     Le joueur 2 reçoit a et b */
  else {

    lock = fopen(L2, "r") ;
    if (flock(fileno(lock), LOCK_EX | LOCK_NB))
      exit(EXIT_FAILURE) ;
    fclose(lock) ;
    
    strcpy(w_path, T2) ;
    strcpy(r_path, T1) ;
    
    lecture = fopen(r_path, "r") ;
    a = file_to_int(lecture) ;
    printf("<-a:%d\n",a) ;
    b = file_to_int(lecture) ;
    printf("<-b:%d\n",b) ;
    fclose(lecture) ;
  }
  /* =================================================================== */

  /* BOUCLE DE JEU
     =================================================================== */
 start :
  /* SAISIE
     Le joueur (quel qu'il soit) saisit son coup tant qu'il ne propose pas
     un coup valide, suivant l'option indiquée à la compilation (humain,
     aléatoire ou toujours 1). */
  while (x < 1 || x > b) {
    printf("[saisir nombre entre 1 et %d]\n", b) ;
#ifdef HUMAN
    x = file_to_int(stdin) ;
#endif
#ifdef RANDOM
    x = rand() % (b - 1) + 1 ;
#endif
#ifdef ONE
    x = 1 ;
#endif
  }
  /* ENVOI
     Le joueur envoie son coup dans le tube. Si c'est un coup gagnant, il
     sort de la boucle et va réaliser les instructions de victoire. */
  ecriture = fopen(w_path, "w") ;
  int_to_file(x, ecriture) ;
  printf("->x:%d\n",x) ;
  if (a-x <= 0) goto win ;
  fclose(ecriture) ;
  /* ÉCOUTE
     Le joueur reçoit le coup de l'autre joueur. Si c'est un coup gagnant,
     il sort de la boucle et va réaliser les instructions de défaite. */
  lecture = fopen(r_path, "r") ;
  a -= file_to_int(lecture) ;
  printf("<-a:%d\n",a) ;
  if (a <= 0) goto lose ;
  fclose(lecture) ;

  goto start ;
  /*==================================================================== */

  /* INSTRUCTIONS DE FIN DE PARTIE
     =================================================================== */
 win :
  printf("Victoire !\n") ;
  remove(r_path) ;
  remove(w_path) ;
  goto end ;
 lose :
  printf("Défaite !\n") ;
  
 end :
  fclose(lock) ;
  free(w_path) ;
  free(r_path) ;
  /* =================================================================== */
}

import java.util.Scanner ;

fun main (args: Array<String>) {
    val obj = ExoString() ;
    val tab = obj.lireChaines() ;
    for (item in tab) {
	println("${item}") ;
    }
}

class ExoString {
    fun lireChaines(): Array<String> {
	val sc = Scanner(System.`in`) ;
	val tab = Array<String>(10, {i -> ""}) ;
	for (i in 0..9) {
	    tab[i] = sc.nextLine() ;
	}
	return tab ;
    }
}

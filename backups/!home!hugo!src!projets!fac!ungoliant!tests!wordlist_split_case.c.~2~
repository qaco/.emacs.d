#include <check.h>
#include <stdlib.h>
#include "../misc/wordlist.h"
#include "../misc/word.h"

Word *dest, *text, *sepok, *sepwrong ;

void split_wordlist_setup(void) {
  dest = construct_word(0, NULL) ;
  text = construct_word(strlen("hello how are?"),
                        "hello how are?") ;
  sepok = construct_word(strlen(" "), " ") ;
  sepwrong = construct_word(strlen("!"), "!") ;
}

void split_wordlist_teardown(void) {
  destruct_word(text) ;
  destruct_word(sepok) ;
  destruct_word(sepwrong) ;
}

START_TEST(test_split_hassep) {
  WordList *splitted ;
  Word *first, *second, *third ;
  int test, size ;

  
  first = construct_word(strlen("hello"), "hello") ;
  second = construct_word(strlen("how"), "how") ;
  third = construct_word(strlen("are?"), "are?") ;
  splitted = split_word(text, sepok) ;
  
  get_word_wordlist(dest, splitted, 0) ;
  test = compare_word(dest, first) == 0 ;
  ck_assert_int_eq(test, 1) ;
  get_word_wordlist(dest, splitted, 1) ;
  test = compare_word(dest, second) == 0 ;
  ck_assert_int_eq(test, 1) ;
  get_word_wordlist(dest, splitted, 2) ;
  test = compare_word(dest, third) == 0 ;
  ck_assert_int_eq(test, 1) ;

  size = get_length_wordlist(splitted) ;
  ck_assert_int_eq(size, 3) ;

  destruct_word(first) ;
  destruct_word(second) ;
  destruct_word(third) ;
  destruct_wordlist(splitted) ;
}
END_TEST

START_TEST(test_split_hasnotsep) {
  WordList *splitted ;
  int test, size ;

  splitted = split_word(text, sepwrong) ;
  get_word_wordlist(dest, splitted, 0) ;
  test = compare_word(dest, text) == 0 ;
  ck_assert_int_eq(test, 1) ;

  size = get_length_wordlist(splitted) ;
  ck_assert_int_eq(size, 1) ;

  destruct_wordlist(splitted) ;
}
END_TEST
  
TCase* wordlist_split_case(void) {
  TCase* tc_split ;

  tc_split = tcase_create("WordList split") ;
  tcase_add_checked_fixture(tc_split,
                            split_wordlist_setup,
                            split_wordlist_teardown) ;
  tcase_add_test(tc_split, test_split_hassep) ;
  tcase_add_test(tc_split, test_split_hasnotsep) ;

  return tc_split ;
}

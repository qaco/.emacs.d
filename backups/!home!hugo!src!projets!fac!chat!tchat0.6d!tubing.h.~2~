#ifndef TUBING

#define TUBING

/**
 * \struct data
 * \brief Les données relatives à une instance du client.
 */
typedef struct
{
  /**
   * \brief Le nom du tube du serveur.
   */
  char* tube_server ;
  /**
   * \brief Le nom du tube de l'utilisateur courant.
   */
  char* tube_client ;
  /**
   * \brief Le pseudo de l'utilisateur courant.
   */
  char* pseudo ;
  /**
   * \brief Le numéro id attribué par le serveur à l'utilisateur courant.
   */
  int id ;
  /**
   * \brief La fenêtre ncurses d'où l'utilisateur envoie des messages.
   */
  WINDOW* outbox ;
  /**
   * \brief La fenêtre ncurses où l'utilisateur reçoit des messages.
   */
  WINDOW* inbox ;
} data ;

int take_msg(int fd_read, char **saisie) ;
int receive_msg (data mydata) ;
void send_msg(data mydata) ;
void connexion(data* mydata) ;
void deconnexion(data* mydata) ;

#endif
